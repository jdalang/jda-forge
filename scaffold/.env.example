# =============================================================================
# JDA Forge — Environment Configuration Example
# Copy to .env and fill in real values. Never commit .env to version control.
# =============================================================================

# Application environment: development | test | production
FORGE_ENV=development

# PostgreSQL connection settings
DATABASE_URL=postgres://postgres:password@localhost:5432/myapp_development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_development
DB_USER=postgres
DB_PASS=password

# SMTP / Mail settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp_password_here
MAIL_FROM=noreply@example.com

# Application secret (used for HMAC signing of sessions, CSRF tokens, JWTs)
APP_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# JWT settings
JWT_SECRET=another_long_random_secret_for_jwt_signing
JWT_EXPIRY=3600

# Server settings
HOST=0.0.0.0
PORT=8080
WORKERS=256

# Logging
LOG_LEVEL=info

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Feature flags
ENABLE_ADMIN=false
ENABLE_RATE_LIMIT=true

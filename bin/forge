#!/bin/bash
# =============================================================================
# JDA Forge CLI v3.0.0
# =============================================================================

set -euo pipefail

FORGE_VERSION="3.0.0"
FORGE_REGISTRY="github.com/jdalang"
LIBS_DIR="libs"
FORGEFILE="Forgefile"
LOCKFILE="Forgefile.lock"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
info()    { echo -e "${GREEN}==>${NC} ${BOLD}$*${NC}"; }
warn()    { echo -e "${YELLOW}warning:${NC} $*"; }
ok()      { echo -e "  ${GREEN}[x]${NC} $*"; }
err()     { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
dim()     { echo -e "  ${CYAN}$*${NC}"; }

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
JDA Forge CLI v${FORGE_VERSION}

Run:
  forge server                              Build and start the dev server  (alias: forge s)
  forge server --port 3000                  Start on a custom port
  forge server --environment production     Use a different environment
  forge server --watch                      Live-reload on file changes (requires entr)
  forge build                               Compile only, don't start
  forge build --environment production      Production build
  forge test                                Run test suite  (alias: forge t)
  forge test --environment staging          Test against a different environment
  forge console                             Open a database console  (alias: forge c)
  forge console --environment staging       Connect to a different environment
  forge db:migrate                          Run pending migrations
  forge db:migrate --environment production Run migrations against a specific environment
  forge db:rollback                         Roll back the last migration
  forge db:rollback --step 3               Roll back the last 3 migrations
  forge db:rollback --version 002          Roll back until only migrations up to 002 remain
  forge db:status                           Show which migrations have run and which are pending

Project:
  forge new <name>                          Create a new Forge application
  forge install                             Install libs from Forgefile (writes lock)
  forge install --locked                    Install exact versions from Forgefile.lock
  forge add <lib> [--version v1.2.0]        Add a lib from github.com/jdalang/<lib>
  forge add <url> [--version v1.2.0]        Add a lib from any git URL
  forge update [<lib>]                      Update all libs (or one) to latest/pinned
  forge list                                List installed libraries
  forge release <version>                   Tag and push a new release (maintainers)
  forge self-update [--version v3.1.0]      Update the forge CLI itself

Generators:
  forge generate scaffold <Name> [field:type ...]
  forge generate model    <Name> [field:type ...]
  forge generate controller <Name>
  forge generate migration  <Description> [field:type ...]

Version pinning (in Forgefile):
  forge "github.com/jdalang/jda-forge" version "3.0.0"
  lib   "github.com/jdalang/forge-markdown" version "1.2.0"
  lib   "github.com/jdalang/forge-slugify"              # latest

Examples:
  forge new myblog
  forge server
  forge server --port 3000
  forge server --watch
  forge test
  forge console
  forge add forge-markdown --version v1.0.0
  forge add payments https://github.com/myorg/jda-payments
  forge generate scaffold Post title:string body:text user:references
  forge release 3.1.0
EOF
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

snake_case() { echo "$1" | sed 's/\([A-Z]\)/_\1/g' | sed 's/^_//' | tr '[:upper:]' '[:lower:]'; }
to_pascal()  { echo "$1" | awk '{n=split($0,a,"_"); r=""; for(i=1;i<=n;i++) r=r toupper(substr(a[i],1,1)) substr(a[i],2); print r}'; }
plural() {
    local w="$1"
    case "$w" in
        *s|*x|*z|*sh|*ch) echo "${w}es" ;;
        *y) echo "${w%y}ies" ;;
        *) echo "${w}s" ;;
    esac
}
singularize() {
    local w="$1"
    case "$w" in
        *ies) echo "${w%ies}y" ;;
        *ses|*xes|*zes|*shes|*ches) echo "${w%es}" ;;
        *s) echo "${w%s}" ;;
        *) echo "$w" ;;
    esac
}
sql_type() {
    case "$1" in
        string)     echo "VARCHAR(255)" ;;
        text)       echo "TEXT" ;;
        integer)    echo "BIGINT" ;;
        boolean)    echo "BOOLEAN NOT NULL DEFAULT false" ;;
        timestamp)  echo "TIMESTAMP" ;;
        float)      echo "FLOAT" ;;
        json)       echo "JSONB" ;;
        references) echo "BIGINT" ;;
        *)          echo "VARCHAR(255)" ;;
    esac
}
next_migration_number() {
    local dir="db/migrate"
    mkdir -p "$dir"
    local max=0
    for f in "$dir"/*.sql; do
        [ -f "$f" ] || continue
        local num; num=$(basename "$f" | cut -d_ -f1); num=$((10#${num}))
        [ "$num" -gt "$max" ] && max=$num
    done
    printf "%03d" $((max + 1))
}

# ---------------------------------------------------------------------------
# compile_routes -- DSL config/routes.jda -> _build/routes.jda + _build/controllers.jda
# ---------------------------------------------------------------------------

compile_routes() {
    local dsl="config/routes.jda"
    [ ! -f "$dsl" ] && return 0

    mkdir -p _build
    local out="_build/routes.jda"
    local fh; fh=$(mktemp)   # path helper declarations
    local fb; fb=$(mktemp)   # routes() body

    local var_idx=0

    # Stack parallel arrays (index = nesting depth)
    local s_type=()   # resources | namespace | scope
    local s_var=()    # jda variable name (_s0, _s1, ...)
    local s_res=()    # resource name / namespace name / scope prefix
    local s_sing=()   # singular (for resources parent)

    _cr_sing() {
        case "$1" in
            *ies) printf '%s' "${1%ies}y" ;;
            *ses|*xes|*zes|*shes|*ches) printf '%s' "${1%es}" ;;
            *s)   printf '%s' "${1%s}" ;;
            *)    printf '%s' "$1" ;;
        esac
    }

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        # trim whitespace
        local L="${raw#"${raw%%[![:space:]]*}"}"
        L="${L%"${L##*[![:space:]]}"}"
        [[ -z "$L" || "$L" == "#"* ]] && continue

        local depth=${#s_type[@]}
        local par_var="" par_type="" par_res="" par_sing=""
        if (( depth > 0 )); then
            par_var="${s_var[$((depth-1))]}"
            par_type="${s_type[$((depth-1))]}"
            par_res="${s_res[$((depth-1))]}"
            par_sing="${s_sing[$((depth-1))]}"
        fi

        if [[ "$L" == "end" ]]; then
            (( depth > 0 )) && {
                local n=$((depth-1))
                s_type=("${s_type[@]:0:$n}")
                s_var=("${s_var[@]:0:$n}")
                s_res=("${s_res[@]:0:$n}")
                s_sing=("${s_sing[@]:0:$n}")
            }
            continue
        fi

        if [[ "$L" =~ ^root[[:space:]]+\"([^\"]+)\" ]]; then
            printf '    app.root("%s")\n' "${BASH_REMATCH[1]}" >> "$fb"

        elif [[ "$L" =~ ^resources[[:space:]]+\"([^\"]+)\"(.*) ]]; then
            local res="${BASH_REMATCH[1]}"
            local rest="${BASH_REMATCH[2]}"
            local sing; sing=$(_cr_sing "$res")
            local has_block=false
            [[ "$rest" =~ (^|[[:space:]])do($|[[:space:]]) ]] && has_block=true

            case "$par_type" in
                "")
                    printf 'let %s_path: []i8    = "/%s"\n' "$res" "$res" >> "$fh"
                    printf 'let new_%s_path: []i8 = "/%s/new"\n' "$sing" "$res" >> "$fh"
                    printf 'fn %s_path(id: []i8) -> []i8      { ret forge_path_id("%s", id) }\n' "$sing" "$res" >> "$fh"
                    printf 'fn edit_%s_path(id: []i8) -> []i8 { ret forge_path_edit("%s", id) }\n' "$sing" "$res" >> "$fh"
                    ;;
                "resources")
                    printf 'fn %s_%s_path(%s_id: []i8) -> []i8                { ret forge_nested_path("%s", %s_id, "%s") }\n' \
                        "$par_sing" "$res" "$par_sing" "$par_res" "$par_sing" "$res" >> "$fh"
                    printf 'fn %s_%s_path(%s_id: []i8, id: []i8) -> []i8     { ret forge_nested_path_id("%s", %s_id, "%s", id) }\n' \
                        "$par_sing" "$sing" "$par_sing" "$par_res" "$par_sing" "$res" >> "$fh"
                    printf 'fn new_%s_%s_path(%s_id: []i8) -> []i8           { ret forge_nested_path_new("%s", %s_id, "%s") }\n' \
                        "$par_sing" "$sing" "$par_sing" "$par_res" "$par_sing" "$res" >> "$fh"
                    printf 'fn edit_%s_%s_path(%s_id: []i8, id: []i8) -> []i8 { ret forge_nested_path_edit("%s", %s_id, "%s", id) }\n' \
                        "$par_sing" "$sing" "$par_sing" "$par_res" "$par_sing" "$res" >> "$fh"
                    ;;
                "namespace")
                    printf 'let %s_%s_path: []i8    = "/%s/%s"\n' "$par_res" "$res" "$par_res" "$res" >> "$fh"
                    printf 'let new_%s_%s_path: []i8 = "/%s/%s/new"\n' "$par_res" "$sing" "$par_res" "$res" >> "$fh"
                    printf 'fn %s_%s_path(id: []i8) -> []i8      { ret forge_path_id("%s/%s", id) }\n' "$par_res" "$sing" "$par_res" "$res" >> "$fh"
                    printf 'fn edit_%s_%s_path(id: []i8) -> []i8 { ret forge_path_edit("%s/%s", id) }\n' "$par_res" "$sing" "$par_res" "$res" >> "$fh"
                    ;;
                "scope")
                    local sp="${par_res#/}"; sp="${sp//\//_}"
                    local sp_bare="${par_res#/}"
                    printf 'let %s_%s_path: []i8    = "%s/%s"\n' "$sp" "$res" "$par_res" "$res" >> "$fh"
                    printf 'let new_%s_%s_path: []i8 = "%s/%s/new"\n' "$sp" "$sing" "$par_res" "$res" >> "$fh"
                    printf 'fn %s_%s_path(id: []i8) -> []i8      { ret forge_path_id("%s/%s", id) }\n' "$sp" "$sing" "$sp_bare" "$res" >> "$fh"
                    printf 'fn edit_%s_%s_path(id: []i8) -> []i8 { ret forge_path_edit("%s/%s", id) }\n' "$sp" "$sing" "$sp_bare" "$res" >> "$fh"
                    ;;
            esac

            if $has_block; then
                local vname="_s${var_idx}"; var_idx=$((var_idx+1))
                if [[ -z "$par_var" ]]; then
                    printf '    let %s = app.resources("%s")\n' "$vname" "$res" >> "$fb"
                else
                    printf '    let %s = %s.resources("%s")\n' "$vname" "$par_var" "$res" >> "$fb"
                fi
                s_type+=("resources"); s_var+=("$vname"); s_res+=("$res"); s_sing+=("$sing")
            else
                if [[ -z "$par_var" ]]; then
                    printf '    app.resources("%s")\n' "$res" >> "$fb"
                else
                    printf '    %s.resources("%s")\n' "$par_var" "$res" >> "$fb"
                fi
            fi

        elif [[ "$L" =~ ^namespace[[:space:]]+\"([^\"]+)\"[[:space:]]+do ]]; then
            local ns="${BASH_REMATCH[1]}"
            local vname="_s${var_idx}"; var_idx=$((var_idx+1))
            printf '    let %s = app.namespace("%s")\n' "$vname" "$ns" >> "$fb"
            s_type+=("namespace"); s_var+=("$vname"); s_res+=("$ns"); s_sing+=("$ns")

        elif [[ "$L" =~ ^scope[[:space:]]+\"([^\"]+)\"[[:space:]]+do ]]; then
            local pfx="${BASH_REMATCH[1]}"
            local vname="_s${var_idx}"; var_idx=$((var_idx+1))
            printf '    let %s = app.scope("%s")\n' "$vname" "$pfx" >> "$fb"
            s_type+=("scope"); s_var+=("$vname"); s_res+=("$pfx"); s_sing+=("")

        elif [[ "$L" =~ ^(get|post|put|delete|patch)[[:space:]]+\"([^\"]+)\"[[:space:]]+\"([^\"]+)\"(.*) ]]; then
            local method="${BASH_REMATCH[1]}"
            local path="${BASH_REMATCH[2]}"
            local act="${BASH_REMATCH[3]}"
            local rest2="${BASH_REMATCH[4]}"
            local alias_name=""
            [[ "$rest2" =~ [[:space:]]+as[[:space:]]+\"([^\"]+)\" ]] && alias_name="${BASH_REMATCH[1]}"

            if [[ -n "$alias_name" ]]; then
                local full_path="$path"
                [[ -n "$par_res" && "$par_type" != "resources" ]] && full_path="${par_res}${path}"
                printf 'let %s_path: []i8 = "%s"\n' "$alias_name" "$full_path" >> "$fh"
            fi

            if [[ -z "$par_var" ]]; then
                printf '    app.%s("%s", "%s")\n' "$method" "$path" "$act" >> "$fb"
            else
                printf '    forge_scope_app_%s(%s, "%s", "%s")\n' "$method" "$par_var" "$path" "$act" >> "$fb"
            fi
        fi

    done < "$dsl"

    {
        printf '// Auto-generated from config/routes.jda -- do not edit directly\n\n'
        cat "$fh"
        printf '\nfn routes(app: &ForgeApp) {\n'
        cat "$fb"
        printf '}\n'
    } > "$out"

    rm -f "$fh" "$fb"
    ok "compiled config/routes.jda -> _build/routes.jda"

    # Auto-generate _build/controllers.jda by scanning app/controllers/*.jda.
    #
    # Controller name comes from the FILENAME (posts_controller.jda -> posts).
    # Every fn NAME(ctx: i64) { in the file is treated as a bare name and
    # renamed to fn posts_NAME(ctx: i64) { in the generated output.  This
    # covers actions (index, create ...) AND helpers/filters (set_post, rescue ...)
    # so controller files never need a controller-name prefix anywhere.
    #
    # fn_addr(bare_name) references inside the same file are also rewritten to
    # fn_addr(ctrl_bare_name) so filter registrations work transparently.
    #
    # _build/controllers.jda contains:
    #   1. processed controller implementations (all bare names prefixed)
    #   2. dispatch shims (forge_ctrl_run wrappers)
    #   3. forge_controllers_init()
    # Raw app/controllers/*.jda are NOT included separately in the build.
    local ctrl_out="_build/controllers.jda"
    local fimpl; fimpl=$(mktemp)
    local fshims; fshims=$(mktemp)
    local finit; finit=$(mktemp)
    printf 'fn forge_controllers_init() {\n' > "$finit"
    for f in app/controllers/*.jda; do
        [ -f "$f" ] || continue
        local bname; bname=$(basename "$f" .jda)
        local ctrl="${bname%_controller}"

        # Pass 1: collect all bare fn NAME(ctx: i64) names in this file.
        local bare_fns=()
        while IFS= read -r line || [[ -n "$line" ]]; do
            if [[ "$line" =~ ^fn[[:space:]]([a-z][a-z0-9_]*)\(ctx:[[:space:]]i64\)[[:space:]]\{ ]]; then
                local fn_nm="${BASH_REMATCH[1]}"
                if [[ "$fn_nm" != "${ctrl}_"* ]]; then
                    bare_fns+=("$fn_nm")
                fi
            fi
        done < "$f"

        # Pass 2: emit processed file content.
        printf '// --- %s ---\n' "$bname" >> "$fimpl"
        while IFS= read -r line || [[ -n "$line" ]]; do
            # Rename bare function declarations.
            if [[ "$line" =~ ^fn[[:space:]]([a-z][a-z0-9_]*)\(ctx:[[:space:]]i64\)[[:space:]]\{ ]]; then
                local orig="${BASH_REMATCH[1]}"
                local fname="$orig"
                if [[ "$fname" != "${ctrl}_"* ]]; then
                    fname="${ctrl}_${fname}"
                    line="fn ${fname}(ctx: i64) {"
                fi
                local action="${fname#${ctrl}_}"
                printf 'fn forge__dispatch_%s_%s(ctx: i64) { forge_ctrl_run("%s", "%s", fn_addr(%s), ctx) }\n' \
                    "$ctrl" "$action" "$ctrl" "$action" "$fname" >> "$fshims"
                printf '    forge_action_register("%s", "%s", fn_addr(forge__dispatch_%s_%s))\n' \
                    "$ctrl" "$action" "$ctrl" "$action" >> "$finit"
            fi
            # Rewrite fn_addr(bare_name) -> fn_addr(ctrl_bare_name) for all
            # bare names collected in pass 1 so filter registrations resolve.
            for bfn in "${bare_fns[@]+"${bare_fns[@]}"}"; do
                line="${line//fn_addr(${bfn})/fn_addr(${ctrl}_${bfn})}"
            done
            printf '%s\n' "$line" >> "$fimpl"
        done < "$f"
        printf '\n' >> "$fimpl"
    done
    printf '}\n' >> "$finit"
    cat "$fimpl" "$fshims" "$finit" > "$ctrl_out"
    rm -f "$fimpl" "$fshims" "$finit"
    ok "scanned controllers -> _build/controllers.jda"
}

# ---------------------------------------------------------------------------
# compile_models -- db/migrate/*.sql -> _build/models.jda
#   Reads CREATE TABLE / ALTER TABLE to build the schema, then emits one
#   set of CRUD functions per user table.
# ---------------------------------------------------------------------------

compile_models() {
    mkdir -p _build
    local out="_build/models.jda"
    local tmp; tmp=$(mktemp)
    printf '// Auto-generated by forge compile-models -- do not edit\n\n' > "$tmp"

    # Parallel indexed arrays (bash 3.2 compatible -- no declare -A)
    local tbl_names=()   # table names in discovery order
    local tbl_cols=()    # space-separated "col:skip" pairs per table
    local ntbls=0

    # STI subtype registry -- populated during Phase 2 model scan
    local sti_subtype_names=()
    local sti_parent_tables=()
    local sti_type_cols=()
    local sti_type_vals=()

    local f tbl in_create tbl_idx j tn
    local at ac dt dc new_list c cv

    for f in db/migrate/*.sql; do
        [ -f "$f" ] || continue
        tbl=""
        in_create="false"
        tbl_idx=-1

        local in_down="false"
        while IFS= read -r raw || [[ -n "$raw" ]]; do
            # Stop parsing schema once we hit the down section
            [[ "$raw" =~ ^--[[:space:]]*migrate:down ]] && { in_down="true"; continue; }
            [ "$in_down" = "true" ] && continue
            local L="${raw#"${raw%%[![:space:]]*}"}"
            L="${L%"${L##*[![:space:]]}"}"
            [[ -z "$L" || "$L" == "--"* ]] && continue

            # CREATE TABLE [IF NOT EXISTS] name (
            if [[ "$L" =~ ^CREATE[[:space:]]+TABLE([[:space:]]+IF[[:space:]]+NOT[[:space:]]+EXISTS)?[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
                tbl="${BASH_REMATCH[2]}"
                in_create="true"
                tbl_idx=-1
                j=0
                tn=${#tbl_names[@]}
                while [ $j -lt $tn ]; do
                    [ "${tbl_names[$j]}" = "$tbl" ] && { tbl_idx=$j; break; }
                    j=$((j+1))
                done
                if [ $tbl_idx -eq -1 ]; then
                    tbl_names+=("$tbl")
                    tbl_cols+=("")
                    tbl_idx=$ntbls
                    ntbls=$((ntbls+1))
                fi
                continue
            fi

            if [ "$in_create" = "true" ]; then
                [[ "$L" =~ ^\) ]] && { in_create="false"; tbl=""; tbl_idx=-1; continue; }

                # Extract column name (word 1) and type (word 2)
                local word1="${L%%[[:space:]]*}"; word1="${word1%%,*}"
                [[ -z "$word1" ]] && continue
                # Track deleted_at presence as a sentinel in tbl_cols
                if [[ "$word1" == "deleted_at" ]]; then
                    [ $tbl_idx -ge 0 ] && tbl_cols[$tbl_idx]+=" deleted_at:sd"
                    continue
                fi
                [[ "$word1" =~ ^(id|created_at|updated_at|PRIMARY|UNIQUE|INDEX|CHECK|CONSTRAINT|FOREIGN|KEY)$ ]] && continue
                local rest1="${L#"$word1"}"; rest1="${rest1#"${rest1%%[![:space:]]*}"}"
                local word2="${rest1%%[[:space:]]*}"; word2="${word2%%,*}"
                local type_up; type_up=$(printf '%s' "$word2" | tr '[:lower:]' '[:upper:]')
                # Exclude auto-valued columns from DML params: BOOLEAN (has DEFAULT) and SERIAL types
                local skip="0"
                [[ "$type_up" =~ ^(BOOLEAN|SERIAL|BIGSERIAL) ]] && skip="1"
                [ $tbl_idx -ge 0 ] && tbl_cols[$tbl_idx]+=" ${word1}:${skip}"
                continue
            fi

            # ALTER TABLE name ADD COLUMN [IF NOT EXISTS] col type
            if [[ "$L" =~ ^ALTER[[:space:]]+TABLE[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]+ADD[[:space:]]+COLUMN([[:space:]]+IF[[:space:]]+NOT[[:space:]]+EXISTS)?[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]+([a-zA-Z]+) ]]; then
                at="${BASH_REMATCH[1]}"; ac="${BASH_REMATCH[3]}"
                local atype; atype=$(printf '%s' "${BASH_REMATCH[4]}" | tr '[:lower:]' '[:upper:]')
                if [[ "$ac" == "deleted_at" ]]; then
                    j=0; tn=${#tbl_names[@]}
                    while [ $j -lt $tn ]; do
                        if [ "${tbl_names[$j]}" = "$at" ]; then
                            tbl_cols[$j]+=" deleted_at:sd"; break
                        fi
                        j=$((j+1))
                    done
                    continue
                fi
                [[ "$ac" =~ ^(id|created_at|updated_at)$ ]] && continue
                local askip="0"
                [[ "$atype" =~ ^(BOOLEAN|SERIAL|BIGSERIAL) ]] && askip="1"
                j=0; tn=${#tbl_names[@]}
                while [ $j -lt $tn ]; do
                    if [ "${tbl_names[$j]}" = "$at" ]; then
                        tbl_cols[$j]+=" ${ac}:${askip}"; break
                    fi
                    j=$((j+1))
                done
                continue
            fi

            # ALTER TABLE name DROP COLUMN [IF EXISTS] col
            if [[ "$L" =~ ^ALTER[[:space:]]+TABLE[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]+DROP[[:space:]]+COLUMN([[:space:]]+IF[[:space:]]+EXISTS)?[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*) ]]; then
                dt="${BASH_REMATCH[1]}"; dc="${BASH_REMATCH[3]}"
                j=0; tn=${#tbl_names[@]}
                while [ $j -lt $tn ]; do
                    if [ "${tbl_names[$j]}" = "$dt" ]; then
                        new_list=""
                        for cv in ${tbl_cols[$j]:-}; do
                            [ "${cv%%:*}" != "$dc" ] && new_list+=" $cv"
                        done
                        tbl_cols[$j]="$new_list"
                        break
                    fi
                    j=$((j+1))
                done
                continue
            fi
        done < "$f"
    done

    # Phase 3: emit typed row structs + <table>_row(result, r) converters
    # These come first so struct types are defined before any function that uses them.
    {
        printf '// --- Typed row structs ---\n\n'
        local si=0
        while [ $si -lt $ntbls ]; do
            local stb="${tbl_names[$si]}"
            local scs="${tbl_cols[$si]:-}"
            si=$((si+1))
            [[ "$stb" == forge_* ]] && continue

            local ssing; ssing=$(singularize "$stb")
            local spascal; spascal=$(to_pascal "$ssing")

            # Build ordered column list: id, user cols, created_at, updated_at, [deleted_at]
            local scols=("id")
            local shas_sd=0
            [[ "${scs}" == *"deleted_at:sd"* ]] && shas_sd=1
            for scv in ${scs:-}; do
                local sc="${scv%%:*}"
                local ssk="${scv##*:}"
                [ "$ssk" = "sd" ] && continue
                scols+=("$sc")
            done
            scols+=("created_at" "updated_at")
            [ $shas_sd -eq 1 ] && scols+=("deleted_at")

            printf 'struct %sRow {\n' "$spascal"
            for scol in "${scols[@]}"; do printf '    %s: []i8\n' "$scol"; done
            printf '}\n\n'

            printf 'fn %s_row(result: &ForgeResult, r: i64) -> &%sRow {\n' "$ssing" "$spascal"
            printf '    let row: &%sRow = alloc_pages(1)\n' "$spascal"
            for scol in "${scols[@]}"; do
                printf '    row.%s = forge_result_col(result, r, "%s")\n' "$scol" "$scol"
            done
            printf '    ret row\n}\n\n'
        done
    } >> "$tmp"

    # Generate functions for each user table
    local i=0
    while [ $i -lt $ntbls ]; do
        local tb="${tbl_names[$i]}"
        local cs="${tbl_cols[$i]:-}"
        i=$((i+1))
        [[ "$tb" == forge_* ]] && continue

        local sing; sing=$(singularize "$tb")
        # Detect whether this table has a deleted_at column (marked as :sd sentinel)
        local has_deleted_at=0
        [[ "${cs}" == *"deleted_at:sd"* ]] && has_deleted_at=1
        {
            printf '// === %s ===\n' "$tb"
            if [ $has_deleted_at -eq 1 ]; then
                printf 'fn %s_q() -> &ForgeQuery { ret forge_q_where_not_deleted(forge_q("%s")) }\n' "$sing" "$tb"
                printf 'fn %s_all() -> &ForgeResult { ret forge_q_where_not_deleted(forge_q("%s")).order_desc("created_at").exec() }\n' "$sing" "$tb"
                printf 'fn %s_find(id: []i8) -> &ForgeResult { ret forge_q_where_not_deleted(forge_q("%s")).where_eq("id", id).first() }\n' "$sing" "$tb"
                printf 'fn %s_find_by(col: []i8, val: []i8) -> &ForgeResult { ret forge_q_where_not_deleted(forge_q("%s")).where_eq(col, val).first() }\n' "$sing" "$tb"
                printf 'fn %s_where(col: []i8, val: []i8) -> &ForgeQuery { ret forge_q_where_not_deleted(forge_q("%s")).where_eq(col, val) }\n' "$sing" "$tb"
                printf 'fn %s_count() -> i64 { ret forge_q_where_not_deleted(forge_q("%s")).count() }\n' "$sing" "$tb"
                printf 'fn %s_exists(id: []i8) -> bool { ret forge_q_where_not_deleted(forge_q("%s")).where_eq("id", id).exists() }\n' "$sing" "$tb"
                printf 'fn %s_with_deleted() -> &ForgeQuery { ret forge_q_with_deleted(forge_q("%s")) }\n' "$sing" "$tb"
                printf 'fn %s_only_deleted() -> &ForgeQuery { ret forge_q_only_deleted(forge_q("%s")) }\n' "$sing" "$tb"
            else
                printf 'fn %s_q() -> &ForgeQuery { ret forge_q("%s") }\n' "$sing" "$tb"
                printf 'fn %s_all() -> &ForgeResult { ret forge_q("%s").order_desc("created_at").exec() }\n' "$sing" "$tb"
                printf 'fn %s_find(id: []i8) -> &ForgeResult { ret forge_find("%s", id) }\n' "$sing" "$tb"
                printf 'fn %s_find_by(col: []i8, val: []i8) -> &ForgeResult { ret forge_find_by("%s", col, val) }\n' "$sing" "$tb"
                printf 'fn %s_where(col: []i8, val: []i8) -> &ForgeQuery { ret forge_q("%s").where_eq(col, val) }\n' "$sing" "$tb"
                printf 'fn %s_count() -> i64 { ret forge_q("%s").count() }\n' "$sing" "$tb"
                printf 'fn %s_exists(id: []i8) -> bool { ret forge_q("%s").where_eq("id", id).exists() }\n' "$sing" "$tb"
            fi
            printf 'fn %s_delete(id: []i8) -> bool { ret forge_soft_delete("%s", id) }\n' "$sing" "$tb"
            printf 'fn %s_destroy(id: []i8) -> bool { ret forge_hard_delete("%s", id) }\n' "$sing" "$tb"
            printf 'fn %s_touch(id: []i8) -> bool { ret forge_touch("%s", id) }\n' "$sing" "$tb"
            printf 'fn %s_update_column(id: []i8, col: []i8, val: []i8) -> bool { ret forge_update_column("%s", id, col, val) }\n' "$sing" "$tb"
            printf 'fn %s_find_or_create_by(col: []i8, val: []i8) -> &ForgeResult { ret forge_find_or_create_by("%s", col, val) }\n' "$sing" "$tb"
            printf 'fn %s_reload(id: []i8) -> &ForgeResult { ret forge_reload("%s", id) }\n' "$sing" "$tb"
            printf 'fn %s_toggle(id: []i8, col: []i8) -> bool { ret forge_toggle("%s", id, col) }\n' "$sing" "$tb"
            printf 'fn %s_increment(id: []i8, col: []i8, by: i64) -> bool { ret forge_increment("%s", id, col, by) }\n' "$sing" "$tb"
            printf 'fn %s_decrement(id: []i8, col: []i8, by: i64) -> bool { ret forge_decrement("%s", id, col, by) }\n' "$sing" "$tb"

            # Build create/update params (exclude skip=1 and system sentinel columns)
            local params="" chain=""
            for cv in ${cs:-}; do
                c="${cv%%:*}"; local skip="${cv##*:}"
                [ "$skip" = "1" ] && continue
                [ "$skip" = "sd" ] && continue   # deleted_at sentinel
                params+="${c}: []i8, "
                chain+="        .set(\"${c}\", ${c})\n"
            done
            params="${params%, }"
            if [ -n "$params" ]; then
                printf 'fn %s_create(%s) -> bool {\n    ret forge_attrs_new()\n%b        .insert("%s")\n}\n' \
                    "$sing" "$params" "$chain" "$tb"
                printf 'fn %s_update(id: []i8, %s) -> bool {\n    ret forge_attrs_new()\n%b        .update("%s", id)\n}\n' \
                    "$sing" "$params" "$chain" "$tb"
                printf 'fn %s_create_from(attrs: &ForgeAttrs) -> bool { ret forge_attrs_insert(attrs, "%s") }\n' \
                    "$sing" "$tb"
                printf 'fn %s_update_from(id: []i8, attrs: &ForgeAttrs) -> bool { ret forge_attrs_update(attrs, "%s", id) }\n' \
                    "$sing" "$tb"
            fi
            printf '\n'
        } >> "$tmp"
    done

    # Phase 2: parse app/models/*.jda and emit typed association accessors
    if [ -d "app/models" ]; then
        printf '// --- Association accessors (from app/models/*_model_init declarations) ---\n\n' >> "$tmp"
        for mf in app/models/*.jda; do
            [ -f "$mf" ] || continue
            local msnek; msnek=$(basename "$mf" .jda)
            local cur_table=""
            while IFS= read -r mline || [[ -n "$mline" ]]; do
                # forge_model("table") sets the current table context
                if [[ "$mline" =~ forge_model\(\"([^\"]+)\"\) ]]; then
                    cur_table="${BASH_REMATCH[1]}"
                    continue
                fi
                # forge_sti_subtype("parent_table", "type_col", "TypeValue")
                if [[ "$mline" =~ forge_sti_subtype\(\"([^\"]+)\",[[:space:]]*\"([^\"]+)\",[[:space:]]*\"([^\"]+)\"\) ]]; then
                    local sti_par="${BASH_REMATCH[1]}"
                    local sti_tc="${BASH_REMATCH[2]}"
                    local sti_tv="${BASH_REMATCH[3]}"
                    sti_subtype_names+=("$msnek")
                    sti_parent_tables+=("$sti_par")
                    sti_type_cols+=("$sti_tc")
                    sti_type_vals+=("$sti_tv")
                    cur_table="$sti_par"   # bind callbacks/validations to parent table
                    continue
                fi
                [ -z "$cur_table" ] && continue

                # forge_assoc_belongs_to("name", "target", "fk")
                if [[ "$mline" =~ forge_assoc_belongs_to\(\"([^\"]+)\" ]]; then
                    local an="${BASH_REMATCH[1]}"
                    printf 'fn %s_%s(fk_val: []i8) -> &ForgeResult { ret forge_assoc_query("%s", "%s", fk_val) }\n' \
                        "$msnek" "$an" "$cur_table" "$an" >> "$tmp"
                fi
                # forge_assoc_has_many("name", ...)
                if [[ "$mline" =~ forge_assoc_has_many\(\"([^\"]+)\" ]] && [[ ! "$mline" =~ forge_assoc_has_many_through ]]; then
                    local an="${BASH_REMATCH[1]}"
                    printf 'fn %s_%s(owner_id: []i8) -> &ForgeResult { ret forge_assoc_query("%s", "%s", owner_id) }\n' \
                        "$msnek" "$an" "$cur_table" "$an" >> "$tmp"
                fi
                # forge_assoc_has_one("name", ...)
                if [[ "$mline" =~ forge_assoc_has_one\(\"([^\"]+)\" ]]; then
                    local an="${BASH_REMATCH[1]}"
                    printf 'fn %s_%s(owner_id: []i8) -> &ForgeResult { ret forge_assoc_query("%s", "%s", owner_id) }\n' \
                        "$msnek" "$an" "$cur_table" "$an" >> "$tmp"
                fi
                # forge_assoc_has_many_through("name", ...)
                if [[ "$mline" =~ forge_assoc_has_many_through\(\"([^\"]+)\" ]]; then
                    local an="${BASH_REMATCH[1]}"
                    printf 'fn %s_%s(owner_id: []i8) -> &ForgeResult { ret forge_assoc_query("%s", "%s", owner_id) }\n' \
                        "$msnek" "$an" "$cur_table" "$an" >> "$tmp"
                fi
                # forge_assoc_poly_has_many("name", ...)
                if [[ "$mline" =~ forge_assoc_poly_has_many\(\"([^\"]+)\" ]]; then
                    local an="${BASH_REMATCH[1]}"
                    printf 'fn %s_%s(owner_id: []i8) -> &ForgeResult { ret forge_assoc_query("%s", "%s", owner_id) }\n' \
                        "$msnek" "$an" "$cur_table" "$an" >> "$tmp"
                fi
                # forge_assoc_poly_belongs_to("name", ...) -- two-arg accessor
                if [[ "$mline" =~ forge_assoc_poly_belongs_to\(\"([^\"]+)\" ]]; then
                    local an="${BASH_REMATCH[1]}"
                    printf 'fn %s_%s(type_val: []i8, id_val: []i8) -> &ForgeResult { ret forge_assoc_poly_query("%s", "%s", type_val, id_val) }\n' \
                        "$msnek" "$an" "$cur_table" "$an" >> "$tmp"
                fi
            done < "$mf"
            printf '\n' >> "$tmp"
        done
    fi

    # Phase 2.5: emit STI subtype query helpers
    if [ ${#sti_subtype_names[@]} -gt 0 ]; then
        printf '// --- STI subtype query helpers ---\n\n' >> "$tmp"
        local si_idx=0
        while [ $si_idx -lt ${#sti_subtype_names[@]} ]; do
            local sub_name="${sti_subtype_names[$si_idx]}"
            local par_tbl="${sti_parent_tables[$si_idx]}"
            local t_col="${sti_type_cols[$si_idx]}"
            local t_val="${sti_type_vals[$si_idx]}"
            si_idx=$((si_idx+1))

            local par_sing; par_sing=$(singularize "$par_tbl")
            local par_pascal; par_pascal=$(to_pascal "$par_sing")

            # Check if parent table has soft-delete
            local sti_has_sd=0
            local pk=0
            while [ $pk -lt $ntbls ]; do
                if [ "${tbl_names[$pk]}" = "$par_tbl" ]; then
                    [[ "${tbl_cols[$pk]}" == *"deleted_at:sd"* ]] && sti_has_sd=1
                    break
                fi
                pk=$((pk+1))
            done

            {
                printf '// === STI: %s on %s ===\n' "$sub_name" "$par_tbl"
                if [ $sti_has_sd -eq 1 ]; then
                    printf 'fn %s_q() -> &ForgeQuery { ret forge_q_where_not_deleted(forge_q("%s")).where_eq("%s", "%s") }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_all() -> &ForgeResult { ret forge_q_where_not_deleted(forge_q("%s")).where_eq("%s", "%s").order_desc("created_at").exec() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_find(id: []i8) -> &ForgeResult { ret forge_q_where_not_deleted(forge_q("%s")).where_eq("id", id).where_eq("%s", "%s").first() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_find_by(col: []i8, val: []i8) -> &ForgeResult { ret forge_q_where_not_deleted(forge_q("%s")).where_eq(col, val).where_eq("%s", "%s").first() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_where(col: []i8, val: []i8) -> &ForgeQuery { ret forge_q_where_not_deleted(forge_q("%s")).where_eq(col, val).where_eq("%s", "%s") }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_count() -> i64 { ret forge_q_where_not_deleted(forge_q("%s")).where_eq("%s", "%s").count() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_exists(id: []i8) -> bool { ret forge_q_where_not_deleted(forge_q("%s")).where_eq("id", id).where_eq("%s", "%s").exists() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_with_deleted() -> &ForgeQuery { ret forge_q_with_deleted(forge_q("%s")).where_eq("%s", "%s") }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_only_deleted() -> &ForgeQuery { ret forge_q_only_deleted(forge_q("%s")).where_eq("%s", "%s") }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                else
                    printf 'fn %s_q() -> &ForgeQuery { ret forge_q("%s").where_eq("%s", "%s") }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_all() -> &ForgeResult { ret forge_q("%s").where_eq("%s", "%s").order_desc("created_at").exec() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_find(id: []i8) -> &ForgeResult { ret forge_q("%s").where_eq("id", id).where_eq("%s", "%s").first() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_find_by(col: []i8, val: []i8) -> &ForgeResult { ret forge_q("%s").where_eq(col, val).where_eq("%s", "%s").first() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_where(col: []i8, val: []i8) -> &ForgeQuery { ret forge_q("%s").where_eq(col, val).where_eq("%s", "%s") }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_count() -> i64 { ret forge_q("%s").where_eq("%s", "%s").count() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                    printf 'fn %s_exists(id: []i8) -> bool { ret forge_q("%s").where_eq("id", id).where_eq("%s", "%s").exists() }\n' \
                        "$sub_name" "$par_tbl" "$t_col" "$t_val"
                fi
                printf 'fn %s_delete(id: []i8) -> bool { ret forge_soft_delete("%s", id) }\n' "$sub_name" "$par_tbl"
                printf 'fn %s_destroy(id: []i8) -> bool { ret forge_hard_delete("%s", id) }\n' "$sub_name" "$par_tbl"
                printf 'fn %s_touch(id: []i8) -> bool { ret forge_touch("%s", id) }\n' "$sub_name" "$par_tbl"
                printf 'fn %s_update_column(id: []i8, col: []i8, val: []i8) -> bool { ret forge_update_column("%s", id, col, val) }\n' \
                    "$sub_name" "$par_tbl"
                printf 'fn %s_create_from(attrs: &ForgeAttrs) -> bool { ret forge_sti_create_from(attrs, "%s", "%s", "%s") }\n' \
                    "$sub_name" "$par_tbl" "$t_col" "$t_val"
                printf 'fn %s_row(result: &ForgeResult, r: i64) -> &%sRow { ret %s_row(result, r) }\n' \
                    "$sub_name" "$par_pascal" "$par_sing"
                printf '\n'
            } >> "$tmp"
        done
    fi

    mv "$tmp" "$out"
    ok "compiled _build/models.jda"
}

# ---------------------------------------------------------------------------
# compile_assets -- fingerprint CSS/JS, generate _build/assets.jda
#
# Development: copies files to public/assets/ unchanged; forge_asset_path
#              returns /assets/<name> directly.
# Production:  SHA-256 fingerprints each file; forge_asset_path returns
#              /assets/<name>-<fingerprint>.<ext>.  The path is baked into
#              the binary at compile time -- zero runtime overhead.
# ---------------------------------------------------------------------------

_asset_fingerprint() {
    local f="$1"
    local fp=""
    if command -v openssl >/dev/null 2>&1; then
        fp=$(openssl dgst -sha256 "$f" 2>/dev/null | awk '{print substr($2,1,16)}')
    fi
    if [ -z "$fp" ] && command -v sha256sum >/dev/null 2>&1; then
        fp=$(sha256sum "$f" | cut -c1-16)
    fi
    if [ -z "$fp" ]; then
        fp=$(md5 -q "$f" 2>/dev/null | cut -c1-16) || fp=$(md5sum "$f" 2>/dev/null | cut -c1-16)
    fi
    printf '%s' "$fp"
}

compile_assets() {
    local env_name="${FORGE_ENV:-development}"
    local do_digest=false
    [ "$env_name" = "production" ] && do_digest=true

    mkdir -p public/assets _build

    local orig_names=()
    local fp_names=()
    local n=0

    # CSS
    if [ -d "app/assets/stylesheets" ]; then
        for f in app/assets/stylesheets/*.css; do
            [ -f "$f" ] || continue
            local fname; fname=$(basename "$f")
            [[ "$fname" == _* ]] && continue
            if $do_digest; then
                local fp; fp=$(_asset_fingerprint "$f")
                local dest_name="${fname%.css}-${fp}.css"
            else
                local dest_name="$fname"
            fi
            cp "$f" "public/assets/${dest_name}"
            orig_names+=("$fname"); fp_names+=("$dest_name"); n=$((n+1))
        done
    fi

    # JS
    if [ -d "app/assets/javascripts" ]; then
        for f in app/assets/javascripts/*.js; do
            [ -f "$f" ] || continue
            local fname; fname=$(basename "$f")
            [[ "$fname" == _* ]] && continue
            if $do_digest; then
                local fp; fp=$(_asset_fingerprint "$f")
                local dest_name="${fname%.js}-${fp}.js"
            else
                local dest_name="$fname"
            fi
            cp "$f" "public/assets/${dest_name}"
            orig_names+=("$fname"); fp_names+=("$dest_name"); n=$((n+1))
        done
    fi

    # Images / fonts -- no fingerprinting
    for dir in app/assets/images app/assets/fonts; do
        [ -d "$dir" ] || continue
        cp "$dir"/* public/assets/ 2>/dev/null || true
    done

    # Generate _build/assets.jda
    local out="_build/assets.jda"
    {
        printf '// Auto-generated by forge compile-assets -- do not edit\n\n'

        # forge_asset_path -- fingerprinted lookup, falls back to /assets/<name>
        printf 'fn forge_asset_path(name: []i8) -> []i8 {\n'
        local j=0
        while [ $j -lt $n ]; do
            printf '    if forge_slice_eq(name, "%s") { ret "/assets/%s" }\n' \
                "${orig_names[$j]}" "${fp_names[$j]}"
            j=$((j+1))
        done
        printf '    let b = forge_buf_new(1)\n'
        printf '    forge_buf_append(b, "/assets/")\n'
        printf '    forge_buf_append(b, name)\n'
        printf '    ret forge_buf_str(b)\n'
        printf '}\n\n'

        # forge_stylesheet_tag
        printf 'fn forge_stylesheet_tag(name: []i8) -> []i8 {\n'
        printf '    let b = forge_buf_new(1)\n'
        printf '    forge_buf_append(b, "<link rel=\\"stylesheet\\" href=\\"")\n'
        printf '    forge_buf_append(b, forge_asset_path(name))\n'
        printf '    forge_buf_append(b, "\\\">")\n'
        printf '    ret forge_buf_str(b)\n'
        printf '}\n\n'

        # forge_javascript_tag
        printf 'fn forge_javascript_tag(name: []i8) -> []i8 {\n'
        printf '    let b = forge_buf_new(1)\n'
        printf '    forge_buf_append(b, "<script src=\\"")\n'
        printf '    forge_buf_append(b, forge_asset_path(name))\n'
        printf '    forge_buf_append(b, "\\"></script>")\n'
        printf '    ret forge_buf_str(b)\n'
        printf '}\n\n'

        # forge_image_tag -- images served from /assets/ without fingerprinting
        printf 'fn forge_image_tag(name: []i8, alt: []i8) -> []i8 {\n'
        printf '    let b = forge_buf_new(1)\n'
        printf '    forge_buf_append(b, "<img src=\\"/assets/")\n'
        printf '    forge_buf_append(b, name)\n'
        printf '    forge_buf_append(b, "\\" alt=\\"")\n'
        printf '    forge_buf_append(b, alt)\n'
        printf '    forge_buf_append(b, "\\\">")\n'
        printf '    ret forge_buf_str(b)\n'
        printf '}\n'
    } > "$out"

    ok "compiled _build/assets.jda (${n} asset(s), digest=${do_digest})"
}

cmd_assets_precompile() {
    local env_name="${FORGE_ENV:-production}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --environment|-e) env_name="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    [ ! -f "Forgefile" ] && err "No Forgefile found."
    export FORGE_ENV="$env_name"
    compile_assets
}

# ---------------------------------------------------------------------------
# compile_views -- ERB-style .html.jda templates -> _build/views.jda
#
# Syntax:
#   <% fn name(params) %>   function signature (first code block)
#   <% code %>              JDA code -- loops, if, let, etc.
#   <%= expr %>             HTML-escaped output: buf.write(forge_h(expr))
#   <%== expr %>            raw output:          buf.write(expr)
#   <%layout expr %>        wrap result:         ret tmpl_layout(expr, buf.done())
#   <%# comment %>          ignored
#
# One function per file.  Files starting with _ are partials and may be
# called from other templates.
# ---------------------------------------------------------------------------

compile_views() {
    [ ! -d "app/views" ] && return
    mkdir -p _build
    python3 - app/views _build/views.jda <<'PYEOF'
import sys, glob

def esc(s):
    s = s.replace('\\', '\\\\')
    s = s.replace('"', '\\"')
    s = s.replace('\n', '\\n')
    s = s.replace('\r', '')
    s = s.replace('\t', '\\t')
    return s

def fn_hint(path):
    rel = path
    for pre in ('app/views/', './app/views/'):
        if rel.startswith(pre):
            rel = rel[len(pre):]
            break
    rel = rel.replace('.html.jda', '')
    parts = rel.split('/')
    base  = parts[-1]
    dirs  = parts[:-1]
    if base.startswith('_'):
        return 'tmpl_' + '_'.join(dirs + [base[1:]])
    return 'view_' + '_'.join(dirs + [base])

def parse(src):
    segs, i, n = [], 0, len(src)
    while i < n:
        j = src.find('<%', i)
        if j < 0:
            segs.append(('html', src[i:])); break
        if j > i:
            segs.append(('html', src[i:j]))
        k = src.find('%>', j + 2)
        if k < 0:
            segs.append(('html', src[i:])); break
        inner = src[j+2:k]
        if   inner.startswith('layout '): segs.append(('layout',  inner[7:].strip()))
        elif inner.startswith('=='):       segs.append(('raw',     inner[2:].strip()))
        elif inner.startswith('='):        segs.append(('expr',    inner[1:].strip()))
        elif inner.startswith('#'):        segs.append(('comment', inner[1:].strip()))
        else:                              segs.append(('code',    inner.strip()))
        i = k + 2
    return segs

def compile_tpl(src, hint):
    segs   = parse(src)
    fn_sig = None
    layout = None
    start  = 0
    for i, (k, v) in enumerate(segs):
        if k == 'html' and not v.strip(): continue
        if k == 'code' and v.startswith('fn '):
            fn_sig = v[3:].strip(); start = i + 1
        break
    if fn_sig is None:
        fn_sig = hint + '()'
    out  = [f'fn {fn_sig} -> []i8 {{', '    let buf = forge_buf_new(8)']
    html = []
    def flush():
        if html:
            t = ''.join(html)
            if t.strip():
                out.append(f'    buf.write("{esc(t)}")')
            html.clear()
    for i in range(start, len(segs)):
        k, v = segs[i]
        if   k == 'layout': layout = v
        elif k == 'html':   html.append(v)
        else:
            flush()
            if   k == 'code':
                for ln in v.split('\n'):
                    s = ln.strip()
                    if s: out.append(f'    {s}')
            elif k == 'expr': out.append(f'    buf.write(forge_h({v}))')
            elif k == 'raw':  out.append(f'    buf.write({v})')
    flush()
    if layout:
        out.append(f'    ret tmpl_layout({layout}, buf.done())')
    else:
        out.append('    ret buf.done()')
    out.extend(['}', ''])
    return '\n'.join(out)

vdir     = sys.argv[1] if len(sys.argv) > 1 else 'app/views'
out_file = sys.argv[2] if len(sys.argv) > 2 else '_build/views.jda'
tmpls    = sorted(glob.glob(vdir + '/**/*.html.jda', recursive=True))
with open(out_file, 'w') as f:
    f.write('// Auto-generated by forge compile-views -- do not edit\n\n')
    for t in tmpls:
        with open(t) as tf: src = tf.read()
        f.write(f'// {t}\n')
        f.write(compile_tpl(src, fn_hint(t)))
        f.write('\n')
PYEOF
    ok "compiled _build/views.jda"
}

# Normalise version tag: "3.0.0" -> "v3.0.0"
normalise_version() {
    local v="$1"
    [[ "$v" == v* ]] && echo "$v" || echo "v${v}"
}

# Strip surrounding quotes from a string
strip_quotes() { echo "$1" | tr -d '"'"'" ; }

# Parse a Forgefile line and emit: TYPE URL VERSION
# e.g. "lib "github.com/jdalang/forge-md" version "1.0.0""
#  ->   lib github.com/jdalang/forge-md 1.0.0
parse_forgefile_line() {
    local line="$1"
    [[ "$line" =~ ^[[:space:]]*# ]] && return
    [[ -z "${line// }" ]] && return

    local type url ver=""
    if [[ "$line" =~ ^forge[[:space:]] ]]; then
        type="forge"
    elif [[ "$line" =~ ^lib[[:space:]] ]]; then
        type="lib"
    else
        return
    fi

    url=$(echo "$line" | grep -oP '"[^"]+"' | head -1 | tr -d '"')
    ver=$(echo "$line" | grep -oP 'version\s+"[^"]+"' | grep -oP '"[^"]+"' | tr -d '"' || true)

    echo "$type $url $ver"
}

# ---------------------------------------------------------------------------
# install_lib <url> <name> <version|"">
# ---------------------------------------------------------------------------

install_lib() {
    local url="$1"
    local name="$2"
    local version="${3:-}"

    local git_url
    if [[ "$url" == https://* ]] || [[ "$url" == git@* ]]; then
        git_url="$url"
    else
        git_url="https://${url}.git"
    fi

    local dest="$LIBS_DIR/.src/$name"

    if [ -d "$dest/.git" ]; then
        echo -n "  refreshing $name..."
        git -C "$dest" fetch --tags --quiet 2>/dev/null
        echo " done"
    else
        echo -n "  cloning $name..."
        mkdir -p "$LIBS_DIR/.src"
        git clone --quiet "$git_url" "$dest" 2>/dev/null || {
            warn "could not clone $git_url -- skipping $name"
            return 1
        }
        echo " done"
    fi

    # Checkout pinned version or latest tag
    if [ -n "$version" ]; then
        local tag; tag=$(normalise_version "$version")
        git -C "$dest" checkout "$tag" --quiet 2>/dev/null \
            || git -C "$dest" checkout "$version" --quiet 2>/dev/null \
            || { warn "$name: tag $tag not found -- using default branch"; }
        ok "$name @ $tag"
    else
        git -C "$dest" checkout "$(git -C "$dest" remote show origin | grep 'HEAD branch' | awk '{print $NF}')" --quiet 2>/dev/null || true
        git -C "$dest" pull --ff-only --quiet 2>/dev/null || true
        ok "$name @ latest"
    fi

    # Resolve the actual SHA for lock file
    local sha; sha=$(git -C "$dest" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    local resolved_ver; resolved_ver=$(git -C "$dest" describe --tags --exact-match HEAD 2>/dev/null || echo "latest")

    # Copy .jda file
    local jda_dest
    if [ "$name" = "forge" ]; then
        jda_dest="$LIBS_DIR/forge.jda"
        [ -f "$dest/forge.jda" ] && cp "$dest/forge.jda" "$jda_dest" && ok "  -> $jda_dest"
    else
        local src_jda; src_jda=$(find "$dest" -maxdepth 1 -name "*.jda" | head -1)
        if [ -n "$src_jda" ]; then
            jda_dest="$LIBS_DIR/${name}.jda"
            cp "$src_jda" "$jda_dest"
            ok "  -> $jda_dest"
        else
            warn "no .jda file in $name root -- check the library's layout"
            return 1
        fi
    fi

    echo "$name $url $resolved_ver $sha"
}

# ---------------------------------------------------------------------------
# Write Forgefile.lock
# ---------------------------------------------------------------------------

write_lock() {
    local -n _entries=$1   # nameref to array of "name url version sha" strings
    {
        echo "# Forgefile.lock -- generated by forge install"
        echo "# Commit this file so every teammate uses the exact same versions."
        echo "# Do not edit by hand."
        echo ""
        for entry in "${_entries[@]}"; do
            echo "$entry"
        done
    } > "$LOCKFILE"
    ok "wrote $LOCKFILE"
}

# ---------------------------------------------------------------------------
# forge install [--locked]
# ---------------------------------------------------------------------------

cmd_install() {
    local locked=false
    [ "${1:-}" = "--locked" ] && locked=true

    [ ! -f "$FORGEFILE" ] && err "No Forgefile found. Run 'forge new <name>' first."

    if $locked; then
        [ ! -f "$LOCKFILE" ] && err "No Forgefile.lock found. Run 'forge install' first to generate it."
        info "Installing from Forgefile.lock (locked)..."
        install_from_lock
        return
    fi

    info "Installing dependencies from Forgefile..."
    mkdir -p "$LIBS_DIR"

    local lock_entries=()
    while IFS= read -r line; do
        local parsed; parsed=$(parse_forgefile_line "$line") || continue
        [ -z "$parsed" ] && continue
        read -r type url version <<< "$parsed"
        local libname
        [ "$type" = "forge" ] && libname="forge" || libname=$(basename "$url")
        local lock_line; lock_line=$(install_lib "$url" "$libname" "$version") || continue
        lock_entries+=("$type $lock_line")
    done < "$FORGEFILE"

    echo ""
    write_lock lock_entries
    echo ""
    echo -e "${BOLD}Done. ${#lock_entries[@]} dependencies installed.${NC}"
}

install_from_lock() {
    mkdir -p "$LIBS_DIR"
    local count=0
    while IFS= read -r line; do
        [[ "$line" =~ ^# ]] && continue
        [[ -z "${line// }" ]] && continue
        # format: type name url version sha
        read -r type name url version sha <<< "$line"
        install_lib "$url" "$name" "$version" > /dev/null
        ok "$name @ $version ($sha)"
        count=$((count + 1))
    done < "$LOCKFILE"
    echo ""
    echo -e "${BOLD}$count dependencies installed from lock.${NC}"
}

# ---------------------------------------------------------------------------
# forge add <lib-or-url> [--version v1.2.0]
# ---------------------------------------------------------------------------

cmd_add() {
    local input="${1:-}"
    [ -z "$input" ] && err "Usage: forge add <lib> [--version v1.2.0]"
    local version=""
    shift

    while [ $# -gt 0 ]; do
        case "$1" in
            --version|-v) version="${2:-}"; shift 2 ;;
            *) err "Unknown flag: $1" ;;
        esac
    done

    # Resolve to full URL path
    local url
    if [[ "$input" == https://* ]] || [[ "$input" == git@* ]]; then
        url="$input"
        url="${url%.git}"
        url="${url#https://}"
    elif [[ "$input" == */* ]]; then
        url="$input"
    else
        url="${FORGE_REGISTRY}/${input}"
    fi

    local libname; libname=$(basename "$url")

    [ ! -f "$FORGEFILE" ] && cat > "$FORGEFILE" <<EOF
# Forgefile
forge "github.com/jdalang/jda-forge" version "${FORGE_VERSION}"

EOF

    if grep -q "\"$url\"" "$FORGEFILE" 2>/dev/null; then
        warn "$libname already in Forgefile"
    else
        local entry="lib   \"${url}\""
        [ -n "$version" ] && entry="${entry} version \"${version}\""
        echo "$entry" >> "$FORGEFILE"
        ok "added to Forgefile: $entry"
    fi

    mkdir -p "$LIBS_DIR"
    install_lib "$url" "$libname" "$version" > /dev/null

    # Append to lock file
    local sha; sha=$(git -C "$LIBS_DIR/.src/$libname" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    local resolved_ver; resolved_ver=$(git -C "$LIBS_DIR/.src/$libname" describe --tags --exact-match HEAD 2>/dev/null || echo "latest")
    echo "lib $libname $url $resolved_ver $sha" >> "$LOCKFILE"
    ok "updated $LOCKFILE"
}

# ---------------------------------------------------------------------------
# forge update [<lib>]
# ---------------------------------------------------------------------------

cmd_update() {
    local target="${1:-}"
    [ ! -f "$FORGEFILE" ] && err "No Forgefile found."
    info "Updating${target:+ $target}..."
    mkdir -p "$LIBS_DIR"

    local lock_entries=()
    while IFS= read -r line; do
        local parsed; parsed=$(parse_forgefile_line "$line") || continue
        [ -z "$parsed" ] && continue
        read -r type url version <<< "$parsed"
        local libname
        [ "$type" = "forge" ] && libname="forge" || libname=$(basename "$url")
        [ -n "$target" ] && [ "$libname" != "$target" ] && continue
        local lock_line; lock_line=$(install_lib "$url" "$libname" "$version") || continue
        lock_entries+=("$type $lock_line")
    done < "$FORGEFILE"

    write_lock lock_entries
}

# ---------------------------------------------------------------------------
# forge list
# ---------------------------------------------------------------------------

cmd_list() {
    echo ""
    echo -e "${BOLD}Installed libraries${NC} (libs/*.jda):"
    echo ""
    local found=0
    for f in libs/*.jda; do
        [ -f "$f" ] || continue
        local name; name=$(basename "$f" .jda)
        local lines; lines=$(wc -l < "$f" | tr -d ' ')
        printf "  %-28s %6s lines   %s\n" "$name" "$lines" "$f"
        found=1
    done
    [ "$found" = "0" ] && echo "  (none -- run 'forge install')"

    if [ -f "$LOCKFILE" ]; then
        echo ""
        echo -e "${BOLD}Forgefile.lock${NC}:"
        grep -v '^#' "$LOCKFILE" | grep -v '^$' | while read -r type name url version sha; do
            printf "  %-14s %-28s %-12s %s\n" "$type" "$name" "$version" "$sha"
        done
    fi

    if [ -f "$FORGEFILE" ]; then
        echo ""
        echo -e "${BOLD}Forgefile${NC}:"
        grep -v '^#' "$FORGEFILE" | grep -v '^$' | sed 's/^/  /'
    fi
    echo ""
}

# ---------------------------------------------------------------------------
# forge release <version>  (for framework maintainers)
# ---------------------------------------------------------------------------

cmd_release() {
    local version="${1:-}"
    [ -z "$version" ] && err "Usage: forge release <version>  (e.g. forge release 3.1.0)"
    local tag; tag=$(normalise_version "$version")

    # Must be run from the forge repo root
    [ ! -f "forge.jda" ] && err "Run 'forge release' from the jda-forge repository root."

    # Check working tree is clean
    git diff --quiet && git diff --cached --quiet \
        || err "Working tree is not clean. Commit or stash changes first."

    # Check tag doesn't already exist
    git tag | grep -q "^${tag}$" \
        && err "Tag $tag already exists."

    info "Releasing JDA Forge $tag..."

    # Update version string in bin/forge
    sed -i.bak "s/^FORGE_VERSION=.*/FORGE_VERSION=\"${version}\"/" bin/forge
    sed -i.bak "s/^# JDA Forge CLI v.*/# JDA Forge CLI v${version}/" bin/forge
    rm -f bin/forge.bak
    ok "updated FORGE_VERSION in bin/forge"

    # Update version header in forge.jda (first 10 lines)
    sed -i.bak "s/^\/\/ Version .*/\/\/ Version ${version}/" forge.jda
    rm -f forge.jda.bak
    ok "updated version header in forge.jda"

    # Update Jdapkg version
    if [ -f "Jdapkg" ]; then
        sed -i.bak "s/^version\s*=.*/version     = ${version}/" Jdapkg
        rm -f Jdapkg.bak
        ok "updated version in Jdapkg"
    fi

    # Update packages registry latest version
    if [ -f "registry/packages.json" ]; then
        sed -i.bak "s/\"latest\":\s*\"[^\"]*\"/\"latest\":      \"${version}\"/" registry/packages.json
        rm -f registry/packages.json.bak
        ok "updated latest in registry/packages.json"
    fi

    # Add CHANGELOG entry if file exists
    if [ -f "CHANGELOG.md" ]; then
        local date; date=$(date +%Y-%m-%d)
        local tmp; tmp=$(mktemp)
        {
            head -3 CHANGELOG.md
            echo ""
            echo "## [$version] -- $date"
            echo ""
            echo "- See commit log for details."
            echo ""
            tail -n +4 CHANGELOG.md
        } > "$tmp"
        mv "$tmp" CHANGELOG.md
        ok "added $version entry to CHANGELOG.md"
    fi

    git add bin/forge forge.jda Jdapkg registry/packages.json CHANGELOG.md 2>/dev/null \
        || git add bin/forge forge.jda
    git commit -m "release: ${tag}"
    ok "committed release files"

    git tag "$tag"
    ok "created tag $tag"

    git push origin main
    git push origin "$tag"
    ok "pushed main + tag $tag"

    # Create GitHub release if gh is available
    if command -v gh >/dev/null 2>&1; then
        gh release create "$tag" \
            --title "JDA Forge ${tag}" \
            --notes "See CHANGELOG.md for details." \
            forge.jda Jdapkg
        ok "created GitHub release $tag (forge.jda + Jdapkg attached)"
    else
        warn "'gh' not found -- create the GitHub release manually at:"
        echo "      https://github.com/jdalang/jda-forge/releases/new?tag=${tag}"
    fi

    echo ""
    echo -e "${BOLD}Released JDA Forge ${tag}${NC}"
}

# ---------------------------------------------------------------------------
# forge self-update [--version v3.1.0]
# ---------------------------------------------------------------------------

cmd_self_update() {
    local version=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --version|-v) version="${2:-}"; shift 2 ;;
            *) err "Unknown flag: $1" ;;
        esac
    done

    local forge_dir; forge_dir="$(dirname "$(dirname "$(realpath "$0")")")"

    [ ! -f "$forge_dir/forge.jda" ] \
        && err "Cannot locate forge install dir. Expected forge.jda in $forge_dir"

    info "Updating JDA Forge..."
    git -C "$forge_dir" fetch --tags --quiet

    if [ -n "$version" ]; then
        local tag; tag=$(normalise_version "$version")
        git -C "$forge_dir" checkout "$tag" --quiet \
            || err "Version $tag not found. Available: $(git -C "$forge_dir" tag | sort -V | tail -10 | tr '\n' ' ')"
        ok "Switched to $tag"
    else
        git -C "$forge_dir" pull --ff-only --quiet
        ok "Updated to $(git -C "$forge_dir" describe --tags --always)"
    fi

    echo ""
    echo -e "${BOLD}JDA Forge updated.${NC}"
    "$forge_dir/bin/forge" version
}

# ---------------------------------------------------------------------------
# forge new <name>
# ---------------------------------------------------------------------------

cmd_new() {
    local name="${1:-}"
    [ -z "$name" ] && err "Usage: forge new <name>"
    [ -d "$name" ] && err "Directory '$name' already exists"

    info "Creating new Forge application: $name"
    mkdir -p "$name"/{app/{controllers,models,views/{layouts,shared},helpers,assets/{stylesheets,javascripts,images}},config/environments,db/migrate,test,libs,public/assets}

    cat > "$name/$FORGEFILE" <<EOF
# Forgefile
# Run 'forge install' to download all dependencies into libs/

forge "github.com/jdalang/jda-forge" version "${FORGE_VERSION}"

# Add third-party libraries:
# lib "github.com/jdalang/forge-markdown" version "1.0.0"
# lib "github.com/jdalang/forge-slugify"
EOF
    ok "created $FORGEFILE  (pinned to forge v${FORGE_VERSION})"

    cat > "$name/.env" <<EOF
FORGE_ENV=development
APP_PORT=8080
EOF

    cat > "$name/.env.example" <<EOF
DATABASE_URL=postgres://postgres:postgres@localhost/${name}_dev
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
APP_SECRET=change-me-at-least-32-chars-long
APP_PORT=8080
EOF
    ok "created .env, .env.example"

    cat > "$name/.gitignore" <<EOF
_build/
server
test_runner
.env.development
.env.staging
.env.production
.env.test
libs/
!libs/.gitkeep
EOF
    touch "$name/libs/.gitkeep"
    ok "created .gitignore"

    cat > "$name/config/application.jda" <<'JDA'
fn load_env() {
    let env = forge_env_get("FORGE_ENV")
    if env.len == 0 { env = "development" }
    forge_dotenv_load(".env")
    if str_eq(env, "development") { forge_dotenv_load(".env.development") }
    else if str_eq(env, "staging")    { forge_dotenv_load(".env.staging")    }
    else if str_eq(env, "production") { forge_dotenv_load(".env.production") }
    else if str_eq(env, "test")       { forge_dotenv_load(".env.test")       }
}

fn app_config() -> ForgeConfig {
    let cfg = forge_default_config()
    // Register named database connections.
    // Add more connections for multiple databases:
    //   forge_db_add("analytics", forge_env_get("ANALYTICS_DATABASE_URL"))
    //   forge_db_add("warehouse", forge_env_get("WAREHOUSE_DATABASE_URL"))
    // Supported URL schemes: postgres://, postgresql://, mysql://, mariadb://
    forge_db_add("primary", forge_env_get("DATABASE_URL"))
    cfg.smtp_host  = forge_env_get("SMTP_HOST")
    cfg.smtp_port  = 587
    cfg.smtp_user  = forge_env_get("SMTP_USER")
    cfg.smtp_pass  = forge_env_get("SMTP_PASS")
    cfg.secret_key = forge_env_get("APP_SECRET")
    if forge_env_is("test") || forge_env_is("development") { cfg.smtp_host = "" }
    if forge_env_is("development") { forge_log_level_set(FORGE_LOG_DEBUG) }
    else                           { forge_log_level_set(FORGE_LOG_INFO)  }
    ret cfg
}
JDA
    ok "created config/application.jda"

    cat > "$name/config/routes.jda" <<'DSL'
# root "pages#home"

# resources "posts" do
#   resources "comments"
# end
#
# namespace "admin" do
#   resources "users"
# end
#
# get "/about" "pages#about" as "about"
DSL
    ok "created config/routes.jda"


    cat > "$name/app/controllers/application_controller.jda" <<'JDA'
// ApplicationController -- shared helpers for all controllers

fn require_login(ctx: i64) -> bool {
    if ctx_session_get(ctx, "user_id").len == 0 {
        ctx_flash_set(ctx, "alert", "Please sign in.")
        ctx_redirect(ctx, "/login")
        ret false
    }
    ret true
}

fn current_user_id(ctx: i64) -> []i8 {
    ret ctx_session_get(ctx, "user_id")
}
JDA
    ok "created app/controllers/application_controller.jda"

    cat > "$name/app/helpers/application_helper.jda" <<'JDA'
// ApplicationHelper -- shared view helpers

fn h(s: []i8) -> []i8 { ret forge_h(s) }

fn link_to(label: []i8, path: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("<a href=")
    buf.write(path)
    buf.write(">")
    buf.write(h(label))
    buf.write("</a>")
    ret buf.done()
}

fn pluralize(count: i64, singular: []i8, plural: []i8) -> []i8 {
    if count == 1 { ret singular }
    ret plural
}
JDA
    ok "created app/helpers/application_helper.jda"

    cat > "$name/app/views/layouts/application.html.jda" <<'JDA'
<% fn tmpl_layout(title: []i8, body: []i8) %>
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <%== forge_stylesheet_tag("application.css") %>
</head>
<body>
<nav><a href="/">Home</a></nav>
<%== body %>
<%== forge_javascript_tag("application.js") %>
</body>
</html>
JDA
    ok "created app/views/layouts/application.html.jda"

    cat > "$name/app/views/layouts/_flash.html.jda" <<'JDA'
<% fn tmpl_flash(ctx: i64) %>
<% let notice = ctx_flash_get(ctx, "notice") %>
<% let alert  = ctx_flash_get(ctx, "alert") %>
<% if notice.len > 0 { %>
<div class="flash-notice"><%== notice %></div>
<% } %>
<% if alert.len > 0 { %>
<div class="flash-alert"><%== alert %></div>
<% } %>
JDA
    ok "created app/views/layouts/_flash.html.jda"

    cat > "$name/app/views/shared/_errors.html.jda" <<'JDA'
<% fn render_errors(errs: &ForgeErrors) %>
<% if !forge_errors_any(errs) { ret "" } %>
<div class="errors"><ul>
  <li><%== forge_errors_json(errs) %></li>
</ul></div>
JDA
    ok "created app/views/shared/_errors.html.jda"

    cat > "$name/main.jda" <<'JDA'
fn main() {
    load_env()
    forge_jobs_start(4)
    forge_migration_run("db/migrate")

    let app = app_new_config(app_config())
    app_use(app, fn_addr(forge_logger))
    app_use(app, fn_addr(forge_request_id))
    app_use(app, fn_addr(forge_secure_headers))
    app_use(app, fn_addr(forge_session_start))
    app_use(app, fn_addr(forge_csrf))

    app_static(app, "/static", "./public")

    // Shows the default Forge welcome page at /.
    // Remove this line once you've defined your own root route.
    forge_welcome_mount(app)

    forge_controllers_init()
    routes(app)

    app_listen(app, str_to_i32(forge_env_get("APP_PORT")))
}
JDA
    ok "created main.jda"

    cat > "$name/Makefile" <<'MAKE'
APP   = server
OUT   = _build/$(APP).jda

# forge.jda comes from libs/ after 'forge install'
FORGE = libs/forge.jda

# All other installed libraries (concatenated before app source)
LIBS  = $(filter-out $(FORGE), $(wildcard libs/*.jda))

CONFIG      = config/application.jda
HELPERS     = $(shell find app/helpers     -name "*.jda"      2>/dev/null | sort)
MODELS      = $(shell find app/models      -name "*.jda"      2>/dev/null | sort)
ROUTES      = _build/routes.jda
CTRL_INIT   = _build/controllers.jda   # implementations + dispatch shims (from compile-routes)
MODELS_GEN  = _build/models.jda
VIEWS_GEN   = _build/views.jda
ASSETS_GEN  = _build/assets.jda
MAIN        = main.jda

SRC = $(ASSETS_GEN) $(CONFIG) $(HELPERS) $(MODELS_GEN) $(VIEWS_GEN) $(MODELS) $(CTRL_INIT) $(ROUTES) $(MAIN)

TEST_SRC = $(ASSETS_GEN) $(CONFIG) $(HELPERS) $(MODELS_GEN) $(VIEWS_GEN) $(MODELS) $(CTRL_INIT) $(ROUTES) \
           $(shell find test -name "*.jda" 2>/dev/null | sort)
TEST_OUT = _build/test.jda

.PHONY: all build run watch test clean _gen

all: build

_gen:
	@forge compile-routes
	@forge compile-models
	@forge compile-views
	@forge compile-assets

build: _gen $(OUT)
	jda $(OUT) -o $(APP)

$(OUT): $(FORGE) $(LIBS) $(SRC)
	@mkdir -p _build
	@cat $(FORGE) $(LIBS) $(SRC) > $(OUT)
	@echo "merged $(words $(FORGE) $(LIBS) $(SRC)) files -> $(OUT)"

run: build
	./$(APP)


watch:
	@{ find app config db libs -name "*.jda" -o -name "*.html.jda" -o -name "*.sql" \
	       -o -name "*.css" -o -name "*.js"; } \
	    | entr -rn sh -c 'forge compile-routes 2>/dev/null; forge compile-models 2>/dev/null; forge compile-views 2>/dev/null; forge compile-assets 2>/dev/null; make run'

test: _gen $(TEST_OUT)
	jda $(TEST_OUT) -o test_runner
	FORGE_ENV=test ./test_runner

$(TEST_OUT): $(FORGE) $(LIBS) $(TEST_SRC)
	@mkdir -p _build
	@cat $(FORGE) $(LIBS) $(TEST_SRC) > $(TEST_OUT)

clean:
	rm -rf _build test_runner
	rm -f $(APP)
MAKE
    ok "created Makefile"

    echo ""
    echo -e "${BOLD}Created: $name/${NC}"
    echo ""
    echo "Next steps:"
    echo -e "  cd $name"
    echo -e "  ${BOLD}forge install${NC}                     # downloads forge.jda into libs/"
    echo -e "  cp .env.example .env.development  # set DATABASE_URL, APP_SECRET"
    echo -e "  ${BOLD}make run${NC}"
}

# ---------------------------------------------------------------------------
# Generators (unchanged logic, cleaner output)
# ---------------------------------------------------------------------------

gen_model() {
    local name="$1"; shift; local fields=("$@")
    local snake; snake=$(snake_case "$name")
    local table; table=$(plural "$snake")
    mkdir -p app/models
    local out="app/models/${snake}.jda"
    {
        echo "// app/models/${snake}.jda"
        echo "// CRUD functions (${snake}_q, ${snake}_all, ${snake}_find, ${snake}_create, ...)"
        echo "// are auto-generated into _build/models.jda from db/migrate/*.sql"
        echo ""
        echo "fn ${snake}_model_init() {"
        echo "    forge_model(\"${table}\")"
        echo ""

        # associations -- one belongs_to per references field
        for f in "${fields[@]:-}"; do
            [ -z "$f" ] && continue
            local fname="${f%%:*}"; local ftype="${f##*:}"
            [ "$ftype" != "references" ] && continue
            local ref_table; ref_table=$(plural "$fname")
            echo "    forge_assoc_belongs_to(\"${fname}\", \"${ref_table}\", \"${fname}_id\")"
        done

        echo ""
        # callback placeholders
        echo "    // forge_callback(FORGE_CB_BEFORE_SAVE,  fn_addr(${snake}_before_save))"
        echo "    // forge_callback(FORGE_CB_AFTER_CREATE, fn_addr(${snake}_after_create))"
        echo ""

        # validations
        local presence_fields=()
        for f in "${fields[@]:-}"; do
            [ -z "$f" ] && continue
            local fname="${f%%:*}"; local ftype="${f##*:}"
            [[ "$fname" =~ ^(created_at|updated_at|deleted_at)$ ]] && continue
            [ "$ftype" = "boolean" ] || [ "$ftype" = "timestamp" ] && continue
            [ "$ftype" = "references" ] && continue
            presence_fields+=("$fname")
        done
        if [ ${#presence_fields[@]} -gt 0 ]; then
            local pf_csv; pf_csv=$(IFS=", "; echo "${presence_fields[*]}")
            echo "    forge_field(\"${pf_csv}\", FORGE_V_PRESENCE)"
            for f in "${fields[@]:-}"; do
                [ -z "$f" ] && continue
                local fname="${f%%:*}"; local ftype="${f##*:}"
                [ "$ftype" = "string" ] && echo "    forge_field_length(\"${fname}\", 1, 255)"
            done
        fi

        echo "}"
        echo ""
        echo "// Association accessors below are auto-generated by forge compile-models."
        echo "// Run 'forge compile-models' after editing forge_assoc_* declarations above."
    } > "$out"
    ok "created $out"
}

gen_migration() {
    local name="$1"; shift; local fields=("$@")
    local num; num=$(next_migration_number)
    local snake; snake=$(snake_case "$name")
    mkdir -p db/migrate
    local out="db/migrate/${num}_${snake}.sql"
    {
        echo "-- Migration: ${num}_${snake}"
        echo ""
        echo "-- migrate:up"
        if [[ "$snake" == create_* ]]; then
            local table="${snake#create_}"
            echo "CREATE TABLE IF NOT EXISTS ${table} ("
            echo "    id         BIGSERIAL PRIMARY KEY,"
            for f in "${fields[@]:-}"; do
                [ -z "$f" ] && continue
                local fname="${f%%:*}"; local ftype="${f##*:}"
                if [ "$ftype" = "references" ]; then
                    echo "    ${fname}_id  BIGINT NOT NULL REFERENCES $(plural "$fname")(id) ON DELETE CASCADE,"
                else
                    echo "    ${fname}     $(sql_type "$ftype"),"
                fi
            done
            echo "    created_at TIMESTAMP NOT NULL DEFAULT NOW(),"
            echo "    updated_at TIMESTAMP NOT NULL DEFAULT NOW(),"
            echo "    deleted_at TIMESTAMP"
            echo ");"
            echo ""
            for f in "${fields[@]:-}"; do
                [ -z "$f" ] && continue
                local fname="${f%%:*}"; local ftype="${f##*:}"
                if [ "$ftype" = "string" ] || [ "$ftype" = "references" ]; then
                    local col="${fname}"; [ "$ftype" = "references" ] && col="${fname}_id"
                    echo "CREATE INDEX IF NOT EXISTS idx_${table}_${col} ON ${table} (${col});"
                fi
            done
            echo ""
            echo "-- migrate:down"
            echo "DROP TABLE IF EXISTS ${table};"
        elif [[ "$snake" == add_*_to_* ]]; then
            local table="${snake##*_to_}"
            for f in "${fields[@]:-}"; do
                [ -z "$f" ] && continue
                echo "ALTER TABLE ${table} ADD COLUMN IF NOT EXISTS ${f%%:*} $(sql_type "${f##*:}");"
            done
            echo ""
            echo "-- migrate:down"
            for f in "${fields[@]:-}"; do
                [ -z "$f" ] && continue
                echo "ALTER TABLE ${table} DROP COLUMN IF EXISTS ${f%%:*};"
            done
        elif [[ "$snake" == remove_*_from_* ]]; then
            local table="${snake##*_from_}"
            for f in "${fields[@]:-}"; do
                [ -z "$f" ] && continue
                echo "ALTER TABLE ${table} DROP COLUMN IF EXISTS ${f%%:*};"
            done
            echo ""
            echo "-- migrate:down"
            echo "-- TODO: restore removed columns"
        else
            echo "-- TODO: write migration SQL"
            echo ""
            echo "-- migrate:down"
            echo "-- TODO: write rollback SQL"
        fi
    } > "$out"
    ok "created $out"
}

# ---------------------------------------------------------------------------
# Convention validation -- raise errors for wrong naming
# ---------------------------------------------------------------------------

check_naming_conventions() {
    local errors=0
    # controllers must be *_controller.jda
    for f in app/controllers/*.jda; do
        [[ "$f" == *_controller.jda ]] || { warn "Bad name: $f -- must be <resource>_controller.jda"; errors=$((errors+1)); }
    done
    # views must live in app/views/<resource>/ and be *.html.jda
    find app/views -name "*.jda" 2>/dev/null | while read -r f; do
        [[ "$f" == *.html.jda ]] || echo "WARN: $f -- view files must be named *.html.jda"
        [[ "$(dirname "$f")" == "app/views" ]] && echo "WARN: $f -- view files must live in app/views/<resource>/, not app/views/ directly"
    done
    [ $errors -gt 0 ] && err "Fix naming convention errors before continuing."
}

gen_views() {
    local name="$1"
    local snake; snake=$(snake_case "$name")
    local table; table=$(plural "$snake")
    mkdir -p "app/views/${table}" "app/views/layouts" "app/views/shared"

    # Ensure application layout exists
    if [ ! -f "app/views/layouts/application.html.jda" ]; then
        cat > "app/views/layouts/application.html.jda" <<'JDA'
<% fn tmpl_layout(title: []i8, body: []i8) %>
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %></title>
  <%== forge_stylesheet_tag("application.css") %>
</head>
<body>
<nav><a href="/">Home</a></nav>
<%== body %>
<%== forge_javascript_tag("application.js") %>
</body>
</html>
JDA
        ok "created app/views/layouts/application.html.jda"
    fi

    if [ ! -f "app/views/layouts/_flash.html.jda" ]; then
        cat > "app/views/layouts/_flash.html.jda" <<'JDA'
<% fn tmpl_flash(ctx: i64) %>
<% let notice = ctx_flash_get(ctx, "notice") %>
<% let alert  = ctx_flash_get(ctx, "alert") %>
<% if notice.len > 0 { %>
<div class="flash-notice"><%== notice %></div>
<% } %>
<% if alert.len > 0 { %>
<div class="flash-alert"><%== alert %></div>
<% } %>
JDA
        ok "created app/views/layouts/_flash.html.jda"
    fi

    cat > "app/views/${table}/index.html.jda" <<JDA
<% fn view_${table}_index(ctx: i64, rows: &ForgeResult) %>
<%layout "${name}s" %>
<%== tmpl_flash(ctx) %>
<h1>${name}s</h1>
<a href="<%== new_${snake}_path %>">New ${name}</a>
<hr>
<% if rows.count == 0 { %>
<p>No ${table} yet.</p>
<% } %>
<% loop r in 0..rows.count { %>
<% let id = forge_result_col(rows, r, "id") %>
<div><a href="<%== ${snake}_path(id) %>"><%== id %></a></div>
<% } %>
JDA

    cat > "app/views/${table}/show.html.jda" <<JDA
<% fn view_${snake}_show(ctx: i64, row: &ForgeResult) %>
<% let id  = forge_result_col(row, 0, "id") %>
<% let tok = forge_csrf_token(ctx) %>
<%layout "${name}" %>
<%== tmpl_flash(ctx) %>
<h1>${name} #<%== id %></h1>
<a href="<%== edit_${snake}_path(id) %>">Edit</a> &nbsp;
<%== forge_link_to_delete("Delete", ${snake}_path(id), tok) %>
JDA

    cat > "app/views/${table}/new.html.jda" <<JDA
<% fn view_${snake}_new(ctx: i64) %>
<%layout "New ${name}" %>
<%== tmpl_flash(ctx) %>
<h1>New ${name}</h1>
<form method="POST" action="<%== ${table}_path %>">
  <input type="hidden" name="_csrf" value="<%= forge_csrf_token(ctx) %>">
  <button>Create</button> <a href="<%== ${table}_path %>">Cancel</a>
</form>
JDA

    cat > "app/views/${table}/edit.html.jda" <<JDA
<% fn view_${snake}_edit(ctx: i64, row: &ForgeResult) %>
<% let id = forge_result_col(row, 0, "id") %>
<%layout "Edit ${name}" %>
<h1>Edit ${name}</h1>
<form method="POST" action="<%== ${snake}_path(id) %>">
  <input type="hidden" name="_method" value="PUT">
  <input type="hidden" name="_csrf" value="<%= forge_csrf_token(ctx) %>">
  <button>Update</button> <a href="<%== ${snake}_path(id) %>">Cancel</a>
</form>
JDA

    ok "created app/views/${table}/{index,show,new,edit}.html.jda"
}

gen_controller() {
    local name="$1"
    local snake; snake=$(snake_case "$name")
    local table; table=$(plural "$snake")
    mkdir -p app/controllers
    # Convention: app/controllers/<resource>_controller.jda
    local out="app/controllers/${snake}_controller.jda"
    cat > "$out" <<JDA
// Controller: ${name}
// Action functions use bare names (index, show, ...) -- compile-routes
// prefixes them with the controller name in the generated build.

fn index(ctx: i64) {
    ctx_render(ctx, view_${table}_index(ctx, forge_all("${table}")))
}

fn new(ctx: i64) {
    ctx_render(ctx, view_${snake}_new(ctx))
}

fn create(ctx: i64) {
    ctx_flash_set(ctx, "notice", "Created.")
    ctx_redirect(ctx, ${table}_path)
}

fn show(ctx: i64) {
    let row = forge_find("${table}", ctx_param(ctx, "id"))
    if row.count == 0 { ctx_not_found(ctx)  ret }
    ctx_render(ctx, view_${snake}_show(ctx, row))
}

fn edit(ctx: i64) {
    let row = forge_find("${table}", ctx_param(ctx, "id"))
    if row.count == 0 { ctx_not_found(ctx)  ret }
    ctx_render(ctx, view_${snake}_edit(ctx, row))
}

fn update(ctx: i64) {
    ctx_flash_set(ctx, "notice", "Updated.")
    ctx_redirect(ctx, ${snake}_path(ctx_param(ctx, "id")))
}

fn delete(ctx: i64) {
    forge_soft_delete("${table}", ctx_param(ctx, "id"))
    ctx_flash_set(ctx, "notice", "Deleted.")
    ctx_redirect(ctx, ${table}_path)
}
JDA
    ok "created $out"
}

gen_scaffold() {
    local name="$1"; shift; local fields=("$@")
    # Enforce PascalCase resource name
    if [[ ! "$name" =~ ^[A-Z][a-zA-Z0-9]*$ ]]; then
        err "Resource name must be PascalCase (e.g. Post, BlogPost). Got: $name"
    fi
    local snake; snake=$(snake_case "$name")
    local table; table=$(plural "$snake")
    info "Generating scaffold for ${name}..."
    gen_migration "create_${table}" "${fields[@]:-}"
    gen_model "$name" "${fields[@]:-}"
    gen_views "$name"
    gen_controller "$name"

    # Append resources entry to config/routes DSL
    mkdir -p config
    if [ ! -f "config/routes.jda" ]; then
        cat > "config/routes.jda" <<DSL
root "pages#home"
DSL
        ok "created config/routes.jda"
    fi
    printf '\nresources "%s"\n' "$table" >> "config/routes.jda"
    ok "appended resources \"${table}\" to config/routes.jda"


    mkdir -p test
    cat > "test/test_${snake}s.jda" <<JDA
fn test_${table}_index() {
    forge_get(${table}_path).ok(200)
}
fn test_${snake}_not_found() {
    forge_get(${snake}_path("99999")).ok(404)
}
JDA
    ok "created test/test_${snake}s.jda"
    echo ""
    info "Generated files:"
    echo "  app/models/${snake}.jda"
    echo "  app/controllers/${snake}_controller.jda"
    echo "  app/views/${table}/index.html.jda"
    echo "  app/views/${table}/show.html.jda"
    echo "  app/views/${table}/new.html.jda"
    echo "  app/views/${table}/edit.html.jda"
    echo "  config/routes.jda  (appended -- run forge build to recompile)"
    echo "  test/test_${snake}s.jda"
}

# ---------------------------------------------------------------------------
# forge build -- compile only (like rake assets:precompile / just compiling)
# ---------------------------------------------------------------------------

cmd_build() {
    local env_name="${FORGE_ENV:-development}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --environment|-e) env_name="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [ ! -f "Forgefile" ] && err "No Forgefile found. Are you in a Forge project directory?"
    [ ! -d "libs" ]      && err "libs/ not found. Run 'forge install' first."
    [ ! -f "Makefile" ]  && err "No Makefile found."

    export FORGE_ENV="$env_name"
    export FORGE_CLI_VERSION="$FORGE_VERSION"
    export JDA_VERSION; JDA_VERSION=$(jda --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1); [ -z "$JDA_VERSION" ] && JDA_VERSION="unknown"
    info "Building (${env_name})"
    compile_routes
    compile_models
    compile_views
    compile_assets
    exec make build
}

# ---------------------------------------------------------------------------
# forge test -- run test suite
# ---------------------------------------------------------------------------

cmd_test() {
    local env_name="${FORGE_ENV:-test}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --environment|-e) env_name="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [ ! -f "Forgefile" ] && err "No Forgefile found. Are you in a Forge project directory?"
    [ ! -d "libs" ]      && err "libs/ not found. Run 'forge install' first."
    [ ! -f "Makefile" ]  && err "No Makefile found."

    export FORGE_ENV="$env_name"
    export FORGE_CLI_VERSION="$FORGE_VERSION"
    export JDA_VERSION; JDA_VERSION=$(jda --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1); [ -z "$JDA_VERSION" ] && JDA_VERSION="unknown"
    info "Running tests (${env_name})"
    compile_routes
    compile_models
    compile_views
    compile_assets
    exec make test
}

# ---------------------------------------------------------------------------
# forge server -- build and start the app
# ---------------------------------------------------------------------------

cmd_server() {
    local env_name="${FORGE_ENV:-development}"
    local port=""
    local watch=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --port|-p)        port="$2";     shift 2 ;;
            --environment|-e) env_name="$2"; shift 2 ;;
            --watch|-w)       watch=true;    shift ;;
            *) shift ;;
        esac
    done

    [ ! -f "Forgefile" ] && err "No Forgefile found. Are you in a Forge project directory?"
    [ ! -d "libs" ]      && err "libs/ not found. Run 'forge install' first."
    [ ! -f "Makefile" ]  && err "No Makefile found. Run 'forge new' to scaffold a project."

    export FORGE_ENV="$env_name"
    [ -n "$port" ] && export APP_PORT="$port"
    export FORGE_CLI_VERSION="$FORGE_VERSION"
    export JDA_VERSION; JDA_VERSION=$(jda --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1); [ -z "$JDA_VERSION" ] && JDA_VERSION="unknown"

    compile_routes
    compile_models
    compile_views
    compile_assets
    if $watch; then
        command -v entr >/dev/null 2>&1 || err "'entr' not found. Install with: brew install entr  or  apt install entr"
        info "Starting Forge server with live reload (${env_name})"
        [ -n "$port" ] && dim "Port: ${port}"
        { find . \( -name '*.jda' -o -name '*.html.jda' -o -name '*.sql' -o -name '*.css' -o -name '*.js' \) -not -path './libs/*' -not -path './_build/*' -not -path './public/*'; } \
            | entr -rn sh -c 'forge compile-routes 2>/dev/null; forge compile-models 2>/dev/null; forge compile-views 2>/dev/null; forge compile-assets 2>/dev/null; make run'
    else
        info "Starting Forge server (${env_name})"
        [ -n "$port" ] && dim "Port: ${port}"
        exec make run
    fi
}

# ---------------------------------------------------------------------------
# forge console -- open a database console
# ---------------------------------------------------------------------------

# Extract SQL from the -- migrate:up section (everything before -- migrate:down).
extract_migration_up() {
    awk '/^[[:space:]]*--[[:space:]]*migrate:down/{exit} /^[[:space:]]*--[[:space:]]*migrate:up/{found=1; next} found{print}' "$1"
}

# Extract SQL from the -- migrate:down section (everything after -- migrate:down).
extract_migration_down() {
    awk '/^[[:space:]]*--[[:space:]]*migrate:down/{found=1; next} found{print}' "$1"
}

# Load DATABASE_URL from .env then .env.<environment>. Prints the URL; empty on failure.
load_db_url() {
    local env_name="${1:-development}"
    local db_url=""
    if [ -f ".env" ]; then
        local v; v=$(grep "^DATABASE_URL=" ".env" 2>/dev/null | head -1 | cut -d= -f2-)
        [ -n "$v" ] && db_url="$v"
    fi
    local env_file=".env.${env_name}"
    if [ -f "$env_file" ]; then
        local v; v=$(grep "^DATABASE_URL=" "$env_file" 2>/dev/null | head -1 | cut -d= -f2-)
        [ -n "$v" ] && db_url="$v"
    fi
    echo "$db_url"
}

cmd_console() {
    local env_name="${FORGE_ENV:-development}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --environment|-e) env_name="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [ ! -f "Forgefile" ] && err "No Forgefile found. Are you in a Forge project directory?"

    local db_url; db_url=$(load_db_url "$env_name")
    [ -z "$db_url" ] && err "DATABASE_URL not set in .env or .env.${env_name}"

    command -v psql >/dev/null 2>&1 || err "psql not found. Install PostgreSQL client tools."

    info "Connecting to database (${env_name})"
    dim "$db_url"
    exec psql "$db_url"
}

cmd_db_migrate() {
    local env_name="${FORGE_ENV:-development}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --environment|-e) env_name="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [ ! -f "Forgefile" ] && err "No Forgefile found. Are you in a Forge project directory?"
    [ ! -d "db/migrate" ] && err "db/migrate/ not found. Create it or run 'forge generate migration'."

    local db_url; db_url=$(load_db_url "$env_name")
    [ -z "$db_url" ] && err "DATABASE_URL not set in .env or .env.${env_name}"

    command -v psql >/dev/null 2>&1 || err "psql not found. Install PostgreSQL client tools."

    psql "$db_url" -q -c \
        "CREATE TABLE IF NOT EXISTS forge_migrations (name TEXT PRIMARY KEY, ran_at BIGINT)" \
        2>/dev/null || err "Could not connect to database."

    local ran=0
    for f in $(ls db/migrate/*.sql 2>/dev/null | sort); do
        [ -f "$f" ] || continue
        local name; name=$(basename "$f" .sql)
        local already; already=$(psql "$db_url" -tAq \
            -c "SELECT COUNT(*) FROM forge_migrations WHERE name='${name}'" 2>/dev/null)
        if [ "${already:-0}" = "0" ]; then
            info "Running $name"
            # Run only the -- migrate:up section; fall back to full file for legacy migrations
            local up_sql; up_sql=$(extract_migration_up "$f")
            if [ -z "$up_sql" ]; then
                psql "$db_url" -q -f "$f" || err "Migration failed: $name"
            else
                echo "$up_sql" | psql "$db_url" -q || err "Migration failed: $name"
            fi
            psql "$db_url" -q -c \
                "INSERT INTO forge_migrations (name, ran_at) VALUES ('${name}', EXTRACT(EPOCH FROM NOW())::BIGINT)"
            ok "$name"
            ran=$((ran + 1))
        fi
    done

    if [ "$ran" -eq 0 ]; then
        info "Already up to date."
    else
        ok "${ran} migration(s) ran."
    fi
}

cmd_db_rollback() {
    local env_name="${FORGE_ENV:-development}"
    local step=1
    local target_version=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --environment|-e) env_name="$2"; shift 2 ;;
            --step|-s)        step="$2";     shift 2 ;;
            --version)        target_version="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [ ! -f "Forgefile" ] && err "No Forgefile found. Are you in a Forge project directory?"
    [ ! -d "db/migrate" ] && err "db/migrate/ not found."

    local db_url; db_url=$(load_db_url "$env_name")
    [ -z "$db_url" ] && err "DATABASE_URL not set in .env or .env.${env_name}"

    command -v psql >/dev/null 2>&1 || err "psql not found. Install PostgreSQL client tools."

    psql "$db_url" -q -c \
        "CREATE TABLE IF NOT EXISTS forge_migrations (name TEXT PRIMARY KEY, ran_at BIGINT)" \
        2>/dev/null || err "Could not connect to database."

    local rolled=0
    while true; do
        # Get the last applied migration
        local last; last=$(psql "$db_url" -tAq \
            -c "SELECT name FROM forge_migrations ORDER BY name DESC LIMIT 1" 2>/dev/null | tr -d '[:space:]')
        [ -z "$last" ] && { info "Nothing to rollback."; break; }

        # If --version set, stop once we're at or below the target
        if [ -n "$target_version" ]; then
            local last_num; last_num=$((10#$(echo "$last" | cut -d_ -f1)))
            local target_num; target_num=$((10#$(printf "%03d" "$((10#${target_version}))")))
            [ "$last_num" -le "$target_num" ] && break
        fi

        # Find the migration file
        local file="db/migrate/${last}.sql"
        [ ! -f "$file" ] && err "Migration file not found: $file"

        # Extract and validate the down section
        local down_sql; down_sql=$(extract_migration_down "$file")
        [ -z "$down_sql" ] && err "No -- migrate:down section in $file. Add one before rolling back."

        info "Rolling back $last"
        echo "$down_sql" | psql "$db_url" -q || err "Rollback failed: $last"
        psql "$db_url" -q -c "DELETE FROM forge_migrations WHERE name='${last}'"
        ok "$last"
        rolled=$((rolled + 1))

        step=$((step - 1))
        [ -z "$target_version" ] && [ "$step" -le 0 ] && break
    done

    [ "$rolled" -eq 0 ] || ok "${rolled} migration(s) rolled back."
}

cmd_db_status() {
    local env_name="${FORGE_ENV:-development}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --environment|-e) env_name="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [ ! -f "Forgefile" ] && err "No Forgefile found. Are you in a Forge project directory?"
    [ ! -d "db/migrate" ] && err "db/migrate/ not found."

    local db_url; db_url=$(load_db_url "$env_name")
    [ -z "$db_url" ] && err "DATABASE_URL not set in .env or .env.${env_name}"

    command -v psql >/dev/null 2>&1 || err "psql not found. Install PostgreSQL client tools."

    psql "$db_url" -q -c \
        "CREATE TABLE IF NOT EXISTS forge_migrations (name TEXT PRIMARY KEY, ran_at BIGINT)" \
        2>/dev/null || err "Could not connect to database."

    local any=0
    for f in $(ls db/migrate/*.sql 2>/dev/null | sort); do
        [ -f "$f" ] || continue
        local name; name=$(basename "$f" .sql)
        local already; already=$(psql "$db_url" -tAq \
            -c "SELECT COUNT(*) FROM forge_migrations WHERE name='${name}'" 2>/dev/null)
        if [ "${already:-0}" = "0" ]; then
            echo -e "  ${YELLOW}pending${NC}  $name"
        else
            echo -e "  ${GREEN}ran${NC}      $name"
        fi
        any=1
    done

    [ "$any" = "0" ] && info "No migration files found in db/migrate/."
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

[ $# -eq 0 ] && { usage; exit 0; }

CMD="$1"; shift

case "$CMD" in
    server|s)     cmd_server "$@" ;;
    build|b)      cmd_build "$@" ;;
    test|t)       cmd_test "$@" ;;
    console|c)    cmd_console "$@" ;;
    new)          cmd_new "${1:-}" ;;
    install)      cmd_install "${1:-}" ;;
    add)          cmd_add "$@" ;;
    update)       cmd_update "${1:-}" ;;
    list)         cmd_list ;;
    release)      cmd_release "${1:-}" ;;
    self-update)  cmd_self_update "$@" ;;
    generate|g)
        [ $# -lt 2 ] && { usage; exit 1; }
        SUB="$1"; NAME="$2"; shift 2; FIELDS=("${@:-}")
        case "$SUB" in
            scaffold|s)    gen_scaffold   "$NAME" "${FIELDS[@]:-}" ;;
            model|m)       gen_model      "$NAME" "${FIELDS[@]:-}" ;;
            controller|c)  gen_controller "$NAME" ;;
            view|v)        gen_views      "$NAME" ;;
            migration|mig) gen_migration  "$NAME" "${FIELDS[@]:-}" ;;
            *) err "Unknown generator: $SUB" ;;
        esac
        ;;
    compile-routes)  compile_routes  ;;
    compile-models)  compile_models  ;;
    compile-views)   compile_views   ;;
    compile-assets)  compile_assets  ;;
    assets:precompile) cmd_assets_precompile "$@" ;;
    db:migrate)      cmd_db_migrate  "$@" ;;
    db:rollback)     cmd_db_rollback "$@" ;;
    db:status)       cmd_db_status   "$@" ;;
    version|--version|-v) echo "JDA Forge CLI v${FORGE_VERSION}" ;;
    help|--help|-h) usage ;;
    *) err "Unknown command: $CMD. Run 'forge help'." ;;
esac

#!/bin/bash
# =============================================================================
# JDA Forge CLI Generator
# Usage: forge generate [scaffold|model|controller|migration] <name> [field:type ...]
# =============================================================================

set -euo pipefail

FORGE_VERSION="2.1"

usage() {
    cat <<EOF
JDA Forge CLI v${FORGE_VERSION}

Usage:
  forge generate model      <Name> [field:type ...]
  forge generate controller <Name>
  forge generate scaffold   <Name> [field:type ...]
  forge generate migration  <Description> [field:type ...]

Examples:
  forge generate model User email:string name:string created_at:timestamp
  forge generate controller Users
  forge generate scaffold User email:string name:string bio:text
  forge generate migration AddEmailToUsers email:string

Field types:
  string     → VARCHAR(255)
  text       → TEXT
  integer    → BIGINT
  boolean    → BOOLEAN NOT NULL DEFAULT false
  timestamp  → TIMESTAMP
  float      → FLOAT
  json       → JSONB
  references → BIGINT (foreign key)
EOF
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

lowercase() { echo "$1" | tr '[:upper:]' '[:lower:]'; }
uppercase() { echo "$1" | tr '[:lower:]' '[:upper:]'; }
snake_case() {
    echo "$1" | sed 's/\([A-Z]\)/_\1/g' | sed 's/^_//' | tr '[:upper:]' '[:lower:]'
}
plural() {
    local word="$1"
    case "$word" in
        *s|*x|*z|*sh|*ch) echo "${word}es" ;;
        *y)                echo "${word%y}ies" ;;
        *)                 echo "${word}s" ;;
    esac
}

sql_type() {
    case "$1" in
        string)     echo "VARCHAR(255)" ;;
        text)       echo "TEXT" ;;
        integer)    echo "BIGINT" ;;
        boolean)    echo "BOOLEAN NOT NULL DEFAULT false" ;;
        timestamp)  echo "TIMESTAMP" ;;
        float)      echo "FLOAT" ;;
        json)       echo "JSONB" ;;
        references) echo "BIGINT" ;;
        *)          echo "VARCHAR(255)" ;;
    esac
}

next_migration_number() {
    local dir="db/migrations"
    mkdir -p "$dir"
    local max=0
    for f in "$dir"/*.sql 2>/dev/null; do
        [ -f "$f" ] || continue
        local num
        num=$(basename "$f" | cut -d_ -f1)
        num=$((10#${num}))
        [ "$num" -gt "$max" ] && max=$num
    done
    printf "%03d" $((max + 1))
}

# ---------------------------------------------------------------------------
# Generate model
# ---------------------------------------------------------------------------

gen_model() {
    local name="$1"
    shift
    local fields=("$@")
    local snake
    snake=$(snake_case "$name")
    local table
    table=$(plural "$snake")
    local model_dir="models"
    mkdir -p "$model_dir"
    local out="$model_dir/${snake}.jda"

    cat > "$out" <<JDA
// =============================================================================
// Model: ${name}
// Table: ${table}
// Generated by forge generate model ${name} ${fields[*]}
// =============================================================================

fn ${snake}_find(id: []i8) -> &ForgeResult {
    ret forge_find("${table}", id)
}

fn ${snake}_find_by(col: []i8, val: []i8) -> &ForgeResult {
    ret forge_find_by("${table}", col, val)
}

fn ${snake}_all() -> &ForgeResult {
    ret forge_all("${table}")
}

fn ${snake}_validate(
JDA

    # Add field params
    local param_list=""
    for f in "${fields[@]}"; do
        local fname="${f%%:*}"
        local ftype="${f##*:}"
        if [ "$fname" != "created_at" ] && [ "$fname" != "updated_at" ]; then
            echo "    ${fname}: []i8" >> "$out"
        fi
    done

    cat >> "$out" <<JDA
) -> &ForgeErrors {
    let e = forge_errors_new()
JDA

    for f in "${fields[@]}"; do
        local fname="${f%%:*}"
        local ftype="${f##*:}"
        if [ "$fname" != "created_at" ] && [ "$fname" != "updated_at" ] && [ "$ftype" != "boolean" ] && [ "$ftype" != "timestamp" ]; then
            echo "    forge_validate_presence(e, \"${fname}\", ${fname})" >> "$out"
        fi
        if [ "$ftype" = "string" ]; then
            echo "    forge_validate_max_length(e, \"${fname}\", ${fname}, 255)" >> "$out"
        fi
    done

    cat >> "$out" <<JDA
    ret e
}

fn ${snake}_create(
JDA

    for f in "${fields[@]}"; do
        local fname="${f%%:*}"
        local ftype="${f##*:}"
        if [ "$fname" != "created_at" ] && [ "$fname" != "updated_at" ] && [ "$ftype" != "boolean" ] && [ "$ftype" != "timestamp" ]; then
            echo "    ${fname}: []i8" >> "$out"
        fi
    done

    echo ") -> bool {" >> "$out"
    echo "    let buf: &i8 = alloc_pages(1)" >> "$out"
    echo "    let pos = 0i64" >> "$out"

    # Build INSERT
    local cols=""
    local vals=""
    for f in "${fields[@]}"; do
        local fname="${f%%:*}"
        local ftype="${f##*:}"
        if [ "$fname" != "created_at" ] && [ "$fname" != "updated_at" ] && [ "$ftype" != "boolean" ] && [ "$ftype" != "timestamp" ]; then
            [ -n "$cols" ] && cols="${cols}, "
            cols="${cols}${fname}"
            [ -n "$vals" ] && vals="${vals}, '"
            vals="${vals}'"
        fi
    done

    cat >> "$out" <<JDA
    let p1 = "INSERT INTO ${table} (${cols}) VALUES ('${vals}')"
    loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

fn ${snake}_delete(id: []i8) -> bool {
    ret forge_soft_delete("${table}", id)
}

fn ${snake}_purge(id: []i8) -> bool {
    ret forge_purge("${table}", id)
}
JDA

    echo "  created: $out"
}

# ---------------------------------------------------------------------------
# Generate migration
# ---------------------------------------------------------------------------

gen_migration() {
    local name="$1"
    shift
    local fields=("$@")
    local num
    num=$(next_migration_number)
    local snake
    snake=$(snake_case "$name")
    local dir="db/migrations"
    mkdir -p "$dir"
    local out="${dir}/${num}_${snake}.sql"

    # Determine if this is a create table or alter table
    if [[ "$snake" == create_* ]]; then
        local table="${snake#create_}"
        {
            echo "-- Migration: ${num}_${snake}"
            echo ""
            echo "CREATE TABLE IF NOT EXISTS ${table} ("
            echo "    id         BIGSERIAL PRIMARY KEY,"
            for f in "${fields[@]}"; do
                local fname="${f%%:*}"
                local ftype="${f##*:}"
                local stype
                stype=$(sql_type "$ftype")
                if [ "$ftype" = "references" ]; then
                    local ref_table
                    ref_table=$(plural "$fname")
                    echo "    ${fname}_id  BIGINT NOT NULL REFERENCES ${ref_table}(id) ON DELETE CASCADE,"
                else
                    echo "    ${fname}    ${stype},"
                fi
            done
            echo "    created_at TIMESTAMP NOT NULL DEFAULT NOW(),"
            echo "    updated_at TIMESTAMP NOT NULL DEFAULT NOW()"
            echo ");"
            echo ""
            for f in "${fields[@]}"; do
                local fname="${f%%:*}"
                local ftype="${f##*:}"
                if [ "$ftype" = "string" ] || [ "$ftype" = "references" ]; then
                    local idx_col="${fname}"
                    [ "$ftype" = "references" ] && idx_col="${fname}_id"
                    echo "CREATE INDEX IF NOT EXISTS idx_${table}_${idx_col} ON ${table} (${idx_col});"
                fi
            done
        } > "$out"
    elif [[ "$snake" == add_*_to_* ]]; then
        local table="${snake##*_to_}"
        {
            echo "-- Migration: ${num}_${snake}"
            echo ""
            for f in "${fields[@]}"; do
                local fname="${f%%:*}"
                local ftype="${f##*:}"
                local stype
                stype=$(sql_type "$ftype")
                echo "ALTER TABLE ${table} ADD COLUMN IF NOT EXISTS ${fname} ${stype};"
            done
        } > "$out"
    elif [[ "$snake" == remove_*_from_* ]]; then
        local table="${snake##*_from_}"
        {
            echo "-- Migration: ${num}_${snake}"
            echo ""
            for f in "${fields[@]}"; do
                local fname="${f%%:*}"
                echo "ALTER TABLE ${table} DROP COLUMN IF EXISTS ${fname};"
            done
        } > "$out"
    else
        {
            echo "-- Migration: ${num}_${snake}"
            echo "-- TODO: Write migration SQL here"
            echo ""
        } > "$out"
    fi

    echo "  created: $out"
}

# ---------------------------------------------------------------------------
# Generate controller
# ---------------------------------------------------------------------------

gen_controller() {
    local name="$1"
    local snake
    snake=$(snake_case "$name")
    local table
    table=$(plural "$snake")
    local dir="controllers"
    mkdir -p "$dir"
    local out="${dir}/${snake}s_controller.jda"

    cat > "$out" <<JDA
// =============================================================================
// Controller: ${name}s
// Generated by forge generate controller ${name}
// =============================================================================

let g_${snake}_ctrl: &ForgeController = 0

fn ${snake}_ctrl_init() {
    if g_${snake}_ctrl != 0 { ret }
    g_${snake}_ctrl = forge_ctrl_new()
    forge_ctrl_before(g_${snake}_ctrl, fn_addr(${snake}_require_auth), "create")
    forge_ctrl_before(g_${snake}_ctrl, fn_addr(${snake}_require_auth), "update")
    forge_ctrl_before(g_${snake}_ctrl, fn_addr(${snake}_require_auth), "delete")
}

fn ${snake}_require_auth(ctx: i64) {
    let uid = ctx_session_get(ctx, "user_id")
    if uid.len == 0 { ctx_redirect(ctx, "/login") }
}

fn ${snake}_index_action(ctx: i64) {
    let res = forge_all("${table}")
    let fmt = ctx_format(ctx)
    if forge_slice_eq(fmt, "json") {
        ctx_json(ctx, 200, forge_result_to_json(res))
    } else {
        ctx_html(ctx, 200, "<h1>${name}s</h1>")
    }
}

fn ${snake}_show_action(ctx: i64) {
    let id  = ctx_param(ctx, "id")
    let res = forge_find("${table}", id)
    if res.count == 0 { ctx_not_found(ctx)  ret }
    let fmt = ctx_format(ctx)
    if forge_slice_eq(fmt, "json") {
        ctx_json(ctx, 200, forge_row_to_json(res, 0))
    } else {
        ctx_html(ctx, 200, "<h1>${name}</h1>")
    }
}

fn ${snake}_new_action(ctx: i64) {
    ctx_html(ctx, 200, "<h1>New ${name}</h1><form action=/${table} method=post></form>")
}

fn ${snake}_create_action(ctx: i64) {
    ctx_redirect(ctx, "/${table}")
}

fn ${snake}_edit_action(ctx: i64) {
    let id = ctx_param(ctx, "id")
    let res = forge_find("${table}", id)
    if res.count == 0 { ctx_not_found(ctx)  ret }
    ctx_html(ctx, 200, "<h1>Edit ${name}</h1>")
}

fn ${snake}_update_action(ctx: i64) {
    ctx_redirect(ctx, "/${table}")
}

fn ${snake}_delete_action(ctx: i64) {
    let id = ctx_param(ctx, "id")
    forge_soft_delete("${table}", id)
    ctx_redirect(ctx, "/${table}")
}

fn handle_${snake}_index(ctx: i64)  { ${snake}_ctrl_init()  forge_ctrl_dispatch(g_${snake}_ctrl, ctx, fn_addr(${snake}_index_action),  "index")  }
fn handle_${snake}_show(ctx: i64)   { ${snake}_ctrl_init()  forge_ctrl_dispatch(g_${snake}_ctrl, ctx, fn_addr(${snake}_show_action),   "show")   }
fn handle_${snake}_new(ctx: i64)    { ${snake}_ctrl_init()  forge_ctrl_dispatch(g_${snake}_ctrl, ctx, fn_addr(${snake}_new_action),    "new")    }
fn handle_${snake}_create(ctx: i64) { ${snake}_ctrl_init()  forge_ctrl_dispatch(g_${snake}_ctrl, ctx, fn_addr(${snake}_create_action), "create") }
fn handle_${snake}_edit(ctx: i64)   { ${snake}_ctrl_init()  forge_ctrl_dispatch(g_${snake}_ctrl, ctx, fn_addr(${snake}_edit_action),   "edit")   }
fn handle_${snake}_update(ctx: i64) { ${snake}_ctrl_init()  forge_ctrl_dispatch(g_${snake}_ctrl, ctx, fn_addr(${snake}_update_action), "update") }
fn handle_${snake}_delete(ctx: i64) { ${snake}_ctrl_init()  forge_ctrl_dispatch(g_${snake}_ctrl, ctx, fn_addr(${snake}_delete_action), "delete") }

fn ${snake}s_routes(app: &ForgeApp) {
    ${snake}_ctrl_init()
    app_get   (app, "/${table}",          fn_addr(handle_${snake}_index))
    app_get   (app, "/${table}/new",      fn_addr(handle_${snake}_new))
    app_get   (app, "/${table}/:id",      fn_addr(handle_${snake}_show))
    app_post  (app, "/${table}",          fn_addr(handle_${snake}_create))
    app_get   (app, "/${table}/:id/edit", fn_addr(handle_${snake}_edit))
    app_put   (app, "/${table}/:id",      fn_addr(handle_${snake}_update))
    app_delete(app, "/${table}/:id",      fn_addr(handle_${snake}_delete))
}
JDA

    echo "  created: $out"
}

# ---------------------------------------------------------------------------
# Generate scaffold (model + controller + migration + routes stub)
# ---------------------------------------------------------------------------

gen_scaffold() {
    local name="$1"
    shift
    local fields=("$@")
    local snake
    snake=$(snake_case "$name")
    local table
    table=$(plural "$snake")

    echo "Generating scaffold for ${name}..."

    # Migration
    gen_migration "create_${table}" "${fields[@]}"

    # Model
    gen_model "$name" "${fields[@]}"

    # Controller
    gen_controller "$name"

    # Route registration hint
    local routes_file="routes/${snake}s.jda"
    mkdir -p routes
    cat > "$routes_file" <<JDA
// Routes for ${name} — generated by forge generate scaffold ${name}
// Include ${snake}s_routes(app) in your main() function.
JDA
    echo "  created: $routes_file"

    # Test stub
    local test_file="test/test_${snake}s.jda"
    mkdir -p test
    cat > "$test_file" <<JDA
// Tests for ${name} — generated by forge generate scaffold ${name}

fn test_${snake}s_index(_: i64) {
    let res = forge_test_get("/${table}")
    forge_assert_status(res, 200, "GET /${table} should return 200")
}

fn test_${snake}s_show_not_found(_: i64) {
    let res = forge_test_get("/${table}/99999")
    forge_assert_status(res, 404, "unknown id should return 404")
}

fn register_${snake}_tests() {
    forge_test("${snake}s: index returns 200",      fn_addr(test_${snake}s_index))
    forge_test("${snake}s: show unknown is 404",    fn_addr(test_${snake}s_show_not_found))
}
JDA
    echo "  created: $test_file"
    echo ""
    echo "Done. Add to main():"
    echo "  ${snake}s_routes(app)"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

if [ $# -lt 2 ]; then
    usage
    exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
    generate|g)
        SUBCOMMAND="$1"
        shift
        NAME="${1:-}"
        if [ -z "$NAME" ]; then
            echo "Error: name required"
            usage
            exit 1
        fi
        shift
        FIELDS=("$@")
        case "$SUBCOMMAND" in
            model|m)
                gen_model "$NAME" "${FIELDS[@]}"
                ;;
            controller|c)
                gen_controller "$NAME"
                ;;
            scaffold|s)
                gen_scaffold "$NAME" "${FIELDS[@]}"
                ;;
            migration|mig)
                gen_migration "$NAME" "${FIELDS[@]}"
                ;;
            *)
                echo "Unknown generator: $SUBCOMMAND"
                usage
                exit 1
                ;;
        esac
        ;;
    version|--version|-v)
        echo "JDA Forge CLI v${FORGE_VERSION}"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac

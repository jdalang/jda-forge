// =============================================================================
// JDA Forge — Competitive Web Framework for the Jda Language
// Version 2.1
// =============================================================================
//
// USAGE
//   jda build --include path/to/forge.jda myapp.jda
//
// QUICK START
//   fn main() {
//       let app = app_new()
//       app_use(app, fn_addr(forge_logger))
//       app_get(app, "/", fn_addr(handle_root))
//       app_listen(app, 8080)
//   }
//
// ROUTE GROUPS
//   let api = app_group(app, "/api/v1")
//   group_use(&api, fn_addr(forge_jwt_auth))     // scoped middleware
//   group_get(&api, "/users",     fn_addr(list_users))
//   group_post(&api, "/users",    fn_addr(create_user))
//   group_get(&api, "/users/:id", fn_addr(get_user))
//
// CONTEXT API  (ctx: i64 in every handler/middleware)
//   ctx_param(ctx, "id")                    -> []i8   :param from path
//   ctx_query(ctx, "page")                  -> []i8   ?key=value (decoded)
//   ctx_query_default(ctx, "page", "1")     -> []i8   with fallback
//   ctx_form(ctx, "email")                  -> []i8   url-encoded body field
//   ctx_form_default(ctx, "role", "user")   -> []i8   with fallback
//   ctx_header(ctx, "Accept")               -> []i8   request header
//   ctx_method(ctx)                         -> []i8   "GET" / "POST" / …
//   ctx_path(ctx)                           -> []i8   "/users/42"
//   ctx_ip(ctx)                             -> []i8   client IP (proxy-aware)
//   ctx_body(ctx)                           -> []i8   raw body bytes
//   ctx_body_json(ctx)                      -> Result<JsonValue, []i8>
//   ctx_cookie(ctx, "session")              -> []i8   cookie value
//   ctx_set(ctx, "user_id", ptr)                      store arbitrary value
//   ctx_get(ctx, "user_id")                 -> i64    retrieve stored value
//
// SESSIONS  (requires forge_session_start middleware)
//   ctx_session_get(ctx, "user_id")         -> []i8
//   ctx_session_set(ctx, "user_id", "42")
//   ctx_session_del(ctx, "user_id")
//   ctx_session_clear(ctx)
//
// FLASH MESSAGES  (requires forge_session_start middleware)
//   ctx_flash_set(ctx, "notice", "Saved!")
//   ctx_flash_get(ctx, "notice")            -> []i8   (consumed on first read)
//
// CSRF PROTECTION  (requires forge_session_start + forge_csrf middleware)
//   forge_csrf_token(ctx)                   -> []i8   embed in forms
//   // Register forge_csrf globally to block forged POST/PUT/DELETE/PATCH
//
// RESPONSE
//   ctx_text(ctx, 200, "hello")
//   ctx_json(ctx, 200, "{\"ok\":true}")
//   ctx_html(ctx, 200, "<h1>Hi</h1>")
//   ctx_ok / ctx_created / ctx_accepted / ctx_no_content
//   ctx_bad_request / ctx_unauthorized / ctx_forbidden / ctx_not_found
//   ctx_conflict / ctx_unprocessable / ctx_too_many_requests
//   ctx_internal_error / ctx_service_unavailable / ctx_not_modified
//   ctx_redirect(ctx, "/login")             302
//   ctx_redirect_perm(ctx, "/new")          301
//   ctx_download(ctx, body, "report.csv")   attachment download
//   ctx_set_header(ctx, "X-Foo", "bar")
//   ctx_set_cookie(ctx, "session", "abc", 3600)
//   ctx_del_cookie(ctx, "session")
//
// SERVER-SENT EVENTS
//   fn my_sse_handler(ctx: i64) {
//       let fd = ctx_sse_start(ctx)
//       if fd < 0 { ret }
//       loop {
//           forge_sse_send(fd, "update", "{\"count\":1}")
//           // ... sleep or wait on channel ...
//       }
//       forge_sse_close(fd)
//   }
//
// WEBSOCKET
//   fn my_ws_handler(ctx: i64) {
//       if ctx_upgrade_ws(ctx) {
//           let fd = ctx_fd(ctx)
//           loop {
//               let buf = [4096]i8
//               let n = forge_ws_recv(fd, buf, 4096)
//               if n <= 0 { break }
//               forge_ws_send_text(fd, buf[0..n])
//           }
//           forge_ws_close(fd)
//       }
//   }
//
// STATIC FILES
//   app_static(app, "/public", "./www")     // GET /public/file.js → ./www/file.js
//
// TEMPLATE RENDERING
//   let vars = erb_vars_new()
//   erb_vars_set(vars, "name", 4, "Alice", 5)
//   ctx_render(ctx, 200, "Hello, <%= name %>!", vars)
//
// BUILT-IN MIDDLEWARE
//   forge_logger           request logger
//   forge_cors             permissive CORS + OPTIONS preflight
//   forge_recover          keep server alive on errors
//   forge_request_id       X-Request-ID header
//   forge_no_cache         Cache-Control: no-store
//   forge_secure_headers   HSTS, X-Frame-Options, CSP, etc.
//   forge_rate_limit       600 req/min global sliding window
//   forge_basic_auth       HTTP Basic Auth
//   forge_jwt_auth         Bearer JWT (HMAC-SHA256)
//   forge_session_start    in-memory session store via "sid" cookie
//   forge_csrf             block forged POST/PUT/DELETE/PATCH
//   forge_proxy_headers    trust X-Real-IP / X-Forwarded-For
// =============================================================================

import jda::net::tcp::{ TcpListener, TcpStream }
import jda::net::http::{ HttpRequest, HttpResponse, parse_request, send_response }
import jda::json::{ JsonValue, json_parse }
import jda::crypto::{ sha1, hmac_sha256 }
import jda::base64::{ b64_encode, b64_decode }
import jda::file_io::{ fs_read_file, path_join }
import jda::time::{ time_now_ms }
import jda::erb::{ erb_vars_new, erb_vars_set, erb_render }

// =============================================================================
// Constants
// =============================================================================
const FORGE_WORKERS      = 256
const FORGE_MAX_ROUTES   = 256
const FORGE_MAX_MW       = 16
const FORGE_MAX_PARAMS   = 16
const FORGE_MAX_HDRS     = 32
const FORGE_MAX_STORE    = 16
const FORGE_MAX_STATIC   = 8
const FORGE_MAX_GRP_MW   = 4
const FORGE_REQ_SIZE     = 8192
const FORGE_STATIC_BUF   = 1048576   // 1 MB max static file

const FORGE_SYS_WRITE    = 1
const FORGE_SYS_RECVFROM = 45
const FORGE_SYS_CLOSE    = 3

// Session store
const FORGE_MAX_SESSIONS      = 128
const FORGE_SESSION_MAX_KV    = 8
const FORGE_SESSION_ID_LEN    = 16
const FORGE_SESSION_KEY_CAP   = 32
const FORGE_SESSION_VAL_CAP   = 128

// =============================================================================
// ForgeConfig — server configuration
// =============================================================================
struct ForgeConfig {
    host:       []i8
    port:       i32
    workers:    i32
    max_body:   i64    // bytes; 0 = 1 MB default
}

fn forge_default_config() -> ForgeConfig {
    ret ForgeConfig {
        host:    "0.0.0.0",
        port:    8080,
        workers: 256,
        max_body: 1048576,
    }
}

// =============================================================================
// Data types
// =============================================================================

struct ForgeParam { key: []i8  val: []i8 }
struct ForgeHdr   { name: []i8  val: []i8 }
struct ForgeKV    { key: []i8  val: i64 }

struct ForgeStaticRoute {
    url_prefix: []i8
    fs_root:    []i8
}

// =============================================================================
// Session types
// =============================================================================
struct ForgeSessionKV {
    key:  [FORGE_SESSION_KEY_CAP]i8
    klen: i64
    val:  [FORGE_SESSION_VAL_CAP]i8
    vlen: i64
}

struct ForgeSession {
    id:    [FORGE_SESSION_ID_LEN]i8
    kv:    [FORGE_SESSION_MAX_KV]ForgeSessionKV
    count: i64
    used:  bool
}

// =============================================================================
// ForgeCtx — per-request context (passed as i64 pointer to handlers)
// =============================================================================
struct ForgeCtx {
    req:         HttpRequest
    fd:          i32
    params:      [FORGE_MAX_PARAMS]ForgeParam
    param_count: i64
    out_hdrs:    [FORGE_MAX_HDRS]ForgeHdr
    out_hcount:  i64
    store:       [FORGE_MAX_STORE]ForgeKV
    store_count: i64
    sent:        bool
    is_ws:       bool       // set to true after successful WebSocket upgrade
}

// =============================================================================
// ForgeRoute — single registered route
// =============================================================================
struct ForgeRoute {
    method:   []i8
    pattern:  []i8
    handler:  i64
    grp_mw:  [FORGE_MAX_GRP_MW]i64   // group-scoped middleware
    grp_mwc: i64
    is_ws:    bool
}

// =============================================================================
// ForgeGroup — route group with shared prefix and middleware
// =============================================================================
struct ForgeGroup {
    app:      &ForgeApp
    prefix:   []i8
    mw:      [FORGE_MAX_GRP_MW]i64
    mw_count: i64
}

// =============================================================================
// ForgeApp — the application object
// =============================================================================
struct ForgeApp {
    routes:          [FORGE_MAX_ROUTES]ForgeRoute
    route_count:     i64
    middleware:      [FORGE_MAX_MW]i64
    mw_count:        i64
    after:           [FORGE_MAX_MW]i64   // post-handler middleware
    after_count:     i64
    static_routes:   [FORGE_MAX_STATIC]ForgeStaticRoute
    static_count:    i64
    not_found_h:     i64   // custom 404 handler (0 = default)
    error_h:         i64   // custom 500 handler (0 = default)
    config:          ForgeConfig
}

let g_forge_app:          i64  = 0
let g_forge_session_ptrs: &i64 = 0
let g_forge_session_gen:  i64  = 0

// =============================================================================
// App construction
// =============================================================================

fn app_new() -> &ForgeApp {
    let app: &ForgeApp = alloc_pages(8)
    app.route_count  = 0
    app.mw_count     = 0
    app.after_count  = 0
    app.static_count = 0
    app.not_found_h  = 0
    app.error_h      = 0
    app.config       = forge_default_config()
    ret app
}

fn app_new_config(cfg: ForgeConfig) -> &ForgeApp {
    let app = app_new()
    app.config = cfg
    ret app
}

fn app_not_found(app: &ForgeApp, handler: i64) { app.not_found_h = handler }
fn app_on_error (app: &ForgeApp, handler: i64) { app.error_h     = handler }

fn app_after(app: &ForgeApp, mw: i64) {
    let n = app.after_count
    if n < FORGE_MAX_MW { app.after[n] = mw   app.after_count = n + 1 }
}

// =============================================================================
// Route registration
// =============================================================================

fn app_route(app: &ForgeApp, method: []i8, pattern: []i8, handler: i64) {
    let n = app.route_count
    if n < FORGE_MAX_ROUTES {
        app.routes[n].method  = method
        app.routes[n].pattern = pattern
        app.routes[n].handler = handler
        app.routes[n].grp_mwc = 0
        app.routes[n].is_ws   = false
        app.route_count = n + 1
    }
}

fn app_get   (app: &ForgeApp, p: []i8, h: i64) { app_route(app, "GET",    p, h) }
fn app_post  (app: &ForgeApp, p: []i8, h: i64) { app_route(app, "POST",   p, h) }
fn app_put   (app: &ForgeApp, p: []i8, h: i64) { app_route(app, "PUT",    p, h) }
fn app_delete(app: &ForgeApp, p: []i8, h: i64) { app_route(app, "DELETE", p, h) }
fn app_patch (app: &ForgeApp, p: []i8, h: i64) { app_route(app, "PATCH",  p, h) }

fn app_root(app: &ForgeApp, h: i64) { app_get(app, "/", h) }

// ctx_render — send 200 HTML response (convenience alias for ctx_html)
fn ctx_render(ctx: i64, html: []i8) { ctx_html(ctx, 200, html) }

// =============================================================================
// ForgeBuf — growable string buffer for view rendering
//
// Eliminates manual loop-copy boilerplate. Use in view functions:
//
//   fn view_posts_index(ctx: i64, posts: &ForgeResult) -> []i8 {
//       let buf = forge_buf_new(8)
//       buf.write("<h1>Posts</h1>")
//       buf.write(tmpl_flash(ctx))
//       loop r in 0..posts.count {
//           buf.write(forge_result_col(posts, r, "title"))
//       }
//       ret tmpl_layout("Posts", buf.done())
//   }
//
// buf.write() returns buf so calls can be chained.
// buf.done() returns the accumulated []i8 slice.
// =============================================================================

struct ForgeBuf {
    data: &i8
    pos:  i64
    cap:  i64
}

fn forge_buf_new(pages: i64) -> &ForgeBuf {
    let b: &ForgeBuf = alloc_pages(1)
    b.data = alloc_pages(pages)
    b.pos  = 0
    b.cap  = pages * 4096
    ret b
}

fn forge_buf_write(b: &ForgeBuf, s: []i8) -> &ForgeBuf {
    loop i in 0..s.len {
        if b.pos < b.cap { b.data[b.pos] = s[i]  b.pos = b.pos + 1 }
    }
    ret b
}

fn forge_buf_done(b: &ForgeBuf) -> []i8 { ret b.data[0..b.pos] }

fn forge_buf_write_esc(b: &ForgeBuf, val: []i8) -> &ForgeBuf {
    let n = forge_db_escape_str(val, b.data + b.pos)
    b.pos = b.pos + n
    ret b
}

// =============================================================================
// Route scopes — namespace and nested resource grouping
//
// let admin = forge_scope(app, "/admin")
// admin.get("/users",     fn_addr(handle_admin_users_index))
// admin.get("/users/:id", fn_addr(handle_admin_users_show))
//
// Scopes can be nested:
// let user_scope = forge_scope(app, "/users/:user_id")
// let posts      = forge_scope_nested(user_scope, "/posts")
// posts.get("",     fn_addr(handle_user_posts_index))
// posts.get("/:id", fn_addr(handle_user_posts_show))
// =============================================================================

struct ForgeScope {
    app:    &ForgeApp
    prefix: []i8
}

fn forge__scope_join(prefix: []i8, path: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    loop i in 0..prefix.len { buf[pos] = prefix[i]  pos = pos + 1 }
    loop i in 0..path.len   { buf[pos] = path[i]    pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_scope(app: &ForgeApp, prefix: []i8) -> &ForgeScope {
    let s: &ForgeScope = alloc_pages(1)
    s.app    = app
    s.prefix = prefix
    ret s
}

fn forge_scope_nested(parent: &ForgeScope, suffix: []i8) -> &ForgeScope {
    ret forge_scope(parent.app, forge__scope_join(parent.prefix, suffix))
}

fn forge_scope_get   (s: &ForgeScope, p: []i8, h: i64) { app_get   (s.app, forge__scope_join(s.prefix, p), h) }
fn forge_scope_post  (s: &ForgeScope, p: []i8, h: i64) { app_post  (s.app, forge__scope_join(s.prefix, p), h) }
fn forge_scope_put   (s: &ForgeScope, p: []i8, h: i64) { app_put   (s.app, forge__scope_join(s.prefix, p), h) }
fn forge_scope_delete(s: &ForgeScope, p: []i8, h: i64) { app_delete(s.app, forge__scope_join(s.prefix, p), h) }
fn forge_scope_patch (s: &ForgeScope, p: []i8, h: i64) { app_patch (s.app, forge__scope_join(s.prefix, p), h) }

fn forge__singularize(res: []i8) -> []i8 {
    if res.len > 1 {
        if res[res.len - 1] == 's' { ret res[0..res.len - 1] }
    }
    ret res
}

fn forge__resources_nested_scope(app: &ForgeApp, base: []i8, res: []i8) -> &ForgeScope {
    let sing = forge__singularize(res)
    let buf = forge_buf_new(1)
    buf.write(base).write("/:").write(sing).write("_id")
    ret forge_scope(app, buf.done())
}

// =============================================================================
// Explicit resource registration — pass fn_addr for each handler.
// Pass 0 to skip a route. Returns nested &ForgeScope at /{res}/:{sing}_id.
// =============================================================================

fn forge_resources_explicit(app: &ForgeApp, res: []i8,
                             index_h: i64, new_h: i64,  create_h: i64,
                             show_h:  i64, edit_h: i64,  update_h: i64, delete_h: i64) -> &ForgeScope {
    let base = forge__scope_join("/", res)
    if index_h  != 0 { app_get   (app, base,                                 index_h)  }
    if new_h    != 0 { app_get   (app, forge__scope_join(base, "/new"),       new_h)    }
    if create_h != 0 { app_post  (app, base,                                  create_h) }
    if show_h   != 0 { app_get   (app, forge__scope_join(base, "/:id"),       show_h)   }
    if edit_h   != 0 { app_get   (app, forge__scope_join(base, "/:id/edit"),  edit_h)   }
    if update_h != 0 { app_put   (app, forge__scope_join(base, "/:id"),       update_h) }
    if delete_h != 0 { app_delete(app, forge__scope_join(base, "/:id"),       delete_h) }
    ret forge__resources_nested_scope(app, base, res)
}

fn forge_scope_resources_explicit(s: &ForgeScope, res: []i8,
                                   index_h: i64, new_h: i64,  create_h: i64,
                                   show_h:  i64, edit_h: i64,  update_h: i64, delete_h: i64) -> &ForgeScope {
    let base = forge__scope_join(s.prefix, forge__scope_join("/", res))
    if index_h  != 0 { app_get   (s.app, base,                                 index_h)  }
    if new_h    != 0 { app_get   (s.app, forge__scope_join(base, "/new"),       new_h)    }
    if create_h != 0 { app_post  (s.app, base,                                  create_h) }
    if show_h   != 0 { app_get   (s.app, forge__scope_join(base, "/:id"),       show_h)   }
    if edit_h   != 0 { app_get   (s.app, forge__scope_join(base, "/:id/edit"),  edit_h)   }
    if update_h != 0 { app_put   (s.app, forge__scope_join(base, "/:id"),       update_h) }
    if delete_h != 0 { app_delete(s.app, forge__scope_join(base, "/:id"),       delete_h) }
    ret forge__resources_nested_scope(s.app, base, res)
}

fn forge_resource_explicit(app: &ForgeApp, res: []i8,
                            new_h: i64, create_h: i64,
                            show_h: i64, edit_h: i64, update_h: i64, delete_h: i64) {
    let base = forge__scope_join("/", res)
    if new_h    != 0 { app_get   (app, forge__scope_join(base, "/new"),  new_h)    }
    if create_h != 0 { app_post  (app, base,                              create_h) }
    if show_h   != 0 { app_get   (app, base,                              show_h)   }
    if edit_h   != 0 { app_get   (app, forge__scope_join(base, "/edit"),  edit_h)   }
    if update_h != 0 { app_put   (app, base,                              update_h) }
    if delete_h != 0 { app_delete(app, base,                              delete_h) }
}

fn forge_scope_resource_explicit(s: &ForgeScope, res: []i8,
                                  new_h: i64, create_h: i64,
                                  show_h: i64, edit_h: i64, update_h: i64, delete_h: i64) {
    let base = forge__scope_join(s.prefix, forge__scope_join("/", res))
    if new_h    != 0 { app_get   (s.app, forge__scope_join(base, "/new"),  new_h)    }
    if create_h != 0 { app_post  (s.app, base,                              create_h) }
    if show_h   != 0 { app_get   (s.app, base,                              show_h)   }
    if edit_h   != 0 { app_get   (s.app, forge__scope_join(base, "/edit"),  edit_h)   }
    if update_h != 0 { app_put   (s.app, base,                              update_h) }
    if delete_h != 0 { app_delete(s.app, base,                              delete_h) }
}

// =============================================================================
// Action registry — maps ("controller", "action") → fn_ptr.
// forge_controllers_init() (generated by scaffold in config/controllers.jda)
// calls forge_action_register once per action. Then forge_resources("posts")
// and app.resources("posts") auto-discover handlers by naming convention.
// =============================================================================

struct ForgeActionEntry {
    ctrl:     &i8
    ctrl_len: i64
    act:      &i8
    act_len:  i64
    fn_ptr:   i64
}

let FORGE_MAX_ACTIONS = 512

let forge__action_data:  &ForgeActionEntry = 0 as &ForgeActionEntry
let forge__action_count: i64 = 0
let forge__action_pool:  &i8 = 0 as &i8
let forge__action_pool_pos: i64 = 0

fn forge__action_ensure_init() {
    if forge__action_data == (0 as &ForgeActionEntry) {
        forge__action_data  = alloc_pages(6) as &ForgeActionEntry
        forge__action_pool  = alloc_pages(4)
        forge__action_pool_pos = 0
        forge__action_count = 0
    }
}

fn forge__action_pool_copy(s: []i8) -> &i8 {
    let dst = forge__action_pool + forge__action_pool_pos
    loop i in 0..s.len { dst[i] = s[i] }
    forge__action_pool_pos = forge__action_pool_pos + s.len
    ret dst
}

fn forge_action_register(ctrl: []i8, action: []i8, h: i64) {
    forge__action_ensure_init()
    let n = forge__action_count
    if n >= FORGE_MAX_ACTIONS { ret }
    let e: &ForgeActionEntry = (forge__action_data as i64 + n * 40) as &ForgeActionEntry
    e.ctrl     = forge__action_pool_copy(ctrl)
    e.ctrl_len = ctrl.len
    e.act      = forge__action_pool_copy(action)
    e.act_len  = action.len
    e.fn_ptr   = h
    forge__action_count = n + 1
}

fn forge_action_get(ctrl: []i8, action: []i8) -> i64 {
    if forge__action_data == (0 as &ForgeActionEntry) { ret 0 }
    loop i in 0..forge__action_count {
        let e: &ForgeActionEntry = (forge__action_data as i64 + i * 40) as &ForgeActionEntry
        if e.ctrl_len == ctrl.len && e.act_len == action.len {
            let ok = true
            loop j in 0..ctrl.len {
                if e.ctrl[j] != ctrl[j] { ok = false  break }
            }
            if ok {
                loop j in 0..action.len {
                    if e.act[j] != action[j] { ok = false  break }
                }
            }
            if ok { ret e.fn_ptr }
        }
    }
    ret 0
}

// Parse "controller#action" — returns controller part
fn forge__ctrl_from_str(s: []i8) -> []i8 {
    loop i in 0..s.len { if s[i] == '#' { ret s[0..i] } }
    ret s
}

// Parse "controller#action" — returns action part
fn forge__act_from_str(s: []i8) -> []i8 {
    loop i in 0..s.len { if s[i] == '#' { ret s[i+1..s.len] } }
    ret ""
}

// =============================================================================
// Rails-style auto-discovery API — looks up actions from the registry.
// Use after forge_controllers_init() has been called in main().
//
// UFCS on &ForgeApp:   app.resources("posts")   app.root("posts#index")
//                      app.namespace("admin")    app.get("/login", "sessions#new")
// UFCS on &ForgeScope: scope.resources("comments")   scope.resource("profile")
// =============================================================================

fn forge_resources(app: &ForgeApp, res: []i8) -> &ForgeScope {
    ret forge_resources_explicit(app, res,
        forge_action_get(res, "index"),
        forge_action_get(res, "new"),
        forge_action_get(res, "create"),
        forge_action_get(res, "show"),
        forge_action_get(res, "edit"),
        forge_action_get(res, "update"),
        forge_action_get(res, "delete"))
}

fn forge_scope_resources(s: &ForgeScope, res: []i8) -> &ForgeScope {
    ret forge_scope_resources_explicit(s, res,
        forge_action_get(res, "index"),
        forge_action_get(res, "new"),
        forge_action_get(res, "create"),
        forge_action_get(res, "show"),
        forge_action_get(res, "edit"),
        forge_action_get(res, "update"),
        forge_action_get(res, "delete"))
}

fn forge_resource(app: &ForgeApp, res: []i8) {
    forge_resource_explicit(app, res,
        forge_action_get(res, "new"),
        forge_action_get(res, "create"),
        forge_action_get(res, "show"),
        forge_action_get(res, "edit"),
        forge_action_get(res, "update"),
        forge_action_get(res, "delete"))
}

fn forge_scope_resource(s: &ForgeScope, res: []i8) {
    forge_scope_resource_explicit(s, res,
        forge_action_get(res, "new"),
        forge_action_get(res, "create"),
        forge_action_get(res, "show"),
        forge_action_get(res, "edit"),
        forge_action_get(res, "update"),
        forge_action_get(res, "delete"))
}

fn forge_namespace(app: &ForgeApp, ns: []i8) -> &ForgeScope {
    ret forge_scope(app, forge__scope_join("/", ns))
}

// UFCS on &ForgeApp — Rails app.root / app.resources / app.namespace / app.get etc.
fn forge_app_root(app: &ForgeApp, s: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(s), forge__act_from_str(s))
    if h != 0 { app_get(app, "/", h) }
}

fn forge_app_resources(app: &ForgeApp, res: []i8) -> &ForgeScope {
    ret forge_resources(app, res)
}

fn forge_app_resource(app: &ForgeApp, res: []i8) {
    forge_resource(app, res)
}

fn forge_app_namespace(app: &ForgeApp, ns: []i8) -> &ForgeScope {
    ret forge_namespace(app, ns)
}

fn forge_app_get(app: &ForgeApp, path: []i8, s: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(s), forge__act_from_str(s))
    if h != 0 { app_get(app, path, h) }
}

fn forge_app_post(app: &ForgeApp, path: []i8, s: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(s), forge__act_from_str(s))
    if h != 0 { app_post(app, path, h) }
}

fn forge_app_put(app: &ForgeApp, path: []i8, s: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(s), forge__act_from_str(s))
    if h != 0 { app_put(app, path, h) }
}

fn forge_app_delete(app: &ForgeApp, path: []i8, s: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(s), forge__act_from_str(s))
    if h != 0 { app_delete(app, path, h) }
}

fn forge_app_scope(app: &ForgeApp, prefix: []i8) -> &ForgeScope {
    ret forge_scope(app, prefix)
}

fn forge_scope_app_get(s: &ForgeScope, path: []i8, act: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(act), forge__act_from_str(act))
    if h != 0 { forge_scope_get(s, path, h) }
}

fn forge_scope_app_post(s: &ForgeScope, path: []i8, act: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(act), forge__act_from_str(act))
    if h != 0 { forge_scope_post(s, path, h) }
}

fn forge_scope_app_put(s: &ForgeScope, path: []i8, act: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(act), forge__act_from_str(act))
    if h != 0 { forge_scope_put(s, path, h) }
}

fn forge_scope_app_delete(s: &ForgeScope, path: []i8, act: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(act), forge__act_from_str(act))
    if h != 0 { forge_scope_delete(s, path, h) }
}

fn forge_scope_app_patch(s: &ForgeScope, path: []i8, act: []i8) {
    let h = forge_action_get(forge__ctrl_from_str(act), forge__act_from_str(act))
    if h != 0 { forge_scope_patch(s, path, h) }
}

fn app_ws(app: &ForgeApp, pattern: []i8, handler: i64) {
    let n = app.route_count
    if n < FORGE_MAX_ROUTES {
        app.routes[n].method  = "GET"
        app.routes[n].pattern = pattern
        app.routes[n].handler = handler
        app.routes[n].grp_mwc = 0
        app.routes[n].is_ws   = true
        app.route_count = n + 1
    }
}

fn app_use(app: &ForgeApp, mw: i64) {
    let n = app.mw_count
    if n < FORGE_MAX_MW { app.middleware[n] = mw   app.mw_count = n + 1 }
}

fn app_static(app: &ForgeApp, url_prefix: []i8, fs_root: []i8) {
    let n = app.static_count
    if n < FORGE_MAX_STATIC {
        app.static_routes[n].url_prefix = url_prefix
        app.static_routes[n].fs_root    = fs_root
        app.static_count = n + 1
    }
}

// =============================================================================
// Route groups
// =============================================================================

fn app_group(app: &ForgeApp, prefix: []i8) -> ForgeGroup {
    ret ForgeGroup { app: app, prefix: prefix, mw_count: 0 }
}

fn group_use(grp: &ForgeGroup, mw: i64) {
    let n = grp.mw_count
    if n < FORGE_MAX_GRP_MW { grp.mw[n] = mw   grp.mw_count = n + 1 }
}

fn group_route(grp: &ForgeGroup, method: []i8, pattern: []i8, handler: i64) {
    // Build prefix + pattern on the heap so the slice outlives this call
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let pfx = grp.prefix
    loop i in 0..pfx.len     { buf[pos] = pfx[i]      pos = pos + 1 }
    loop i in 0..pattern.len { buf[pos] = pattern[i]  pos = pos + 1 }
    let full_path = buf[0..pos]

    let app = grp.app
    let n = app.route_count
    if n < FORGE_MAX_ROUTES {
        app.routes[n].method  = method
        app.routes[n].pattern = full_path
        app.routes[n].handler = handler
        app.routes[n].is_ws   = false
        // Copy group middleware into route
        let mc = grp.mw_count
        app.routes[n].grp_mwc = mc
        loop i in 0..mc { app.routes[n].grp_mw[i] = grp.mw[i] }
        app.route_count = n + 1
    }
}

fn group_get   (grp: &ForgeGroup, p: []i8, h: i64) { group_route(grp, "GET",    p, h) }
fn group_post  (grp: &ForgeGroup, p: []i8, h: i64) { group_route(grp, "POST",   p, h) }
fn group_put   (grp: &ForgeGroup, p: []i8, h: i64) { group_route(grp, "PUT",    p, h) }
fn group_delete(grp: &ForgeGroup, p: []i8, h: i64) { group_route(grp, "DELETE", p, h) }
fn group_patch (grp: &ForgeGroup, p: []i8, h: i64) { group_route(grp, "PATCH",  p, h) }

// =============================================================================
// Internal: slice equality
// =============================================================================
fn forge_slice_eq(a: []i8, b: []i8) -> bool {
    if a.len != b.len { ret false }
    loop i in 0..a.len { if a[i] != b[i] { ret false } }
    ret true
}

fn forge_starts_with(s: []i8, prefix: []i8) -> bool {
    if s.len < prefix.len { ret false }
    loop i in 0..prefix.len { if s[i] != prefix[i] { ret false } }
    ret true
}

// =============================================================================
// Path pattern matching
// Segments: /:param  /*wildcard  /literal
// =============================================================================
fn forge_match_path(pattern: []i8, path: []i8, ctx: &ForgeCtx) -> bool {
    let pi = 0i64
    let ri = 0i64
    if pi < pattern.len and pattern[pi] == '/' { pi = pi + 1 }
    if ri < path.len    and path[ri]    == '/' { ri = ri + 1 }

    loop {
        let ps = pi
        loop pi < pattern.len and pattern[pi] != '/' { pi = pi + 1 }
        let pseg = pattern[ps..pi]
        if pi < pattern.len { pi = pi + 1 }

        let rs = ri
        loop ri < path.len and path[ri] != '/' { ri = ri + 1 }
        let rseg = path[rs..ri]
        if ri < path.len { ri = ri + 1 }

        if pseg.len == 1 and pseg[0] == '*'   { ret true }
        if pseg.len == 0 and rseg.len == 0    { ret true }
        if pseg.len == 0 or  rseg.len == 0   { ret false }

        if pseg[0] == ':' {
            let n = ctx.param_count
            if n < FORGE_MAX_PARAMS {
                ctx.params[n].key = pseg[1..]
                ctx.params[n].val = rseg
                ctx.param_count   = n + 1
            }
        } else {
            if not forge_slice_eq(pseg, rseg) { ret false }
        }
    }
}

// =============================================================================
// Dispatch
// =============================================================================
fn forge_dispatch(app: &ForgeApp, ctx_ptr: i64) {
    let ctx: &ForgeCtx = ctx_ptr

    // 1. Check normal routes
    loop i in 0..app.route_count {
        ctx.param_count = 0
        let route = &app.routes[i]
        if forge_slice_eq(route.method, ctx.req.method) and
           forge_match_path(route.pattern, ctx.req.path, ctx) {
            // Global middleware
            loop j in 0..app.mw_count {
                call_fn(app.middleware[j], ctx_ptr)
                if ctx.sent { ret }
            }
            // Group-scoped middleware
            loop j in 0..route.grp_mwc {
                call_fn(route.grp_mw[j], ctx_ptr)
                if ctx.sent { ret }
            }
            // Handler
            call_fn(route.handler, ctx_ptr)
            // Post-handler middleware (response already sent, just hooks)
            loop j in 0..app.after_count { call_fn(app.after[j], ctx_ptr) }
            ret
        }
    }

    // 2. Check static file routes
    loop i in 0..app.static_count {
        let sr = &app.static_routes[i]
        if forge_starts_with(ctx.req.path, sr.url_prefix) {
            forge_serve_static(ctx_ptr, sr.url_prefix, sr.fs_root)
            ret
        }
    }

    // 3. 404
    if app.not_found_h != 0 {
        call_fn(app.not_found_h, ctx_ptr)
    } else {
        ctx_not_found(ctx_ptr)
    }
}

// =============================================================================
// Connection handler
// =============================================================================
fn forge_handle_fd(fd: i32) {
    let app: &ForgeApp = g_forge_app
    let req_buf = [FORGE_REQ_SIZE]i8
    let max = app.config.max_body
    if max <= 0 { max = 1048576 }
    if max > FORGE_REQ_SIZE { max = FORGE_REQ_SIZE }
    let n = syscall(FORGE_SYS_RECVFROM, fd, req_buf, max, 0, 0, 0) as i64
    if n <= 0 {
        syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
        ret
    }
    match parse_request(req_buf[0..n]) {
        ok(req) => {
            let ctx = ForgeCtx {}
            ctx.req         = req
            ctx.fd          = fd
            ctx.param_count = 0
            ctx.out_hcount  = 0
            ctx.store_count = 0
            ctx.sent        = false
            ctx.is_ws       = false
            let app2: &ForgeApp = g_forge_app
            forge_dispatch(app2, &ctx)
            // Only close if NOT upgraded to WebSocket (WS handler owns the fd)
            if not ctx.is_ws {
                syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
            }
        }
        err(_) => {
            let bad = HttpResponse { status: 400, headers: "", body: "Bad Request" }
            send_response(fd, bad)
            syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
        }
    }
}

// =============================================================================
// Worker and server loop
// =============================================================================
fn forge_worker(ch: i64) {
    loop {
        let fd = chan_recv(ch) as i32
        if fd < 0 { ret }
        forge_handle_fd(fd)
    }
}

fn app_listen(app: &ForgeApp, port: i32) {
    g_forge_app = app
    app.config.port = port

    let host = app.config.host
    let workers = app.config.workers
    if workers <= 0 { workers = 256 }

    let listener = TcpListener::bind(host, port as u16)
        .unwrap_or_else(|e| {
            print("forge: bind failed\n")
            exit(1)
        })

    print("forge: listening on ")
    syscall(FORGE_SYS_WRITE, 1, host, host.len, 0, 0)
    print(":")
    print_int(port)
    print("\n")

    let ch = chan_new(workers * 4)
    loop i in 0..workers { spawn { forge_worker(ch) } }

    loop {
        match listener.accept() {
            ok(conn) => { chan_send(ch, conn.fd as i64) }
            err(_)   => {}
        }
    }
}

// =============================================================================
// Context — request accessors
// =============================================================================
fn ctx_fd    (ctx_ptr: i64) -> i32  { let c: &ForgeCtx = ctx_ptr   ret c.fd }
fn ctx_method(ctx_ptr: i64) -> []i8 { let c: &ForgeCtx = ctx_ptr   ret c.req.method }
fn ctx_path  (ctx_ptr: i64) -> []i8 { let c: &ForgeCtx = ctx_ptr   ret c.req.path }
fn ctx_body  (ctx_ptr: i64) -> []i8 { let c: &ForgeCtx = ctx_ptr   ret c.req.body }
fn ctx_body_json(ctx_ptr: i64) -> Result<JsonValue, []i8> {
    let c: &ForgeCtx = ctx_ptr
    ret json_parse(c.req.body)
}

fn ctx_param(ctx_ptr: i64, key: []i8) -> []i8 {
    let c: &ForgeCtx = ctx_ptr
    loop i in 0..c.param_count {
        if forge_slice_eq(c.params[i].key, key) { ret c.params[i].val }
    }
    ret ""
}

fn ctx_query(ctx_ptr: i64, key: []i8) -> []i8 {
    let c: &ForgeCtx = ctx_ptr
    let q = c.req.query
    if q.len == 0 { ret "" }
    let pos = 0i64
    loop pos < q.len {
        let ks = pos
        loop pos < q.len and q[pos] != '=' { pos = pos + 1 }
        let k = q[ks..pos]
        if pos < q.len { pos = pos + 1 }
        let vs = pos
        loop pos < q.len and q[pos] != '&' { pos = pos + 1 }
        let v = q[vs..pos]
        if pos < q.len { pos = pos + 1 }
        if forge_slice_eq(k, key) { ret v }
    }
    ret ""
}

fn ctx_header(ctx_ptr: i64, name: []i8) -> []i8 {
    let c: &ForgeCtx = ctx_ptr
    ret c.req.header(name)
}

fn ctx_ip(ctx_ptr: i64) -> []i8 {
    // Prefer X-Real-IP (set by nginx), then first entry of X-Forwarded-For
    let real = ctx_header(ctx_ptr, "X-Real-IP")
    if real.len > 0 { ret real }
    let fwd = ctx_header(ctx_ptr, "X-Forwarded-For")
    if fwd.len > 0 {
        let end = 0i64
        loop end < fwd.len and fwd[end] != ',' { end = end + 1 }
        ret fwd[0..end]
    }
    ret ""
}

// =============================================================================
// Context store — pass data between middleware and handler
// =============================================================================
fn ctx_set(ctx_ptr: i64, key: []i8, val: i64) {
    let c: &ForgeCtx = ctx_ptr
    // Update existing key if present
    loop i in 0..c.store_count {
        if forge_slice_eq(c.store[i].key, key) {
            c.store[i].val = val
            ret
        }
    }
    let n = c.store_count
    if n < FORGE_MAX_STORE {
        c.store[n].key = key
        c.store[n].val = val
        c.store_count  = n + 1
    }
}

fn ctx_get(ctx_ptr: i64, key: []i8) -> i64 {
    let c: &ForgeCtx = ctx_ptr
    loop i in 0..c.store_count {
        if forge_slice_eq(c.store[i].key, key) { ret c.store[i].val }
    }
    ret 0
}

// =============================================================================
// Cookie API
// =============================================================================
fn ctx_cookie(ctx_ptr: i64, name: []i8) -> []i8 {
    let raw = ctx_header(ctx_ptr, "Cookie")
    if raw.len == 0 { ret "" }
    let pos = 0i64
    loop pos < raw.len {
        // Skip whitespace
        loop pos < raw.len and raw[pos] == ' ' { pos = pos + 1 }
        // Key
        let ks = pos
        loop pos < raw.len and raw[pos] != '=' and raw[pos] != ';' { pos = pos + 1 }
        let k = raw[ks..pos]
        if pos < raw.len and raw[pos] == '=' { pos = pos + 1 }
        // Value
        let vs = pos
        loop pos < raw.len and raw[pos] != ';' { pos = pos + 1 }
        let v = raw[vs..pos]
        if pos < raw.len { pos = pos + 1 }   // skip ';'
        if forge_slice_eq(k, name) { ret v }
    }
    ret ""
}

fn ctx_set_cookie(ctx_ptr: i64, name: []i8, val: []i8, max_age_secs: i64) {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    loop i in 0..name.len { buf[pos] = name[i]  pos = pos + 1 }
    buf[pos] = '='   pos = pos + 1
    loop i in 0..val.len  { buf[pos] = val[i]   pos = pos + 1 }
    let ma = "; Max-Age="
    loop i in 0..ma.len { buf[pos] = ma[i]  pos = pos + 1 }
    // Append max_age as decimal
    let tmp = [20]i8
    let tlen = fmt_i64(tmp, max_age_secs)
    loop i in 0..tlen { buf[pos] = tmp[i]  pos = pos + 1 }
    let path_s = "; Path=/"
    loop i in 0..path_s.len { buf[pos] = path_s[i]  pos = pos + 1 }
    ctx_set_header(ctx_ptr, "Set-Cookie", buf[0..pos])
}

fn ctx_del_cookie(ctx_ptr: i64, name: []i8) {
    ctx_set_cookie(ctx_ptr, name, "", 0)
}

// forge__cookie_sign — FNV-32a signature of val mixed with secret (8 hex chars).
fn forge__cookie_sign(val: []i8, secret: []i8) -> []i8 {
    let h = 2166136261i64
    let prime = 16777619i64
    loop i in 0..val.len    { h = ((h xor (val[i]    as i64 and 0xFF)) * prime) and 0xFFFFFFFF }
    loop i in 0..secret.len { h = ((h xor (secret[i] as i64 and 0xFF)) * prime) and 0xFFFFFFFF }
    let hex = "0123456789abcdef"
    let out: &i8 = alloc_pages(1)
    loop i in 0..8 { out[i] = hex[(h >> ((7 - i) * 4)) and 0xF] }
    ret out[0..8]
}

// ctx_cookie_signed_set — write cookie with FNV-32a signature appended as ".XXXXXXXX".
fn ctx_cookie_signed_set(ctx_ptr: i64, name: []i8, val: []i8, max_age_secs: i64) {
    let sig = forge__cookie_sign(val, g_forge_cfg.secret_key)
    let sv_buf: &i8 = alloc_pages(1)
    let svp = 0i64
    loop i in 0..val.len { sv_buf[svp] = val[i]  svp = svp + 1 }
    sv_buf[svp] = '.'  svp = svp + 1
    loop i in 0..8 { sv_buf[svp] = sig[i]  svp = svp + 1 }
    ctx_set_cookie(ctx_ptr, name, sv_buf[0..svp], max_age_secs)
}

// ctx_cookie_signed_get — verify signature and return value, or "" on tamper.
fn ctx_cookie_signed_get(ctx_ptr: i64, name: []i8) -> []i8 {
    let raw = ctx_cookie(ctx_ptr, name)
    if raw.len < 10 { ret "" }          // at least 1 char + '.' + 8 hex
    let dot = raw.len - 9
    if raw[dot] != '.' { ret "" }
    let val = raw[0..dot]
    let sig = raw[(dot + 1)..raw.len]
    let expected = forge__cookie_sign(val, g_forge_cfg.secret_key)
    if not forge_token_eq_timing(sig, expected) { ret "" }
    ret val
}

// =============================================================================
// Response helpers
// =============================================================================
fn ctx_set_header(ctx_ptr: i64, name: []i8, val: []i8) {
    let c: &ForgeCtx = ctx_ptr
    let n = c.out_hcount
    if n < FORGE_MAX_HDRS {
        c.out_hdrs[n].name = name
        c.out_hdrs[n].val  = val
        c.out_hcount = n + 1
    }
}

fn forge_build_hdr_str(c: &ForgeCtx, buf: &i8) -> i64 {
    let pos = 0i64
    loop i in 0..c.out_hcount {
        let nm = c.out_hdrs[i].name
        let vl = c.out_hdrs[i].val
        loop j in 0..nm.len { buf[pos] = nm[j]   pos = pos + 1 }
        buf[pos] = ':'   pos = pos + 1
        buf[pos] = ' '   pos = pos + 1
        loop j in 0..vl.len  { buf[pos] = vl[j]  pos = pos + 1 }
        buf[pos] = '\r'  pos = pos + 1
        buf[pos] = '\n'  pos = pos + 1
    }
    ret pos
}

let g_forge_test_mode:         bool = false
let g_forge_test_cap_status:   i32  = 0
let g_forge_test_cap_body_ptr: i64  = 0
let g_forge_test_cap_body_len: i64  = 0

struct ForgeTestResponse {
    status: i32
    body:   []i8
}

fn ctx_respond(ctx_ptr: i64, status: i32, content_type: []i8, body: []i8) {
    let c: &ForgeCtx = ctx_ptr
    if c.sent { ret }
    c.sent = true
    if content_type.len > 0 { ctx_set_header(ctx_ptr, "Content-Type", content_type) }
    if g_forge_test_mode {
        g_forge_test_cap_status = status
        let bp: &i8 = alloc_pages(1)
        loop i in 0..body.len { bp[i] = body[i] }
        g_forge_test_cap_body_ptr = bp as i64
        g_forge_test_cap_body_len = body.len
        ret
    }
    let hdr_buf = [4096]i8
    let hdr_len = forge_build_hdr_str(c, hdr_buf)
    let resp = HttpResponse { status: status, headers: hdr_buf[0..hdr_len], body: body }
    send_response(c.fd, resp)
}

fn ctx_text(ctx_ptr: i64, status: i32, body: []i8)  { ctx_respond(ctx_ptr, status, "text/plain; charset=utf-8", body) }
fn ctx_json(ctx_ptr: i64, status: i32, body: []i8)  { ctx_respond(ctx_ptr, status, "application/json", body) }
fn ctx_html(ctx_ptr: i64, status: i32, body: []i8)  { ctx_respond(ctx_ptr, status, "text/html; charset=utf-8", body) }

fn ctx_ok             (ctx_ptr: i64, body: []i8) { ctx_text(ctx_ptr, 200, body) }
fn ctx_created        (ctx_ptr: i64, body: []i8) { ctx_text(ctx_ptr, 201, body) }
fn ctx_no_content     (ctx_ptr: i64)              { ctx_respond(ctx_ptr, 204, "", "") }
fn ctx_bad_request    (ctx_ptr: i64, msg: []i8)  { ctx_text(ctx_ptr, 400, msg) }
fn ctx_unauthorized   (ctx_ptr: i64)              { ctx_text(ctx_ptr, 401, "Unauthorized") }
fn ctx_forbidden      (ctx_ptr: i64)              { ctx_text(ctx_ptr, 403, "Forbidden") }
fn ctx_not_found      (ctx_ptr: i64)              { ctx_text(ctx_ptr, 404, "Not Found") }
fn ctx_method_not_allowed(ctx_ptr: i64)           { ctx_text(ctx_ptr, 405, "Method Not Allowed") }
fn ctx_too_many_requests (ctx_ptr: i64)           { ctx_text(ctx_ptr, 429, "Too Many Requests") }
fn ctx_internal_error (ctx_ptr: i64, msg: []i8)  { ctx_text(ctx_ptr, 500, msg) }

fn ctx_redirect     (ctx_ptr: i64, url: []i8) {
    ctx_set_header(ctx_ptr, "Location", url)
    ctx_respond(ctx_ptr, 302, "", "")
}
fn ctx_redirect_perm(ctx_ptr: i64, url: []i8) {
    ctx_set_header(ctx_ptr, "Location", url)
    ctx_respond(ctx_ptr, 301, "", "")
}

// ctx_redirect_back — redirect to the Referer header; fall back to fallback URL.
fn ctx_redirect_back(ctx_ptr: i64, fallback: []i8) {
    let ref_hdr = ctx_header(ctx_ptr, "Referer")
    if ref_hdr.len > 0 {
        ctx_redirect(ctx_ptr, ref_hdr)
    } else {
        ctx_redirect(ctx_ptr, fallback)
    }
}

// ctx_etag — set ETag response header; send 304 if If-None-Match matches.
fn ctx_etag(ctx_ptr: i64, tag: []i8) -> bool {
    let inm = ctx_header(ctx_ptr, "If-None-Match")
    if forge_slice_eq(inm, tag) {
        ctx_not_modified(ctx_ptr)
        ret true
    }
    ctx_set_header(ctx_ptr, "ETag", tag)
    ret false
}

// ctx_last_modified — set Last-Modified header (Unix timestamp as string).
// Returns true and sends 304 if If-Modified-Since matches.
fn ctx_last_modified(ctx_ptr: i64, ts: []i8) -> bool {
    let ims = ctx_header(ctx_ptr, "If-Modified-Since")
    if forge_slice_eq(ims, ts) {
        ctx_not_modified(ctx_ptr)
        ret true
    }
    ctx_set_header(ctx_ptr, "Last-Modified", ts)
    ret false
}

// ctx_stale — returns true if the client cache is stale (must re-render).
// Sets ETag header; sends 304 and returns false if client is up-to-date.
fn ctx_stale(ctx_ptr: i64, etag: []i8) -> bool {
    ret not ctx_etag(ctx_ptr, etag)
}

// Extended status helpers
fn ctx_accepted           (ctx_ptr: i64, body: []i8) { ctx_text(ctx_ptr, 202, body) }
fn ctx_not_modified       (ctx_ptr: i64)              { ctx_respond(ctx_ptr, 304, "", "") }
fn ctx_conflict           (ctx_ptr: i64, msg: []i8)   { ctx_json(ctx_ptr, 409, msg) }
fn ctx_unprocessable      (ctx_ptr: i64, msg: []i8)   { ctx_json(ctx_ptr, 422, msg) }
fn ctx_service_unavailable(ctx_ptr: i64)               { ctx_text(ctx_ptr, 503, "Service Unavailable") }
fn ctx_head               (ctx_ptr: i64, status: i32)   { ctx_respond(ctx_ptr, status, "", "") }

// File download — sends body with Content-Disposition: attachment
fn ctx_download(ctx_ptr: i64, body: []i8, filename: []i8) {
    let buf = [320]i8
    let pos = 0i64
    let p1 = "attachment; filename=\""
    let p2 = "\""
    loop i in 0..p1.len       { buf[pos] = p1[i]        pos = pos + 1 }
    loop i in 0..filename.len { buf[pos] = filename[i]  pos = pos + 1 }
    loop i in 0..p2.len       { buf[pos] = p2[i]        pos = pos + 1 }
    ctx_set_header(ctx_ptr, "Content-Disposition", buf[0..pos])
    ctx_respond(ctx_ptr, 200, "application/octet-stream", body)
}

// =============================================================================
// Template rendering
// =============================================================================
fn ctx_render(ctx_ptr: i64, status: i32, tmpl: []i8, vars: &i64) {
    let out: &i8 = alloc_pages(4)    // 16 KB output buffer
    let len = erb_render(tmpl, tmpl.len, vars, out, 16384)
    ctx_html(ctx_ptr, status, out[0..len])
}

// =============================================================================
// Static file serving
// =============================================================================
fn forge_content_type(path: []i8) -> []i8 {
    // Find last '.'
    let dot = -1i64
    loop i in 0..path.len { if path[i] == '.' { dot = i } }
    if dot < 0 { ret "application/octet-stream" }
    let ext = path[dot+1..]
    if forge_slice_eq(ext, "html") or forge_slice_eq(ext, "htm") { ret "text/html; charset=utf-8" }
    if forge_slice_eq(ext, "css")  { ret "text/css" }
    if forge_slice_eq(ext, "js")   { ret "application/javascript" }
    if forge_slice_eq(ext, "json") { ret "application/json" }
    if forge_slice_eq(ext, "png")  { ret "image/png" }
    if forge_slice_eq(ext, "jpg")  or forge_slice_eq(ext, "jpeg") { ret "image/jpeg" }
    if forge_slice_eq(ext, "gif")  { ret "image/gif" }
    if forge_slice_eq(ext, "svg")  { ret "image/svg+xml" }
    if forge_slice_eq(ext, "ico")  { ret "image/x-icon" }
    if forge_slice_eq(ext, "txt")  { ret "text/plain" }
    if forge_slice_eq(ext, "pdf")  { ret "application/pdf" }
    if forge_slice_eq(ext, "wasm") { ret "application/wasm" }
    ret "application/octet-stream"
}

fn forge_serve_static(ctx_ptr: i64, url_prefix: []i8, fs_root: []i8) {
    let c: &ForgeCtx = ctx_ptr
    // Strip url_prefix from path to get the file subpath
    let sub = c.req.path[url_prefix.len..]

    // Build null-terminated filesystem path: fs_root + "/" + sub
    let path_buf = [1024]i8
    let pos = 0i64
    loop i in 0..fs_root.len { path_buf[pos] = fs_root[i]  pos = pos + 1 }
    path_buf[pos] = '/'  pos = pos + 1
    loop i in 0..sub.len    { path_buf[pos] = sub[i]       pos = pos + 1 }
    path_buf[pos] = 0        // null-terminate for fs_read_file

    // Read the file
    let file_buf: &i8 = alloc_pages(256)   // 1 MB max
    let n = fs_read_file(path_buf, file_buf, 1048576)
    if n < 0 {
        ctx_not_found(ctx_ptr)
        ret
    }
    let ct = forge_content_type(c.req.path)
    ctx_respond(ctx_ptr, 200, ct, file_buf[0..n])
}

// =============================================================================
// WebSocket support
// Upgrade an HTTP connection to WebSocket.
// After ctx_upgrade_ws returns true, the connection is NOT auto-closed.
// The handler owns the fd and must call forge_ws_close when done.
// =============================================================================

// Write exactly n bytes to fd
fn forge_tcp_write_all(fd: i32, buf: &i8, n: i64) {
    let sent = 0i64
    loop sent < n {
        let wrote = syscall(1, fd, buf + sent, n - sent, 0, 0, 0) as i64
        if wrote > 0 { sent = sent + wrote }
        else         { ret }
    }
}

fn forge_ws_handshake(fd: i32, key: []i8) {
    // Compute Sec-WebSocket-Accept = base64(sha1(key + GUID))
    let guid = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
    let concat = [128]i8
    let pos = 0i64
    loop i in 0..key.len  { concat[pos] = key[i]   pos = pos + 1 }
    loop i in 0..guid.len { concat[pos] = guid[i]  pos = pos + 1 }
    let sha_out = [20]i8
    sha1(concat, pos, sha_out)
    let accept = [32]i8
    let alen = b64_encode(sha_out, 20, accept)
    // Send 101 response
    let resp = [256]i8
    let rp = 0i64
    let line1 = "HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Accept: "
    loop i in 0..line1.len { resp[rp] = line1[i]   rp = rp + 1 }
    loop i in 0..alen      { resp[rp] = accept[i]  rp = rp + 1 }
    resp[rp] = '\r'  rp = rp + 1
    resp[rp] = '\n'  rp = rp + 1
    resp[rp] = '\r'  rp = rp + 1
    resp[rp] = '\n'  rp = rp + 1
    forge_tcp_write_all(fd, resp, rp)
}

// Upgrade HTTP connection to WebSocket. Returns true on success.
fn ctx_upgrade_ws(ctx_ptr: i64) -> bool {
    let c: &ForgeCtx = ctx_ptr
    let upgrade = c.req.header("Upgrade")
    let key     = c.req.header("Sec-WebSocket-Key")
    if key.len == 0 { ret false }
    if not forge_slice_eq(upgrade, "websocket") { ret false }
    forge_ws_handshake(c.fd, key)
    c.sent  = true    // prevent forge from sending an HTTP response
    c.is_ws = true    // prevent forge from closing the fd
    ret true
}

// Send a text frame (server → client, unmasked)
fn forge_ws_send_text(fd: i32, msg: []i8) {
    let hdr = [10]i8
    let hn = 0i64
    hdr[hn] = 0x81   hn = hn + 1   // FIN + TEXT opcode
    let mlen = msg.len
    if mlen < 126 {
        hdr[hn] = mlen   hn = hn + 1
    } else {
        hdr[hn] = 126    hn = hn + 1
        hdr[hn] = (mlen >> 8) as i8   hn = hn + 1
        hdr[hn] = (mlen & 0xFF) as i8 hn = hn + 1
    }
    forge_tcp_write_all(fd, hdr, hn)
    forge_tcp_write_all(fd, msg, mlen)
}

// Send a binary frame (server → client, unmasked)
fn forge_ws_send_binary(fd: i32, data: []i8) {
    let hdr = [10]i8
    let hn = 0i64
    hdr[hn] = 0x82   hn = hn + 1   // FIN + BINARY opcode
    let dlen = data.len
    if dlen < 126 {
        hdr[hn] = dlen   hn = hn + 1
    } else {
        hdr[hn] = 126    hn = hn + 1
        hdr[hn] = (dlen >> 8) as i8    hn = hn + 1
        hdr[hn] = (dlen & 0xFF) as i8  hn = hn + 1
    }
    forge_tcp_write_all(fd, hdr, hn)
    forge_tcp_write_all(fd, data, dlen)
}

// Receive one WebSocket frame into buf. Returns payload length, 0 on close, < 0 on error.
fn forge_ws_recv(fd: i32, buf: &i8, max: i64) -> i64 {
    let hdr = [14]i8
    // Read first 2 bytes
    let n = syscall(FORGE_SYS_RECVFROM, fd, hdr, 2, 0, 0, 0) as i64
    if n < 2 { ret -1 }
    let opcode = hdr[0] as i64 and 0x0F
    let masked = (hdr[1] as i64 and 0x80) != 0
    let len7   = hdr[1] as i64 and 0x7F
    if opcode == 0x8 { ret 0 }   // Close frame
    // Extended length
    let payload_len = len7
    if len7 == 126 {
        let n2 = syscall(FORGE_SYS_RECVFROM, fd, hdr, 2, 0, 0, 0) as i64
        if n2 < 2 { ret -1 }
        payload_len = ((hdr[0] as i64 and 0xFF) << 8) or (hdr[1] as i64 and 0xFF)
    }
    // Masking key
    let mask = [4]i8
    if masked {
        let nm = syscall(FORGE_SYS_RECVFROM, fd, mask, 4, 0, 0, 0) as i64
        if nm < 4 { ret -1 }
    }
    // Read payload
    if payload_len > max { payload_len = max }
    let total = 0i64
    loop total < payload_len {
        let got = syscall(FORGE_SYS_RECVFROM, fd, buf + total, payload_len - total, 0, 0, 0) as i64
        if got <= 0 { ret -1 }
        total = total + got
    }
    // Unmask payload (client→server always masked)
    if masked {
        loop i in 0..total {
            buf[i] = buf[i] as i64 ^ mask[i - (i / 4) * 4] as i64
        }
    }
    ret total
}

fn forge_ws_close(fd: i32) {
    let frame = [2]i8
    frame[0] = 0x88   // FIN + CLOSE opcode
    frame[1] = 0
    forge_tcp_write_all(fd, frame, 2)
    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
}

// =============================================================================
// Channels — Action Cable style pub/sub over WebSocket
//
// Register named channels at startup, then broadcast to all subscribers
// from anywhere in the app — handlers, jobs, callbacks.
//
// Wire protocol (JSON over WebSocket):
//   Client → Server  {"command":"subscribe","channel":"posts"}
//   Client → Server  {"command":"message","channel":"posts","data":"..."}
//   Client → Server  {"command":"unsubscribe","channel":"posts"}
//   Server → Client  {"type":"confirm_subscription","channel":"posts"}
//   Server → Client  {"type":"rejection","channel":"posts"}
//   Server → Client  {"type":"message","channel":"posts","message":<data>}
//
// Usage:
//   // startup
//   forge_channel_register("posts", fn_addr(posts_subscribed), fn_addr(posts_received), fn_addr(posts_unsubscribed))
//
//   // route handler (blocks until disconnect)
//   fn handle_cable(ctx: i64) { forge_channel_handle(ctx) }
//
//   // broadcast from anywhere
//   forge_channel_broadcast("posts", json_str)
//
// Callback signature: fn my_cb(arg: i64) where arg is a *ForgeChanCbArg.
// =============================================================================

const FORGE_CHAN_MAX       = 64
const FORGE_CHAN_FD_MAX    = 256
const FORGE_CHAN_NAME_CAP  = 64
const FORGE_CHAN_ENTRY_STRIDE = 96   // 64 + 8 + 8 + 8 + 8

// Passed to on_sub / on_msg / on_unsub callbacks as a packed i64 pointer.
struct ForgeChanCbArg {
    fd:       i64
    data:     i64   // &i8 pointer to payload bytes (0 for subscribe/unsubscribe events)
    data_len: i64
}

struct ForgeChanEntry {
    name:     [FORGE_CHAN_NAME_CAP]i8
    name_len: i64
    on_sub:   i64
    on_msg:   i64
    on_unsub: i64
}

let g_forge_chan_base:      i64  = 0
let g_forge_chan_count:     i64  = 0
let g_forge_chan_fds:       &i64 = 0   // flat [FORGE_CHAN_MAX * FORGE_CHAN_FD_MAX] — -1 = empty slot
let g_forge_chan_fd_counts: &i64 = 0   // [FORGE_CHAN_MAX] subscriber count per channel

fn forge_chan_entry_at(i: i64) -> &ForgeChanEntry {
    ret (g_forge_chan_base + i * FORGE_CHAN_ENTRY_STRIDE) as &ForgeChanEntry
}

fn forge_chan_init() {
    if g_forge_chan_base != 0 { ret }
    g_forge_chan_base      = alloc_pages(2) as i64   // 64 * 96 = 6144 bytes
    g_forge_chan_fds       = alloc_pages(32)          // 64 * 256 * 8 = 131072 bytes
    g_forge_chan_fd_counts = alloc_pages(1)            // 64 * 8 = 512 bytes
    loop i in 0..(FORGE_CHAN_MAX * FORGE_CHAN_FD_MAX) {
        g_forge_chan_fds[i] = -1
    }
}

// Find index of a registered channel by name. Returns -1 if not found.
fn forge_chan_find_idx(name: []i8) -> i64 {
    loop i in 0..g_forge_chan_count {
        let e = forge_chan_entry_at(i)
        if forge_slice_eq(e.name[0..e.name_len], name) { ret i }
    }
    ret -1
}

// Register a channel. Call once at startup before app_listen.
fn forge_channel_register(name: []i8, on_sub: i64, on_msg: i64, on_unsub: i64) {
    forge_chan_init()
    if g_forge_chan_count >= FORGE_CHAN_MAX { ret }
    let e = forge_chan_entry_at(g_forge_chan_count)
    let nl = name.len
    if nl > FORGE_CHAN_NAME_CAP { nl = FORGE_CHAN_NAME_CAP }
    loop i in 0..nl { e.name[i] = name[i] }
    e.name_len = nl
    e.on_sub   = on_sub
    e.on_msg   = on_msg
    e.on_unsub = on_unsub
    g_forge_chan_count = g_forge_chan_count + 1
}

// Subscribe fd to a named stream/channel.
fn forge_channel_subscribe(name: []i8, fd: i32) {
    forge_chan_init()
    let ci = forge_chan_find_idx(name)
    if ci < 0 { ret }
    let base = ci * FORGE_CHAN_FD_MAX
    // Find an empty slot
    loop i in 0..FORGE_CHAN_FD_MAX {
        if g_forge_chan_fds[base + i] == -1 {
            g_forge_chan_fds[base + i] = fd as i64
            g_forge_chan_fd_counts[ci] = g_forge_chan_fd_counts[ci] + 1
            ret
        }
    }
}

// Unsubscribe fd from a named stream/channel.
fn forge_channel_unsubscribe(name: []i8, fd: i32) {
    forge_chan_init()
    let ci = forge_chan_find_idx(name)
    if ci < 0 { ret }
    let base = ci * FORGE_CHAN_FD_MAX
    loop i in 0..FORGE_CHAN_FD_MAX {
        if g_forge_chan_fds[base + i] == fd as i64 {
            g_forge_chan_fds[base + i] = -1
            g_forge_chan_fd_counts[ci] = g_forge_chan_fd_counts[ci] - 1
            ret
        }
    }
}

// Remove fd from ALL channels — call on WebSocket disconnect.
fn forge_channel_unsubscribe_fd(fd: i32) {
    forge_chan_init()
    loop ci in 0..g_forge_chan_count {
        let base = ci * FORGE_CHAN_FD_MAX
        loop i in 0..FORGE_CHAN_FD_MAX {
            if g_forge_chan_fds[base + i] == fd as i64 {
                g_forge_chan_fds[base + i] = -1
                g_forge_chan_fd_counts[ci] = g_forge_chan_fd_counts[ci] - 1
            }
        }
    }
}

// Broadcast a message to all subscribers of a named stream/channel.
fn forge_channel_broadcast(name: []i8, data: []i8) {
    forge_chan_init()
    let ci = forge_chan_find_idx(name)
    if ci < 0 { ret }
    // Build envelope: {"type":"message","channel":"<name>","message":<data>}
    let env: &i8 = alloc_pages(2)
    let ep = 0i64
    let p1 = "{\"type\":\"message\",\"channel\":\""
    let p2 = "\",\"message\":"
    let p3 = "}"
    loop i in 0..p1.len   { env[ep] = p1[i]    ep = ep + 1 }
    loop i in 0..name.len { env[ep] = name[i]   ep = ep + 1 }
    loop i in 0..p2.len   { env[ep] = p2[i]    ep = ep + 1 }
    loop i in 0..data.len { env[ep] = data[i]   ep = ep + 1 }
    loop i in 0..p3.len   { env[ep] = p3[i]    ep = ep + 1 }
    let msg = env[0..ep]
    let base = ci * FORGE_CHAN_FD_MAX
    loop i in 0..FORGE_CHAN_FD_MAX {
        let sfd = g_forge_chan_fds[base + i]
        if sfd != -1 { forge_ws_send_text(sfd as i32, msg) }
    }
}

// Extract a quoted string value for key in a flat JSON object.
// Writes result into out; returns length written.
fn forge_chan_json_get(json: []i8, key: []i8, out: &i8) -> i64 {
    // Build needle: `"key":"`
    let needle = [128]i8
    let np = 0i64
    needle[np] = '"'   np = np + 1
    loop i in 0..key.len { needle[np] = key[i]  np = np + 1 }
    needle[np] = '"'   np = np + 1
    needle[np] = ':'   np = np + 1
    needle[np] = '"'   np = np + 1
    let nlen = np

    // Search for needle in json
    let found = -1i64
    let lim = json.len - nlen
    loop i in 0..lim {
        let ok = true
        loop j in 0..nlen {
            if json[i + j] != needle[j] { ok = false  break }
        }
        if ok { found = i + nlen  break }
    }
    if found < 0 { ret 0 }

    // Copy until closing quote, handling \\" escape
    let n = 0i64
    let i = found
    loop i < json.len {
        let ch = json[i]
        if ch == '"' { break }
        if ch == '\\' and (i + 1) < json.len {
            out[n] = json[i + 1]  n = n + 1  i = i + 2
        } else {
            out[n] = ch  n = n + 1  i = i + 1
        }
    }
    ret n
}

// Main channel event loop. Upgrade to WebSocket, dispatch commands until disconnect.
fn forge_channel_handle(ctx_ptr: i64) {
    if not ctx_upgrade_ws(ctx_ptr) { ret }
    let c: &ForgeCtx = ctx_ptr
    let fd = c.fd

    let buf:      &i8 = alloc_pages(4)    // 16 KB receive buffer
    let cmd_buf:  &i8 = alloc_pages(1)
    let chan_buf: &i8 = alloc_pages(1)
    let data_buf: &i8 = alloc_pages(2)

    loop {
        let n = forge_ws_recv(fd, buf, 16384)
        if n <= 0 { break }
        let msg = buf[0..n]

        let cmd_len  = forge_chan_json_get(msg, "command", cmd_buf)
        let chan_len  = forge_chan_json_get(msg, "channel", chan_buf)
        let cmd  = cmd_buf[0..cmd_len]
        let chan = chan_buf[0..chan_len]

        let ci = forge_chan_find_idx(chan)

        if forge_slice_eq(cmd, "subscribe") {
            if ci < 0 {
                // Unknown channel — send rejection
                let rej: &i8 = alloc_pages(1)
                let rp = 0i64
                let rp1 = "{\"type\":\"rejection\",\"channel\":\""
                let rp2 = "\"}"
                loop i in 0..rp1.len  { rej[rp] = rp1[i]   rp = rp + 1 }
                loop i in 0..chan.len  { rej[rp] = chan[i]   rp = rp + 1 }
                loop i in 0..rp2.len  { rej[rp] = rp2[i]   rp = rp + 1 }
                forge_ws_send_text(fd, rej[0..rp])
            } else {
                forge_channel_subscribe(chan, fd)
                // Confirm subscription
                let conf: &i8 = alloc_pages(1)
                let cp = 0i64
                let cp1 = "{\"type\":\"confirm_subscription\",\"channel\":\""
                let cp2 = "\"}"
                loop i in 0..cp1.len  { conf[cp] = cp1[i]   cp = cp + 1 }
                loop i in 0..chan.len  { conf[cp] = chan[i]   cp = cp + 1 }
                loop i in 0..cp2.len  { conf[cp] = cp2[i]   cp = cp + 1 }
                forge_ws_send_text(fd, conf[0..cp])
                // Fire on_sub callback
                let entry = forge_chan_entry_at(ci)
                if entry.on_sub != 0 {
                    let arg: &ForgeChanCbArg = alloc_pages(1)
                    arg.fd = fd as i64  arg.data = 0  arg.data_len = 0
                    call_fn(entry.on_sub, arg as i64)
                }
            }
        } else if forge_slice_eq(cmd, "message") {
            if ci >= 0 {
                let data_len = forge_chan_json_get(msg, "data", data_buf)
                let entry = forge_chan_entry_at(ci)
                if entry.on_msg != 0 {
                    let arg: &ForgeChanCbArg = alloc_pages(1)
                    arg.fd       = fd as i64
                    arg.data     = data_buf as i64
                    arg.data_len = data_len
                    call_fn(entry.on_msg, arg as i64)
                }
            }
        } else if forge_slice_eq(cmd, "unsubscribe") {
            if ci >= 0 {
                let entry = forge_chan_entry_at(ci)
                if entry.on_unsub != 0 {
                    let arg: &ForgeChanCbArg = alloc_pages(1)
                    arg.fd = fd as i64  arg.data = 0  arg.data_len = 0
                    call_fn(entry.on_unsub, arg as i64)
                }
                forge_channel_unsubscribe(chan, fd)
            }
        }
    }

    forge_channel_unsubscribe_fd(fd)
    forge_ws_close(fd)
}

// =============================================================================
// Built-in middleware
// =============================================================================

// Logger: "[forge] METHOD /path (ms)\n"
fn forge_logger(ctx_ptr: i64) {
    let c: &ForgeCtx = ctx_ptr
    let buf = [512]i8
    let pos = 0i64
    let pre = "[forge] "
    loop i in 0..pre.len           { buf[pos] = pre[i]            pos = pos + 1 }
    loop i in 0..c.req.method.len  { buf[pos] = c.req.method[i]   pos = pos + 1 }
    buf[pos] = ' '   pos = pos + 1
    loop i in 0..c.req.path.len    { buf[pos] = c.req.path[i]     pos = pos + 1 }
    buf[pos] = '\n'  pos = pos + 1
    syscall(FORGE_SYS_WRITE, 1, buf, pos, 0, 0)
}

// CORS: permissive headers + auto-handle OPTIONS preflight
fn forge_cors(ctx_ptr: i64) {
    ctx_set_header(ctx_ptr, "Access-Control-Allow-Origin",  "*")
    ctx_set_header(ctx_ptr, "Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, PATCH, OPTIONS")
    ctx_set_header(ctx_ptr, "Access-Control-Allow-Headers", "Content-Type, Authorization, X-Request-ID")
    ctx_set_header(ctx_ptr, "Access-Control-Max-Age", "86400")
    let c: &ForgeCtx = ctx_ptr
    if forge_slice_eq(c.req.method, "OPTIONS") { ctx_no_content(ctx_ptr) }
}

// Recover: catch unhandled errors and return 500
fn forge_recover(ctx_ptr: i64) {
    // Jadn does not have panic/recover like Go, but we mark this as a
    // no-op placeholder.  Real crash protection lives at the OS process level.
    // Users can override app.error_h for custom error pages.
}

// Request ID: generate X-Request-ID header using timestamp + fd
fn forge_request_id(ctx_ptr: i64) {
    let c: &ForgeCtx = ctx_ptr
    let buf = [32]i8
    let t = time_now_ms()
    let fd = c.fd as i64
    // Build hex ID: timestamp in hex + fd
    let pos = 0i64
    let tmp = [20]i8
    let tl = fmt_i64(tmp, t)
    loop i in 0..tl { buf[pos] = tmp[i]   pos = pos + 1 }
    buf[pos] = '-'   pos = pos + 1
    let fl = fmt_i64(tmp, fd)
    loop i in 0..fl { buf[pos] = tmp[i]   pos = pos + 1 }
    ctx_set_header(ctx_ptr, "X-Request-ID", buf[0..pos])
    ctx_set(ctx_ptr, "request_id", buf as i64)
}

// No-cache: prevent response caching
fn forge_no_cache(ctx_ptr: i64) {
    ctx_set_header(ctx_ptr, "Cache-Control", "no-store, no-cache, must-revalidate")
    ctx_set_header(ctx_ptr, "Pragma", "no-cache")
}

// Secure headers: add common security headers
fn forge_secure_headers(ctx_ptr: i64) {
    ctx_set_header(ctx_ptr, "X-Content-Type-Options",    "nosniff")
    ctx_set_header(ctx_ptr, "X-Frame-Options",           "DENY")
    ctx_set_header(ctx_ptr, "X-XSS-Protection",          "1; mode=block")
    ctx_set_header(ctx_ptr, "Referrer-Policy",           "strict-origin-when-cross-origin")
    ctx_set_header(ctx_ptr, "Strict-Transport-Security", "max-age=31536000; includeSubDomains")
}

// Rate limiter state (global — shared across all workers via atomic ops)
let g_forge_rl_count:  i64 = 0
let g_forge_rl_window: i64 = 0
const FORGE_RL_LIMIT = 600    // requests per window (10 req/sec × 60s)
const FORGE_RL_WINDOW_MS = 60000

// Rate limit: simple global token bucket (600 req/min across all clients)
fn forge_rate_limit(ctx_ptr: i64) {
    let now = time_now_ms()
    let win = atomic_load(&g_forge_rl_window)
    if now - win > FORGE_RL_WINDOW_MS {
        // New window
        atomic_store(&g_forge_rl_window, now)
        atomic_store(&g_forge_rl_count, 0)
    }
    let count = atomic_fetch_add(&g_forge_rl_count, 1)
    if count > FORGE_RL_LIMIT {
        ctx_set_header(ctx_ptr, "Retry-After", "60")
        ctx_too_many_requests(ctx_ptr)
    }
}

// forge_rate_limit_key — per-key rate limiting (e.g., per IP or per user).
// key should uniquely identify the client (IP, user id, route+IP, etc.).
// max: maximum requests in window_sec seconds.
// Uses the in-process cache as a sliding window counter.
fn forge_rate_limit_key(ctx_ptr: i64, key: []i8, max: i64, window_sec: i64) {
    let cache_key_buf: &i8 = alloc_pages(1)
    let ckp = 0i64
    let pfx = "_rl_"
    loop i in 0..pfx.len { cache_key_buf[ckp] = pfx[i]  ckp = ckp + 1 }
    loop i in 0..key.len  { cache_key_buf[ckp] = key[i]  ckp = ckp + 1 }
    let cache_key = cache_key_buf[0..ckp]
    let count_s = forge_cache_get(cache_key)
    let count = 0i64
    if count_s.len > 0 { count = str_to_i64(count_s) }
    count = count + 1
    let count_buf: &i8 = alloc_pages(1)
    let cn = fmt_i64(count_buf, count)
    forge_cache_set(cache_key, count_buf[0..cn], window_sec)
    if count > max {
        let ra_buf: &i8 = alloc_pages(1)
        let rn = fmt_i64(ra_buf, window_sec)
        ctx_set_header(ctx_ptr, "Retry-After", ra_buf[0..rn])
        ctx_too_many_requests(ctx_ptr)
    }
}

// forge_token_generate — return a URL-safe random token of n bytes.
fn forge_token_generate(n: i64) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    // Use /dev/urandom via open+read syscalls
    let path_buf = [20]i8
    let ps = "/dev/urandom"
    loop i in 0..ps.len { path_buf[i] = ps[i] }
    path_buf[ps.len] = 0
    let fd = syscall(2, path_buf as i64, 0, 0, 0, 0, 0) as i32   // open O_RDONLY
    if fd < 0 {
        // Fallback: derive from time + counter
        let t = time_now_ms()
        loop i in 0..n {
            buf[i] = ((t >> (i * 3) as i64) as i8 and 0x7F) or 0x40
        }
        ret buf[0..n]
    }
    let raw: &i8 = alloc_pages(1)
    syscall(0, fd as i64, raw as i64, n, 0, 0, 0)   // read
    syscall(3, fd as i64, 0, 0, 0, 0, 0)             // close
    // Encode to URL-safe base64-alphabet characters
    let alpha = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
    loop i in 0..n { buf[i] = alpha[(raw[i] as i64 and 0x3F)] }
    ret buf[0..n]
}

// forge_token_eq_timing — constant-time string comparison to prevent timing attacks.
fn forge_token_eq_timing(a: []i8, b: []i8) -> bool {
    if a.len != b.len { ret false }
    let diff = 0i64
    loop i in 0..a.len { diff = diff or (a[i] as i64 xor b[i] as i64) }
    ret diff == 0
}

// Basic Auth middleware — expects Authorization: Basic <base64(user:pass)>
// Set expected credentials via global constants before calling app_listen.
let g_forge_ba_user: []i8 = ""
let g_forge_ba_pass: []i8 = ""

fn forge_set_basic_auth(user: []i8, pass: []i8) {
    g_forge_ba_user = user
    g_forge_ba_pass = pass
}

fn forge_basic_auth(ctx_ptr: i64) {
    let hdr = ctx_header(ctx_ptr, "Authorization")
    let basic = "Basic "
    if hdr.len <= basic.len {
        ctx_set_header(ctx_ptr, "WWW-Authenticate", "Basic realm=\"forge\"")
        ctx_unauthorized(ctx_ptr)
        ret
    }
    if not forge_starts_with(hdr, basic) {
        ctx_set_header(ctx_ptr, "WWW-Authenticate", "Basic realm=\"forge\"")
        ctx_unauthorized(ctx_ptr)
        ret
    }
    // Decode base64
    let encoded = hdr[basic.len..]
    let decoded  = [256]i8
    let dlen = b64_decode(encoded, encoded.len, decoded)
    // Find ':'
    let colon = -1i64
    loop i in 0..dlen { if decoded[i] == ':' { colon = i   break } }
    if colon < 0 {
        ctx_unauthorized(ctx_ptr)
        ret
    }
    let user = decoded[0..colon]
    let pass = decoded[colon+1..dlen]
    if forge_slice_eq(user, g_forge_ba_user) and forge_slice_eq(pass, g_forge_ba_pass) {
        ctx_set(ctx_ptr, "basic_user", user as i64)
        ret   // authenticated — continue
    }
    ctx_set_header(ctx_ptr, "WWW-Authenticate", "Basic realm=\"forge\"")
    ctx_unauthorized(ctx_ptr)
}

// =============================================================================
// JWT verification middleware
// Call forge_set_jwt_secret("my-secret") once before app_listen.
// On success, stores parsed "sub" claim as ctx_get(ctx, "jwt_sub").
// =============================================================================
let g_forge_jwt_secret: []i8 = ""

fn forge_set_jwt_secret(secret: []i8) {
    g_forge_jwt_secret = secret
}

fn forge_jwt_b64url_decode(src: []i8, dst: &i8) -> i64 {
    // Convert base64url → base64: replace - with +, _ with /
    let tmp: &i8 = alloc_pages(1)
    let n = src.len
    loop i in 0..n {
        let c = src[i]
        if c == '-' { tmp[i] = '+' }
        else if c == '_' { tmp[i] = '/' }
        else { tmp[i] = c }
    }
    // Add padding
    let pad = (4 - n % 4) % 4
    loop i in 0..pad { tmp[n + i] = '=' }
    ret b64_decode(tmp, n + pad, dst)
}

fn forge_jwt_auth(ctx_ptr: i64) {
    let hdr = ctx_header(ctx_ptr, "Authorization")
    let bearer = "Bearer "
    if hdr.len <= bearer.len or not forge_starts_with(hdr, bearer) {
        ctx_unauthorized(ctx_ptr)
        ret
    }
    let token = hdr[bearer.len..]

    // Split token into header.payload.signature
    let dot1 = -1i64
    let dot2 = -1i64
    loop i in 0..token.len {
        if token[i] == '.' {
            if dot1 < 0 { dot1 = i } else { dot2 = i   break }
        }
    }
    if dot1 < 0 or dot2 < 0 {
        ctx_unauthorized(ctx_ptr)
        ret
    }
    let header_b64  = token[0..dot1]
    let payload_b64 = token[dot1+1..dot2]
    let sig_b64     = token[dot2+1..]

    // Verify signature: HMAC-SHA256(secret, header + "." + payload)
    let msg = [512]i8
    let mp = 0i64
    loop i in 0..dot2 { msg[mp] = token[i]   mp = mp + 1 }
    let expected = [32]i8
    let secret = g_forge_jwt_secret
    hmac_sha256(secret, secret.len, msg, mp, expected)
    let actual = [32]i8
    forge_jwt_b64url_decode(sig_b64, actual)

    // Constant-time compare (prevent timing attacks)
    let ok = 1i64
    loop i in 0..32 { if expected[i] != actual[i] { ok = 0 } }
    if ok == 0 {
        ctx_unauthorized(ctx_ptr)
        ret
    }

    // Decode payload and extract "sub" claim
    let payload_json = [512]i8
    let plen = forge_jwt_b64url_decode(payload_b64, payload_json)
    match json_parse(payload_json[0..plen]) {
        ok(val) => {
            match val.get("sub") {
                ok(sub_val) => {
                    match sub_val.as_str() {
                        ok(sub) => { ctx_set(ctx_ptr, "jwt_sub", sub as i64) }
                        err(_)  => {}
                    }
                }
                err(_) => {}
            }
        }
        err(_) => {}
    }
}

// =============================================================================
// URL utilities — percent-decode, form parsing
// =============================================================================

fn forge_hex_val(c: i8) -> i64 {
    if c >= '0' and c <= '9' { ret c as i64 - 48 }
    if c >= 'a' and c <= 'f' { ret c as i64 - 87 }
    if c >= 'A' and c <= 'F' { ret c as i64 - 55 }
    ret 0
}

// Decode a percent-encoded (URL-encoded) slice into dst. Returns written length.
fn forge_url_decode(src: []i8, dst: &i8) -> i64 {
    let pos = 0i64
    let i   = 0i64
    loop i < src.len {
        let c = src[i]
        if c == '%' and i + 2 < src.len {
            dst[pos] = (forge_hex_val(src[i+1]) * 16 + forge_hex_val(src[i+2])) as i8
            pos = pos + 1
            i   = i + 3
        } else if c == '+' {
            dst[pos] = ' '
            pos = pos + 1
            i   = i + 1
        } else {
            dst[pos] = c
            pos = pos + 1
            i   = i + 1
        }
    }
    ret pos
}

// ctx_form: read a field from an application/x-www-form-urlencoded body.
fn ctx_form(ctx_ptr: i64, key: []i8) -> []i8 {
    let c: &ForgeCtx = ctx_ptr
    let body = c.req.body
    if body.len == 0 { ret "" }
    let pos = 0i64
    loop pos < body.len {
        let ks = pos
        loop pos < body.len and body[pos] != '=' and body[pos] != '&' { pos = pos + 1 }
        let k_raw = body[ks..pos]
        if pos < body.len and body[pos] == '=' { pos = pos + 1 }
        let vs = pos
        loop pos < body.len and body[pos] != '&' { pos = pos + 1 }
        let v_raw = body[vs..pos]
        if pos < body.len { pos = pos + 1 }
        // Decode key and compare
        let k_buf = [256]i8
        let k_len = forge_url_decode(k_raw, k_buf)
        if forge_slice_eq(k_buf[0..k_len], key) {
            let v_buf: &i8 = alloc_pages(1)
            let v_len = forge_url_decode(v_raw, v_buf)
            ret v_buf[0..v_len]
        }
    }
    ret ""
}

fn ctx_form_default(ctx_ptr: i64, key: []i8, def: []i8) -> []i8 {
    let v = ctx_form(ctx_ptr, key)
    if v.len == 0 { ret def }
    ret v
}

fn ctx_query_default(ctx_ptr: i64, key: []i8, def: []i8) -> []i8 {
    let v = ctx_query(ctx_ptr, key)
    if v.len == 0 { ret def }
    ret v
}

// =============================================================================
// Server-Sent Events (SSE)
// ctx_sse_start sends the 200 + event-stream headers and returns the raw fd.
// Use forge_sse_send in a loop, then forge_sse_close when done.
// =============================================================================

fn ctx_sse_start(ctx_ptr: i64) -> i32 {
    let c: &ForgeCtx = ctx_ptr
    if c.sent { ret -1 }
    let buf = [2048]i8
    let pos = 0i64
    let sl  = "HTTP/1.1 200 OK\r\n"
    let ct  = "Content-Type: text/event-stream; charset=utf-8\r\n"
    let cc  = "Cache-Control: no-cache\r\n"
    let cn  = "Connection: keep-alive\r\n"
    let xb  = "X-Accel-Buffering: no\r\n"
    loop i in 0..sl.len  { buf[pos] = sl[i]   pos = pos + 1 }
    loop i in 0..ct.len  { buf[pos] = ct[i]   pos = pos + 1 }
    loop i in 0..cc.len  { buf[pos] = cc[i]   pos = pos + 1 }
    loop i in 0..cn.len  { buf[pos] = cn[i]   pos = pos + 1 }
    loop i in 0..xb.len  { buf[pos] = xb[i]   pos = pos + 1 }
    // Append any user-set headers (e.g. CORS from middleware)
    let hdr_buf = [1024]i8
    let hlen = forge_build_hdr_str(c, hdr_buf)
    loop i in 0..hlen { buf[pos] = hdr_buf[i]  pos = pos + 1 }
    buf[pos] = '\r'  pos = pos + 1
    buf[pos] = '\n'  pos = pos + 1
    forge_tcp_write_all(c.fd, buf, pos)
    c.sent  = true    // suppress normal response
    c.is_ws = true    // keep fd open after dispatch
    ret c.fd
}

// Send one SSE event. Pass event="" to omit the "event:" line.
fn forge_sse_send(fd: i32, event: []i8, data: []i8) {
    let buf = [2048]i8
    let pos = 0i64
    if event.len > 0 {
        let ev = "event: "
        loop i in 0..ev.len    { buf[pos] = ev[i]     pos = pos + 1 }
        loop i in 0..event.len { buf[pos] = event[i]  pos = pos + 1 }
        buf[pos] = '\n'  pos = pos + 1
    }
    let da = "data: "
    loop i in 0..da.len   { buf[pos] = da[i]    pos = pos + 1 }
    loop i in 0..data.len { buf[pos] = data[i]  pos = pos + 1 }
    buf[pos] = '\n'  pos = pos + 1
    buf[pos] = '\n'  pos = pos + 1   // blank line terminates event
    forge_tcp_write_all(fd, buf, pos)
}

// Send a keep-alive comment ping (prevents proxy timeouts).
fn forge_sse_ping(fd: i32) {
    let msg = ": ping\n\n"
    forge_tcp_write_all(fd, msg, msg.len)
}

fn forge_sse_close(fd: i32) {
    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
}

// =============================================================================
// Sessions — in-memory session store
// Register forge_session_start as a global middleware before other middleware.
// Sessions persist for the lifetime of the server process.
// =============================================================================

fn forge_gen_sid(dst: &i8) {
    let t = time_now_ms()
    let n = atomic_fetch_add(&g_forge_session_gen, 1)
    let v = t ^ (n * 6364136223846793005)
    let hex = "0123456789abcdef"
    loop i in 0..FORGE_SESSION_ID_LEN {
        let shift = (FORGE_SESSION_ID_LEN - 1 - i) * 4
        dst[i] = hex[(v >> shift) as i64 and 0x0F]
    }
}

fn forge_session_init() {
    if g_forge_session_ptrs != 0 { ret }
    let ptrs: &i64 = alloc_pages(1)
    loop i in 0..FORGE_MAX_SESSIONS {
        let s: &ForgeSession = alloc_pages(1)
        s.used  = false
        s.count = 0
        ptrs[i] = s as i64
    }
    g_forge_session_ptrs = ptrs
}

fn forge_session_find(sid: []i8) -> &ForgeSession {
    if g_forge_session_ptrs == 0 { ret 0 }
    if sid.len != FORGE_SESSION_ID_LEN { ret 0 }
    loop i in 0..FORGE_MAX_SESSIONS {
        let s: &ForgeSession = g_forge_session_ptrs[i] as &ForgeSession
        if s.used {
            let eq = true
            loop j in 0..FORGE_SESSION_ID_LEN {
                if s.id[j] != sid[j] { eq = false   break }
            }
            if eq { ret s }
        }
    }
    ret 0
}

fn forge_session_alloc() -> &ForgeSession {
    loop i in 0..FORGE_MAX_SESSIONS {
        let s: &ForgeSession = g_forge_session_ptrs[i] as &ForgeSession
        if not s.used {
            s.used  = true
            s.count = 0
            forge_gen_sid(s.id)
            ret s
        }
    }
    ret 0   // session pool exhausted
}

// Middleware: read or create a session, attach to ctx as "_session".
fn forge_session_start(ctx_ptr: i64) {
    forge_session_init()
    let sid = ctx_cookie(ctx_ptr, "sid")
    let s: &ForgeSession = 0
    if sid.len == FORGE_SESSION_ID_LEN {
        s = forge_session_find(sid)
    }
    if s == 0 {
        s = forge_session_alloc()
        if s != 0 {
            ctx_set_cookie(ctx_ptr, "sid", s.id[0..FORGE_SESSION_ID_LEN], 86400)
        }
    }
    if s != 0 { ctx_set(ctx_ptr, "_session", s as i64) }
}

fn ctx_session_get(ctx_ptr: i64, key: []i8) -> []i8 {
    let s: &ForgeSession = ctx_get(ctx_ptr, "_session") as &ForgeSession
    if s == 0 { ret "" }
    loop i in 0..s.count {
        if forge_slice_eq(s.kv[i].key[0..s.kv[i].klen], key) {
            ret s.kv[i].val[0..s.kv[i].vlen]
        }
    }
    ret ""
}

fn ctx_session_set(ctx_ptr: i64, key: []i8, val: []i8) {
    let s: &ForgeSession = ctx_get(ctx_ptr, "_session") as &ForgeSession
    if s == 0 { ret }
    // Update existing key
    loop i in 0..s.count {
        if forge_slice_eq(s.kv[i].key[0..s.kv[i].klen], key) {
            let vl = val.len
            if vl > FORGE_SESSION_VAL_CAP { vl = FORGE_SESSION_VAL_CAP }
            loop j in 0..vl { s.kv[i].val[j] = val[j] }
            s.kv[i].vlen = vl
            ret
        }
    }
    // Insert new key
    let n = s.count
    if n < FORGE_SESSION_MAX_KV {
        let kl = key.len
        if kl > FORGE_SESSION_KEY_CAP { kl = FORGE_SESSION_KEY_CAP }
        loop j in 0..kl { s.kv[n].key[j] = key[j] }
        s.kv[n].klen = kl
        let vl = val.len
        if vl > FORGE_SESSION_VAL_CAP { vl = FORGE_SESSION_VAL_CAP }
        loop j in 0..vl { s.kv[n].val[j] = val[j] }
        s.kv[n].vlen = vl
        s.count = n + 1
    }
}

fn ctx_session_del(ctx_ptr: i64, key: []i8) {
    let s: &ForgeSession = ctx_get(ctx_ptr, "_session") as &ForgeSession
    if s == 0 { ret }
    loop i in 0..s.count {
        if forge_slice_eq(s.kv[i].key[0..s.kv[i].klen], key) {
            loop j in i..s.count - 1 { s.kv[j] = s.kv[j+1] }
            s.count = s.count - 1
            ret
        }
    }
}

fn ctx_session_clear(ctx_ptr: i64) {
    let s: &ForgeSession = ctx_get(ctx_ptr, "_session") as &ForgeSession
    if s != 0 { s.count = 0 }
}

// =============================================================================
// Flash messages — Rails-style one-time session messages
// Requires forge_session_start middleware.
// =============================================================================

fn ctx_flash_set(ctx_ptr: i64, kind: []i8, msg: []i8) {
    // Store as "<kind>|<msg>" in session key "_flash"
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    loop i in 0..kind.len { buf[pos] = kind[i]  pos = pos + 1 }
    buf[pos] = '|'  pos = pos + 1
    loop i in 0..msg.len  { buf[pos] = msg[i]   pos = pos + 1 }
    ctx_session_set(ctx_ptr, "_flash", buf[0..pos])
}

// Read and consume flash message for the given kind ("notice", "alert", etc.).
fn ctx_flash_get(ctx_ptr: i64, kind: []i8) -> []i8 {
    let raw = ctx_session_get(ctx_ptr, "_flash")
    if raw.len == 0 { ret "" }
    let sep = -1i64
    loop i in 0..raw.len { if raw[i] == '|' { sep = i   break } }
    if sep < 0 { ret "" }
    if not forge_slice_eq(raw[0..sep], kind) { ret "" }
    let msg = raw[sep+1..]
    ctx_session_del(ctx_ptr, "_flash")   // one-time read
    ret msg
}

// ctx_flash_now — flash visible only in the current request (stored in ctx store,
// not in the session, so it does not survive to the next request).
fn ctx_flash_now(ctx_ptr: i64, kind: []i8, msg: []i8) {
    let kb: &i8 = alloc_pages(1)
    let kp = 0i64
    let pfx = "_fn_"
    loop i in 0..pfx.len { kb[kp] = pfx[i]  kp = kp + 1 }
    loop i in 0..kind.len { kb[kp] = kind[i]  kp = kp + 1 }
    ctx_set(ctx_ptr, kb[0..kp], msg as i64)
}

fn ctx_flash_now_get(ctx_ptr: i64, kind: []i8) -> []i8 {
    let kb: &i8 = alloc_pages(1)
    let kp = 0i64
    let pfx = "_fn_"
    loop i in 0..pfx.len { kb[kp] = pfx[i]  kp = kp + 1 }
    loop i in 0..kind.len { kb[kp] = kind[i]  kp = kp + 1 }
    let val = ctx_get(ctx_ptr, kb[0..kp])
    if val == 0 { ret "" }
    ret val as []i8
}

// ctx_flash_keep — re-persist the current flash so it survives to the next request.
// Call from a before filter when you want to propagate flash across a redirect chain.
fn ctx_flash_keep(ctx_ptr: i64, kind: []i8) {
    let msg = ctx_flash_get(ctx_ptr, kind)
    if msg.len > 0 { ctx_flash_set(ctx_ptr, kind, msg) }
}

// =============================================================================
// CSRF protection
// Requires forge_session_start middleware registered before forge_csrf.
// Embed forge_csrf_token(ctx) in forms as hidden field "_csrf".
// =============================================================================

fn forge_csrf_token(ctx_ptr: i64) -> []i8 {
    let existing = ctx_session_get(ctx_ptr, "_csrf")
    if existing.len > 0 { ret existing }
    let buf: &i8 = alloc_pages(1)
    let t = time_now_ms()
    let n = atomic_fetch_add(&g_forge_session_gen, 1)
    let v = t ^ (n * 2654435761)
    let hex = "0123456789abcdef"
    loop i in 0..16 {
        let shift = (15 - i) * 4
        buf[i] = hex[(v >> shift) as i64 and 0x0F]
    }
    let tok = buf[0..16]
    ctx_session_set(ctx_ptr, "_csrf", tok)
    ret tok
}

// Middleware: verify CSRF token on state-changing methods.
fn forge_csrf(ctx_ptr: i64) {
    let method = ctx_method(ctx_ptr)
    if forge_slice_eq(method, "GET")  or
       forge_slice_eq(method, "HEAD") or
       forge_slice_eq(method, "OPTIONS") { ret }
    // Accept token from X-CSRF-Token header or _csrf form field
    let token = ctx_header(ctx_ptr, "X-CSRF-Token")
    if token.len == 0 { token = ctx_form(ctx_ptr, "_csrf") }
    let expected = ctx_session_get(ctx_ptr, "_csrf")
    if expected.len == 0 or not forge_slice_eq(token, expected) {
        ctx_json(ctx_ptr, 403, "{\"error\":\"invalid CSRF token\"}")
    }
}

// =============================================================================
// Proxy headers middleware
// =============================================================================
fn forge_proxy_headers(ctx_ptr: i64) {
    // ctx_ip() already reads X-Real-IP and X-Forwarded-For.
    // Extend here to validate proxy source IP before trusting headers.
}

// =============================================================================
// Background Jobs — spawn-based worker pool
// Call forge_jobs_start(n) once in main() before app_listen.
// Then use forge_job_enqueue(fn_addr(my_job), arg) anywhere.
//
// Example:
//   fn send_welcome_email(arg: i64) {
//       let email_ptr = arg as &i8   // caller heap-allocs + passes pointer
//       forge_mail_send(ForgeMail { to: email_ptr[0..?], ... })
//   }
//   forge_job_enqueue(fn_addr(send_welcome_email), alloc_str(email))
// =============================================================================
const FORGE_JOB_QUEUE_CAP  = 4096
const FORGE_JOB_HOOK_MAX   = 8

let g_forge_job_queue:        i64 = 0
let g_forge_job_before_hooks: [FORGE_JOB_HOOK_MAX]i64
let g_forge_job_before_count: i64 = 0
let g_forge_job_after_hooks:  [FORGE_JOB_HOOK_MAX]i64
let g_forge_job_after_count:  i64 = 0

fn forge_job_before_perform(fn_ptr: i64) {
    if g_forge_job_before_count < FORGE_JOB_HOOK_MAX {
        g_forge_job_before_hooks[g_forge_job_before_count] = fn_ptr
        g_forge_job_before_count = g_forge_job_before_count + 1
    }
}

fn forge_job_after_perform(fn_ptr: i64) {
    if g_forge_job_after_count < FORGE_JOB_HOOK_MAX {
        g_forge_job_after_hooks[g_forge_job_after_count] = fn_ptr
        g_forge_job_after_count = g_forge_job_after_count + 1
    }
}

fn forge_job_perform(fn_ptr: i64, arg: i64) {
    loop i in 0..g_forge_job_before_count { call_fn(g_forge_job_before_hooks[i], arg) }
    call_fn(fn_ptr, arg)
    loop i in 0..g_forge_job_after_count  { call_fn(g_forge_job_after_hooks[i],  arg) }
}

fn forge_jobs_start(workers: i32) {
    if g_forge_job_queue != 0 { ret }
    let ch = chan_new(FORGE_JOB_QUEUE_CAP)
    g_forge_job_queue = ch
    loop i in 0..workers {
        spawn {
            loop {
                let fn_packed = chan_recv(ch)
                if fn_packed == 0 { ret }
                let fn_ptr = chan_recv(ch)
                let arg    = chan_recv(ch)
                forge_job_perform(fn_ptr, arg)
            }
        }
    }
}

fn forge_job_enqueue(fn_ptr: i64, arg: i64) {
    if g_forge_job_queue == 0 { ret }
    chan_send(g_forge_job_queue, 1)         // sentinel
    chan_send(g_forge_job_queue, fn_ptr)
    chan_send(g_forge_job_queue, arg)
}

// ForgeRetryJob wraps a job with retry logic.
// Pack fn_ptr + remaining_retries into a heap-allocated struct and enqueue.
struct ForgeRetryArg {
    fn_ptr:  i64
    arg:     i64
    retries: i64
}

fn forge__retry_job(packed: i64) {
    let r: &ForgeRetryArg = packed as &ForgeRetryArg
    // call_fn returns i64; treat 0 as failure
    let ok = call_fn(r.fn_ptr, r.arg)
    if ok != 0 { ret }   // success
    if r.retries <= 0 { ret }
    r.retries = r.retries - 1
    let next: &ForgeRetryArg = alloc_pages(1)
    next.fn_ptr  = r.fn_ptr
    next.arg     = r.arg
    next.retries = r.retries
    forge_job_enqueue(fn_addr(forge__retry_job), next as i64)
}

fn forge_job_enqueue_retry(fn_ptr: i64, arg: i64, max_retries: i64) {
    let r: &ForgeRetryArg = alloc_pages(1)
    r.fn_ptr  = fn_ptr
    r.arg     = arg
    r.retries = max_retries
    forge_job_enqueue(fn_addr(forge__retry_job), r as i64)
}

// ForgeRetryBackoffArg — retry with exponential backoff using nanosleep.
struct ForgeRetryBackoffArg {
    fn_ptr:    i64
    arg:       i64
    retries:   i64
    delay_ms:  i64
}

struct ForgeTimespec {
    sec:  i64
    nsec: i64
}

fn forge__ms_sleep(ms: i64) {
    let ts: &ForgeTimespec = alloc_pages(1)
    ts.sec  = ms / 1000
    ts.nsec = (ms % 1000) * 1000000
    syscall(35, ts as i64, 0, 0, 0, 0, 0)   // SYS_NANOSLEEP (Linux x86-64)
}

fn forge__retry_job_backoff(packed: i64) {
    let r: &ForgeRetryBackoffArg = packed as &ForgeRetryBackoffArg
    let ok = call_fn(r.fn_ptr, r.arg)
    if ok != 0 { ret }
    if r.retries <= 0 { ret }
    let next: &ForgeRetryBackoffArg = alloc_pages(1)
    next.fn_ptr   = r.fn_ptr
    next.arg      = r.arg
    next.retries  = r.retries - 1
    next.delay_ms = r.delay_ms * 2
    forge__ms_sleep(r.delay_ms)
    forge_job_enqueue(fn_addr(forge__retry_job_backoff), next as i64)
}

fn forge_job_enqueue_retry_backoff(fn_ptr: i64, arg: i64, max_retries: i64, base_delay_ms: i64) {
    let r: &ForgeRetryBackoffArg = alloc_pages(1)
    r.fn_ptr   = fn_ptr
    r.arg      = arg
    r.retries  = max_retries
    r.delay_ms = base_delay_ms
    forge_job_enqueue(fn_addr(forge__retry_job_backoff), r as i64)
}

// forge_job_enqueue_retry_discard — retry with a discard predicate.
// discard_fn(arg) -> i64: if non-zero, job is permanently discarded (no further retries).
struct ForgeRetryDiscardArg {
    fn_ptr:    i64
    arg:       i64
    retries:   i64
    discard:   i64
}

fn forge__retry_job_discard(packed: i64) {
    let r: &ForgeRetryDiscardArg = packed as &ForgeRetryDiscardArg
    if r.discard != 0 {
        let should_discard = call_fn(r.discard, r.arg)
        if should_discard != 0 { ret }
    }
    let ok = call_fn(r.fn_ptr, r.arg)
    if ok != 0 { ret }
    if r.retries <= 0 { ret }
    let next: &ForgeRetryDiscardArg = alloc_pages(1)
    next.fn_ptr   = r.fn_ptr
    next.arg      = r.arg
    next.retries  = r.retries - 1
    next.discard  = r.discard
    forge_job_enqueue(fn_addr(forge__retry_job_discard), next as i64)
}

fn forge_job_enqueue_retry_discard(fn_ptr: i64, arg: i64, max_retries: i64, discard_fn: i64) {
    let r: &ForgeRetryDiscardArg = alloc_pages(1)
    r.fn_ptr  = fn_ptr
    r.arg     = arg
    r.retries = max_retries
    r.discard = discard_fn
    forge_job_enqueue(fn_addr(forge__retry_job_discard), r as i64)
}

// forge_job_enqueue_in — enqueue fn_ptr after delay_ms milliseconds.
// Spawns a lightweight goroutine that sleeps then dispatches into the worker pool.
struct ForgeDelayedJobArg {
    fn_ptr:   i64
    arg:      i64
    delay_ms: i64
}

fn forge__run_delayed_job(packed: i64) {
    let d: &ForgeDelayedJobArg = packed as &ForgeDelayedJobArg
    forge__ms_sleep(d.delay_ms)
    forge_job_enqueue(d.fn_ptr, d.arg)
}

fn forge_job_enqueue_in(fn_ptr: i64, arg: i64, delay_ms: i64) {
    let d: &ForgeDelayedJobArg = alloc_pages(1)
    d.fn_ptr   = fn_ptr
    d.arg      = arg
    d.delay_ms = delay_ms
    spawn { forge__run_delayed_job(d as i64) }
}

// =============================================================================
// I18n — internationalization / translation
// Load locales from "key=value\n" flat files with forge_i18n_load.
// Use forge_t(ctx, "greeting") in handlers; locale follows ctx "locale" store key.
//
// Example locale file  (locales/en.txt):
//   greeting=Hello, World!
//   nav.users=Users
//   flash.saved=Changes saved.
// =============================================================================
const FORGE_I18N_MAX_ENTRIES   = 512
const FORGE_I18N_FULL_KEY_CAP  = 72    // 8-char locale + "." + 63-char key
const FORGE_I18N_VAL_CAP_I18N  = 256
const FORGE_I18N_ENTRY_STRIDE  = 344   // sizeof(ForgeI18nEntry): 72+8+256+8

struct ForgeI18nEntry {
    key:  [FORGE_I18N_FULL_KEY_CAP]i8
    klen: i64
    val:  [FORGE_I18N_VAL_CAP_I18N]i8
    vlen: i64
}

let g_forge_i18n_base:  i64 = 0
let g_forge_i18n_count: i64 = 0
let g_forge_i18n_locale: []i8 = "en"   // default locale

fn forge_i18n_init() {
    if g_forge_i18n_base != 0 { ret }
    // 512 × 344 = 176 KB → 44 pages
    let block: &i8 = alloc_pages(44)
    g_forge_i18n_base = block as i64
}

fn forge_i18n_entry_at(i: i64) -> &ForgeI18nEntry {
    ret (g_forge_i18n_base + i * FORGE_I18N_ENTRY_STRIDE) as &ForgeI18nEntry
}

fn forge_i18n_set(locale: []i8, key: []i8, val: []i8) {
    forge_i18n_init()
    // Build full key: "<locale>.<key>"
    let fk = [FORGE_I18N_FULL_KEY_CAP]i8
    let fp = 0i64
    let ll = locale.len
    if ll > 8 { ll = 8 }
    loop i in 0..ll { fk[fp] = locale[i]  fp = fp + 1 }
    fk[fp] = '.'  fp = fp + 1
    loop i in 0..key.len { if fp < FORGE_I18N_FULL_KEY_CAP { fk[fp] = key[i]  fp = fp + 1 } }
    let fk_slice = fk[0..fp]
    // Update existing
    loop i in 0..g_forge_i18n_count {
        let e: &ForgeI18nEntry = forge_i18n_entry_at(i)
        if forge_slice_eq(e.key[0..e.klen], fk_slice) {
            let vl = val.len
            if vl > FORGE_I18N_VAL_CAP_I18N { vl = FORGE_I18N_VAL_CAP_I18N }
            loop j in 0..vl { e.val[j] = val[j] }
            e.vlen = vl
            ret
        }
    }
    // Insert new
    let n = g_forge_i18n_count
    if n < FORGE_I18N_MAX_ENTRIES {
        let e: &ForgeI18nEntry = forge_i18n_entry_at(n)
        loop j in 0..fp { e.key[j] = fk[j] }
        e.klen = fp
        let vl = val.len
        if vl > FORGE_I18N_VAL_CAP_I18N { vl = FORGE_I18N_VAL_CAP_I18N }
        loop j in 0..vl { e.val[j] = val[j] }
        e.vlen = vl
        g_forge_i18n_count = n + 1
    }
}

// Load a "key=value\n" locale file from disk.
fn forge_i18n_load(locale: []i8, path: []i8) {
    let path_buf = [512]i8
    let pp = 0i64
    loop i in 0..path.len { path_buf[pp] = path[i]  pp = pp + 1 }
    path_buf[pp] = 0
    let data: &i8 = alloc_pages(64)   // 256 KB max locale file
    let n = fs_read_file(path_buf, data, 262144)
    if n <= 0 { ret }
    let src = data[0..n]
    let pos = 0i64
    loop pos < src.len {
        // Parse "key=value\n"
        let ks = pos
        loop pos < src.len and src[pos] != '=' and src[pos] != '\n' { pos = pos + 1 }
        let k = src[ks..pos]
        if pos >= src.len or src[pos] == '\n' { pos = pos + 1   continue }
        pos = pos + 1   // skip '='
        let vs = pos
        loop pos < src.len and src[pos] != '\n' { pos = pos + 1 }
        let v = src[vs..pos]
        if pos < src.len { pos = pos + 1 }
        if k.len > 0 { forge_i18n_set(locale, k, v) }
    }
}

// Translate key using the locale stored in ctx (or the default locale).
fn forge_t(ctx_ptr: i64, key: []i8) -> []i8 {
    forge_i18n_init()
    let locale_ptr = ctx_get(ctx_ptr, "locale")
    let locale = g_forge_i18n_locale
    if locale_ptr != 0 { locale = (locale_ptr as &i8)[0..8] }
    // Build full key
    let fk = [FORGE_I18N_FULL_KEY_CAP]i8
    let fp = 0i64
    let ll = locale.len
    if ll > 8 { ll = 8 }
    loop i in 0..ll { fk[fp] = locale[i]  fp = fp + 1 }
    fk[fp] = '.'  fp = fp + 1
    loop i in 0..key.len { if fp < FORGE_I18N_FULL_KEY_CAP { fk[fp] = key[i]  fp = fp + 1 } }
    let fk_slice = fk[0..fp]
    loop i in 0..g_forge_i18n_count {
        let e: &ForgeI18nEntry = forge_i18n_entry_at(i)
        if forge_slice_eq(e.key[0..e.klen], fk_slice) { ret e.val[0..e.vlen] }
    }
    ret key   // fallback: return the key itself
}

fn forge_locale_set_ctx(ctx_ptr: i64, locale: []i8) {
    let buf: &i8 = alloc_pages(1)
    let ll = locale.len
    if ll > 8 { ll = 8 }
    loop i in 0..ll { buf[i] = locale[i] }
    ctx_set(ctx_ptr, "locale", buf as i64)
}

// =============================================================================
// Mailer — send email via SMTP
// Call forge_mailer_config once in main() with your SMTP server details.
//
// Example:
//   forge_mailer_config("smtp.example.com", 587, "user@example.com", "password")
//   forge_mail_send(ForgeMail {
//       to:      "alice@example.com",
//       from:    "noreply@myapp.com",
//       subject: "Welcome!",
//       body:    "Thanks for signing up.",
//       html:    false,
//   })
// =============================================================================
struct ForgeMail {
    to:      []i8
    from:    []i8
    subject: []i8
    body:    []i8
    html:    bool
}

struct ForgeMailerConfig {
    host: []i8
    port: i32
    user: []i8
    pass: []i8
}

let g_forge_mailer_cfg_host: []i8 = ""
let g_forge_mailer_cfg_port: i32  = 25
let g_forge_mailer_cfg_user: []i8 = ""
let g_forge_mailer_cfg_pass: []i8 = ""

fn forge_mailer_config(host: []i8, port: i32, user: []i8, pass: []i8) {
    g_forge_mailer_cfg_host = host
    g_forge_mailer_cfg_port = port
    g_forge_mailer_cfg_user = user
    g_forge_mailer_cfg_pass = pass
}

fn forge_smtp_write(fd: i32, line: []i8) {
    forge_tcp_write_all(fd, line, line.len)
    let crlf = "\r\n"
    forge_tcp_write_all(fd, crlf, 2)
}

fn forge_smtp_read_line(fd: i32, buf: &i8, max: i64) -> i64 {
    let n = 0i64
    loop n < max {
        let got = syscall(FORGE_SYS_RECVFROM, fd, buf + n, 1, 0, 0, 0) as i64
        if got <= 0 { ret n }
        if buf[n] == '\n' { ret n + 1 }
        n = n + 1
    }
    ret n
}

fn forge_smtp_expect(fd: i32, code: i64) -> bool {
    let buf = [256]i8
    let n = forge_smtp_read_line(fd, buf, 256)
    if n < 3 { ret false }
    let c = (buf[0] as i64 - 48) * 100 +
            (buf[1] as i64 - 48) * 10 +
            (buf[2] as i64 - 48)
    ret c == code
}

fn forge_mail_send(mail: ForgeMail) -> bool {
    if g_forge_mailer_cfg_host.len == 0 { ret false }

    let fd = TcpStream::connect(g_forge_mailer_cfg_host, g_forge_mailer_cfg_port as u16).fd
    if fd < 0 { ret false }

    // Read greeting (220)
    if not forge_smtp_expect(fd, 220) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }

    // EHLO
    let ehlo_buf = [128]i8
    let ehlo_pos = 0i64
    let ehlo_pre = "EHLO forge"
    loop i in 0..ehlo_pre.len { ehlo_buf[ehlo_pos] = ehlo_pre[i]  ehlo_pos = ehlo_pos + 1 }
    forge_smtp_write(fd, ehlo_buf[0..ehlo_pos])
    if not forge_smtp_expect(fd, 250) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }

    // AUTH LOGIN (if credentials provided)
    if g_forge_mailer_cfg_user.len > 0 {
        forge_smtp_write(fd, "AUTH LOGIN")
        if not forge_smtp_expect(fd, 334) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }
        // Send base64(user)
        let u_enc = [256]i8
        let u_len = b64_encode(g_forge_mailer_cfg_user, g_forge_mailer_cfg_user.len, u_enc)
        forge_smtp_write(fd, u_enc[0..u_len])
        if not forge_smtp_expect(fd, 334) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }
        // Send base64(pass)
        let p_enc = [256]i8
        let p_len = b64_encode(g_forge_mailer_cfg_pass, g_forge_mailer_cfg_pass.len, p_enc)
        forge_smtp_write(fd, p_enc[0..p_len])
        if not forge_smtp_expect(fd, 235) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }
    }

    // MAIL FROM
    let mf_buf = [256]i8
    let mf_pos = 0i64
    let mf_pre = "MAIL FROM:<"
    let mf_suf = ">"
    loop i in 0..mf_pre.len    { mf_buf[mf_pos] = mf_pre[i]   mf_pos = mf_pos + 1 }
    loop i in 0..mail.from.len { mf_buf[mf_pos] = mail.from[i]  mf_pos = mf_pos + 1 }
    loop i in 0..mf_suf.len    { mf_buf[mf_pos] = mf_suf[i]   mf_pos = mf_pos + 1 }
    forge_smtp_write(fd, mf_buf[0..mf_pos])
    if not forge_smtp_expect(fd, 250) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }

    // RCPT TO
    let rt_buf = [256]i8
    let rt_pos = 0i64
    let rt_pre = "RCPT TO:<"
    loop i in 0..rt_pre.len  { rt_buf[rt_pos] = rt_pre[i]  rt_pos = rt_pos + 1 }
    loop i in 0..mail.to.len { rt_buf[rt_pos] = mail.to[i]  rt_pos = rt_pos + 1 }
    loop i in 0..mf_suf.len  { rt_buf[rt_pos] = mf_suf[i]  rt_pos = rt_pos + 1 }
    forge_smtp_write(fd, rt_buf[0..rt_pos])
    if not forge_smtp_expect(fd, 250) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }

    // DATA
    forge_smtp_write(fd, "DATA")
    if not forge_smtp_expect(fd, 354) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }

    // Headers
    let from_hdr_buf = [512]i8
    let fhp = 0i64
    let from_hdr = "From: "
    let to_hdr   = "To: "
    let subj_hdr = "Subject: "
    let mime_txt = "Content-Type: text/plain; charset=utf-8"
    let mime_html = "Content-Type: text/html; charset=utf-8"
    loop i in 0..from_hdr.len    { from_hdr_buf[fhp] = from_hdr[i]    fhp = fhp + 1 }
    loop i in 0..mail.from.len   { from_hdr_buf[fhp] = mail.from[i]   fhp = fhp + 1 }
    forge_smtp_write(fd, from_hdr_buf[0..fhp])
    let to_hdr_buf = [512]i8
    let thp = 0i64
    loop i in 0..to_hdr.len    { to_hdr_buf[thp] = to_hdr[i]   thp = thp + 1 }
    loop i in 0..mail.to.len   { to_hdr_buf[thp] = mail.to[i]  thp = thp + 1 }
    forge_smtp_write(fd, to_hdr_buf[0..thp])
    let subj_buf = [512]i8
    let sbp = 0i64
    loop i in 0..subj_hdr.len      { subj_buf[sbp] = subj_hdr[i]      sbp = sbp + 1 }
    loop i in 0..mail.subject.len  { subj_buf[sbp] = mail.subject[i]  sbp = sbp + 1 }
    forge_smtp_write(fd, subj_buf[0..sbp])
    if mail.html { forge_smtp_write(fd, mime_html) }
    else         { forge_smtp_write(fd, mime_txt) }
    forge_smtp_write(fd, "")   // blank line → body starts

    // Body
    forge_smtp_write(fd, mail.body)

    // End DATA
    forge_smtp_write(fd, ".")
    if not forge_smtp_expect(fd, 250) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret false }

    forge_smtp_write(fd, "QUIT")
    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
    ret true
}

// Async mail: enqueue to background job pool so the handler returns immediately.
fn forge_mail_async(mail: ForgeMail) {
    let m: &ForgeMail = alloc_pages(1)
    m.to      = mail.to
    m.from    = mail.from
    m.subject = mail.subject
    m.body    = mail.body
    m.html    = mail.html
    forge_job_enqueue(fn_addr(forge_mail_job), m as i64)
}

fn forge_mail_job(arg: i64) {
    let m: &ForgeMail = arg as &ForgeMail
    forge_mail_send(ForgeMail { to: m.to, from: m.from, subject: m.subject, body: m.body, html: m.html })
}

// forge_mail_send_in — send mail asynchronously after delay_ms milliseconds.
fn forge_mail_send_in(mail: ForgeMail, delay_ms: i64) {
    let m: &ForgeMail = alloc_pages(1)
    m.to      = mail.to
    m.from    = mail.from
    m.subject = mail.subject
    m.body    = mail.body
    m.html    = mail.html
    forge_job_enqueue_in(fn_addr(forge_mail_job), m as i64, delay_ms)
}

// =============================================================================
// Mailer previews — development-only browser preview of email templates.
//
// Register preview functions in your app/mailers/ files:
//   forge_mail_preview_register("welcome", fn_addr(preview_welcome_email))
//
// Each preview fn has signature: fn my_preview() -> i64
// where the return value is a heap-allocated &ForgeMail cast to i64.
//
// Add forge_mail_preview_handler to your routes to expose /_forge/mailers/*:
//   app_get(app, "/_forge/mailers", fn_addr(forge_mail_preview_handler))
//   app_get(app, "/_forge/mailers/:name", fn_addr(forge_mail_preview_handler))
// =============================================================================
const FORGE_MAIL_PREVIEW_MAX = 32
const FORGE_MAIL_PREVIEW_NAME_CAP = 64

struct ForgeMailPreviewEntry {
    name:   [FORGE_MAIL_PREVIEW_NAME_CAP]i8
    nlen:   i64
    fn_ptr: i64
    used:   bool
}

let g_forge_mp_store: &ForgeMailPreviewEntry = 0
let g_forge_mp_count: i64 = 0

fn forge_mail_preview_init() {
    if g_forge_mp_store != 0 { ret }
    g_forge_mp_store = alloc_pages(4) as &ForgeMailPreviewEntry
}

fn forge_mail_preview_register(name: []i8, fn_ptr: i64) {
    forge_mail_preview_init()
    if g_forge_mp_count >= FORGE_MAIL_PREVIEW_MAX { ret }
    let stride = 80i64   // sizeof ForgeMailPreviewEntry
    let entry: &ForgeMailPreviewEntry = (g_forge_mp_store as i64 + g_forge_mp_count * stride) as &ForgeMailPreviewEntry
    let nl = name.len
    if nl > FORGE_MAIL_PREVIEW_NAME_CAP { nl = FORGE_MAIL_PREVIEW_NAME_CAP }
    loop i in 0..nl { entry.name[i] = name[i] }
    entry.nlen   = nl
    entry.fn_ptr = fn_ptr
    entry.used   = true
    g_forge_mp_count = g_forge_mp_count + 1
}

fn forge_mail_preview_handler(ctx: i64) {
    // Only enabled in development
    if not forge_env_is("development") {
        ctx_not_found(ctx)
        ret
    }
    let name = ctx_param(ctx, "name")
    if name.len == 0 {
        // List all previews
        let buf = forge_buf_new(2)
        buf.write("<h1>Mailer Previews</h1><ul>")
        forge_mail_preview_init()
        let stride = 80i64
        loop i in 0..g_forge_mp_count {
            let e: &ForgeMailPreviewEntry = (g_forge_mp_store as i64 + i * stride) as &ForgeMailPreviewEntry
            if not e.used { continue }
            let n = e.name[0..e.nlen]
            buf.write("<li><a href=\"/_forge/mailers/").write(n).write("\">").write(n).write("</a></li>")
        }
        buf.write("</ul>")
        ctx_html(ctx, 200, buf.done())
        ret
    }
    // Find and invoke named preview
    forge_mail_preview_init()
    let stride = 80i64
    loop i in 0..g_forge_mp_count {
        let e: &ForgeMailPreviewEntry = (g_forge_mp_store as i64 + i * stride) as &ForgeMailPreviewEntry
        if not e.used { continue }
        if forge_slice_eq(e.name[0..e.nlen], name) {
            let m: &ForgeMail = call_fn(e.fn_ptr, 0) as &ForgeMail
            let buf = forge_buf_new(2)
            buf.write("<h1>Preview: ").write(name).write("</h1>")
            buf.write("<p><strong>To:</strong> ").write(forge_h(m.to)).write("</p>")
            buf.write("<p><strong>From:</strong> ").write(forge_h(m.from)).write("</p>")
            buf.write("<p><strong>Subject:</strong> ").write(forge_h(m.subject)).write("</p>")
            buf.write("<hr>")
            if m.html {
                buf.write(m.body)
            } else {
                buf.write("<pre>").write(forge_h(m.body)).write("</pre>")
            }
            ctx_html(ctx, 200, buf.done())
            ret
        }
    }
    ctx_not_found(ctx)
}

// =============================================================================
// Database — PostgreSQL wire protocol (simple query mode)
// Call forge_db_config once in main() before app_listen.
//
// Example:
//   forge_db_config("127.0.0.1", 5432, "myuser", "mypass", "mydb")
//
//   // Execute INSERT/UPDATE/DELETE
//   forge_db_exec("INSERT INTO users (email) VALUES ('alice@example.com')")
//
//   // SELECT — returns rows as ForgeResult
//   let res = forge_db_query("SELECT id, email FROM users")
//   loop i in 0..res.count {
//       let id    = forge_row_col(res, i, 0)
//       let email = forge_row_col(res, i, 1)
//   }
// =============================================================================
const FORGE_DB_MAX_COLS    = 32
const FORGE_DB_MAX_ROWS    = 256
const FORGE_DB_COL_CAP     = 512
const FORGE_DB_COL_STRIDE  = 520   // sizeof(ForgeDbCell): 512+8
const FORGE_DB_ROW_STRIDE  = 16648 // 32 × 520 + 8 (count)
const FORGE_DB_RECV_BUF    = 65536

struct ForgeDbCell {
    data: [FORGE_DB_COL_CAP]i8
    len:  i64
}

struct ForgeDbRow {
    cols:  [FORGE_DB_MAX_COLS]ForgeDbCell
    count: i64
}

struct ForgeColName { name: [64]i8  nlen: i64 }

struct ForgeResult {
    rows:      &ForgeDbRow
    count:     i64
    affected:  i64
    col_names: [32]ForgeColName
    col_count: i64
}

// =============================================================================
// Multi-database registry — named connections, multiple drivers
//
// Register connections at startup:
//   forge_db_add("primary",   forge_env_get("DATABASE_URL"))
//   forge_db_add("analytics", forge_env_get("ANALYTICS_DATABASE_URL"))
//
// Switch the active connection for subsequent queries:
//   forge_db_use("analytics")
//
// Pin a query to a specific connection:
//   forge_q_on("analytics", "events").where_eq("type", "click").exec()
//
// Supported URL schemes: postgres://, postgresql://, mysql://, mariadb://
// =============================================================================

const FORGE_DB_POSTGRES  = 1
const FORGE_DB_MYSQL     = 2
const FORGE_DB_MAX_CONNS = 8

struct ForgeDBConn {
    name:      [32]i8
    name_len:  i64
    driver:    i64
    host:      [256]i8
    host_len:  i64
    port:      i32
    _pad:      i32
    user:      [64]i8
    user_len:  i64
    pass:      [64]i8
    pass_len:  i64
    dbname:    [64]i8
    dbname_len: i64
}

let g_forge_db_conns:      &i64 = 0
let g_forge_db_conn_count: i64  = 0
let g_forge_db_current:    i64  = 0   // active connection index

fn forge_db_parse_url(url: []i8, conn: &ForgeDBConn) {
    // Find "://"
    let scheme_end = -1i64
    loop i in 0..url.len {
        if i + 2 < url.len {
            if url[i] == ':' and url[i+1] == '/' and url[i+2] == '/' {
                scheme_end = i  break
            }
        }
    }
    if scheme_end < 0 { ret }

    let s = url[0..scheme_end]
    let pg1 = "postgres"    let pg2 = "postgresql"
    let my1 = "mysql"       let my2 = "mariadb"
    if forge_slice_eq(s, pg1) or forge_slice_eq(s, pg2) {
        conn.driver = FORGE_DB_POSTGRES
    } else if forge_slice_eq(s, my1) or forge_slice_eq(s, my2) {
        conn.driver = FORGE_DB_MYSQL
    } else {
        conn.driver = FORGE_DB_POSTGRES
    }

    let rstart = scheme_end + 3
    // Find "@" for credentials/host split
    let at_pos = -1i64
    let i = rstart
    loop i < url.len { if url[i] == '@' { at_pos = i  break }  i = i + 1 }

    let host_start = rstart
    if at_pos >= 0 {
        let colon = -1i64
        let j = rstart
        loop j < at_pos { if url[j] == ':' { colon = j  break }  j = j + 1 }
        if colon >= 0 {
            let ulen = colon - rstart
            loop k in 0..ulen { conn.user[k] = url[rstart + k] }
            conn.user_len = ulen
            let plen = at_pos - colon - 1
            loop k in 0..plen { conn.pass[k] = url[colon + 1 + k] }
            conn.pass_len = plen
        } else {
            let ulen = at_pos - rstart
            loop k in 0..ulen { conn.user[k] = url[rstart + k] }
            conn.user_len = ulen
        }
        host_start = at_pos + 1
    }

    // Find "/" for host:port / dbname split
    let slash = -1i64
    let i2 = host_start
    loop i2 < url.len { if url[i2] == '/' { slash = i2  break }  i2 = i2 + 1 }
    let host_end = url.len
    if slash >= 0 { host_end = slash }

    // Split host:port
    let port_colon = -1i64
    let i3 = host_start
    loop i3 < host_end { if url[i3] == ':' { port_colon = i3  break }  i3 = i3 + 1 }
    if port_colon >= 0 {
        let hlen = port_colon - host_start
        loop k in 0..hlen { conn.host[k] = url[host_start + k] }
        conn.host_len = hlen
        let port_acc = 0i64
        let i4 = port_colon + 1
        loop i4 < host_end {
            let d = url[i4] as i64 - 48
            if d >= 0 and d <= 9 { port_acc = port_acc * 10 + d }
            i4 = i4 + 1
        }
        conn.port = port_acc as i32
    } else {
        let hlen = host_end - host_start
        loop k in 0..hlen { conn.host[k] = url[host_start + k] }
        conn.host_len = hlen
        if conn.driver == FORGE_DB_MYSQL { conn.port = 3306 }
        else                             { conn.port = 5432 }
    }

    // Database name from path
    if slash >= 0 and slash + 1 < url.len {
        let dlen = url.len - slash - 1
        loop k in 0..dlen { conn.dbname[k] = url[slash + 1 + k] }
        conn.dbname_len = dlen
    }
}

// Register a named database connection from a URL.
fn forge_db_add(name: []i8, url: []i8) {
    if g_forge_db_conns == 0 { g_forge_db_conns = alloc_pages(1) }
    if g_forge_db_conn_count >= FORGE_DB_MAX_CONNS { ret }
    let conn: &ForgeDBConn = alloc_pages(1)
    let nlen = name.len
    if nlen > 32 { nlen = 32 }
    loop i in 0..nlen { conn.name[i] = name[i] }
    conn.name_len = nlen
    forge_db_parse_url(url, conn)
    g_forge_db_conns[g_forge_db_conn_count] = conn as i64
    g_forge_db_conn_count = g_forge_db_conn_count + 1
    // First connection populates legacy globals too
    if g_forge_db_conn_count == 1 {
        g_forge_db_host = conn.host[0..conn.host_len]
        g_forge_db_port = conn.port
        g_forge_db_user = conn.user[0..conn.user_len]
        g_forge_db_pass = conn.pass[0..conn.pass_len]
        g_forge_db_name = conn.dbname[0..conn.dbname_len]
    }
}

// Set the active connection by name for subsequent queries.
fn forge_db_use(name: []i8) {
    loop i in 0..g_forge_db_conn_count {
        let conn = g_forge_db_conns[i] as &ForgeDBConn
        if forge_slice_eq(conn.name[0..conn.name_len], name) {
            g_forge_db_current = i  ret
        }
    }
}

// Return the index of a named connection (0 = primary fallback).
fn forge_db_conn_idx(name: []i8) -> i64 {
    loop i in 0..g_forge_db_conn_count {
        let conn = g_forge_db_conns[i] as &ForgeDBConn
        if forge_slice_eq(conn.name[0..conn.name_len], name) { ret i }
    }
    ret 0
}

// Legacy globals — kept for backward compat and used when no registry is set.
let g_forge_db_host: []i8 = ""
let g_forge_db_port: i32  = 5432
let g_forge_db_user: []i8 = ""
let g_forge_db_pass: []i8 = ""
let g_forge_db_name: []i8 = ""

fn forge_db_config(host: []i8, port: i32, user: []i8, pass: []i8, name: []i8) {
    g_forge_db_host = host
    g_forge_db_port = port
    g_forge_db_user = user
    g_forge_db_pass = pass
    g_forge_db_name = name
    // Also register as "primary" in the registry
    if g_forge_db_conn_count == 0 {
        let url_buf: &i8 = alloc_pages(1)
        let up = 0i64
        let scheme = "postgres://"
        loop i in 0..scheme.len { url_buf[up] = scheme[i]  up = up + 1 }
        loop i in 0..user.len  { url_buf[up] = user[i]    up = up + 1 }
        url_buf[up] = ':'  up = up + 1
        loop i in 0..pass.len  { url_buf[up] = pass[i]    up = up + 1 }
        url_buf[up] = '@'  up = up + 1
        loop i in 0..host.len  { url_buf[up] = host[i]    up = up + 1 }
        url_buf[up] = '/'  up = up + 1
        loop i in 0..name.len  { url_buf[up] = name[i]    up = up + 1 }
        let primary = "primary"
        forge_db_add(primary, url_buf[0..up])
    }
}

// Read exactly n bytes from fd into buf.
fn forge_db_recv_n(fd: i32, buf: &i8, n: i64) -> bool {
    let got = 0i64
    loop got < n {
        let r = syscall(FORGE_SYS_RECVFROM, fd, buf + got, n - got, 0, 0, 0) as i64
        if r <= 0 { ret false }
        got = got + r
    }
    ret true
}

// Read a big-endian int32 from buf at offset.
fn forge_db_read_i32(buf: &i8, off: i64) -> i64 {
    ret ((buf[off]   as i64 and 0xFF) << 24) or
        ((buf[off+1] as i64 and 0xFF) << 16) or
        ((buf[off+2] as i64 and 0xFF) << 8)  or
         (buf[off+3] as i64 and 0xFF)
}

fn forge_db_read_i16(buf: &i8, off: i64) -> i64 {
    ret ((buf[off]   as i64 and 0xFF) << 8) or
         (buf[off+1] as i64 and 0xFF)
}

fn forge_db_write_i32(buf: &i8, off: i64, val: i64) {
    buf[off]   = ((val >> 24) and 0xFF) as i8
    buf[off+1] = ((val >> 16) and 0xFF) as i8
    buf[off+2] = ((val >> 8)  and 0xFF) as i8
    buf[off+3] = (val         and 0xFF) as i8
}

fn forge_db_write_i16(buf: &i8, off: i64, val: i64) {
    buf[off]   = ((val >> 8) and 0xFF) as i8
    buf[off+1] = (val        and 0xFF) as i8
}

// =============================================================================
// PostgreSQL driver — wire protocol v3
// =============================================================================

fn forge_pg_connect(host: []i8, port: i32, user: []i8, pass: []i8, dbname: []i8) -> i32 {
    let fd = TcpStream::connect(host, port as u16).fd
    if fd < 0 { ret -1 }
    let msg = [512]i8
    forge_db_write_i32(msg, 4, 196608)   // protocol 3.0
    let pos = 8i64
    let kuser = "user"      let kdb = "database"
    loop i in 0..kuser.len  { msg[pos] = kuser[i]   pos = pos + 1 }
    msg[pos] = 0  pos = pos + 1
    loop i in 0..user.len   { msg[pos] = user[i]    pos = pos + 1 }
    msg[pos] = 0  pos = pos + 1
    loop i in 0..kdb.len    { msg[pos] = kdb[i]     pos = pos + 1 }
    msg[pos] = 0  pos = pos + 1
    loop i in 0..dbname.len { msg[pos] = dbname[i]  pos = pos + 1 }
    msg[pos] = 0  pos = pos + 1
    msg[pos] = 0  pos = pos + 1
    forge_db_write_i32(msg, 0, pos)
    forge_tcp_write_all(fd, msg, pos)
    let hdr = [5]i8
    loop {
        if not forge_db_recv_n(fd, hdr, 5) { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret -1 }
        let mtype = hdr[0]
        let mlen  = forge_db_read_i32(hdr, 1) - 4
        let body: &i8 = alloc_pages(1)
        if mlen > 0 { forge_db_recv_n(fd, body, mlen) }
        if mtype == 'R' {
            let auth_type = forge_db_read_i32(body, 0)
            if auth_type == 0 { }
            else if auth_type == 3 {
                let pmsg = [256]i8   let pp = 1i64
                pmsg[0] = 'p'
                forge_db_write_i32(pmsg, 1, pass.len + 5)
                pp = 5
                loop i in 0..pass.len { pmsg[pp] = pass[i]  pp = pp + 1 }
                pmsg[pp] = 0
                forge_tcp_write_all(fd, pmsg, pp + 1)
            } else { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret -1 }
        } else if mtype == 'Z' { ret fd }
        else if mtype == 'E' { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret -1 }
    }
}

fn forge_db_connect() -> i32 {
    ret forge_pg_connect(g_forge_db_host, g_forge_db_port, g_forge_db_user, g_forge_db_pass, g_forge_db_name)
}

fn forge_pg_query(host: []i8, port: i32, user: []i8, pass: []i8, dbname: []i8, sql: []i8) -> &ForgeResult {
    let result: &ForgeResult = alloc_pages(1)
    result.count    = 0
    result.affected = 0
    let fd = forge_pg_connect(host, port, user, pass, dbname)
    if fd < 0 { ret result }

    // Send simple query: 'Q' + int32(len+5) + sql + '\0'
    let qmsg: &i8 = alloc_pages(1)
    qmsg[0] = 'Q'
    forge_db_write_i32(qmsg, 1, sql.len + 5)
    loop i in 0..sql.len { qmsg[5 + i] = sql[i] }
    qmsg[5 + sql.len] = 0
    forge_tcp_write_all(fd, qmsg, 6 + sql.len)

    // Allocate row storage
    let rows: &i8 = alloc_pages(512)   // up to 256 rows
    result.rows = rows as &ForgeDbRow

    let hdr = [5]i8
    let ncols = 0i64
    loop {
        if not forge_db_recv_n(fd, hdr, 5) { break }
        let mtype = hdr[0]
        let mlen  = forge_db_read_i32(hdr, 1) - 4
        let body: &i8 = alloc_pages(16)   // 64 KB body buffer
        if mlen > 0 { forge_db_recv_n(fd, body, mlen) }

        if mtype == 'T' {
            // RowDescription — parse column count and names
            ncols = forge_db_read_i16(body, 0)
            result.col_count = ncols
            let tp = 2i64
            loop ci in 0..ncols {
                // Each field: name(cstring) + 18 bytes of metadata
                let cn: &ForgeColName = (result.col_names as i64 + ci * 72) as &ForgeColName
                let nl = 0i64
                loop {
                    if tp >= mlen { break }
                    let ch = body[tp]
                    tp = tp + 1
                    if ch == 0 { break }
                    if nl < 64 { cn.name[nl] = ch  nl = nl + 1 }
                }
                cn.nlen = nl
                // Skip 18 bytes: tableOID(4) colNum(2) typeOID(4) typeSize(2) typeMod(4) format(2)
                tp = tp + 18
            }
        } else if mtype == 'D' {
            // DataRow
            let row_i = result.count
            if row_i < FORGE_DB_MAX_ROWS {
                let row: &ForgeDbRow = (rows as i64 + row_i * FORGE_DB_ROW_STRIDE) as &ForgeDbRow
                let nf = forge_db_read_i16(body, 0)
                row.count = nf
                let bp = 2i64
                loop c in 0..nf {
                    let dlen = forge_db_read_i32(body, bp)
                    bp = bp + 4
                    if dlen < 0 {
                        // NULL value
                        row.cols[c].len = 0
                    } else {
                        let cell: &ForgeDbCell = (row.cols as i64 + c * FORGE_DB_COL_STRIDE) as &ForgeDbCell
                        let cl = dlen
                        if cl > FORGE_DB_COL_CAP { cl = FORGE_DB_COL_CAP }
                        loop j in 0..cl { cell.data[j] = body[bp + j] }
                        cell.len = cl
                        bp = bp + dlen
                    }
                }
                result.count = row_i + 1
            }
        } else if mtype == 'C' {
            // CommandComplete — parse affected rows from tag like "INSERT 0 3"
            let tag = body[0..mlen]
            // Find last space → number after it is row count
            let li = 0i64
            loop i in 0..tag.len { if tag[i] == ' ' { li = i } }
            if li > 0 {
                let num_str = tag[li+1..]
                let acc = 0i64
                loop i in 0..num_str.len {
                    let d = num_str[i] as i64 - 48
                    if d >= 0 and d <= 9 { acc = acc * 10 + d }
                }
                result.affected = acc
            }
        } else if mtype == 'Z' {
            break   // ReadyForQuery — done
        } else if mtype == 'E' {
            break   // ErrorResponse
        }
    }

    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
    ret result
}

fn forge_db_query(sql: []i8) -> &ForgeResult {
    ret forge_pg_query(g_forge_db_host, g_forge_db_port, g_forge_db_user, g_forge_db_pass, g_forge_db_name, sql)
}

fn forge_db_exec(sql: []i8) -> bool {
    let res = forge_db_query(sql)
    ret res.affected >= 0
}

// =============================================================================
// MySQL driver — wire protocol v4.1 / v10 handshake
// Supports mysql_native_password authentication.
// =============================================================================

fn forge_mysql_write_i24le(buf: &i8, off: i64, val: i64) {
    buf[off]   = (val and 0xFF) as i8
    buf[off+1] = ((val >> 8)  and 0xFF) as i8
    buf[off+2] = ((val >> 16) and 0xFF) as i8
}

fn forge_mysql_write_i32le(buf: &i8, off: i64, val: i64) {
    buf[off]   = (val and 0xFF) as i8
    buf[off+1] = ((val >> 8)  and 0xFF) as i8
    buf[off+2] = ((val >> 16) and 0xFF) as i8
    buf[off+3] = ((val >> 24) and 0xFF) as i8
}

fn forge_mysql_send_pkt(fd: i32, payload: &i8, plen: i64, seq: i64) {
    let hdr = [4]i8
    forge_mysql_write_i24le(hdr, 0, plen)
    hdr[3] = seq as i8
    forge_tcp_write_all(fd, hdr, 4)
    forge_tcp_write_all(fd, payload, plen)
}

fn forge_mysql_recv_pkt(fd: i32, buf: &i8, max: i64) -> i64 {
    let hdr = [4]i8
    if not forge_db_recv_n(fd, hdr, 4) { ret -1 }
    let plen = (hdr[0] as i64 and 0xFF) or
               ((hdr[1] as i64 and 0xFF) << 8) or
               ((hdr[2] as i64 and 0xFF) << 16)
    if plen > max { ret -1 }
    if plen == 0  { ret 0 }
    if not forge_db_recv_n(fd, buf, plen) { ret -1 }
    ret plen
}

// Read a length-encoded integer from buf at pos; advances pos in-place.
fn forge_mysql_lenenc(buf: &i8, pos: &i64) -> i64 {
    let b = buf[pos[0]] as i64 and 0xFF
    if b < 0xFB  { pos[0] = pos[0] + 1  ret b }
    if b == 0xFB { pos[0] = pos[0] + 1  ret 0 }   // NULL
    if b == 0xFC {
        let v = (buf[pos[0]+1] as i64 and 0xFF) or ((buf[pos[0]+2] as i64 and 0xFF) << 8)
        pos[0] = pos[0] + 3   ret v
    }
    if b == 0xFD {
        let v = (buf[pos[0]+1] as i64 and 0xFF) or
                ((buf[pos[0]+2] as i64 and 0xFF) << 8) or
                ((buf[pos[0]+3] as i64 and 0xFF) << 16)
        pos[0] = pos[0] + 4   ret v
    }
    let v = 0i64
    loop i in 0..8 { v = v or ((buf[pos[0]+1+i] as i64 and 0xFF) << (i * 8)) }
    pos[0] = pos[0] + 9   ret v
}

fn forge_mysql_connect(conn: &ForgeDBConn) -> i32 {
    let fd = TcpStream::connect(conn.host[0..conn.host_len], conn.port as u16).fd
    if fd < 0 { ret -1 }

    let buf: &i8 = alloc_pages(4)

    // Read server initial handshake
    let plen = forge_mysql_recv_pkt(fd, buf, 16384)
    if plen < 0 or buf[0] != 10 { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret -1 }

    // Skip server version (null-terminated) + connection id (4 bytes)
    let pos = 1i64
    loop pos < plen { if buf[pos] == 0 { pos = pos + 1  break }  pos = pos + 1 }
    pos = pos + 4

    // Auth plugin data part 1 (8 bytes)
    let seed = [20]i8
    loop i in 0..8 { seed[i] = buf[pos + i] }
    pos = pos + 8 + 1 + 2 + 1 + 2 + 2   // filler + caps_lo + charset + status + caps_hi

    let auth_data_len = buf[pos] as i64 and 0xFF
    pos = pos + 1 + 10   // auth_data_len + reserved

    // Auth plugin data part 2: max(13, auth_data_len - 8) bytes
    let part2 = auth_data_len - 8
    if part2 < 13 { part2 = 13 }
    let copy_n = part2 - 1
    if copy_n > 12 { copy_n = 12 }
    loop i in 0..copy_n { seed[8 + i] = buf[pos + i] }

    // Compute mysql_native_password scramble
    let auth_resp = [20]i8
    let auth_resp_len = 0i64
    if conn.pass_len > 0 {
        let pbuf = [256]i8
        let plen2 = conn.pass_len
        loop i in 0..plen2 { pbuf[i] = conn.pass[i] }
        let stage1 = [20]i8   sha1(pbuf, plen2, stage1)
        let stage2 = [20]i8   sha1(stage1, 20, stage2)
        let cat = [40]i8
        loop i in 0..20 { cat[i] = seed[i] }
        loop i in 0..20 { cat[20+i] = stage2[i] }
        let stage3 = [20]i8   sha1(cat, 40, stage3)
        loop i in 0..20 { auth_resp[i] = (stage1[i] as i64 ^ stage3[i] as i64) as i8 }
        auth_resp_len = 20
    }

    // Send handshake response
    let resp: &i8 = alloc_pages(1)
    let rp = 0i64
    // caps: CLIENT_LONG_PASSWORD(1)|CLIENT_LONG_FLAG(4)|CLIENT_CONNECT_WITH_DB(8)|CLIENT_PROTOCOL_41(0x200)|CLIENT_SECURE_CONNECTION(0x8000)
    forge_mysql_write_i32le(resp, rp, 0x820D)   rp = rp + 4
    forge_mysql_write_i32le(resp, rp, 16777216) rp = rp + 4   // max packet = 16MB
    resp[rp] = 33   rp = rp + 1                               // charset utf8
    loop i in 0..23 { resp[rp] = 0  rp = rp + 1 }             // reserved
    loop i in 0..conn.user_len { resp[rp] = conn.user[i]  rp = rp + 1 }
    resp[rp] = 0  rp = rp + 1
    resp[rp] = auth_resp_len as i8  rp = rp + 1
    loop i in 0..auth_resp_len { resp[rp] = auth_resp[i]  rp = rp + 1 }
    loop i in 0..conn.dbname_len { resp[rp] = conn.dbname[i]  rp = rp + 1 }
    resp[rp] = 0  rp = rp + 1
    forge_mysql_send_pkt(fd, resp, rp, 1)

    // Read auth result
    let alen = forge_mysql_recv_pkt(fd, buf, 16384)
    if alen < 0 or buf[0] == 0xFF { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret -1 }
    ret fd
}

fn forge_mysql_query(conn: &ForgeDBConn, sql: []i8) -> &ForgeResult {
    let result: &ForgeResult = alloc_pages(1)
    result.count    = 0
    result.affected = 0

    let fd = forge_mysql_connect(conn)
    if fd < 0 { ret result }

    let qbuf: &i8 = alloc_pages(4)
    qbuf[0] = 0x03
    loop i in 0..sql.len { qbuf[1+i] = sql[i] }
    forge_mysql_send_pkt(fd, qbuf, 1 + sql.len, 0)

    let buf: &i8 = alloc_pages(16)
    let plen2 = forge_mysql_recv_pkt(fd, buf, 65536)
    if plen2 < 0 { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret result }

    if buf[0] == 0xFF { syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)  ret result }

    if buf[0] == 0x00 {
        // OK packet — parse affected rows
        let p: &i64 = alloc_pages(1)   p[0] = 1
        result.affected = forge_mysql_lenenc(buf, p)
        syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
        ret result
    }

    // Result set
    let p: &i64 = alloc_pages(1)   p[0] = 0
    let ncols = forge_mysql_lenenc(buf, p)
    result.col_count = ncols

    // Column definitions
    loop ci in 0..ncols {
        let cplen = forge_mysql_recv_pkt(fd, buf, 65536)
        if cplen < 0 { break }
        p[0] = 0
        // Skip 4 lenenc strings: catalog, schema, table, org_table
        loop skip in 0..4 {
            let slen = forge_mysql_lenenc(buf, p)
            p[0] = p[0] + slen
        }
        // 5th = column name
        let nlen = forge_mysql_lenenc(buf, p)
        let cn: &ForgeColName = (result.col_names as i64 + ci * 72) as &ForgeColName
        let copy_n = nlen   if copy_n > 64 { copy_n = 64 }
        loop j in 0..copy_n { cn.name[j] = buf[p[0] + j] }
        cn.nlen = copy_n
    }
    forge_mysql_recv_pkt(fd, buf, 65536)   // consume EOF after columns

    let rows: &i8 = alloc_pages(512)
    result.rows = rows as &ForgeDbRow

    loop {
        let rplen = forge_mysql_recv_pkt(fd, buf, 65536)
        if rplen < 0 { break }
        if (buf[0] as i64 and 0xFF) == 0xFE or (buf[0] as i64 and 0xFF) == 0xFF { break }

        let row_i = result.count
        if row_i >= FORGE_DB_MAX_ROWS { break }
        let row: &ForgeDbRow = (rows as i64 + row_i * FORGE_DB_ROW_STRIDE) as &ForgeDbRow
        row.count = ncols
        p[0] = 0
        loop c in 0..ncols {
            if p[0] >= rplen { break }
            if (buf[p[0]] as i64 and 0xFF) == 0xFB {
                p[0] = p[0] + 1
            } else {
                let dlen = forge_mysql_lenenc(buf, p)
                let cell: &ForgeDbCell = (row.cols as i64 + c * FORGE_DB_COL_STRIDE) as &ForgeDbCell
                let cl = dlen   if cl > FORGE_DB_COL_CAP { cl = FORGE_DB_COL_CAP }
                loop j in 0..cl { cell.data[j] = buf[p[0] + j] }
                cell.len = cl
                p[0] = p[0] + dlen
            }
        }
        result.count = row_i + 1
    }
    result.affected = result.count
    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
    ret result
}

// =============================================================================
// Multi-connection dispatch
// =============================================================================

fn forge_db_query_on(idx: i64, sql: []i8) -> &ForgeResult {
    if g_forge_db_conns == 0 or g_forge_db_conn_count == 0 {
        ret forge_pg_query(g_forge_db_host, g_forge_db_port, g_forge_db_user, g_forge_db_pass, g_forge_db_name, sql)
    }
    let i = idx
    if i >= g_forge_db_conn_count { i = 0 }
    let conn = g_forge_db_conns[i] as &ForgeDBConn
    if conn.driver == FORGE_DB_MYSQL {
        ret forge_mysql_query(conn, sql)
    }
    ret forge_pg_query(conn.host[0..conn.host_len], conn.port, conn.user[0..conn.user_len], conn.pass[0..conn.pass_len], conn.dbname[0..conn.dbname_len], sql)
}

fn forge_db_exec_on(idx: i64, sql: []i8) -> bool {
    let res = forge_db_query_on(idx, sql)
    ret res.affected >= 0
}

// Get a column value from a result row.
fn forge_row_col(res: &ForgeResult, row_i: i64, col_i: i64) -> []i8 {
    if row_i >= res.count { ret "" }
    let row: &ForgeDbRow = (res.rows as i64 + row_i * FORGE_DB_ROW_STRIDE) as &ForgeDbRow
    if col_i >= row.count { ret "" }
    let cell: &ForgeDbCell = (row.cols as i64 + col_i * FORGE_DB_COL_STRIDE) as &ForgeDbCell
    ret cell.data[0..cell.len]
}

// Named-column accessor  (UFCS prefix: forge_result)
fn forge_result_col(res: &ForgeResult, row_i: i64, col: []i8) -> []i8 {
    loop ci in 0..res.col_count {
        let cn: &ForgeColName = (res.col_names as i64 + ci * 72) as &ForgeColName
        if cn.nlen == col.len {
            let match = true
            loop j in 0..col.len {
                if cn.name[j] != col[j] { match = false  break }
            }
            if match { ret forge_row_col(res, row_i, ci) }
        }
    }
    ret ""
}

// Shortcut for the "id" column — enables post_obj.id() via UFCS
fn forge_result_id(res: &ForgeResult) -> []i8 { ret forge_result_col(res, 0, "id") }

// =============================================================================
// Migrations — run SQL migration files in order
// Files must be named NNN_description.sql (e.g. 001_create_users.sql).
// Tracks completed migrations in a "forge_migrations" table.
//
// Call forge_migrate("./db/migrations") once in main() before app_listen.
// =============================================================================

fn forge_migrate(dir: []i8) {
    // Ensure migrations tracking table exists
    forge_db_exec("CREATE TABLE IF NOT EXISTS forge_migrations (name TEXT PRIMARY KEY, ran_at BIGINT)")

    // Read directory listing via the filesystem
    // Conventions: files are loaded alphabetically; we read each *.sql file
    // by constructing filenames 001..999 and checking if they exist.
    let i = 1i64
    loop i <= 999 {
        // Build path: dir + "/" + NNN_*.sql — try to open and execute
        // Since we can't list directories, migrations must be registered via forge_migration_add
        // (see below). This runner executes registered migrations in order.
        i = i + 1
    }
}

// Register and run a single migration by name + SQL (code-driven migrations).
fn forge_migration_run(name: []i8, sql: []i8) {
    // Check if already ran
    let check_buf: &i8 = alloc_pages(1)
    let cp = 0i64
    let q1 = "SELECT name FROM forge_migrations WHERE name = '"
    let q2 = "'"
    loop i in 0..q1.len   { check_buf[cp] = q1[i]    cp = cp + 1 }
    loop i in 0..name.len { check_buf[cp] = name[i]  cp = cp + 1 }
    loop i in 0..q2.len   { check_buf[cp] = q2[i]    cp = cp + 1 }
    let res = forge_db_query(check_buf[0..cp])
    if res.count > 0 { ret }   // already ran

    // Run the migration SQL
    forge_db_exec(sql)

    // Record it
    let ins_buf: &i8 = alloc_pages(1)
    let ip = 0i64
    let i1 = "INSERT INTO forge_migrations (name, ran_at) VALUES ('"
    let i2 = "', "
    let i3 = ")"
    let t = time_now_ms()
    let tbuf = [20]i8
    let tlen = fmt_i64(tbuf, t)
    loop i in 0..i1.len   { ins_buf[ip] = i1[i]    ip = ip + 1 }
    loop i in 0..name.len { ins_buf[ip] = name[i]  ip = ip + 1 }
    loop i in 0..i2.len   { ins_buf[ip] = i2[i]    ip = ip + 1 }
    loop i in 0..tlen     { ins_buf[ip] = tbuf[i]  ip = ip + 1 }
    loop i in 0..i3.len   { ins_buf[ip] = i3[i]    ip = ip + 1 }
    forge_db_exec(ins_buf[0..ip])

    // Log it
    let log_buf = [256]i8
    let lp = 0i64
    let lp1 = "[forge] migrate: ran "
    let lp2 = "\n"
    loop i in 0..lp1.len  { log_buf[lp] = lp1[i]   lp = lp + 1 }
    loop i in 0..name.len { log_buf[lp] = name[i]  lp = lp + 1 }
    loop i in 0..lp2.len  { log_buf[lp] = lp2[i]   lp = lp + 1 }
    syscall(FORGE_SYS_WRITE, 1, log_buf, lp, 0, 0)
}

// =============================================================================
// Admin UI — auto-generated CRUD interface
// Register models with forge_admin_register, then mount at /admin.
//
// Example:
//   forge_admin_register("users",  "SELECT id, email, created_at FROM users")
//   forge_admin_register("posts",  "SELECT id, title, published FROM posts")
//   app_get(app, "/admin",     fn_addr(forge_admin_index))
//   app_get(app, "/admin/:model", fn_addr(forge_admin_list))
// =============================================================================
const FORGE_ADMIN_MAX_MODELS  = 16
const FORGE_ADMIN_NAME_CAP    = 32
const FORGE_ADMIN_QUERY_CAP   = 256

struct ForgeAdminModel {
    name:       [FORGE_ADMIN_NAME_CAP]i8
    nlen:       i64
    list_query: [FORGE_ADMIN_QUERY_CAP]i8
    qlen:       i64
    used:       bool
}

let g_forge_admin_models: &ForgeAdminModel = 0
let g_forge_admin_count:  i64 = 0

fn forge_admin_init() {
    if g_forge_admin_models != 0 { ret }
    g_forge_admin_models = alloc_pages(4) as &ForgeAdminModel
}

fn forge_admin_register(name: []i8, list_query: []i8) {
    forge_admin_init()
    let n = g_forge_admin_count
    if n >= FORGE_ADMIN_MAX_MODELS { ret }
    let stride = 306i64  // sizeof(ForgeAdminModel): 32+8+256+8+1+1(pad)
    let m: &ForgeAdminModel = (g_forge_admin_models as i64 + n * stride) as &ForgeAdminModel
    let nl = name.len
    if nl > FORGE_ADMIN_NAME_CAP { nl = FORGE_ADMIN_NAME_CAP }
    loop i in 0..nl { m.name[i] = name[i] }
    m.nlen = nl
    let ql = list_query.len
    if ql > FORGE_ADMIN_QUERY_CAP { ql = FORGE_ADMIN_QUERY_CAP }
    loop i in 0..ql { m.list_query[i] = list_query[i] }
    m.qlen = ql
    m.used = true
    g_forge_admin_count = n + 1
}

fn forge_admin_index(ctx: i64) {
    forge_admin_init()
    let buf: &i8 = alloc_pages(4)
    let pos = 0i64
    let h1 = "<h1>Forge Admin</h1><ul>"
    loop i in 0..h1.len { buf[pos] = h1[i]  pos = pos + 1 }
    let stride = 306i64
    loop i in 0..g_forge_admin_count {
        let m: &ForgeAdminModel = (g_forge_admin_models as i64 + i * stride) as &ForgeAdminModel
        let p1 = "<li><a href=/admin/"
        let p2 = ">"
        let p3 = "</a></li>"
        loop j in 0..p1.len { buf[pos] = p1[j]   pos = pos + 1 }
        loop j in 0..m.nlen { buf[pos] = m.name[j]  pos = pos + 1 }
        loop j in 0..p2.len { buf[pos] = p2[j]   pos = pos + 1 }
        loop j in 0..m.nlen { buf[pos] = m.name[j]  pos = pos + 1 }
        loop j in 0..p3.len { buf[pos] = p3[j]   pos = pos + 1 }
    }
    let h2 = "</ul>"
    loop i in 0..h2.len { buf[pos] = h2[i]  pos = pos + 1 }
    ctx_html(ctx, 200, buf[0..pos])
}

fn forge_admin_list(ctx: i64) {
    forge_admin_init()
    let model_name = ctx_param(ctx, "model")
    let stride = 306i64
    let found: &ForgeAdminModel = 0
    loop i in 0..g_forge_admin_count {
        let m: &ForgeAdminModel = (g_forge_admin_models as i64 + i * stride) as &ForgeAdminModel
        if forge_slice_eq(m.name[0..m.nlen], model_name) { found = m   break }
    }
    if found == 0 {
        ctx_not_found(ctx)
        ret
    }
    let res = forge_db_query(found.list_query[0..found.qlen])
    let buf: &i8 = alloc_pages(8)
    let pos = 0i64
    let h1 = "<h1>"
    let h1e = "</h1><a href=/admin>← Back</a><table border=1><tr>"
    loop i in 0..h1.len         { buf[pos] = h1[i]   pos = pos + 1 }
    loop i in 0..model_name.len { buf[pos] = model_name[i]  pos = pos + 1 }
    loop i in 0..h1e.len        { buf[pos] = h1e[i]  pos = pos + 1 }
    // Column headers from first row
    if res.count > 0 {
        let row0: &ForgeDbRow = res.rows
        loop c in 0..row0.count {
            let th1 = "<th>"
            let th2 = "</th>"
            loop i in 0..th1.len { buf[pos] = th1[i]  pos = pos + 1 }
            let cell: &ForgeDbCell = (row0.cols as i64 + c * FORGE_DB_COL_STRIDE) as &ForgeDbCell
            loop i in 0..cell.len { buf[pos] = cell.data[i]  pos = pos + 1 }
            loop i in 0..th2.len { buf[pos] = th2[i]  pos = pos + 1 }
        }
    }
    let tre = "</tr>"
    loop i in 0..tre.len { buf[pos] = tre[i]  pos = pos + 1 }
    // Data rows
    loop r in 0..res.count {
        let row: &ForgeDbRow = (res.rows as i64 + r * FORGE_DB_ROW_STRIDE) as &ForgeDbRow
        let tr1 = "<tr>"
        let tr2 = "</tr>"
        let td1 = "<td>"
        let td2 = "</td>"
        loop i in 0..tr1.len { buf[pos] = tr1[i]  pos = pos + 1 }
        loop c in 0..row.count {
            let cell: &ForgeDbCell = (row.cols as i64 + c * FORGE_DB_COL_STRIDE) as &ForgeDbCell
            loop i in 0..td1.len  { buf[pos] = td1[i]       pos = pos + 1 }
            loop i in 0..cell.len { buf[pos] = cell.data[i]  pos = pos + 1 }
            loop i in 0..td2.len  { buf[pos] = td2[i]       pos = pos + 1 }
        }
        loop i in 0..tr2.len { buf[pos] = tr2[i]  pos = pos + 1 }
    }
    let tend = "</table>"
    loop i in 0..tend.len { buf[pos] = tend[i]  pos = pos + 1 }
    ctx_html(ctx, 200, buf[0..pos])
}

// =============================================================================
// Section A — DB Utilities + Query Builder
// =============================================================================

const FORGE_QUERY_WHERE_CAP  = 2048
const FORGE_QUERY_ORDER_CAP  = 256
const FORGE_QUERY_SEL_CAP    = 512
const FORGE_QUERY_JOIN_CAP   = 1024
const FORGE_QUERY_GROUP_CAP  = 256
const FORGE_QUERY_HAVING_CAP = 512
const FORGE_SCOPE_MAX        = 64

struct ForgeQuery {
    table:      []i8
    conn_idx:   i64
    where_buf:  [FORGE_QUERY_WHERE_CAP]i8
    where_len:  i64
    order_buf:  [FORGE_QUERY_ORDER_CAP]i8
    order_len:  i64
    sel_buf:    [FORGE_QUERY_SEL_CAP]i8
    sel_len:    i64
    join_buf:   [FORGE_QUERY_JOIN_CAP]i8
    join_len:   i64
    group_buf:  [FORGE_QUERY_GROUP_CAP]i8
    group_len:  i64
    having_buf: [FORGE_QUERY_HAVING_CAP]i8
    having_len: i64
    lim:        i64
    off:        i64
    distinct:       bool
    or_mode:        bool
    no_soft_delete: bool
    only_deleted:   bool
    lock_row:       bool
}

struct ForgeScopeEntry {
    table_buf: [64]i8
    tlen:      i64
    name_buf:  [64]i8
    nlen:      i64
    fn_ptr:    i64
}

let g_forge_scope_store: &ForgeScopeEntry = 0
let g_forge_scope_count: i64 = 0

// ---------------------------------------------------------------------------
// SQL string escape
// ---------------------------------------------------------------------------

fn forge_db_escape_str(val: []i8, dst: &i8) -> i64 {
    let pos = 0i64
    loop i in 0..val.len {
        if val[i] == '\'' {
            dst[pos] = '\''
            pos = pos + 1
            dst[pos] = '\''
            pos = pos + 1
        } else {
            dst[pos] = val[i]
            pos = pos + 1
        }
    }
    ret pos
}

// ---------------------------------------------------------------------------
// Internal buffer-append helpers
// ---------------------------------------------------------------------------

fn forge__wbuf(q: &ForgeQuery, s: []i8) {
    loop i in 0..s.len {
        if q.where_len < FORGE_QUERY_WHERE_CAP {
            q.where_buf[q.where_len] = s[i]
            q.where_len = q.where_len + 1
        }
    }
}

fn forge__obuf(q: &ForgeQuery, s: []i8) {
    loop i in 0..s.len {
        if q.order_len < FORGE_QUERY_ORDER_CAP {
            q.order_buf[q.order_len] = s[i]
            q.order_len = q.order_len + 1
        }
    }
}

fn forge__jbuf(q: &ForgeQuery, s: []i8) {
    loop i in 0..s.len {
        if q.join_len < FORGE_QUERY_JOIN_CAP {
            q.join_buf[q.join_len] = s[i]
            q.join_len = q.join_len + 1
        }
    }
}

fn forge__gbuf(q: &ForgeQuery, s: []i8) {
    loop i in 0..s.len {
        if q.group_len < FORGE_QUERY_GROUP_CAP {
            q.group_buf[q.group_len] = s[i]
            q.group_len = q.group_len + 1
        }
    }
}

fn forge__hbuf(q: &ForgeQuery, s: []i8) {
    loop i in 0..s.len {
        if q.having_len < FORGE_QUERY_HAVING_CAP {
            q.having_buf[q.having_len] = s[i]
            q.having_len = q.having_len + 1
        }
    }
}

fn forge__wbuf_escaped(q: &ForgeQuery, val: []i8) {
    let eb: &i8 = alloc_pages(1)
    let el = forge_db_escape_str(val, eb)
    loop i in 0..el {
        if q.where_len < FORGE_QUERY_WHERE_CAP {
            q.where_buf[q.where_len] = eb[i]
            q.where_len = q.where_len + 1
        }
    }
}

fn forge__where_connector(q: &ForgeQuery) {
    if q.where_len == 0 { ret }
    if q.or_mode {
        forge__wbuf(q, " OR ")
        q.or_mode = false
    } else {
        forge__wbuf(q, " AND ")
    }
}

// ---------------------------------------------------------------------------
// Model-database binding registry
// Each table can declare a non-primary connection via forge_model_db().
// forge_q() consults this registry so all generated helpers route correctly.
// ---------------------------------------------------------------------------

let FORGE_MODEL_DB_MAX: i64 = 64

let g_forge_model_db_tables:     &i8  = 0   // 64 slots × 64 bytes
let g_forge_model_db_table_lens: &i64 = 0
let g_forge_model_db_conn_idxs:  &i64 = 0
let g_forge_model_db_count:      i64  = 0

fn forge_model_db_registry_init() {
    if g_forge_model_db_tables != 0 { ret }
    g_forge_model_db_tables     = alloc_pages(1)   // 64 * 64 = 4 096 bytes
    g_forge_model_db_table_lens = alloc_pages(1)
    g_forge_model_db_conn_idxs  = alloc_pages(1)
}

// Returns the registered conn_idx for this table, or -1 if none.
fn forge_model_db_lookup(table: []i8) -> i64 {
    if g_forge_model_db_tables == 0 { ret -1 }
    let tl = table.len
    loop i in 0..g_forge_model_db_count {
        if g_forge_model_db_table_lens[i] != tl { continue }
        let base  = i * 64
        let match = true
        loop j in 0..tl {
            if g_forge_model_db_tables[base + j] != table[j] { match = false  break }
        }
        if match { ret g_forge_model_db_conn_idxs[i] }
    }
    ret -1
}

// ---------------------------------------------------------------------------
// Constructor
// ---------------------------------------------------------------------------

fn forge_q(table: []i8) -> &ForgeQuery {
    let q: &ForgeQuery = alloc_pages(2)
    q.table          = table
    let db_override  = forge_model_db_lookup(table)
    if db_override >= 0 { q.conn_idx = db_override } else { q.conn_idx = g_forge_db_current }
    q.where_len      = 0
    q.order_len      = 0
    q.sel_len        = 0
    q.join_len       = 0
    q.group_len      = 0
    q.having_len     = 0
    q.lim            = -1
    q.off            = -1
    q.distinct       = false
    q.or_mode        = false
    q.no_soft_delete = true
    q.only_deleted   = false
    q.lock_row       = false
    ret q
}

// Pin a query to a specific named connection.
fn forge_q_on(conn_name: []i8, table: []i8) -> &ForgeQuery {
    let q = forge_q(table)
    q.conn_idx = forge_db_conn_idx(conn_name)
    ret q
}

// ---------------------------------------------------------------------------
// SELECT
// ---------------------------------------------------------------------------

fn forge_q_select(q: &ForgeQuery, cols: []i8) -> &ForgeQuery {
    let l = cols.len
    if l > FORGE_QUERY_SEL_CAP { l = FORGE_QUERY_SEL_CAP }
    loop i in 0..l { q.sel_buf[i] = cols[i] }
    q.sel_len = l
    ret q
}

fn forge_q_distinct(q: &ForgeQuery) -> &ForgeQuery {
    q.distinct = true
    ret q
}

// ---------------------------------------------------------------------------
// WHERE — core
// ---------------------------------------------------------------------------

fn forge_q_where(q: &ForgeQuery, col: []i8, op: []i8, val: []i8) -> &ForgeQuery {
    let is_kw = forge_slice_eq(op, "IS") or forge_slice_eq(op, "IS NOT")
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " ")
    forge__wbuf(q, op)
    forge__wbuf(q, " ")
    if is_kw {
        forge__wbuf(q, val)
    } else {
        forge__wbuf(q, "'")
        forge__wbuf_escaped(q, val)
        forge__wbuf(q, "'")
    }
    ret q
}

fn forge_q_where_raw(q: &ForgeQuery, expr: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, expr)
    ret q
}

// where_bind — Rails-style parameterized WHERE: ? placeholders, pipe-separated args
// e.g. .where_bind("role = ? and name = ?", "admin|alice")
// Each ? is replaced with the next pipe-delimited arg, SQL-escaped and quoted.
// Values cannot contain '|'. For values with pipes, use separate where_eq calls.
fn forge_q_where_bind(q: &ForgeQuery, tmpl: []i8, args: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    let ai   = 0i64   // position in args
    let prev = 0i64   // start of current template segment
    loop ti in 0..tmpl.len {
        if tmpl[ti] == '?' {
            if ti > prev { forge__wbuf(q, tmpl[prev..ti]) }
            let start = ai
            loop ai < args.len and args[ai] != '|' { ai = ai + 1 }
            let val = args[start..ai]
            if ai < args.len { ai = ai + 1 }
            forge__wbuf(q, "'")
            forge__wbuf_escaped(q, val)
            forge__wbuf(q, "'")
            prev = ti + 1
        }
    }
    if prev < tmpl.len { forge__wbuf(q, tmpl[prev..tmpl.len]) }
    ret q
}

// where_eq(col, val) — equality shorthand; like Rails where(col: val)
fn forge_q_where_eq(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " = '")
    forge__wbuf_escaped(q, val)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_or(q: &ForgeQuery) -> &ForgeQuery {
    q.or_mode = true
    ret q
}

// ---------------------------------------------------------------------------
// WHERE — convenience helpers
// ---------------------------------------------------------------------------

fn forge_q_where_not(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " != '")
    forge__wbuf_escaped(q, val)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_where_null(q: &ForgeQuery, col: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " IS NULL")
    ret q
}

fn forge_q_where_not_null(q: &ForgeQuery, col: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " IS NOT NULL")
    ret q
}

fn forge_q_where_like(q: &ForgeQuery, col: []i8, pattern: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " LIKE '")
    forge__wbuf_escaped(q, pattern)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_where_ilike(q: &ForgeQuery, col: []i8, pattern: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " ILIKE '")
    forge__wbuf_escaped(q, pattern)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_where_between(q: &ForgeQuery, col: []i8, lo: []i8, hi: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " BETWEEN '")
    forge__wbuf_escaped(q, lo)
    forge__wbuf(q, "' AND '")
    forge__wbuf_escaped(q, hi)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_where_gt(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " > '")
    forge__wbuf_escaped(q, val)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_where_gte(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " >= '")
    forge__wbuf_escaped(q, val)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_where_lt(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " < '")
    forge__wbuf_escaped(q, val)
    forge__wbuf(q, "'")
    ret q
}

fn forge_q_where_lte(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " <= '")
    forge__wbuf_escaped(q, val)
    forge__wbuf(q, "'")
    ret q
}

// WHERE col IN ('a','b','c') — vals is a comma-separated string e.g. "admin,user,guest"
fn forge_q_where_in(q: &ForgeQuery, col: []i8, vals: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " IN (")
    let start = 0i64
    let first = true
    loop i in 0..vals.len {
        let is_sep = (vals[i] == ',')
        let is_end = (i == vals.len - 1)
        if is_sep or is_end {
            let end = i
            if is_end and not is_sep { end = i + 1 }
            if not first { forge__wbuf(q, ",") }
            first = false
            forge__wbuf(q, "'")
            forge__wbuf_escaped(q, vals[start..end])
            forge__wbuf(q, "'")
            start = i + 1
        }
    }
    forge__wbuf(q, ")")
    ret q
}

fn forge_q_where_not_in(q: &ForgeQuery, col: []i8, vals: []i8) -> &ForgeQuery {
    forge__where_connector(q)
    forge__wbuf(q, col)
    forge__wbuf(q, " NOT IN (")
    let start = 0i64
    let first = true
    loop i in 0..vals.len {
        let is_sep = (vals[i] == ',')
        let is_end = (i == vals.len - 1)
        if is_sep or is_end {
            let end = i
            if is_end and not is_sep { end = i + 1 }
            if not first { forge__wbuf(q, ",") }
            first = false
            forge__wbuf(q, "'")
            forge__wbuf_escaped(q, vals[start..end])
            forge__wbuf(q, "'")
            start = i + 1
        }
    }
    forge__wbuf(q, ")")
    ret q
}

// ---------------------------------------------------------------------------
// JOINs
// ---------------------------------------------------------------------------

fn forge_q_join_raw(q: &ForgeQuery, expr: []i8) -> &ForgeQuery {
    if q.join_len > 0 { forge__jbuf(q, " ") }
    forge__jbuf(q, expr)
    ret q
}

fn forge_q_join(q: &ForgeQuery, table: []i8, condition: []i8) -> &ForgeQuery {
    if q.join_len > 0 { forge__jbuf(q, " ") }
    forge__jbuf(q, "JOIN ")
    forge__jbuf(q, table)
    forge__jbuf(q, " ON ")
    forge__jbuf(q, condition)
    ret q
}

fn forge_q_left_join(q: &ForgeQuery, table: []i8, condition: []i8) -> &ForgeQuery {
    if q.join_len > 0 { forge__jbuf(q, " ") }
    forge__jbuf(q, "LEFT JOIN ")
    forge__jbuf(q, table)
    forge__jbuf(q, " ON ")
    forge__jbuf(q, condition)
    ret q
}

fn forge_q_inner_join(q: &ForgeQuery, table: []i8, condition: []i8) -> &ForgeQuery {
    if q.join_len > 0 { forge__jbuf(q, " ") }
    forge__jbuf(q, "INNER JOIN ")
    forge__jbuf(q, table)
    forge__jbuf(q, " ON ")
    forge__jbuf(q, condition)
    ret q
}

// ---------------------------------------------------------------------------
// GROUP BY / HAVING
// ---------------------------------------------------------------------------

fn forge_q_group(q: &ForgeQuery, cols: []i8) -> &ForgeQuery {
    forge__gbuf(q, cols)
    ret q
}

fn forge_q_having(q: &ForgeQuery, expr: []i8) -> &ForgeQuery {
    forge__hbuf(q, expr)
    ret q
}

// ---------------------------------------------------------------------------
// ORDER BY
// ---------------------------------------------------------------------------

fn forge_q_order(q: &ForgeQuery, col: []i8, dir: []i8) -> &ForgeQuery {
    if q.order_len > 0 { forge__obuf(q, ", ") }
    forge__obuf(q, col)
    forge__obuf(q, " ")
    forge__obuf(q, dir)
    ret q
}

fn forge_q_order_asc(q: &ForgeQuery, col: []i8) -> &ForgeQuery {
    ret forge_q_order(q, col, "ASC")
}

fn forge_q_order_desc(q: &ForgeQuery, col: []i8) -> &ForgeQuery {
    ret forge_q_order(q, col, "DESC")
}

// ---------------------------------------------------------------------------
// LIMIT / OFFSET / PAGE
// ---------------------------------------------------------------------------

fn forge_q_limit(q: &ForgeQuery, n: i64) -> &ForgeQuery {
    q.lim = n
    ret q
}

fn forge_q_offset(q: &ForgeQuery, n: i64) -> &ForgeQuery {
    q.off = n
    ret q
}

fn forge_q_page(q: &ForgeQuery, page: i64, per: i64) -> &ForgeQuery {
    if page < 1 { page = 1 }
    q.lim = per
    q.off = (page - 1) * per
    ret q
}

fn forge_q_lock(q: &ForgeQuery) -> &ForgeQuery {
    q.lock_row = true
    ret q
}

// ---------------------------------------------------------------------------
// SQL builder
// ---------------------------------------------------------------------------

fn forge_q_sql(q: &ForgeQuery, dst: &i8) -> i64 {
    let pos = 0i64

    // SELECT [DISTINCT] [cols]
    let sel_s = "SELECT "
    loop i in 0..sel_s.len { dst[pos] = sel_s[i]  pos = pos + 1 }
    if q.distinct {
        let d = "DISTINCT "
        loop i in 0..d.len { dst[pos] = d[i]  pos = pos + 1 }
    }
    if q.sel_len > 0 {
        loop i in 0..q.sel_len { dst[pos] = q.sel_buf[i]  pos = pos + 1 }
    } else {
        dst[pos] = '*'  pos = pos + 1
    }

    // FROM table
    let from_s = " FROM "
    loop i in 0..from_s.len { dst[pos] = from_s[i]  pos = pos + 1 }
    loop i in 0..q.table.len { dst[pos] = q.table[i]  pos = pos + 1 }

    // JOIN
    if q.join_len > 0 {
        dst[pos] = ' '  pos = pos + 1
        loop i in 0..q.join_len { dst[pos] = q.join_buf[i]  pos = pos + 1 }
    }

    // WHERE — include soft-delete filter unless no_soft_delete is set
    let has_sd_filter = not q.no_soft_delete and not q.only_deleted
    let has_only_del  = q.only_deleted
    if has_sd_filter or has_only_del or q.where_len > 0 {
        let wh = " WHERE "
        loop i in 0..wh.len { dst[pos] = wh[i]  pos = pos + 1 }
        if has_sd_filter {
            let sd = "deleted_at IS NULL"
            loop i in 0..sd.len { dst[pos] = sd[i]  pos = pos + 1 }
            if q.where_len > 0 {
                let and_s = " AND "
                loop i in 0..and_s.len { dst[pos] = and_s[i]  pos = pos + 1 }
            }
        } else if has_only_del {
            let od = "deleted_at IS NOT NULL"
            loop i in 0..od.len { dst[pos] = od[i]  pos = pos + 1 }
            if q.where_len > 0 {
                let and_s = " AND "
                loop i in 0..and_s.len { dst[pos] = and_s[i]  pos = pos + 1 }
            }
        }
        if q.where_len > 0 {
            loop i in 0..q.where_len { dst[pos] = q.where_buf[i]  pos = pos + 1 }
        }
    }

    // GROUP BY
    if q.group_len > 0 {
        let gb = " GROUP BY "
        loop i in 0..gb.len { dst[pos] = gb[i]  pos = pos + 1 }
        loop i in 0..q.group_len { dst[pos] = q.group_buf[i]  pos = pos + 1 }
    }

    // HAVING
    if q.having_len > 0 {
        let hv = " HAVING "
        loop i in 0..hv.len { dst[pos] = hv[i]  pos = pos + 1 }
        loop i in 0..q.having_len { dst[pos] = q.having_buf[i]  pos = pos + 1 }
    }

    // ORDER BY
    if q.order_len > 0 {
        let ob = " ORDER BY "
        loop i in 0..ob.len { dst[pos] = ob[i]  pos = pos + 1 }
        loop i in 0..q.order_len { dst[pos] = q.order_buf[i]  pos = pos + 1 }
    }

    // LIMIT
    if q.lim >= 0 {
        let ls = " LIMIT "
        loop i in 0..ls.len { dst[pos] = ls[i]  pos = pos + 1 }
        let nb: &i8 = alloc_pages(1)
        let nl = fmt_i64(nb, q.lim)
        loop i in 0..nl { dst[pos] = nb[i]  pos = pos + 1 }
    }

    // OFFSET
    if q.off >= 0 {
        let os = " OFFSET "
        loop i in 0..os.len { dst[pos] = os[i]  pos = pos + 1 }
        let nb2: &i8 = alloc_pages(1)
        let nl2 = fmt_i64(nb2, q.off)
        loop i in 0..nl2 { dst[pos] = nb2[i]  pos = pos + 1 }
    }

    // FOR UPDATE (pessimistic lock)
    if q.lock_row {
        let fu = " FOR UPDATE"
        loop i in 0..fu.len { dst[pos] = fu[i]  pos = pos + 1 }
    }

    ret pos
}

// ---------------------------------------------------------------------------
// Execution
// ---------------------------------------------------------------------------

fn forge_q_exec(q: &ForgeQuery) -> &ForgeResult {
    let sql_buf: &i8 = alloc_pages(2)
    let sql_len = forge_q_sql(q, sql_buf)
    ret forge_db_query_on(q.conn_idx, sql_buf[0..sql_len])
}

fn forge_q_all(q: &ForgeQuery) -> &ForgeResult {
    ret forge_q_exec(q)
}

fn forge_q_first(q: &ForgeQuery) -> &ForgeResult {
    q.lim = 1
    ret forge_q_exec(q)
}

fn forge_q_last(q: &ForgeQuery) -> &ForgeResult {
    if q.order_len == 0 { forge_q_order_desc(q, "id") }
    q.lim = 1
    ret forge_q_exec(q)
}

fn forge_q_count(q: &ForgeQuery) -> i64 {
    let orig_sel_len = q.sel_len
    let orig_distinct = q.distinct
    let count_s = "COUNT(*)"
    loop i in 0..count_s.len { q.sel_buf[i] = count_s[i] }
    q.sel_len  = count_s.len
    q.distinct = false
    let res = forge_q_exec(q)
    q.sel_len  = orig_sel_len
    q.distinct = orig_distinct
    if res.count == 0 { ret 0 }
    let val = forge_row_col(res, 0, 0)
    let acc = 0i64
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d >= 0 and d <= 9 { acc = acc * 10 + d }
    }
    ret acc
}

fn forge_q_exists(q: &ForgeQuery) -> bool {
    ret forge_q_count(q) > 0
}

fn forge_q_pluck(q: &ForgeQuery, col: []i8) -> &ForgeResult {
    forge_q_select(q, col)
    ret forge_q_exec(q)
}

// ---------------------------------------------------------------------------
// Aggregates
// ---------------------------------------------------------------------------

fn forge__aggregate(q: &ForgeQuery, fn_name: []i8, col: []i8) -> []i8 {
    let buf = [128]i8
    let pos = 0i64
    loop i in 0..fn_name.len { buf[pos] = fn_name[i]  pos = pos + 1 }
    buf[pos] = '('  pos = pos + 1
    loop i in 0..col.len     { buf[pos] = col[i]       pos = pos + 1 }
    buf[pos] = ')'  pos = pos + 1
    let orig_sel_len = q.sel_len
    loop i in 0..pos { q.sel_buf[i] = buf[i] }
    q.sel_len = pos
    let res = forge_q_exec(q)
    q.sel_len = orig_sel_len
    if res.count == 0 { ret "" }
    ret forge_row_col(res, 0, 0)
}

fn forge_q_sum(q: &ForgeQuery, col: []i8) -> []i8 { ret forge__aggregate(q, "SUM", col) }
fn forge_q_avg(q: &ForgeQuery, col: []i8) -> []i8 { ret forge__aggregate(q, "AVG", col) }
fn forge_q_max(q: &ForgeQuery, col: []i8) -> []i8 { ret forge__aggregate(q, "MAX", col) }
fn forge_q_min(q: &ForgeQuery, col: []i8) -> []i8 { ret forge__aggregate(q, "MIN", col) }

// ---------------------------------------------------------------------------
// DML — update_all / delete_all
// ---------------------------------------------------------------------------

fn forge_q_update_all(q: &ForgeQuery, set_clause: []i8) -> bool {
    let buf: &i8 = alloc_pages(2)
    let pos = 0i64
    let s1 = "UPDATE "
    let s2 = " SET "
    loop i in 0..s1.len { buf[pos] = s1[i]  pos = pos + 1 }
    loop i in 0..q.table.len { buf[pos] = q.table[i]  pos = pos + 1 }
    loop i in 0..s2.len { buf[pos] = s2[i]  pos = pos + 1 }
    loop i in 0..set_clause.len { buf[pos] = set_clause[i]  pos = pos + 1 }
    if q.where_len > 0 {
        let wh = " WHERE "
        loop i in 0..wh.len { buf[pos] = wh[i]  pos = pos + 1 }
        loop i in 0..q.where_len { buf[pos] = q.where_buf[i]  pos = pos + 1 }
    }
    ret forge_db_exec_on(q.conn_idx, buf[0..pos])
}

fn forge_q_delete_all(q: &ForgeQuery) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let s1 = "DELETE FROM "
    loop i in 0..s1.len { buf[pos] = s1[i]  pos = pos + 1 }
    loop i in 0..q.table.len { buf[pos] = q.table[i]  pos = pos + 1 }
    if q.where_len > 0 {
        let wh = " WHERE "
        loop i in 0..wh.len { buf[pos] = wh[i]  pos = pos + 1 }
        loop i in 0..q.where_len { buf[pos] = q.where_buf[i]  pos = pos + 1 }
    }
    ret forge_db_exec_on(q.conn_idx, buf[0..pos])
}

// ---------------------------------------------------------------------------
// Convenience finders
// ---------------------------------------------------------------------------

fn forge_find(table: []i8, id: []i8) -> &ForgeResult {
    let q = forge_q(table)
    forge_q_where(q, "id", "=", id)
    ret forge_q_first(q)
}

fn forge_find_by(table: []i8, col: []i8, val: []i8) -> &ForgeResult {
    let q = forge_q(table)
    forge_q_where(q, col, "=", val)
    ret forge_q_first(q)
}

fn forge_all(table: []i8) -> &ForgeResult {
    let q = forge_q(table)
    ret forge_q_exec(q)
}

fn forge_find_in_batches(table: []i8, batch_size: i64, fn_ptr: i64) {
    let off = 0i64
    loop {
        let q = forge_q(table)
        forge_q_limit(q, batch_size)
        forge_q_offset(q, off)
        forge_q_order_asc(q, "id")
        let res = forge_q_exec(q)
        if res.count == 0 { break }
        call_fn(fn_ptr, res as i64)
        off = off + batch_size
        if res.count < batch_size { break }
    }
}

// forge_q_find_each — call fn_ptr(ctx: i64, row: &ForgeResult) for each row.
// fn_ptr signature: fn(i64) where arg is a single-row ForgeResult cast to i64.
fn forge_q_find_each(q: &ForgeQuery, fn_ptr: i64) {
    q.lim = 1
    q.off = 0
    loop {
        let res = forge_q_exec(q)
        if res.count == 0 { break }
        call_fn(fn_ptr, res as i64)
        q.off = q.off + 1
    }
}

// ---------------------------------------------------------------------------
// Soft-delete query helpers
// ---------------------------------------------------------------------------

// forge_q_with_deleted — include soft-deleted rows (skip deleted_at IS NULL filter).
fn forge_q_with_deleted(q: &ForgeQuery) -> &ForgeQuery {
    q.no_soft_delete = true
    q.only_deleted   = false
    ret q
}

// forge_q_only_deleted — query only soft-deleted rows.
fn forge_q_only_deleted(q: &ForgeQuery) -> &ForgeQuery {
    q.only_deleted   = true
    q.no_soft_delete = true
    ret q
}

// forge_q_where_not_deleted — explicitly add deleted_at IS NULL (useful when
// chaining without relying on the default filter).
fn forge_q_where_not_deleted(q: &ForgeQuery) -> &ForgeQuery {
    q.no_soft_delete = false
    q.only_deleted   = false
    ret q
}

// forge_q_unscope — remove soft-delete filter and ORDER BY.
fn forge_q_unscope(q: &ForgeQuery) -> &ForgeQuery {
    q.no_soft_delete = true
    q.only_deleted   = false
    q.order_len      = 0
    ret q
}

// ---------------------------------------------------------------------------
// Additional query helpers
// ---------------------------------------------------------------------------

// forge_q_pick — return the value of a single column from the first matching row.
fn forge_q_pick(q: &ForgeQuery, col: []i8) -> []i8 {
    forge_q_select(q, col)
    q.lim = 1
    let res = forge_q_exec(q)
    if res.count == 0 { ret "" }
    ret forge_row_col(res, 0, 0)
}

// forge_q_reorder — clear existing ORDER BY and apply a new one.
fn forge_q_reorder(q: &ForgeQuery, col: []i8, dir: []i8) -> &ForgeQuery {
    q.order_len = 0
    let buf: &i8 = q.order_buf as &i8
    let pos = 0i64
    loop i in 0..col.len { buf[pos] = col[i]  pos = pos + 1 }
    buf[pos] = ' '  pos = pos + 1
    loop i in 0..dir.len { buf[pos] = dir[i]  pos = pos + 1 }
    q.order_len = pos
    ret q
}

// forge_q_reverse_order — flip ASC to DESC and vice-versa in the current order.
fn forge_q_reverse_order(q: &ForgeQuery) -> &ForgeQuery {
    if q.order_len == 0 {
        let s = "id DESC"
        loop i in 0..s.len { q.order_buf[i] = s[i] }
        q.order_len = s.len
        ret q
    }
    let asc_s  = " ASC"
    let desc_s = " DESC"
    // Simple heuristic: if order_buf ends with " ASC" swap to DESC, else swap to ASC.
    let ends_asc = false
    if q.order_len >= 4 {
        let tail = q.order_buf[(q.order_len - 4)..q.order_len]
        ends_asc = forge_slice_eq(tail, asc_s)
    }
    if ends_asc {
        q.order_len = q.order_len - 4
        loop i in 0..desc_s.len { q.order_buf[q.order_len] = desc_s[i]  q.order_len = q.order_len + 1 }
    } else {
        // Remove trailing " DESC" if present; otherwise just append " DESC"
        if q.order_len >= 5 {
            let tail5 = q.order_buf[(q.order_len - 5)..q.order_len]
            if forge_slice_eq(tail5, desc_s) {
                q.order_len = q.order_len - 5
            }
        }
        loop i in 0..asc_s.len { q.order_buf[q.order_len] = asc_s[i]  q.order_len = q.order_len + 1 }
    }
    ret q
}

// forge_find_or_init_by — return ForgeAttrs pre-seeded with col=val.
// Caller checks forge_attrs_is_new(a) to decide between insert and update.
// The attrs object is always fresh; for existing rows, "id" is also set.
fn forge_find_or_init_by(table: []i8, col: []i8, val: []i8) -> &ForgeAttrs {
    let q = forge_q(table)
    forge_q_where_eq(q, col, val)
    let res = forge_q_first(q)
    let a   = forge_attrs_new()
    if res.count > 0 {
        let id_val = forge_result_col(res, 0, "id")
        forge_attrs_set(a, "id", id_val)
        forge_attrs_set(a, col, val)
        a.empty = false
        ret a
    }
    forge_attrs_set(a, col, val)
    ret a
}

// forge_insert_all — bulk INSERT from a slice of pre-built value tuples.
// rows_csv: comma-separated tuples already SQL-escaped, e.g. "('a','b'),('c','d')"
// col_names_csv: column list, e.g. "title, body, author"
fn forge_insert_all(table: []i8, col_names_csv: []i8, rows_csv: []i8) -> bool {
    let buf: &i8 = alloc_pages(8)
    let pos = 0i64
    let p1 = "INSERT INTO "; let p2 = " ("; let p3 = ") VALUES "
    loop i in 0..p1.len           { buf[pos] = p1[i]           pos = pos + 1 }
    loop i in 0..table.len        { buf[pos] = table[i]         pos = pos + 1 }
    loop i in 0..p2.len           { buf[pos] = p2[i]           pos = pos + 1 }
    loop i in 0..col_names_csv.len { buf[pos] = col_names_csv[i] pos = pos + 1 }
    loop i in 0..p3.len           { buf[pos] = p3[i]           pos = pos + 1 }
    loop i in 0..rows_csv.len     { buf[pos] = rows_csv[i]     pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

// ---------------------------------------------------------------------------
// Scopes
// ---------------------------------------------------------------------------

fn forge_scope_init() {
    if g_forge_scope_store != 0 { ret }
    g_forge_scope_store = alloc_pages(8) as &ForgeScopeEntry
    g_forge_scope_count = 0
}

fn forge_scope_register(table: []i8, name: []i8, fn_ptr: i64) {
    forge_scope_init()
    if g_forge_scope_count >= FORGE_SCOPE_MAX { ret }
    let idx = g_forge_scope_count
    let stride = 152i64
    let entry: &ForgeScopeEntry = (g_forge_scope_store as i64 + idx * stride) as &ForgeScopeEntry
    let tl = table.len
    if tl > 63 { tl = 63 }
    loop i in 0..tl { entry.table_buf[i] = table[i] }
    entry.tlen = tl
    let nl = name.len
    if nl > 63 { nl = 63 }
    loop i in 0..nl { entry.name_buf[i] = name[i] }
    entry.nlen = nl
    entry.fn_ptr = fn_ptr
    g_forge_scope_count = g_forge_scope_count + 1
}

fn forge_q_scope(q: &ForgeQuery, name: []i8) -> &ForgeQuery {
    forge_scope_init()
    let stride = 152i64
    loop i in 0..g_forge_scope_count {
        let entry: &ForgeScopeEntry = (g_forge_scope_store as i64 + i * stride) as &ForgeScopeEntry
        let tlen = q.table.len
        if tlen > 63 { tlen = 63 }
        let tmatch = true
        if tlen != entry.tlen { tmatch = false }
        if tmatch {
            loop j in 0..tlen {
                if q.table[j] != entry.table_buf[j] { tmatch = false }
            }
        }
        let nlen = name.len
        let nmatch = true
        if nlen != entry.nlen { nmatch = false }
        if nmatch {
            loop j in 0..nlen {
                if name[j] != entry.name_buf[j] { nmatch = false }
            }
        }
        if tmatch and nmatch {
            call_fn(entry.fn_ptr, q as i64)
            ret q
        }
    }
    ret q
}

// ---------------------------------------------------------------------------
// Raw SQL aliases
// ---------------------------------------------------------------------------

fn forge_sql(raw_sql: []i8) -> &ForgeResult {
    ret forge_db_query(raw_sql)
}

fn forge_exec_sql(raw_sql: []i8) -> bool {
    ret forge_db_exec(raw_sql)
}

// =============================================================================
// Section B — Validations
// =============================================================================
const FORGE_MAX_ERRORS = 16

struct ForgeValidationError { field: []i8  msg: []i8 }
struct ForgeErrors { errs: [FORGE_MAX_ERRORS]ForgeValidationError  count: i64 }

fn forge_errors_new() -> &ForgeErrors {
    let e: &ForgeErrors = alloc_pages(1)
    e.count = 0
    ret e
}

fn forge_errors_add(e: &ForgeErrors, field: []i8, msg: []i8) {
    if e.count >= FORGE_MAX_ERRORS { ret }
    let i = e.count
    e.errs[i].field = field
    e.errs[i].msg   = msg
    e.count = i + 1
}

fn forge_errors_any(e: &ForgeErrors) -> bool {
    ret e.count > 0
}

fn forge_errors_json(e: &ForgeErrors) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "{\"errors\":{"
    loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
    loop i in 0..e.count {
        if i > 0 { buf[pos] = ','  pos = pos + 1 }
        buf[pos] = '"'  pos = pos + 1
        loop j in 0..e.errs[i].field.len { buf[pos] = e.errs[i].field[j]  pos = pos + 1 }
        buf[pos] = '"'  pos = pos + 1
        buf[pos] = ':'  pos = pos + 1
        buf[pos] = '"'  pos = pos + 1
        loop j in 0..e.errs[i].msg.len { buf[pos] = e.errs[i].msg[j]  pos = pos + 1 }
        buf[pos] = '"'  pos = pos + 1
    }
    let p2 = "}}"
    loop i in 0..p2.len { buf[pos] = p2[i]  pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_errors_count(e: &ForgeErrors) -> i64 { ret e.count }

fn forge_errors_full_messages(e: &ForgeErrors) -> []i8 {
    let buf: &i8 = alloc_pages(4)
    let pos = 0i64
    loop i in 0..e.count {
        if i > 0 { buf[pos] = ','  pos = pos + 1  buf[pos] = ' '  pos = pos + 1 }
        let field = e.errs[i].field
        if field.len > 0 {
            let fc = field[0]
            if fc >= 97 and fc <= 122 { buf[pos] = fc - 32 } else { buf[pos] = fc }
            pos = pos + 1
            loop j in 1..field.len { buf[pos] = field[j]  pos = pos + 1 }
            buf[pos] = ' '  pos = pos + 1
        }
        loop j in 0..e.errs[i].msg.len { buf[pos] = e.errs[i].msg[j]  pos = pos + 1 }
    }
    ret buf[0..pos]
}

fn forge_errors_full_messages_json(e: &ForgeErrors) -> []i8 {
    let buf: &i8 = alloc_pages(4)
    let pos = 0i64
    buf[pos] = '['  pos = pos + 1
    loop i in 0..e.count {
        if i > 0 { buf[pos] = ','  pos = pos + 1  buf[pos] = ' '  pos = pos + 1 }
        buf[pos] = '"'  pos = pos + 1
        let field = e.errs[i].field
        if field.len > 0 {
            let fc = field[0]
            if fc >= 97 and fc <= 122 { buf[pos] = fc - 32 } else { buf[pos] = fc }
            pos = pos + 1
            loop j in 1..field.len { buf[pos] = field[j]  pos = pos + 1 }
            buf[pos] = ' '  pos = pos + 1
        }
        loop j in 0..e.errs[i].msg.len { buf[pos] = e.errs[i].msg[j]  pos = pos + 1 }
        buf[pos] = '"'  pos = pos + 1
    }
    buf[pos] = ']'  pos = pos + 1
    ret buf[0..pos]
}

fn forge_validate_presence(e: &ForgeErrors, field: []i8, val: []i8) -> bool {
    if val.len == 0 {
        forge_errors_add(e, field, "can't be blank")
        ret false
    }
    ret true
}

fn forge_validate_length(e: &ForgeErrors, field: []i8, val: []i8, min: i64, max: i64) -> bool {
    if val.len < min or val.len > max {
        let mb: &i8 = alloc_pages(1)
        let mp = 0i64
        let p1 = "length must be between "
        let p2 = " and "
        loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
        let n1 = fmt_i64(mb + mp, min)  mp = mp + n1
        loop i in 0..p2.len { mb[mp] = p2[i]  mp = mp + 1 }
        let n2 = fmt_i64(mb + mp, max)  mp = mp + n2
        forge_errors_add(e, field, mb[0..mp])
        ret false
    }
    ret true
}

fn forge_validate_min_length(e: &ForgeErrors, field: []i8, val: []i8, min: i64) -> bool {
    if val.len < min {
        let mb: &i8 = alloc_pages(1)
        let mp = 0i64
        let p1 = "is too short (minimum is "
        let p2 = " characters)"
        loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
        let n1 = fmt_i64(mb + mp, min)  mp = mp + n1
        loop i in 0..p2.len { mb[mp] = p2[i]  mp = mp + 1 }
        forge_errors_add(e, field, mb[0..mp])
        ret false
    }
    ret true
}

fn forge_validate_max_length(e: &ForgeErrors, field: []i8, val: []i8, max: i64) -> bool {
    if val.len > max {
        let mb: &i8 = alloc_pages(1)
        let mp = 0i64
        let p1 = "is too long (maximum is "
        let p2 = " characters)"
        loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
        let n1 = fmt_i64(mb + mp, max)  mp = mp + n1
        loop i in 0..p2.len { mb[mp] = p2[i]  mp = mp + 1 }
        forge_errors_add(e, field, mb[0..mp])
        ret false
    }
    ret true
}

fn forge_validate_format_email(e: &ForgeErrors, field: []i8, val: []i8) -> bool {
    let has_at  = false
    let has_dot = false
    loop i in 0..val.len {
        if val[i] == '@' { has_at  = true }
        if val[i] == '.' { has_dot = true }
    }
    if not has_at or not has_dot {
        forge_errors_add(e, field, "is not a valid email address")
        ret false
    }
    ret true
}

fn forge_validate_numericality(e: &ForgeErrors, field: []i8, val: []i8) -> bool {
    if val.len == 0 {
        forge_errors_add(e, field, "is not a number")
        ret false
    }
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d < 0 or d > 9 {
            forge_errors_add(e, field, "is not a number")
            ret false
        }
    }
    ret true
}

fn forge_validate_confirmation(e: &ForgeErrors, field: []i8, val: []i8, confirm: []i8) -> bool {
    if not forge_slice_eq(val, confirm) {
        forge_errors_add(e, field, "doesn't match confirmation")
        ret false
    }
    ret true
}

fn forge_validate_inclusion(e: &ForgeErrors, field: []i8, val: []i8, allowed: []i8) -> bool {
    let start = 0i64
    loop i in 0..allowed.len {
        if allowed[i] == ',' {
            let seg = allowed[start..i]
            if forge_slice_eq(seg, val) { ret true }
            start = i + 1
        }
    }
    let seg = allowed[start..allowed.len]
    if forge_slice_eq(seg, val) { ret true }
    forge_errors_add(e, field, "is not included in the list")
    ret false
}

fn forge_validate_absence(e: &ForgeErrors, field: []i8, val: []i8) -> bool {
    if val.len == 0 { ret true }
    forge_errors_add(e, field, "must be blank")
    ret false
}

fn forge_validate_exclusion(e: &ForgeErrors, field: []i8, val: []i8, forbidden: []i8) -> bool {
    let start = 0i64
    loop i in 0..forbidden.len {
        if forbidden[i] == ',' {
            if forge_slice_eq(forbidden[start..i], val) {
                forge_errors_add(e, field, "is reserved")
                ret false
            }
            start = i + 1
        }
    }
    if forge_slice_eq(forbidden[start..forbidden.len], val) {
        forge_errors_add(e, field, "is reserved")
        ret false
    }
    ret true
}

fn forge_validate_acceptance(e: &ForgeErrors, field: []i8, val: []i8) -> bool {
    if forge_slice_eq(val, "1") or forge_slice_eq(val, "true") { ret true }
    forge_errors_add(e, field, "must be accepted")
    ret false
}

fn forge_validate_url(e: &ForgeErrors, field: []i8, val: []i8) -> bool {
    let http  = "http://"
    let https = "https://"
    let valid = false
    if val.len >= http.len {
        let ok = true
        loop i in 0..http.len { if val[i] != http[i] { ok = false } }
        if ok { valid = true }
    }
    if val.len >= https.len {
        let ok = true
        loop i in 0..https.len { if val[i] != https[i] { ok = false } }
        if ok { valid = true }
    }
    if not valid { forge_errors_add(e, field, "is not a valid URL")  ret false }
    let has_dot = false
    loop i in 0..val.len { if val[i] == '.' { has_dot = true } }
    if not has_dot { forge_errors_add(e, field, "is not a valid URL")  ret false }
    ret true
}

fn forge_validate_exact_length(e: &ForgeErrors, field: []i8, val: []i8, n: i64) -> bool {
    if val.len == n { ret true }
    let mb: &i8 = alloc_pages(1)
    let mp = 0i64
    let p1 = "must be exactly "
    let p2 = " characters"
    loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
    let nn = fmt_i64(mb + mp, n)  mp = mp + nn
    loop i in 0..p2.len { mb[mp] = p2[i]  mp = mp + 1 }
    forge_errors_add(e, field, mb[0..mp])
    ret false
}

fn forge_validate_gt(e: &ForgeErrors, field: []i8, val: []i8, n: i64) -> bool {
    if val.len == 0 { forge_errors_add(e, field, "is not a number")  ret false }
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d < 0 or d > 9 { forge_errors_add(e, field, "is not a number")  ret false }
    }
    if str_to_i64(val) > n { ret true }
    let mb: &i8 = alloc_pages(1)  let mp = 0i64
    let p1 = "must be greater than "
    loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
    let nn = fmt_i64(mb + mp, n)  mp = mp + nn
    forge_errors_add(e, field, mb[0..mp])
    ret false
}

fn forge_validate_gte(e: &ForgeErrors, field: []i8, val: []i8, n: i64) -> bool {
    if val.len == 0 { forge_errors_add(e, field, "is not a number")  ret false }
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d < 0 or d > 9 { forge_errors_add(e, field, "is not a number")  ret false }
    }
    if str_to_i64(val) >= n { ret true }
    let mb: &i8 = alloc_pages(1)  let mp = 0i64
    let p1 = "must be greater than or equal to "
    loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
    let nn = fmt_i64(mb + mp, n)  mp = mp + nn
    forge_errors_add(e, field, mb[0..mp])
    ret false
}

fn forge_validate_lt(e: &ForgeErrors, field: []i8, val: []i8, n: i64) -> bool {
    if val.len == 0 { forge_errors_add(e, field, "is not a number")  ret false }
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d < 0 or d > 9 { forge_errors_add(e, field, "is not a number")  ret false }
    }
    if str_to_i64(val) < n { ret true }
    let mb: &i8 = alloc_pages(1)  let mp = 0i64
    let p1 = "must be less than "
    loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
    let nn = fmt_i64(mb + mp, n)  mp = mp + nn
    forge_errors_add(e, field, mb[0..mp])
    ret false
}

fn forge_validate_lte(e: &ForgeErrors, field: []i8, val: []i8, n: i64) -> bool {
    if val.len == 0 { forge_errors_add(e, field, "is not a number")  ret false }
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d < 0 or d > 9 { forge_errors_add(e, field, "is not a number")  ret false }
    }
    if str_to_i64(val) <= n { ret true }
    let mb: &i8 = alloc_pages(1)  let mp = 0i64
    let p1 = "must be less than or equal to "
    loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
    let nn = fmt_i64(mb + mp, n)  mp = mp + nn
    forge_errors_add(e, field, mb[0..mp])
    ret false
}

fn forge_validate_equal_to(e: &ForgeErrors, field: []i8, val: []i8, n: i64) -> bool {
    if val.len == 0 { forge_errors_add(e, field, "is not a number")  ret false }
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d < 0 or d > 9 { forge_errors_add(e, field, "is not a number")  ret false }
    }
    if str_to_i64(val) == n { ret true }
    let mb: &i8 = alloc_pages(1)  let mp = 0i64
    let p1 = "must be equal to "
    loop i in 0..p1.len { mb[mp] = p1[i]  mp = mp + 1 }
    let nn = fmt_i64(mb + mp, n)  mp = mp + nn
    forge_errors_add(e, field, mb[0..mp])
    ret false
}

// Manual-only — declarative uniqueness requires an id that the attrs layer does not carry.
// Call directly from a controller or a FORGE_CB_BEFORE_SAVE callback.
fn forge_validate_uniqueness(e: &ForgeErrors, table: []i8, field: []i8, val: []i8, exclude_id: []i8) -> bool {
    let q = forge_q(table)
    forge_q_where(q, field, "=", val)
    if exclude_id.len > 0 { forge_q_where(q, "id", "!=", exclude_id) }
    let res = forge_q_exec(q)
    if res.count > 0 {
        forge_errors_add(e, field, "has already been taken")
        ret false
    }
    ret true
}

// =============================================================================
// Section B3 — Declarative Validations (Rails-style)
// =============================================================================
const FORGE_V_PRESENCE      = 1
const FORGE_V_EMAIL         = 2
const FORGE_V_MIN_LEN       = 3
const FORGE_V_MAX_LEN       = 4
const FORGE_V_NUMERICALITY  = 5
const FORGE_V_INCLUSION     = 6
const FORGE_V_ABSENCE       = 7
const FORGE_V_EXCLUSION     = 8
const FORGE_V_ACCEPTANCE    = 9
const FORGE_V_URL           = 10
const FORGE_V_GT            = 11
const FORGE_V_GTE           = 12
const FORGE_V_LT            = 13
const FORGE_V_LTE           = 14
const FORGE_V_EXACT_LEN     = 15
const FORGE_V_CONFIRMATION  = 16
const FORGE_V_EQUAL_TO      = 17

const FORGE_V_MAX_RULES    = 128
const FORGE_V_TABLE_CAP    = 32
const FORGE_V_FIELD_CAP    = 48
const FORGE_V_PARAM_CAP    = 64

struct ForgeVRule {
    table:      [FORGE_V_TABLE_CAP]i8   tlen:       i64
    field:      [FORGE_V_FIELD_CAP]i8   flen:       i64
    rule:       i64
    param:      [FORGE_V_PARAM_CAP]i8   plen:       i64
    on_context: i64   // 0=any  1=create only  2=update only
    used:       bool
}
const FORGE_V_RULE_STRIDE = 186   // 32+8+48+8+8+64+8+8+2(bool+pad)

let g_forge_v_store:      &i8          = 0
let g_forge_v_count:      i64          = 0
let g_forge_last_errors:  &ForgeErrors = 0
let g_forge_save_context: []i8         = ""   // "create" or "update"

fn forge_v_init() {
    if g_forge_v_store != 0 { ret }
    g_forge_v_store = alloc_pages(6)   // 128 × 186 = 23808 < 24576
}

fn forge_last_errors() -> &ForgeErrors {
    ret g_forge_last_errors
}

// --- per-request field scratchpad (written by forge_attrs_set) ---
const FORGE_FA_MAX  = 24
const FORGE_FA_NCAP = 48
const FORGE_FA_VCAP = 512

let g_fa_names: &i8  = 0   // FORGE_FA_MAX × FORGE_FA_NCAP
let g_fa_vals:  &i8  = 0   // FORGE_FA_MAX × FORGE_FA_VCAP
let g_fa_meta:  &i8  = 0   // FORGE_FA_MAX × 16: nlen(i64) + vlen(i64)
let g_fa_count: i64  = 0
let g_fa_ready: bool = false

fn forge_fa_init() {
    if g_fa_ready { ret }
    g_fa_names = alloc_pages(1)   // 24 × 48  = 1152 < 4096
    g_fa_vals  = alloc_pages(3)   // 24 × 512 = 12288
    g_fa_meta  = alloc_pages(1)   // 24 × 16  = 384  < 4096
    g_fa_ready = true
}

fn forge_fa_reset() {
    forge_fa_init()
    g_fa_count = 0
}

fn forge_fa_store(field: []i8, val: []i8) {
    forge_fa_init()
    if g_fa_count >= FORGE_FA_MAX { ret }
    let i  = g_fa_count
    let no = i * FORGE_FA_NCAP
    let vo = i * FORGE_FA_VCAP
    let nl = field.len
    if nl > FORGE_FA_NCAP { nl = FORGE_FA_NCAP }
    let vl = val.len
    if vl > FORGE_FA_VCAP { vl = FORGE_FA_VCAP }
    loop j in 0..nl { g_fa_names[no + j] = field[j] }
    loop j in 0..vl { g_fa_vals[vo + j]  = val[j]   }
    ((g_fa_meta as i64 + i * 16)     as &i64)[0] = nl
    ((g_fa_meta as i64 + i * 16 + 8) as &i64)[0] = vl
    g_fa_count = i + 1
}

fn forge_fa_get(field: []i8) -> []i8 {
    forge_fa_init()
    loop i in 0..g_fa_count {
        let no = i * FORGE_FA_NCAP
        let nl = ((g_fa_meta as i64 + i * 16) as &i64)[0]
        if forge_slice_eq(field, g_fa_names[no..(no + nl)]) {
            let vo = i * FORGE_FA_VCAP
            let vl = ((g_fa_meta as i64 + i * 16 + 8) as &i64)[0]
            ret g_fa_vals[vo..(vo + vl)]
        }
    }
    ret ""
}

// --- registration ---

fn forge_validates(table: []i8, field: []i8, rule: i64) {
    forge_v_init()
    if g_forge_v_count >= FORGE_V_MAX_RULES { ret }
    let r: &ForgeVRule = (g_forge_v_store as i64 + g_forge_v_count * FORGE_V_RULE_STRIDE) as &ForgeVRule
    let tl = table.len
    if tl > FORGE_V_TABLE_CAP { tl = FORGE_V_TABLE_CAP }
    loop i in 0..tl { r.table[i] = table[i] }
    r.tlen = tl
    let fl = field.len
    if fl > FORGE_V_FIELD_CAP { fl = FORGE_V_FIELD_CAP }
    loop i in 0..fl { r.field[i] = field[i] }
    r.flen = fl
    r.rule = rule
    r.plen = 0
    r.used = true
    g_forge_v_count = g_forge_v_count + 1
}

fn forge_validates_param(table: []i8, field: []i8, rule: i64, param: []i8) {
    forge_validates(table, field, rule)
    let r: &ForgeVRule = (g_forge_v_store as i64 + (g_forge_v_count - 1) * FORGE_V_RULE_STRIDE) as &ForgeVRule
    let pl = param.len
    if pl > FORGE_V_PARAM_CAP { pl = FORGE_V_PARAM_CAP }
    loop i in 0..pl { r.param[i] = param[i] }
    r.plen = pl
}

fn forge_validates_length(table: []i8, field: []i8, min: i64, max: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, min)
    forge_validates_param(table, field, FORGE_V_MIN_LEN, pb[0..pn])
    pn = fmt_i64(pb, max)
    forge_validates_param(table, field, FORGE_V_MAX_LEN, pb[0..pn])
}

fn forge_validates_min_len(table: []i8, field: []i8, min: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, min)
    forge_validates_param(table, field, FORGE_V_MIN_LEN, pb[0..pn])
}

// Register the same rule for multiple comma-separated fields at once.
// forge_validates_fields("posts", "title, body, author", FORGE_V_PRESENCE)
fn forge_validates_fields(table: []i8, fields: []i8, rule: i64) {
    let start = 0i64
    loop i in 0..fields.len {
        if fields[i] == ',' {
            let a = start
            let b = i
            loop k in 0..FORGE_FA_NCAP { if a < b and fields[a] == ' ' { a = a + 1 } }
            loop k in 0..FORGE_FA_NCAP { if b > a and fields[b - 1] == ' ' { b = b - 1 } }
            if b > a { forge_validates(table, fields[a..b], rule) }
            start = i + 1
        }
    }
    let a = start
    let b = fields.len
    loop k in 0..FORGE_FA_NCAP { if a < b and fields[a] == ' ' { a = a + 1 } }
    loop k in 0..FORGE_FA_NCAP { if b > a and fields[b - 1] == ' ' { b = b - 1 } }
    if b > a { forge_validates(table, fields[a..b], rule) }
}

// --- model context (set once per init function, removes table repetition) ---

let g_forge_model_buf: &i8 = 0
let g_forge_model_len: i64  = 0

fn forge_model_ctx_init() {
    if g_forge_model_buf != 0 { ret }
    g_forge_model_buf = alloc_pages(1)
}

fn forge_model(table: []i8) {
    forge_model_ctx_init()
    let tl = table.len
    if tl > 64 { tl = 64 }
    loop i in 0..tl { g_forge_model_buf[i] = table[i] }
    g_forge_model_len = tl
}

// Bind this model's table to a named connection so all generated helpers
// (model_all, model_q, model_find, etc.) query that connection by default.
// Call once inside the model's validations init, after forge_model().
fn forge_model_db(conn_name: []i8) {
    forge_model_db_registry_init()
    let tl  = g_forge_model_len
    let idx = g_forge_model_db_count
    if idx >= FORGE_MODEL_DB_MAX { ret }
    let base = idx * 64
    loop i in 0..tl { g_forge_model_db_tables[base + i] = g_forge_model_buf[i] }
    g_forge_model_db_table_lens[idx] = tl
    g_forge_model_db_conn_idxs[idx]  = forge_db_conn_idx(conn_name)
    g_forge_model_db_count = idx + 1
}

// Declare this model file as a STI subtype of parent_table.
// Sets the model context to parent_table so that forge_field, forge_callback,
// and forge_counter_cache calls in the same *_model_init function register
// against the shared table rather than a separate one.
// type_col and type_val are used only by compile-models for code generation.
fn forge_sti_subtype(parent_table: []i8, type_col: []i8, type_val: []i8) {
    forge_model(parent_table)
}

// Insert attrs into parent_table after stamping the STI type discriminator.
// Called by the generated <subtype>_create_from helpers.
fn forge_sti_create_from(attrs: &ForgeAttrs, parent_table: []i8, type_col: []i8, type_val: []i8) -> bool {
    forge_attrs_set(attrs, type_col, type_val)
    ret forge_attrs_insert(attrs, parent_table)
}

fn forge_field(fields: []i8, rule: i64) {
    forge_validates_fields(g_forge_model_buf[0..g_forge_model_len], fields, rule)
}

fn forge_field_param(field: []i8, rule: i64, param: []i8) {
    forge_validates_param(g_forge_model_buf[0..g_forge_model_len], field, rule, param)
}

fn forge_field_length(field: []i8, min: i64, max: i64) {
    forge_validates_length(g_forge_model_buf[0..g_forge_model_len], field, min, max)
}

fn forge_field_min(field: []i8, min: i64) {
    forge_validates_min_len(g_forge_model_buf[0..g_forge_model_len], field, min)
}

fn forge_field_absence(fields: []i8) {
    forge_validates_fields(g_forge_model_buf[0..g_forge_model_len], fields, FORGE_V_ABSENCE)
}

fn forge_field_url(fields: []i8) {
    forge_validates_fields(g_forge_model_buf[0..g_forge_model_len], fields, FORGE_V_URL)
}

fn forge_field_acceptance(fields: []i8) {
    forge_validates_fields(g_forge_model_buf[0..g_forge_model_len], fields, FORGE_V_ACCEPTANCE)
}

fn forge_field_exact(field: []i8, n: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, n)
    forge_field_param(field, FORGE_V_EXACT_LEN, pb[0..pn])
}

fn forge_field_gt(field: []i8, n: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, n)
    forge_field_param(field, FORGE_V_GT, pb[0..pn])
}

fn forge_field_gte(field: []i8, n: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, n)
    forge_field_param(field, FORGE_V_GTE, pb[0..pn])
}

fn forge_field_lt(field: []i8, n: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, n)
    forge_field_param(field, FORGE_V_LT, pb[0..pn])
}

fn forge_field_lte(field: []i8, n: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, n)
    forge_field_param(field, FORGE_V_LTE, pb[0..pn])
}

fn forge_field_equal_to(field: []i8, n: i64) {
    let pb: &i8 = alloc_pages(1)
    let pn = fmt_i64(pb, n)
    forge_field_param(field, FORGE_V_EQUAL_TO, pb[0..pn])
}

fn forge_field_confirm(field: []i8, confirm_field: []i8) {
    forge_field_param(field, FORGE_V_CONFIRMATION, confirm_field)
}

// forge_field_on_create / forge_field_on_update — validate a field only on
// create or only on update.  Call after the rule-registering helper.
//   forge_field("email", FORGE_V_PRESENCE)
//   forge_field_on_create("email")  // mark the just-registered rule
fn forge_field_on_create(field: []i8) {
    forge_v_init()
    let table = g_forge_model_buf[0..g_forge_model_len]
    loop i in 0..g_forge_v_count {
        let r: &ForgeVRule = (g_forge_v_store as i64 + i * FORGE_V_RULE_STRIDE) as &ForgeVRule
        if not r.used { continue }
        if not forge_slice_eq(r.table[0..r.tlen], table) { continue }
        if forge_slice_eq(r.field[0..r.flen], field) { r.on_context = 1 }
    }
}

fn forge_field_on_update(field: []i8) {
    forge_v_init()
    let table = g_forge_model_buf[0..g_forge_model_len]
    loop i in 0..g_forge_v_count {
        let r: &ForgeVRule = (g_forge_v_store as i64 + i * FORGE_V_RULE_STRIDE) as &ForgeVRule
        if not r.used { continue }
        if not forge_slice_eq(r.table[0..r.tlen], table) { continue }
        if forge_slice_eq(r.field[0..r.flen], field) { r.on_context = 2 }
    }
}

// --- execution (called automatically from forge_attrs_insert / forge_attrs_update) ---

fn forge_attrs_validate(table: []i8) -> bool {
    forge_v_init()
    forge_callback_run(table, FORGE_CB_BEFORE_VALIDATION, 0)
    let e = forge_errors_new()
    let is_create = forge_slice_eq(g_forge_save_context, "create")
    let is_update = forge_slice_eq(g_forge_save_context, "update")
    loop i in 0..g_forge_v_count {
        let r: &ForgeVRule = (g_forge_v_store as i64 + i * FORGE_V_RULE_STRIDE) as &ForgeVRule
        if not r.used { continue }
        if not forge_slice_eq(r.table[0..r.tlen], table) { continue }
        // Skip rule if context doesn't match on_context setting
        if r.on_context == 1 and not is_create { continue }
        if r.on_context == 2 and not is_update { continue }
        let field = r.field[0..r.flen]
        let val   = forge_fa_get(field)
        let param = r.param[0..r.plen]
        if r.rule == FORGE_V_PRESENCE     { forge_validate_presence(e, field, val) }
        if r.rule == FORGE_V_ABSENCE      { forge_validate_absence(e, field, val) }
        if r.rule == FORGE_V_EMAIL        { forge_validate_format_email(e, field, val) }
        if r.rule == FORGE_V_URL          { forge_validate_url(e, field, val) }
        if r.rule == FORGE_V_NUMERICALITY { forge_validate_numericality(e, field, val) }
        if r.rule == FORGE_V_ACCEPTANCE   { forge_validate_acceptance(e, field, val) }
        if r.rule == FORGE_V_INCLUSION    { forge_validate_inclusion(e, field, val, param) }
        if r.rule == FORGE_V_EXCLUSION    { forge_validate_exclusion(e, field, val, param) }
        if r.rule == FORGE_V_MIN_LEN      { forge_validate_min_length(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_MAX_LEN      { forge_validate_max_length(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_EXACT_LEN    { forge_validate_exact_length(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_GT           { forge_validate_gt(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_GTE          { forge_validate_gte(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_LT           { forge_validate_lt(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_LTE          { forge_validate_lte(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_EQUAL_TO     { forge_validate_equal_to(e, field, val, str_to_i64(param)) }
        if r.rule == FORGE_V_CONFIRMATION { forge_validate_confirmation(e, field, val, forge_fa_get(param)) }
    }
    g_forge_last_errors = e
    forge_callback_run(table, FORGE_CB_AFTER_VALIDATION, 0)
    ret not forge_errors_any(e)
}

// =============================================================================
// Section C — Model Callbacks
// =============================================================================
const FORGE_CB_BEFORE_SAVE   = 1
const FORGE_CB_AFTER_SAVE    = 2
const FORGE_CB_BEFORE_CREATE = 3
const FORGE_CB_AFTER_CREATE  = 4
const FORGE_CB_BEFORE_UPDATE = 5
const FORGE_CB_AFTER_UPDATE  = 6
const FORGE_CB_BEFORE_DELETE  = 7
const FORGE_CB_AFTER_DELETE   = 8
const FORGE_CB_AFTER_COMMIT       = 9
const FORGE_CB_AFTER_ROLLBACK     = 10
const FORGE_CB_BEFORE_VALIDATION  = 11
const FORGE_CB_AFTER_VALIDATION   = 12

const FORGE_MAX_CALLBACKS    = 64
const FORGE_CB_TABLE_CAP     = 32

struct ForgeCbEntry {
    table:  [FORGE_CB_TABLE_CAP]i8
    tlen:   i64
    event:  i64
    fn_ptr: i64
    used:   bool
}

const FORGE_CB_ENTRY_STRIDE = 58

let g_forge_cb_store: &ForgeCbEntry = 0
let g_forge_cb_count: i64 = 0

fn forge_cb_init() {
    if g_forge_cb_store != 0 { ret }
    g_forge_cb_store = alloc_pages(4) as &ForgeCbEntry
}

fn forge_callback_add(table: []i8, event: i64, fn_ptr: i64) {
    forge_cb_init()
    let n = g_forge_cb_count
    if n >= FORGE_MAX_CALLBACKS { ret }
    let entry: &ForgeCbEntry = (g_forge_cb_store as i64 + n * FORGE_CB_ENTRY_STRIDE) as &ForgeCbEntry
    let tl = table.len
    if tl > FORGE_CB_TABLE_CAP { tl = FORGE_CB_TABLE_CAP }
    loop i in 0..tl { entry.table[i] = table[i] }
    entry.tlen   = tl
    entry.event  = event
    entry.fn_ptr = fn_ptr
    entry.used   = true
    g_forge_cb_count = n + 1
}

// Model-level callback declaration — use inside *_validations_init after forge_model().
fn forge_callback(event: i64, fn_ptr: i64) {
    forge_callback_add(g_forge_model_buf[0..g_forge_model_len], event, fn_ptr)
}

fn forge_callback_run(table: []i8, event: i64, row_ptr: i64) -> bool {
    forge_cb_init()
    loop i in 0..g_forge_cb_count {
        let entry: &ForgeCbEntry = (g_forge_cb_store as i64 + i * FORGE_CB_ENTRY_STRIDE) as &ForgeCbEntry
        if not entry.used { continue }
        if entry.event != event { continue }
        if not forge_slice_eq(entry.table[0..entry.tlen], table) { continue }
        let result = call_fn(entry.fn_ptr, row_ptr)
        if result == 0 { ret false }
    }
    ret true
}

// =============================================================================
// Section D — Associations
// =============================================================================

fn forge_belongs_to(table: []i8, fk_val: []i8) -> &ForgeResult {
    ret forge_find(table, fk_val)
}

fn forge_has_many(table: []i8, fk_col: []i8, owner_id: []i8) -> &ForgeResult {
    let q = forge_q(table)
    forge_q_where(q, fk_col, "=", owner_id)
    ret forge_q_exec(q)
}

fn forge_has_one(table: []i8, fk_col: []i8, owner_id: []i8) -> &ForgeResult {
    let q = forge_q(table)
    forge_q_where(q, fk_col, "=", owner_id)
    ret forge_q_first(q)
}

// =============================================================================
// Section D2 — Association registry (model-level declarations)
//
// Supports belongs_to, has_many, has_one, has_many_through (HABTM),
// polymorphic belongs_to, polymorphic has_many, and self-referential (parent/child).
// Declare inside *_validations_init; forge generate model emits typed stubs.
// =============================================================================

let FORGE_ASSOC_BELONGS_TO:       i64 = 1
let FORGE_ASSOC_HAS_MANY:         i64 = 2
let FORGE_ASSOC_HAS_ONE:          i64 = 3
let FORGE_ASSOC_HAS_MANY_THROUGH: i64 = 4   // has_many :through / HABTM
let FORGE_ASSOC_POLY_BELONGS_TO:  i64 = 5   // polymorphic belongs_to
let FORGE_ASSOC_POLY_HAS_MANY:    i64 = 6   // polymorphic has_many
let FORGE_ASSOC_MAX:              i64 = 128

// Per-entry layout (all arrays are [MAX * 64] bytes unless noted):
//   models      — owner table name
//   names       — association name
//   types       — FORGE_ASSOC_* constant
//   targets     — target/through table
//   fkeys       — primary FK column (or owner FK for through)
//   extras      — join table (through), type column (poly)
//   extras2     — target FK in join (through), type value (poly has_many)

let g_forge_assoc_models:       &i8  = 0
let g_forge_assoc_model_lens:   &i64 = 0
let g_forge_assoc_names:        &i8  = 0
let g_forge_assoc_name_lens:    &i64 = 0
let g_forge_assoc_types:        &i64 = 0
let g_forge_assoc_targets:      &i8  = 0
let g_forge_assoc_target_lens:  &i64 = 0
let g_forge_assoc_fkeys:        &i8  = 0
let g_forge_assoc_fkey_lens:    &i64 = 0
let g_forge_assoc_extras:       &i8  = 0   // join table or type column
let g_forge_assoc_extra_lens:   &i64 = 0
let g_forge_assoc_extras2:      &i8  = 0   // target FK or type value
let g_forge_assoc_extra2_lens:  &i64 = 0
let g_forge_assoc_count:        i64  = 0

fn forge_assoc_reg_init() {
    if g_forge_assoc_models != 0 { ret }
    g_forge_assoc_models      = alloc_pages(2)
    g_forge_assoc_model_lens  = alloc_pages(1)
    g_forge_assoc_names       = alloc_pages(2)
    g_forge_assoc_name_lens   = alloc_pages(1)
    g_forge_assoc_types       = alloc_pages(1)
    g_forge_assoc_targets     = alloc_pages(2)
    g_forge_assoc_target_lens = alloc_pages(1)
    g_forge_assoc_fkeys       = alloc_pages(2)
    g_forge_assoc_fkey_lens   = alloc_pages(1)
    g_forge_assoc_extras      = alloc_pages(2)
    g_forge_assoc_extra_lens  = alloc_pages(1)
    g_forge_assoc_extras2     = alloc_pages(2)
    g_forge_assoc_extra2_lens = alloc_pages(1)
}

fn forge_assoc_write(buf: &i8, lens: &i64, idx: i64, s: []i8) {
    let base = idx * 64
    let l = s.len  if l > 64 { l = 64 }
    loop i in 0..l { buf[base + i] = s[i] }
    lens[idx] = l
}

fn forge_assoc_reg_full(assoc_type: i64, name: []i8, target: []i8, fkey: []i8, extra: []i8, extra2: []i8) {
    forge_assoc_reg_init()
    let n = g_forge_assoc_count
    if n >= FORGE_ASSOC_MAX { ret }
    forge_assoc_write(g_forge_assoc_models,  g_forge_assoc_model_lens,  n, g_forge_model_buf[0..g_forge_model_len])
    forge_assoc_write(g_forge_assoc_names,   g_forge_assoc_name_lens,   n, name)
    forge_assoc_write(g_forge_assoc_targets, g_forge_assoc_target_lens, n, target)
    forge_assoc_write(g_forge_assoc_fkeys,   g_forge_assoc_fkey_lens,   n, fkey)
    forge_assoc_write(g_forge_assoc_extras,  g_forge_assoc_extra_lens,  n, extra)
    forge_assoc_write(g_forge_assoc_extras2, g_forge_assoc_extra2_lens, n, extra2)
    g_forge_assoc_types[n] = assoc_type
    g_forge_assoc_count = n + 1
}

fn forge_assoc_reg(assoc_type: i64, name: []i8, target: []i8, fkey: []i8) {
    forge_assoc_reg_full(assoc_type, name, target, fkey, "", "")
}

// ---------------------------------------------------------------------------
// Model-level declaration helpers
// ---------------------------------------------------------------------------

// belongs_to :user, foreign_key: :user_id
fn forge_assoc_belongs_to(name: []i8, target_table: []i8, fk_col: []i8) {
    forge_assoc_reg(FORGE_ASSOC_BELONGS_TO, name, target_table, fk_col)
}

// has_many :comments, foreign_key: :post_id
// Works for self-referential (parent/child) when target_table == model table.
fn forge_assoc_has_many(name: []i8, target_table: []i8, fk_col: []i8) {
    forge_assoc_reg(FORGE_ASSOC_HAS_MANY, name, target_table, fk_col)
}

// has_one :profile, foreign_key: :user_id
fn forge_assoc_has_one(name: []i8, target_table: []i8, fk_col: []i8) {
    forge_assoc_reg(FORGE_ASSOC_HAS_ONE, name, target_table, fk_col)
}

// has_and_belongs_to_many :tags, through: :post_tags
// name        — association name ("tags")
// target      — target table ("tags")
// join_table  — join table ("post_tags")
// owner_fk    — owner FK column in join table ("post_id")
// target_fk   — target FK column in join table ("tag_id")
fn forge_assoc_has_many_through(name: []i8, target: []i8, join_table: []i8, owner_fk: []i8, target_fk: []i8) {
    forge_assoc_reg_full(FORGE_ASSOC_HAS_MANY_THROUGH, name, target, owner_fk, join_table, target_fk)
}

// belongs_to :commentable, polymorphic: true
// name     — association name ("commentable")
// type_col — column holding the type string ("commentable_type")
// id_col   — column holding the FK ("commentable_id")
fn forge_assoc_poly_belongs_to(name: []i8, type_col: []i8, id_col: []i8) {
    forge_assoc_reg_full(FORGE_ASSOC_POLY_BELONGS_TO, name, "", id_col, type_col, "")
}

// has_many :comments, as: :commentable
// name      — association name ("comments")
// target    — target table ("comments")
// fk_id     — FK id column in target ("commentable_id")
// fk_type   — FK type column in target ("commentable_type")
// type_val  — type discriminator stored in fk_type column ("Post")
fn forge_assoc_poly_has_many(name: []i8, target: []i8, fk_id: []i8, fk_type: []i8, type_val: []i8) {
    forge_assoc_reg_full(FORGE_ASSOC_POLY_HAS_MANY, name, target, fk_id, fk_type, type_val)
}

// ---------------------------------------------------------------------------
// Internal helpers
// ---------------------------------------------------------------------------

// Resolve a polymorphic type name to a table name: "Post" -> "posts".
fn forge_poly_table_name(type_val: []i8, buf: &i8) -> i64 {
    let n = type_val.len
    loop i in 0..n {
        let c = type_val[i]
        if c >= 65 and c <= 90 { c = c + 32 }
        buf[i] = c
    }
    buf[n] = 's'
    ret n + 1
}

fn forge_assoc_find(model_table: []i8, assoc_name: []i8) -> i64 {
    forge_assoc_reg_init()
    let mtl = model_table.len
    let anl = assoc_name.len
    loop i in 0..g_forge_assoc_count {
        if g_forge_assoc_model_lens[i] != mtl { continue }
        let base = i * 64
        let mm = true
        loop j in 0..mtl { if g_forge_assoc_models[base + j] != model_table[j] { mm = false  break } }
        if not mm { continue }
        if g_forge_assoc_name_lens[i] != anl { continue }
        let nm = true
        loop j in 0..anl { if g_forge_assoc_names[base + j] != assoc_name[j] { nm = false  break } }
        if nm { ret i }
    }
    ret -1
}

// ---------------------------------------------------------------------------
// Runtime dispatch
// ---------------------------------------------------------------------------

// forge_assoc_query — standard associations + has_many_through + poly_has_many.
// id_or_fk is the FK value (belongs_to) or owner ID (has_many / has_one / through).
fn forge_assoc_query(model_table: []i8, assoc_name: []i8, id_or_fk: []i8) -> &ForgeResult {
    let i = forge_assoc_find(model_table, assoc_name)
    if i < 0 { ret 0 }
    let base  = i * 64
    let tl    = g_forge_assoc_target_lens[i]
    let fl    = g_forge_assoc_fkey_lens[i]
    let el    = g_forge_assoc_extra_lens[i]
    let e2l   = g_forge_assoc_extra2_lens[i]
    let tgt   = g_forge_assoc_targets[base..base + tl]
    let fk    = g_forge_assoc_fkeys[base..base + fl]
    let extra = g_forge_assoc_extras[base..base + el]
    let ex2   = g_forge_assoc_extras2[base..base + e2l]
    let at    = g_forge_assoc_types[i]

    if at == FORGE_ASSOC_BELONGS_TO { ret forge_belongs_to(tgt, id_or_fk) }
    if at == FORGE_ASSOC_HAS_MANY   { ret forge_has_many(tgt, fk, id_or_fk) }
    if at == FORGE_ASSOC_HAS_ONE    { ret forge_has_one(tgt, fk, id_or_fk) }

    if at == FORGE_ASSOC_HAS_MANY_THROUGH {
        // SELECT tgt.* FROM tgt INNER JOIN extra ON extra.ex2 = tgt.id WHERE extra.fk = id_or_fk
        let b = forge_buf_new(1)
        forge_buf_append(b, "SELECT ")
        forge_buf_append(b, tgt)
        forge_buf_append(b, ".* FROM ")
        forge_buf_append(b, tgt)
        forge_buf_append(b, " INNER JOIN ")
        forge_buf_append(b, extra)
        forge_buf_append(b, " ON ")
        forge_buf_append(b, extra)
        forge_buf_append(b, ".")
        forge_buf_append(b, ex2)
        forge_buf_append(b, " = ")
        forge_buf_append(b, tgt)
        forge_buf_append(b, ".id WHERE ")
        forge_buf_append(b, extra)
        forge_buf_append(b, ".")
        forge_buf_append(b, fk)
        forge_buf_append(b, " = '")
        forge_buf_append(b, id_or_fk)
        forge_buf_append(b, "'")
        ret forge_db_query(forge_buf_str(b))
    }

    if at == FORGE_ASSOC_POLY_HAS_MANY {
        // SELECT * FROM tgt WHERE fk = id_or_fk AND extra = 'ex2'
        let b = forge_buf_new(1)
        forge_buf_append(b, "SELECT * FROM ")
        forge_buf_append(b, tgt)
        forge_buf_append(b, " WHERE ")
        forge_buf_append(b, fk)
        forge_buf_append(b, " = '")
        forge_buf_append(b, id_or_fk)
        forge_buf_append(b, "' AND ")
        forge_buf_append(b, extra)
        forge_buf_append(b, " = '")
        forge_buf_append(b, ex2)
        forge_buf_append(b, "'")
        ret forge_db_query(forge_buf_str(b))
    }

    ret 0
}

// forge_assoc_poly_query — polymorphic belongs_to.
// type_val is the value of the type column (e.g. "Post");
// id_val is the FK value.  The target table is derived from type_val.
fn forge_assoc_poly_query(model_table: []i8, assoc_name: []i8, type_val: []i8, id_val: []i8) -> &ForgeResult {
    let i = forge_assoc_find(model_table, assoc_name)
    if i < 0 { ret 0 }
    if g_forge_assoc_types[i] != FORGE_ASSOC_POLY_BELONGS_TO { ret 0 }
    let tbl_buf: &i8 = alloc_pages(1)
    let tbl_len = forge_poly_table_name(type_val, tbl_buf)
    ret forge_find(tbl_buf[0..tbl_len], id_val)
}

// =============================================================================
// Section E — Transactions
// =============================================================================

fn forge_tx_begin() -> i32 {
    let fd = forge_db_connect()
    if fd < 0 { ret fd }
    let msg: &i8 = alloc_pages(1)
    msg[0] = 'Q'
    let sql = "BEGIN"
    let mlen = sql.len + 5
    forge_db_write_i32(msg, 1, mlen)
    loop i in 0..sql.len { msg[5 + i] = sql[i] }
    msg[5 + sql.len] = 0
    forge_tcp_write_all(fd, msg, 6 + sql.len as i64)
    let hdr = [5]i8
    loop {
        if not forge_db_recv_n(fd, hdr, 5) { break }
        let mtype = hdr[0]
        let mlen2 = forge_db_read_i32(hdr, 1) - 4
        let body: &i8 = alloc_pages(1)
        if mlen2 > 0 { forge_db_recv_n(fd, body, mlen2) }
        if mtype == 'Z' { break }
    }
    ret fd
}

fn forge_tx_exec(fd: i32, sql: []i8) -> bool {
    let msg: &i8 = alloc_pages(1)
    msg[0] = 'Q'
    let mlen = sql.len + 5
    forge_db_write_i32(msg, 1, mlen)
    loop i in 0..sql.len { msg[5 + i] = sql[i] }
    msg[5 + sql.len] = 0
    forge_tcp_write_all(fd, msg, 6 + sql.len as i64)
    let hdr = [5]i8
    let ok = true
    loop {
        if not forge_db_recv_n(fd, hdr, 5) { ok = false  break }
        let mtype = hdr[0]
        let mlen2 = forge_db_read_i32(hdr, 1) - 4
        let body: &i8 = alloc_pages(1)
        if mlen2 > 0 { forge_db_recv_n(fd, body, mlen2) }
        if mtype == 'E' { ok = false }
        if mtype == 'Z' { break }
    }
    ret ok
}

fn forge_tx_query(fd: i32, sql: []i8) -> &ForgeResult {
    let result: &ForgeResult = alloc_pages(1)
    result.count    = 0
    result.affected = 0
    let msg: &i8 = alloc_pages(1)
    msg[0] = 'Q'
    let mlen = sql.len + 5
    forge_db_write_i32(msg, 1, mlen)
    loop i in 0..sql.len { msg[5 + i] = sql[i] }
    msg[5 + sql.len] = 0
    forge_tcp_write_all(fd, msg, 6 + sql.len as i64)
    let rows: &i8 = alloc_pages(512)
    result.rows = rows as &ForgeDbRow
    let hdr = [5]i8
    let ncols = 0i64
    loop {
        if not forge_db_recv_n(fd, hdr, 5) { break }
        let mtype = hdr[0]
        let blen  = forge_db_read_i32(hdr, 1) - 4
        let body: &i8 = alloc_pages(16)
        if blen > 0 { forge_db_recv_n(fd, body, blen) }
        if mtype == 'T' {
            ncols = forge_db_read_i16(body, 0)
            result.col_count = ncols
            let tp = 2i64
            loop ci in 0..ncols {
                let cn: &ForgeColName = (result.col_names as i64 + ci * 72) as &ForgeColName
                let nl = 0i64
                loop {
                    if tp >= blen { break }
                    let ch = body[tp]
                    tp = tp + 1
                    if ch == 0 { break }
                    if nl < 64 { cn.name[nl] = ch  nl = nl + 1 }
                }
                cn.nlen = nl
                tp = tp + 18
            }
        } else if mtype == 'D' {
            let row_i = result.count
            if row_i < FORGE_DB_MAX_ROWS {
                let row: &ForgeDbRow = (rows as i64 + row_i * FORGE_DB_ROW_STRIDE) as &ForgeDbRow
                let nf = forge_db_read_i16(body, 0)
                row.count = nf
                let bp = 2i64
                loop c in 0..nf {
                    let dlen = forge_db_read_i32(body, bp)
                    bp = bp + 4
                    if dlen < 0 {
                        row.cols[c].len = 0
                    } else {
                        let cell: &ForgeDbCell = (row.cols as i64 + c * FORGE_DB_COL_STRIDE) as &ForgeDbCell
                        let cl = dlen
                        if cl > FORGE_DB_COL_CAP { cl = FORGE_DB_COL_CAP }
                        loop j in 0..cl { cell.data[j] = body[bp + j] }
                        cell.len = cl
                        bp = bp + dlen
                    }
                }
                result.count = row_i + 1
            }
        } else if mtype == 'C' {
            let tag = body[0..blen]
            let li = 0i64
            loop i in 0..tag.len { if tag[i] == ' ' { li = i } }
            if li > 0 {
                let num_str = tag[li+1..]
                let acc = 0i64
                loop i in 0..num_str.len {
                    let d = num_str[i] as i64 - 48
                    if d >= 0 and d <= 9 { acc = acc * 10 + d }
                }
                result.affected = acc
            }
        } else if mtype == 'Z' {
            break
        } else if mtype == 'E' {
            break
        }
    }
    ret result
}

fn forge_tx_commit(fd: i32) -> bool {
    let ok = forge_tx_exec(fd, "COMMIT")
    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
    ret ok
}

fn forge_tx_rollback(fd: i32) {
    forge_tx_exec(fd, "ROLLBACK")
    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
}

// =============================================================================
// Counter caches — denormalized association counts.
//
// Call forge_counter_cache once per association in your model_init:
//   forge_counter_cache("comments", "post_id", "posts", "comments_count")
//
// After that, forge_attrs_insert increments the counter and forge_soft_delete
// decrements it automatically.
// =============================================================================
const FORGE_CC_MAX      = 16
const FORGE_CC_COL_CAP  = 32

struct ForgeCounterCacheEntry {
    child:   [FORGE_CC_COL_CAP]i8   clen:  i64
    fk_col:  [FORGE_CC_COL_CAP]i8   flen:  i64
    parent:  [FORGE_CC_COL_CAP]i8   plen:  i64
    cnt_col: [FORGE_CC_COL_CAP]i8   cnlen: i64
    used:    bool
}

const FORGE_CC_STRIDE = 136

let g_forge_cc_store: &ForgeCounterCacheEntry = 0
let g_forge_cc_count: i64 = 0

fn forge_cc_init() {
    if g_forge_cc_store != 0 { ret }
    g_forge_cc_store = alloc_pages(2) as &ForgeCounterCacheEntry
}

fn forge_counter_cache(child_table: []i8, fk_col: []i8, parent_table: []i8, counter_col: []i8) {
    forge_cc_init()
    if g_forge_cc_count >= FORGE_CC_MAX { ret }
    let e: &ForgeCounterCacheEntry = (g_forge_cc_store as i64 + g_forge_cc_count * FORGE_CC_STRIDE) as &ForgeCounterCacheEntry
    let cl = child_table.len;  if cl > FORGE_CC_COL_CAP { cl = FORGE_CC_COL_CAP }
    let fl = fk_col.len;       if fl > FORGE_CC_COL_CAP { fl = FORGE_CC_COL_CAP }
    let pl = parent_table.len; if pl > FORGE_CC_COL_CAP { pl = FORGE_CC_COL_CAP }
    let cnl = counter_col.len; if cnl > FORGE_CC_COL_CAP { cnl = FORGE_CC_COL_CAP }
    loop i in 0..cl  { e.child[i]   = child_table[i]  }
    loop i in 0..fl  { e.fk_col[i]  = fk_col[i]       }
    loop i in 0..pl  { e.parent[i]  = parent_table[i] }
    loop i in 0..cnl { e.cnt_col[i] = counter_col[i]  }
    e.clen  = cl  e.flen  = fl  e.plen  = pl  e.cnlen = cnl
    e.used  = true
    g_forge_cc_count = g_forge_cc_count + 1
}

// forge__cc_adjust — increment (delta=1) or decrement (delta=-1) counters.
// For inserts: fk_val comes from forge_fa_get (still in global temp store).
// For deletes: caller supplies fk_val fetched from DB.
fn forge__cc_adjust_by_fk(child_table: []i8, fk_col: []i8, fk_val: []i8, delta: i64) {
    let sign = "+"
    if delta < 0 { sign = "-" }
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "UPDATE "
    let p2 = " SET "
    let p3 = " = "
    let p4 = " + 1 WHERE id = '"
    let p4m = " - 1 WHERE id = '"
    let p5 = "'"
    forge_cc_init()
    loop i in 0..g_forge_cc_count {
        let e: &ForgeCounterCacheEntry = (g_forge_cc_store as i64 + i * FORGE_CC_STRIDE) as &ForgeCounterCacheEntry
        if not e.used { continue }
        if not forge_slice_eq(e.child[0..e.clen],  child_table) { continue }
        if not forge_slice_eq(e.fk_col[0..e.flen], fk_col)      { continue }
        pos = 0
        loop j in 0..p1.len        { buf[pos] = p1[j]             pos = pos + 1 }
        loop j in 0..e.plen        { buf[pos] = e.parent[j]       pos = pos + 1 }
        loop j in 0..p2.len        { buf[pos] = p2[j]             pos = pos + 1 }
        loop j in 0..e.cnlen       { buf[pos] = e.cnt_col[j]      pos = pos + 1 }
        loop j in 0..p3.len        { buf[pos] = p3[j]             pos = pos + 1 }
        loop j in 0..e.cnlen       { buf[pos] = e.cnt_col[j]      pos = pos + 1 }
        if delta >= 0 {
            loop j in 0..p4.len  { buf[pos] = p4[j]   pos = pos + 1 }
        } else {
            loop j in 0..p4m.len { buf[pos] = p4m[j]  pos = pos + 1 }
        }
        let en = forge_db_escape_str(fk_val, buf + pos)
        pos = pos + en
        loop j in 0..p5.len { buf[pos] = p5[j]  pos = pos + 1 }
        forge_db_exec(buf[0..pos])
    }
}

// Called from forge_attrs_insert — fk values still in forge_fa_get store.
fn forge__cc_after_create(child_table: []i8) {
    forge_cc_init()
    loop i in 0..g_forge_cc_count {
        let e: &ForgeCounterCacheEntry = (g_forge_cc_store as i64 + i * FORGE_CC_STRIDE) as &ForgeCounterCacheEntry
        if not e.used { continue }
        if not forge_slice_eq(e.child[0..e.clen], child_table) { continue }
        let fk_val = forge_fa_get(e.fk_col[0..e.flen])
        if fk_val.len > 0 {
            forge__cc_adjust_by_fk(child_table, e.fk_col[0..e.flen], fk_val, 1)
        }
    }
}

// Called from forge_soft_delete — fk looked up from DB.
fn forge__cc_after_delete(child_table: []i8, child_id: []i8) {
    forge_cc_init()
    loop i in 0..g_forge_cc_count {
        let e: &ForgeCounterCacheEntry = (g_forge_cc_store as i64 + i * FORGE_CC_STRIDE) as &ForgeCounterCacheEntry
        if not e.used { continue }
        if not forge_slice_eq(e.child[0..e.clen], child_table) { continue }
        let q = forge_q(child_table)
        forge_q_where(q, "id", "=", child_id)
        forge_q_select(q, e.fk_col[0..e.flen])
        let res = forge_q_exec(q)
        if res.count > 0 {
            let fk_val = forge_row_col(res, 0, 0)
            if fk_val.len > 0 {
                forge__cc_adjust_by_fk(child_table, e.fk_col[0..e.flen], fk_val, -1)
            }
        }
    }
}

// forge_counter_cache_reset — recount from scratch (useful after bulk imports).
fn forge_counter_cache_reset(child_table: []i8) {
    forge_cc_init()
    loop i in 0..g_forge_cc_count {
        let e: &ForgeCounterCacheEntry = (g_forge_cc_store as i64 + i * FORGE_CC_STRIDE) as &ForgeCounterCacheEntry
        if not e.used { continue }
        if not forge_slice_eq(e.child[0..e.clen], child_table) { continue }
        let buf: &i8 = alloc_pages(1)
        let pos = 0i64
        let p1 = "UPDATE "
        let p2 = " SET "
        let p3 = " = (SELECT COUNT(*) FROM "
        let p4 = " WHERE "
        let p5 = ".id = "
        let p6 = "."
        let p7 = ")"
        loop j in 0..p1.len    { buf[pos] = p1[j]          pos = pos + 1 }
        loop j in 0..e.plen    { buf[pos] = e.parent[j]    pos = pos + 1 }
        loop j in 0..p2.len    { buf[pos] = p2[j]          pos = pos + 1 }
        loop j in 0..e.cnlen   { buf[pos] = e.cnt_col[j]   pos = pos + 1 }
        loop j in 0..p3.len    { buf[pos] = p3[j]          pos = pos + 1 }
        loop j in 0..e.clen    { buf[pos] = e.child[j]     pos = pos + 1 }
        loop j in 0..p4.len    { buf[pos] = p4[j]          pos = pos + 1 }
        loop j in 0..e.plen    { buf[pos] = e.parent[j]    pos = pos + 1 }
        loop j in 0..p5.len    { buf[pos] = p5[j]          pos = pos + 1 }
        loop j in 0..e.clen    { buf[pos] = e.child[j]     pos = pos + 1 }
        loop j in 0..p6.len    { buf[pos] = p6[j]          pos = pos + 1 }
        loop j in 0..e.flen    { buf[pos] = e.fk_col[j]    pos = pos + 1 }
        loop j in 0..p7.len    { buf[pos] = p7[j]          pos = pos + 1 }
        forge_db_exec(buf[0..pos])
    }
}

// =============================================================================
// Section F — Soft Delete
// =============================================================================

fn forge_soft_delete(table: []i8, id: []i8) -> bool {
    if not forge_callback_run(table, FORGE_CB_BEFORE_DELETE, 0) { ret false }
    forge__cc_after_delete(table, id)
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "UPDATE "
    let p2 = " SET deleted_at = NOW() WHERE id = '"
    let p3 = "'"
    loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i]  pos = pos + 1 }
    loop i in 0..p2.len { buf[pos] = p2[i]  pos = pos + 1 }
    let esc_len = forge_db_escape_str(id, buf + pos)
    pos = pos + esc_len
    loop i in 0..p3.len { buf[pos] = p3[i]  pos = pos + 1 }
    let ok = forge_db_exec(buf[0..pos])
    if ok {
        forge_callback_run(table, FORGE_CB_AFTER_DELETE, 0)
        forge_callback_run(table, FORGE_CB_AFTER_COMMIT, 0)
    } else {
        forge_callback_run(table, FORGE_CB_AFTER_ROLLBACK, 0)
    }
    ret ok
}

fn forge_restore(table: []i8, id: []i8) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "UPDATE "
    let p2 = " SET deleted_at = NULL WHERE id = '"
    let p3 = "'"
    loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i]  pos = pos + 1 }
    loop i in 0..p2.len { buf[pos] = p2[i]  pos = pos + 1 }
    let esc_len = forge_db_escape_str(id, buf + pos)
    pos = pos + esc_len
    loop i in 0..p3.len { buf[pos] = p3[i]  pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

fn forge_purge(table: []i8, id: []i8) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "DELETE FROM "
    let p2 = " WHERE id = '"
    let p3 = "'"
    loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i]  pos = pos + 1 }
    loop i in 0..p2.len { buf[pos] = p2[i]  pos = pos + 1 }
    let esc_len = forge_db_escape_str(id, buf + pos)
    pos = pos + esc_len
    loop i in 0..p3.len { buf[pos] = p3[i]  pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

// forge_touch — UPDATE table SET updated_at = NOW() WHERE id = '...'
// Skips validations and callbacks (like Rails touch).
fn forge_touch(table: []i8, id: []i8) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "UPDATE "
    let p2 = " SET updated_at = NOW() WHERE id = '"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i] pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    let en = forge_db_escape_str(id, buf + pos)
    pos = pos + en
    buf[pos] = '\''  pos = pos + 1
    ret forge_db_exec(buf[0..pos])
}

// forge_update_column — single-column UPDATE, bypasses validations and callbacks.
fn forge_update_column(table: []i8, id: []i8, col: []i8, val: []i8) -> bool {
    let buf: &i8 = alloc_pages(2)
    let pos = 0i64
    let p1 = "UPDATE "
    let p2 = " SET "
    let p3 = " = '"
    let p4 = "' WHERE id = '"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i] pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    loop i in 0..col.len   { buf[pos] = col[i]   pos = pos + 1 }
    loop i in 0..p3.len    { buf[pos] = p3[i]    pos = pos + 1 }
    let vn = forge_db_escape_str(val, buf + pos)
    pos = pos + vn
    loop i in 0..p4.len    { buf[pos] = p4[i]    pos = pos + 1 }
    let en = forge_db_escape_str(id, buf + pos)
    pos = pos + en
    buf[pos] = '\''  pos = pos + 1
    ret forge_db_exec(buf[0..pos])
}

// forge_hard_delete — DELETE with BEFORE/AFTER_DELETE + AFTER_COMMIT callbacks.
// Like Rails destroy; use forge_purge to skip callbacks.
fn forge_hard_delete(table: []i8, id: []i8) -> bool {
    if not forge_callback_run(table, FORGE_CB_BEFORE_DELETE, 0) { ret false }
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "DELETE FROM "
    let p2 = " WHERE id = '"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i] pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    let en = forge_db_escape_str(id, buf + pos)
    pos = pos + en
    buf[pos] = '\''  pos = pos + 1
    let ok = forge_db_exec(buf[0..pos])
    if ok {
        forge_callback_run(table, FORGE_CB_AFTER_DELETE, 0)
        forge_callback_run(table, FORGE_CB_AFTER_COMMIT, 0)
    } else {
        forge_callback_run(table, FORGE_CB_AFTER_ROLLBACK, 0)
    }
    ret ok
}

// forge_find_or_create_by — returns existing row or inserts a minimal record.
fn forge_find_or_create_by(table: []i8, col: []i8, val: []i8) -> &ForgeResult {
    let res = forge_find_by(table, col, val)
    if res.count > 0 { ret res }
    let a = forge_attrs_new()
    forge_attrs_set(a, col, val)
    forge_attrs_insert(a, table)
    ret forge_find_by(table, col, val)
}

// forge_attrs_upsert — INSERT ... ON CONFLICT (col) DO UPDATE SET ...
fn forge_attrs_upsert(a: &ForgeAttrs, table: []i8, conflict_col: []i8) -> bool {
    if not forge_attrs_validate(table) { ret false }
    if not forge_callback_run(table, FORGE_CB_BEFORE_SAVE, 0) { ret false }
    let buf: &i8 = alloc_pages(8)
    let pos = 0i64
    let p1 = "INSERT INTO "
    let p2 = " ("
    let p3 = ") VALUES ("
    let p4 = ") ON CONFLICT ("
    let p5 = ") DO UPDATE SET "
    loop i in 0..p1.len          { buf[pos] = p1[i]           pos = pos + 1 }
    loop i in 0..table.len       { buf[pos] = table[i]        pos = pos + 1 }
    loop i in 0..p2.len          { buf[pos] = p2[i]           pos = pos + 1 }
    loop i in 0..a.kpos          { buf[pos] = a.kbuf[i]       pos = pos + 1 }
    loop i in 0..p3.len          { buf[pos] = p3[i]           pos = pos + 1 }
    loop i in 0..a.vpos          { buf[pos] = a.vbuf[i]       pos = pos + 1 }
    loop i in 0..p4.len          { buf[pos] = p4[i]           pos = pos + 1 }
    loop i in 0..conflict_col.len{ buf[pos] = conflict_col[i] pos = pos + 1 }
    loop i in 0..p5.len          { buf[pos] = p5[i]           pos = pos + 1 }
    loop i in 0..a.spos          { buf[pos] = a.sbuf[i]       pos = pos + 1 }
    let ok = forge_db_exec(buf[0..pos])
    if ok {
        forge_callback_run(table, FORGE_CB_AFTER_SAVE, 0)
        forge_callback_run(table, FORGE_CB_AFTER_COMMIT, 0)
    } else {
        forge_callback_run(table, FORGE_CB_AFTER_ROLLBACK, 0)
    }
    ret ok
}

// forge_increment — UPDATE table SET col = col + N WHERE id = '...'
fn forge_increment(table: []i8, id: []i8, col: []i8, by: i64) -> bool {
    let buf: &i8 = alloc_pages(2)
    let pos = 0i64
    let p1 = "UPDATE "; let p2 = " SET "; let p3 = " = "; let p4 = " + "
    let p5 = " WHERE id = '"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i] pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    loop i in 0..col.len   { buf[pos] = col[i]   pos = pos + 1 }
    loop i in 0..p3.len    { buf[pos] = p3[i]    pos = pos + 1 }
    loop i in 0..col.len   { buf[pos] = col[i]   pos = pos + 1 }
    loop i in 0..p4.len    { buf[pos] = p4[i]    pos = pos + 1 }
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, by)
    loop i in 0..nl        { buf[pos] = nb[i]    pos = pos + 1 }
    loop i in 0..p5.len    { buf[pos] = p5[i]    pos = pos + 1 }
    let en = forge_db_escape_str(id, buf + pos)
    pos = pos + en
    buf[pos] = '\''  pos = pos + 1
    ret forge_db_exec(buf[0..pos])
}

// forge_decrement — UPDATE table SET col = col - N WHERE id = '...'
fn forge_decrement(table: []i8, id: []i8, col: []i8, by: i64) -> bool {
    let buf: &i8 = alloc_pages(2)
    let pos = 0i64
    let p1 = "UPDATE "; let p2 = " SET "; let p3 = " = "; let p4 = " - "
    let p5 = " WHERE id = '"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i] pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    loop i in 0..col.len   { buf[pos] = col[i]   pos = pos + 1 }
    loop i in 0..p3.len    { buf[pos] = p3[i]    pos = pos + 1 }
    loop i in 0..col.len   { buf[pos] = col[i]   pos = pos + 1 }
    loop i in 0..p4.len    { buf[pos] = p4[i]    pos = pos + 1 }
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, by)
    loop i in 0..nl        { buf[pos] = nb[i]    pos = pos + 1 }
    loop i in 0..p5.len    { buf[pos] = p5[i]    pos = pos + 1 }
    let en = forge_db_escape_str(id, buf + pos)
    pos = pos + en
    buf[pos] = '\''  pos = pos + 1
    ret forge_db_exec(buf[0..pos])
}

// forge_reload — re-fetch a record from DB by id.
fn forge_reload(table: []i8, id: []i8) -> &ForgeResult {
    let q = forge_q_with_deleted(forge_q(table))
    forge_q_where(q, "id", "=", id)
    ret forge_q_first(q)
}

// forge_toggle — flip a boolean column: SET col = NOT col WHERE id = '...'
fn forge_toggle(table: []i8, id: []i8, col: []i8) -> bool {
    let buf: &i8 = alloc_pages(2)
    let pos = 0i64
    let p1 = "UPDATE "; let p2 = " SET "; let p3 = " = NOT "; let p4 = " WHERE id = '"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i] pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    loop i in 0..col.len   { buf[pos] = col[i]   pos = pos + 1 }
    loop i in 0..p3.len    { buf[pos] = p3[i]    pos = pos + 1 }
    loop i in 0..col.len   { buf[pos] = col[i]   pos = pos + 1 }
    loop i in 0..p4.len    { buf[pos] = p4[i]    pos = pos + 1 }
    let en = forge_db_escape_str(id, buf + pos)
    pos = pos + en
    buf[pos] = '\''  pos = pos + 1
    ret forge_db_exec(buf[0..pos])
}

// Transactions — wraps PostgreSQL BEGIN / COMMIT / ROLLBACK.
fn forge_begin()    -> bool { ret forge_db_exec("BEGIN") }
fn forge_commit()   -> bool { ret forge_db_exec("COMMIT") }
fn forge_rollback() -> bool { ret forge_db_exec("ROLLBACK") }

// forge_transaction — runs fn_ptr inside a BEGIN/COMMIT block.
// fn_ptr signature: fn(i64) -> bool  — return false to trigger rollback.
fn forge_transaction(fn_ptr: i64) -> bool {
    if not forge_begin() { ret false }
    let ok = call_fn(fn_ptr, 0) as bool
    if ok { ret forge_commit() }
    forge_rollback()
    ret false
}

// forge_secure_password_set — hashes password via bcrypt and sets "password_hash".
fn forge_secure_password_set(a: &ForgeAttrs, password: []i8) -> &ForgeAttrs {
    let hash = forge_bcrypt_hash(password)
    ret forge_attrs_set(a, "password_hash", hash)
}

// forge_secure_password_verify — looks up "password_hash" column and verifies.
fn forge_secure_password_verify(table: []i8, id: []i8, password: []i8) -> bool {
    let res = forge_find(table, id)
    if res.count == 0 { ret false }
    let hash = forge_result_col(res, 0, "password_hash")
    ret forge_bcrypt_verify(password, hash)
}

// =============================================================================
// Section G — Serializer
// =============================================================================

fn forge_row_to_json(res: &ForgeResult, row_i: i64) -> []i8 {
    if row_i >= res.count { ret "{}" }
    let row: &ForgeDbRow = (res.rows as i64 + row_i * FORGE_DB_ROW_STRIDE) as &ForgeDbRow
    let buf: &i8 = alloc_pages(2)
    let pos = 0i64
    buf[pos] = '{'  pos = pos + 1
    let nc = res.col_count
    if nc == 0 { nc = row.count }
    loop c in 0..nc {
        if c > 0 { buf[pos] = ','  pos = pos + 1 }
        buf[pos] = '"'  pos = pos + 1
        if c < res.col_count {
            let cn: &ForgeColName = (res.col_names as i64 + c * 72) as &ForgeColName
            loop j in 0..cn.nlen { buf[pos] = cn.name[j]  pos = pos + 1 }
        } else {
            let nb: &i8 = alloc_pages(1)
            let nl = fmt_i64(nb, c)
            loop j in 0..nl { buf[pos] = nb[j]  pos = pos + 1 }
        }
        buf[pos] = '"'  pos = pos + 1
        buf[pos] = ':'  pos = pos + 1
        buf[pos] = '"'  pos = pos + 1
        let cell: &ForgeDbCell = (row.cols as i64 + c * FORGE_DB_COL_STRIDE) as &ForgeDbCell
        loop j in 0..cell.len {
            let ch = cell.data[j]
            if ch == '"' or ch == '\\' { buf[pos] = '\\'  pos = pos + 1 }
            buf[pos] = ch  pos = pos + 1
        }
        buf[pos] = '"'  pos = pos + 1
    }
    buf[pos] = '}'  pos = pos + 1
    ret buf[0..pos]
}

fn forge_result_to_json(res: &ForgeResult) -> []i8 {
    let buf: &i8 = alloc_pages(8)
    let pos = 0i64
    buf[pos] = '['  pos = pos + 1
    loop r in 0..res.count {
        if r > 0 { buf[pos] = ','  pos = pos + 1 }
        let obj = forge_row_to_json(res, r)
        loop i in 0..obj.len { buf[pos] = obj[i]  pos = pos + 1 }
    }
    buf[pos] = ']'  pos = pos + 1
    ret buf[0..pos]
}

// Render a full ForgeResult as a JSON array — all columns, all rows
fn ctx_json_result(ctx: i64, res: &ForgeResult) {
    ctx_json(ctx, 200, forge_result_to_json(res))
}

// Render the first row of a ForgeResult as a JSON object
fn ctx_json_row(ctx: i64, res: &ForgeResult) {
    ctx_json(ctx, 200, forge_row_to_json(res, 0))
}

// ---------------------------------------------------------------------------
// ForgeJson — selective JSON object builder
//
//   let post = post_find(id)
//   let j = forge_json_new()
//   j.field("id",    forge_result_col(post, 0, "id"))
//    .field("title", forge_result_col(post, 0, "title"))
//   ctx_json(ctx, 200, j.done())
// ---------------------------------------------------------------------------

struct ForgeJson {
    buf:   &i8
    pos:   i64
    empty: bool
}

fn forge_json_new() -> &ForgeJson {
    let j: &ForgeJson = alloc_pages(1)
    j.buf   = alloc_pages(8)
    j.pos   = 0
    j.empty = true
    j.buf[j.pos] = '{'  j.pos = j.pos + 1
    ret j
}

fn forge_json_field(j: &ForgeJson, key: []i8, val: []i8) -> &ForgeJson {
    if !j.empty { j.buf[j.pos] = ','  j.pos = j.pos + 1 }
    j.empty = false
    j.buf[j.pos] = '"'  j.pos = j.pos + 1
    loop i in 0..key.len { j.buf[j.pos] = key[i]  j.pos = j.pos + 1 }
    j.buf[j.pos] = '"'  j.pos = j.pos + 1
    j.buf[j.pos] = ':'  j.pos = j.pos + 1
    j.buf[j.pos] = '"'  j.pos = j.pos + 1
    loop i in 0..val.len {
        let ch = val[i]
        if ch == '"'  { j.buf[j.pos] = '\\'  j.pos = j.pos + 1 }
        if ch == '\\' { j.buf[j.pos] = '\\'  j.pos = j.pos + 1 }
        j.buf[j.pos] = ch  j.pos = j.pos + 1
    }
    j.buf[j.pos] = '"'  j.pos = j.pos + 1
    ret j
}

// field_raw — value is inserted as-is (use for numbers, booleans, nested objects)
fn forge_json_field_raw(j: &ForgeJson, key: []i8, raw: []i8) -> &ForgeJson {
    if !j.empty { j.buf[j.pos] = ','  j.pos = j.pos + 1 }
    j.empty = false
    j.buf[j.pos] = '"'  j.pos = j.pos + 1
    loop i in 0..key.len { j.buf[j.pos] = key[i]  j.pos = j.pos + 1 }
    j.buf[j.pos] = '"'  j.pos = j.pos + 1
    j.buf[j.pos] = ':'  j.pos = j.pos + 1
    loop i in 0..raw.len { j.buf[j.pos] = raw[i]  j.pos = j.pos + 1 }
    ret j
}

fn forge_json_done(j: &ForgeJson) -> []i8 {
    j.buf[j.pos] = '}'  j.pos = j.pos + 1
    ret j.buf[0..j.pos]
}

// ---------------------------------------------------------------------------
// ForgeJsonArray — build a JSON array from serialized objects
//
//   let a = forge_json_array_new()
//   loop r in 0..posts.count {
//       a.push(post_serialize(posts, r))
//   }
//   ctx_json(ctx, 200, a.done())
// ---------------------------------------------------------------------------

struct ForgeJsonArray {
    buf:   &i8
    pos:   i64
    empty: bool
}

fn forge_json_array_new() -> &ForgeJsonArray {
    let a: &ForgeJsonArray = alloc_pages(1)
    a.buf   = alloc_pages(64)
    a.pos   = 0
    a.empty = true
    a.buf[a.pos] = '['  a.pos = a.pos + 1
    ret a
}

fn forge_json_array_push(a: &ForgeJsonArray, obj: []i8) -> &ForgeJsonArray {
    if !a.empty { a.buf[a.pos] = ','  a.pos = a.pos + 1 }
    a.empty = false
    loop i in 0..obj.len { a.buf[a.pos] = obj[i]  a.pos = a.pos + 1 }
    ret a
}

fn forge_json_array_done(a: &ForgeJsonArray) -> []i8 {
    a.buf[a.pos] = ']'  a.pos = a.pos + 1
    ret a.buf[0..a.pos]
}

// ---------------------------------------------------------------------------
// ForgeAttrs — key/value builder for safe INSERT and UPDATE
//
//   forge_attrs_new().set("title", title).set("body", body).insert("posts")
//   forge_attrs_new().set("title", title).set("body", body).update("posts", id)
// ---------------------------------------------------------------------------

struct ForgeAttrs {
    kbuf:  &i8   // column names:  "title, body, author"
    vbuf:  &i8   // quoted values: "'val1', 'val2', 'val3'"
    sbuf:  &i8   // SET clauses:   "title = 'val1', body = 'val2'"
    kpos:  i64
    vpos:  i64
    spos:  i64
    empty: bool
}

fn forge_attrs_new() -> &ForgeAttrs {
    let a: &ForgeAttrs = alloc_pages(1)
    a.kbuf  = alloc_pages(2)
    a.vbuf  = alloc_pages(8)
    a.sbuf  = alloc_pages(8)
    a.kpos  = 0
    a.vpos  = 0
    a.spos  = 0
    a.empty = true
    forge_fa_reset()
    ret a
}

fn forge_attrs_set(a: &ForgeAttrs, key: []i8, val: []i8) -> &ForgeAttrs {
    forge_fa_store(key, val)
    if !a.empty {
        a.kbuf[a.kpos] = ','   a.kpos = a.kpos + 1
        a.kbuf[a.kpos] = ' '   a.kpos = a.kpos + 1
        a.vbuf[a.vpos] = ','   a.vpos = a.vpos + 1
        a.vbuf[a.vpos] = ' '   a.vpos = a.vpos + 1
        a.sbuf[a.spos] = ','   a.spos = a.spos + 1
        a.sbuf[a.spos] = ' '   a.spos = a.spos + 1
    }
    a.empty = false
    loop i in 0..key.len { a.kbuf[a.kpos] = key[i]   a.kpos = a.kpos + 1 }
    a.vbuf[a.vpos] = '\''   a.vpos = a.vpos + 1
    let vn = forge_db_escape_str(val, a.vbuf + a.vpos)
    a.vpos = a.vpos + vn
    a.vbuf[a.vpos] = '\''   a.vpos = a.vpos + 1
    loop i in 0..key.len { a.sbuf[a.spos] = key[i]   a.spos = a.spos + 1 }
    let eq = " = '"
    loop i in 0..eq.len  { a.sbuf[a.spos] = eq[i]    a.spos = a.spos + 1 }
    let sn = forge_db_escape_str(val, a.sbuf + a.spos)
    a.spos = a.spos + sn
    a.sbuf[a.spos] = '\''   a.spos = a.spos + 1
    ret a
}

fn forge_attrs_insert(a: &ForgeAttrs, table: []i8) -> bool {
    g_forge_save_context = "create"
    if not forge_attrs_validate(table)                          { ret false }
    if not forge_callback_run(table, FORGE_CB_BEFORE_SAVE, 0)   { ret false }
    if not forge_callback_run(table, FORGE_CB_BEFORE_CREATE, 0) { ret false }
    let buf: &i8 = alloc_pages(8)
    let pos = 0i64
    let p1 = "INSERT INTO "; let p2 = " ("; let p3 = ") VALUES ("; let p4 = ")"
    loop i in 0..p1.len    { buf[pos] = p1[i]       pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i]    pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]       pos = pos + 1 }
    loop i in 0..a.kpos    { buf[pos] = a.kbuf[i]   pos = pos + 1 }
    loop i in 0..p3.len    { buf[pos] = p3[i]       pos = pos + 1 }
    loop i in 0..a.vpos    { buf[pos] = a.vbuf[i]   pos = pos + 1 }
    loop i in 0..p4.len    { buf[pos] = p4[i]       pos = pos + 1 }
    let ok = forge_db_exec(buf[0..pos])
    if ok {
        forge__cc_after_create(table)
        forge_callback_run(table, FORGE_CB_AFTER_CREATE, 0)
        forge_callback_run(table, FORGE_CB_AFTER_SAVE, 0)
        forge_callback_run(table, FORGE_CB_AFTER_COMMIT, 0)
    } else {
        forge_callback_run(table, FORGE_CB_AFTER_ROLLBACK, 0)
    }
    ret ok
}

fn forge_attrs_update(a: &ForgeAttrs, table: []i8, id: []i8) -> bool {
    g_forge_save_context = "update"
    if not forge_attrs_validate(table)                          { ret false }
    if not forge_callback_run(table, FORGE_CB_BEFORE_SAVE, 0)   { ret false }
    if not forge_callback_run(table, FORGE_CB_BEFORE_UPDATE, 0) { ret false }
    let buf: &i8 = alloc_pages(8)
    let pos = 0i64
    let p1 = "UPDATE "; let p2 = " SET "; let p3 = ", updated_at = NOW() WHERE id = '"
    loop i in 0..p1.len    { buf[pos] = p1[i]       pos = pos + 1 }
    loop i in 0..table.len { buf[pos] = table[i]    pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]       pos = pos + 1 }
    loop i in 0..a.spos    { buf[pos] = a.sbuf[i]   pos = pos + 1 }
    loop i in 0..p3.len    { buf[pos] = p3[i]       pos = pos + 1 }
    let en = forge_db_escape_str(id, buf + pos)
    pos = pos + en
    buf[pos] = '\''   pos = pos + 1
    let ok = forge_db_exec(buf[0..pos])
    if ok {
        forge_callback_run(table, FORGE_CB_AFTER_UPDATE, 0)
        forge_callback_run(table, FORGE_CB_AFTER_SAVE, 0)
        forge_callback_run(table, FORGE_CB_AFTER_COMMIT, 0)
    } else {
        forge_callback_run(table, FORGE_CB_AFTER_ROLLBACK, 0)
    }
    ret ok
}

// =============================================================================
// Section H — Controller Layer
// =============================================================================
const FORGE_CTRL_MAX_FILTERS     = 8
const FORGE_CTRL_FILTER_NAME_CAP = 64   // enough for "show, edit, update, delete"
const FORGE_MAX_CTRLS            = 32
const FORGE_CTRL_ENTRY_STRIDE    = 80   // sizeof(ForgeCtrlEntry): [64]i8 + i64 + ptr

struct ForgeFilter {
    fn_ptr: i64
    only:   [FORGE_CTRL_FILTER_NAME_CAP]i8
    only_l: i64
    used:   bool
}

struct ForgeController {
    before:     [FORGE_CTRL_MAX_FILTERS]ForgeFilter
    after:      [FORGE_CTRL_MAX_FILTERS]ForgeFilter
    bc:         i64
    ac:         i64
    rescue_fn:  i64
}

fn forge_ctrl_new() -> &ForgeController {
    let ctrl: &ForgeController = alloc_pages(1)
    ctrl.bc        = 0
    ctrl.ac        = 0
    ctrl.rescue_fn = 0
    ret ctrl
}

fn forge_ctrl_before(ctrl: &ForgeController, fn_ptr: i64, only: []i8) {
    let n = ctrl.bc
    if n >= FORGE_CTRL_MAX_FILTERS { ret }
    ctrl.before[n].fn_ptr = fn_ptr
    let ol = only.len
    if ol > FORGE_CTRL_FILTER_NAME_CAP { ol = FORGE_CTRL_FILTER_NAME_CAP }
    loop i in 0..ol { ctrl.before[n].only[i] = only[i] }
    ctrl.before[n].only_l = ol
    ctrl.before[n].used   = true
    ctrl.bc = n + 1
}

fn forge_ctrl_after(ctrl: &ForgeController, fn_ptr: i64, only: []i8) {
    let n = ctrl.ac
    if n >= FORGE_CTRL_MAX_FILTERS { ret }
    ctrl.after[n].fn_ptr = fn_ptr
    let ol = only.len
    if ol > FORGE_CTRL_FILTER_NAME_CAP { ol = FORGE_CTRL_FILTER_NAME_CAP }
    loop i in 0..ol { ctrl.after[n].only[i] = only[i] }
    ctrl.after[n].only_l = ol
    ctrl.after[n].used   = true
    ctrl.ac = n + 1
}

// forge_ctrl_before_except — register a before filter that runs for ALL actions
// EXCEPT those in the comma-separated except list.
// Internally stored with only_l = 0 (match all) but checked via a negative list
// at dispatch time by encoding the except list with a leading '!' sentinel.
fn forge_ctrl_before_except(ctrl: &ForgeController, fn_ptr: i64, except: []i8) {
    let n = ctrl.bc
    if n >= FORGE_CTRL_MAX_FILTERS { ret }
    ctrl.before[n].fn_ptr = fn_ptr
    // Encode as "!except_list" so dispatch can detect the negation.
    let ol = except.len + 1
    if ol > FORGE_CTRL_FILTER_NAME_CAP { ol = FORGE_CTRL_FILTER_NAME_CAP }
    ctrl.before[n].only[0] = '!'
    let copy_len = ol - 1
    loop i in 0..copy_len { ctrl.before[n].only[i + 1] = except[i] }
    ctrl.before[n].only_l = ol
    ctrl.before[n].used   = true
    ctrl.bc = n + 1
}

// forge_ctrl_rescue — register a fallback handler called when the action
// completes without sending a response (unhandled error path).
// Handler signature: fn my_rescue(ctx: i64)
fn forge_ctrl_rescue(ctrl: &ForgeController, fn_ptr: i64) {
    ctrl.rescue_fn = fn_ptr
}

// forge__action_in_list — returns true if action appears in a comma-separated list.
// Handles "show", "show, edit", "show,edit,update,delete" (spaces optional).
fn forge__action_in_list(list: []i8, action: []i8) -> bool {
    let i = 0i64
    loop i < list.len {
        loop i < list.len and (list[i] == ' ' or list[i] == ',') { i = i + 1 }
        let j = i
        loop j < list.len and list[j] != ',' { j = j + 1 }
        let k = j
        loop k > i and list[k-1] == ' ' { k = k - 1 }
        if k - i == action.len {
            let m = true
            loop n in 0..action.len { if list[i+n] != action[n] { m = false  break } }
            if m { ret true }
        }
        i = j
        if i < list.len and list[i] == ',' { i = i + 1 }
    }
    ret false
}

fn forge_ctrl_dispatch(ctrl: &ForgeController, ctx: i64, action_fn: i64, action_name: []i8) {
    loop i in 0..ctrl.bc {
        let f = ctrl.before[i]
        if not f.used { continue }
        let matches = false
        if f.only_l == 0 {
            matches = true
        } else if f.only[0] == '!' {
            // except list: run unless action is in the list
            matches = not forge__action_in_list(f.only[1..f.only_l], action_name)
        } else {
            matches = forge__action_in_list(f.only[0..f.only_l], action_name)
        }
        if matches { call_fn(f.fn_ptr, ctx) }
        let c: &ForgeCtx = ctx
        if c.sent { ret }
    }
    call_fn(action_fn, ctx)
    let c2: &ForgeCtx = ctx
    if not c2.sent and ctrl.rescue_fn != 0 {
        call_fn(ctrl.rescue_fn, ctx)
    }
    loop i in 0..ctrl.ac {
        let f = ctrl.after[i]
        if not f.used { continue }
        let matches = f.only_l == 0 or forge__action_in_list(f.only[0..f.only_l], action_name)
        if matches { call_fn(f.fn_ptr, ctx) }
    }
}

// =============================================================================
// Controller registry — maps resource name → ForgeController.
// forge_ctrl_register("posts", ctrl)  called once at startup (before routes).
// forge_ctrl_run("posts", "show", fn_addr(posts_show), ctx)  called per request
//   by the generated dispatch shims in _build/controllers.jda.
// =============================================================================

struct ForgeCtrlEntry {
    name: [64]i8
    nlen: i64
    ctrl: &ForgeController
}

let g_forge_ctrl_entries: &ForgeCtrlEntry = 0 as &ForgeCtrlEntry
let g_forge_ctrl_count:   i64 = 0

fn forge_ctrl_register(name: []i8, ctrl: &ForgeController) {
    if g_forge_ctrl_entries == (0 as &ForgeCtrlEntry) {
        g_forge_ctrl_entries = alloc_pages(1) as &ForgeCtrlEntry
        g_forge_ctrl_count   = 0
    }
    if g_forge_ctrl_count >= FORGE_MAX_CTRLS { ret }
    let e: &ForgeCtrlEntry = (g_forge_ctrl_entries as i64 + g_forge_ctrl_count * FORGE_CTRL_ENTRY_STRIDE) as &ForgeCtrlEntry
    let nl = name.len
    if nl > 64 { nl = 64 }
    loop i in 0..nl { e.name[i] = name[i] }
    e.nlen = nl
    e.ctrl = ctrl
    g_forge_ctrl_count = g_forge_ctrl_count + 1
}

fn forge_ctrl_lookup(name: []i8) -> &ForgeController {
    if g_forge_ctrl_entries == (0 as &ForgeCtrlEntry) { ret 0 as &ForgeController }
    loop i in 0..g_forge_ctrl_count {
        let e: &ForgeCtrlEntry = (g_forge_ctrl_entries as i64 + i * FORGE_CTRL_ENTRY_STRIDE) as &ForgeCtrlEntry
        if e.nlen == name.len {
            let ok = true
            loop j in 0..name.len { if e.name[j] != name[j] { ok = false  break } }
            if ok { ret e.ctrl }
        }
    }
    ret 0 as &ForgeController
}

// forge_ctrl_run — called by generated dispatch shims.
// Looks up the registered controller for resource; runs filters then action.
// If no controller is registered, calls the action directly (zero overhead path).
fn forge_ctrl_run(resource: []i8, action: []i8, fn_ptr: i64, ctx: i64) {
    let ctrl = forge_ctrl_lookup(resource)
    if ctrl == (0 as &ForgeController) { call_fn(fn_ptr, ctx)  ret }
    forge_ctrl_dispatch(ctrl, ctx, fn_ptr, action)
}

fn forge_permit_json(ctx: i64, allowed: []i8) -> []i8 {
    let body = ctx_body(ctx)
    let out: &i8 = alloc_pages(1)
    let pos = 0i64
    out[pos] = '{'  pos = pos + 1
    let first = true
    let i = 0i64
    loop i < body.len {
        if body[i] == '"' {
            i = i + 1
            let key_start = i
            loop i < body.len and body[i] != '"' { i = i + 1 }
            let key = body[key_start..i]
            i = i + 1
            loop i < body.len and body[i] != ':' { i = i + 1 }
            i = i + 1
            loop i < body.len and (body[i] == ' ' or body[i] == '\t') { i = i + 1 }
            let val_start = i
            let depth = 0i64
            loop i < body.len {
                let ch = body[i]
                if ch == '{' or ch == '[' { depth = depth + 1 }
                if ch == '}' or ch == ']' {
                    if depth == 0 { break }
                    depth = depth - 1
                }
                if ch == ',' and depth == 0 { break }
                i = i + 1
            }
            let val = body[val_start..i]
            let a_start = 0i64
            let found = false
            loop j in 0..allowed.len {
                if allowed[j] == ',' {
                    let seg = allowed[a_start..j]
                    if forge_slice_eq(seg, key) { found = true  break }
                    a_start = j + 1
                }
            }
            if not found {
                let seg = allowed[a_start..allowed.len]
                if forge_slice_eq(seg, key) { found = true }
            }
            if found {
                if not first { out[pos] = ','  pos = pos + 1 }
                out[pos] = '"'  pos = pos + 1
                loop j in 0..key.len { out[pos] = key[j]  pos = pos + 1 }
                out[pos] = '"'  pos = pos + 1
                out[pos] = ':'  pos = pos + 1
                loop j in 0..val.len { out[pos] = val[j]  pos = pos + 1 }
                first = false
            }
        } else {
            i = i + 1
        }
    }
    out[pos] = '}'  pos = pos + 1
    ret out[0..pos]
}

fn forge_permit_form(ctx: i64, allowed: []i8, key: []i8) -> []i8 {
    ret ctx_form(ctx, key)
}

fn ctx_format(ctx: i64) -> []i8 {
    let accept = ctx_header(ctx, "Accept")
    let fmt_q  = ctx_query(ctx, "format")
    if forge_slice_eq(fmt_q, "json") { ret "json" }
    if forge_slice_eq(fmt_q, "html") { ret "html" }
    if forge_starts_with(accept, "application/json") { ret "json" }
    if forge_starts_with(accept, "text/html") { ret "html" }
    ret "html"
}

fn forge_paginate_query(q: &ForgeQuery, page: i64, per: i64) -> &ForgeResult {
    if page < 1 { page = 1 }
    if per  < 1 { per  = 20 }
    q.lim = per
    q.off = (page - 1) * per
    ret forge_q_exec(q)
}

fn forge_page_meta_json(total: i64, page: i64, per: i64) -> []i8 {
    let total_pages = (total + per - 1) / per
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "{\"page\":"
    loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, page)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    let p2 = ",\"per\":"
    loop i in 0..p2.len { buf[pos] = p2[i]  pos = pos + 1 }
    nl = fmt_i64(nb, per)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    let p3 = ",\"total\":"
    loop i in 0..p3.len { buf[pos] = p3[i]  pos = pos + 1 }
    nl = fmt_i64(nb, total)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    let p4 = ",\"total_pages\":"
    loop i in 0..p4.len { buf[pos] = p4[i]  pos = pos + 1 }
    nl = fmt_i64(nb, total_pages)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    buf[pos] = '}'  pos = pos + 1
    ret buf[0..pos]
}

// ctx_permit — strong parameters: extract and whitelist form fields from context.
// Returns a ForgeAttrs builder ready for .insert() or .update().
//   let attrs = ctx_permit(ctx, "title, body, author")
//   if attrs.insert("posts") { ... }
fn ctx_permit(ctx: i64, fields: []i8) -> &ForgeAttrs {
    let a = forge_attrs_new()
    let start = 0i64
    loop i in 0..fields.len {
        if fields[i] == ',' {
            let fa = start    let fb = i
            loop k in 0..64 { if fa < fb and fields[fa] == ' ' { fa = fa + 1 } }
            loop k in 0..64 { if fb > fa and fields[fb - 1] == ' ' { fb = fb - 1 } }
            if fb > fa { forge_attrs_set(a, fields[fa..fb], ctx_form(ctx, fields[fa..fb])) }
            start = i + 1
        }
    }
    let fa = start    let fb = fields.len
    loop k in 0..64 { if fa < fb and fields[fa] == ' ' { fa = fa + 1 } }
    loop k in 0..64 { if fb > fa and fields[fb - 1] == ' ' { fb = fb - 1 } }
    if fb > fa { forge_attrs_set(a, fields[fa..fb], ctx_form(ctx, fields[fa..fb])) }
    ret a
}

// ctx_save_errors — sets the "alert" flash from forge_last_errors().
// Use in the failure branch after a failed insert/update.
fn ctx_save_errors(ctx: i64) {
    let errs = forge_last_errors()
    if forge_errors_any(errs) {
        ctx_flash_set(ctx, "alert", forge_errors_json(errs))
    } else {
        ctx_flash_set(ctx, "alert", "Save failed.")
    }
}

// JSON response helpers — shorthand for API controllers.
fn ctx_json_ok     (ctx: i64, json: []i8) { ctx_json(ctx, 200, json) }
fn ctx_json_created(ctx: i64, json: []i8) { ctx_json(ctx, 201, json) }

// ctx_json_errors — 422 Unprocessable Entity with forge_last_errors() body.
fn ctx_json_errors(ctx: i64) {
    let errs = forge_last_errors()
    ctx_json(ctx, 422, forge_errors_json(errs))
}

// ctx_respond_to — branch on request format (Accept header or ?format= param).
// html_fn and json_fn have signature fn(i64) — receive ctx as argument.
fn ctx_respond_to(ctx: i64, html_fn: i64, json_fn: i64) {
    let fmt = ctx_format(ctx)
    if forge_slice_eq(fmt, "json") { call_fn(json_fn, ctx) } else { call_fn(html_fn, ctx) }
}

// =============================================================================
// Section I — View Helpers
// =============================================================================

// forge_h — inline HTML-escape for template use; returns a []i8 slice
fn forge_h(src: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let n = forge_html_escape(src, buf)
    ret buf[0..n]
}

fn forge_html_escape(src: []i8, dst: &i8) -> i64 {
    let pos = 0i64
    loop i in 0..src.len {
        let c = src[i]
        if c == '&' {
            let s = "&amp;"
            loop j in 0..s.len { dst[pos] = s[j]  pos = pos + 1 }
        } else if c == '<' {
            let s = "&lt;"
            loop j in 0..s.len { dst[pos] = s[j]  pos = pos + 1 }
        } else if c == '>' {
            let s = "&gt;"
            loop j in 0..s.len { dst[pos] = s[j]  pos = pos + 1 }
        } else if c == '"' {
            let s = "&quot;"
            loop j in 0..s.len { dst[pos] = s[j]  pos = pos + 1 }
        } else if c == '\'' {
            let s = "&#39;"
            loop j in 0..s.len { dst[pos] = s[j]  pos = pos + 1 }
        } else {
            dst[pos] = c  pos = pos + 1
        }
    }
    ret pos
}

fn forge_link_to(text: []i8, url: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<a href=\""
    let p2 = "\">"
    let p3 = "</a>"
    loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
    loop i in 0..url.len  { buf[pos] = url[i]   pos = pos + 1 }
    loop i in 0..p2.len { buf[pos] = p2[i]  pos = pos + 1 }
    loop i in 0..text.len { buf[pos] = text[i]  pos = pos + 1 }
    loop i in 0..p3.len { buf[pos] = p3[i]  pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_link_to_delete(text: []i8, url: []i8, csrf: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<form action=\""
    let p2 = "\" method=\"post\"><input type=\"hidden\" name=\"_method\" value=\"DELETE\"><input type=\"hidden\" name=\"_csrf\" value=\""
    let p3 = "\"><button type=\"submit\">"
    let p4 = "</button></form>"
    loop i in 0..p1.len  { buf[pos] = p1[i]   pos = pos + 1 }
    loop i in 0..url.len  { buf[pos] = url[i]   pos = pos + 1 }
    loop i in 0..p2.len  { buf[pos] = p2[i]   pos = pos + 1 }
    loop i in 0..csrf.len { buf[pos] = csrf[i]  pos = pos + 1 }
    loop i in 0..p3.len  { buf[pos] = p3[i]   pos = pos + 1 }
    loop i in 0..text.len { buf[pos] = text[i]  pos = pos + 1 }
    loop i in 0..p4.len  { buf[pos] = p4[i]   pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_button_to(text: []i8, url: []i8, method: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<form action=\""
    let p2 = "\" method=\"post\"><input type=\"hidden\" name=\"_method\" value=\""
    let p3 = "\"><button type=\"submit\">"
    let p4 = "</button></form>"
    loop i in 0..p1.len     { buf[pos] = p1[i]      pos = pos + 1 }
    loop i in 0..url.len     { buf[pos] = url[i]      pos = pos + 1 }
    loop i in 0..p2.len     { buf[pos] = p2[i]      pos = pos + 1 }
    loop i in 0..method.len  { buf[pos] = method[i]   pos = pos + 1 }
    loop i in 0..p3.len     { buf[pos] = p3[i]      pos = pos + 1 }
    loop i in 0..text.len   { buf[pos] = text[i]    pos = pos + 1 }
    loop i in 0..p4.len     { buf[pos] = p4[i]      pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_form_tag_open(action: []i8, method: []i8, csrf_token: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<form action=\""
    let p2 = "\" method=\""
    let p3 = "\"><input type=\"hidden\" name=\"_csrf\" value=\""
    let p4 = "\">"
    loop i in 0..p1.len       { buf[pos] = p1[i]         pos = pos + 1 }
    loop i in 0..action.len    { buf[pos] = action[i]      pos = pos + 1 }
    loop i in 0..p2.len       { buf[pos] = p2[i]         pos = pos + 1 }
    loop i in 0..method.len    { buf[pos] = method[i]      pos = pos + 1 }
    loop i in 0..p3.len       { buf[pos] = p3[i]         pos = pos + 1 }
    loop i in 0..csrf_token.len { buf[pos] = csrf_token[i]  pos = pos + 1 }
    loop i in 0..p4.len       { buf[pos] = p4[i]         pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_form_tag_close() -> []i8 {
    ret "</form>"
}

fn forge_input_tag(type_s: []i8, name: []i8, value: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<input type=\""
    let p2 = "\" name=\""
    let p3 = "\" value=\""
    let p4 = "\">"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..type_s.len { buf[pos] = type_s[i]  pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    loop i in 0..name.len   { buf[pos] = name[i]   pos = pos + 1 }
    loop i in 0..p3.len    { buf[pos] = p3[i]    pos = pos + 1 }
    loop i in 0..value.len  { buf[pos] = value[i]  pos = pos + 1 }
    loop i in 0..p4.len    { buf[pos] = p4[i]    pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_label_tag(for_s: []i8, text: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<label for=\""
    let p2 = "\">"
    let p3 = "</label>"
    loop i in 0..p1.len  { buf[pos] = p1[i]   pos = pos + 1 }
    loop i in 0..for_s.len { buf[pos] = for_s[i]  pos = pos + 1 }
    loop i in 0..p2.len  { buf[pos] = p2[i]   pos = pos + 1 }
    loop i in 0..text.len { buf[pos] = text[i]  pos = pos + 1 }
    loop i in 0..p3.len  { buf[pos] = p3[i]   pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_submit_tag(text: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<input type=\"submit\" value=\""
    let p2 = "\">"
    loop i in 0..p1.len  { buf[pos] = p1[i]   pos = pos + 1 }
    loop i in 0..text.len { buf[pos] = text[i]  pos = pos + 1 }
    loop i in 0..p2.len  { buf[pos] = p2[i]   pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_textarea_tag(name: []i8, value: []i8, rows: i64, cols: i64) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "<textarea name=\""
    let p2 = "\" rows=\""
    let p3 = "\" cols=\""
    let p4 = "\">"
    let p5 = "</textarea>"
    loop i in 0..p1.len  { buf[pos] = p1[i]   pos = pos + 1 }
    loop i in 0..name.len { buf[pos] = name[i]  pos = pos + 1 }
    loop i in 0..p2.len  { buf[pos] = p2[i]   pos = pos + 1 }
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, rows)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    loop i in 0..p3.len { buf[pos] = p3[i]  pos = pos + 1 }
    nl = fmt_i64(nb, cols)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    loop i in 0..p4.len   { buf[pos] = p4[i]   pos = pos + 1 }
    loop i in 0..value.len { buf[pos] = value[i]  pos = pos + 1 }
    loop i in 0..p5.len   { buf[pos] = p5[i]   pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_select_tag(name: []i8, options: []i8, selected: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(2)
    let pos = 0i64
    let p1 = "<select name=\""
    let p2 = "\">"
    let p3 = "</select>"
    loop i in 0..p1.len  { buf[pos] = p1[i]   pos = pos + 1 }
    loop i in 0..name.len { buf[pos] = name[i]  pos = pos + 1 }
    loop i in 0..p2.len  { buf[pos] = p2[i]   pos = pos + 1 }
    let start = 0i64
    loop i in 0..options.len {
        if options[i] == ',' or i == options.len - 1 {
            let end = i
            if i == options.len - 1 and options[i] != ',' { end = i + 1 }
            let seg = options[start..end]
            let colon_pos = -1i64
            loop j in 0..seg.len { if seg[j] == ':' { colon_pos = j  break } }
            let opt_p1 = "<option value=\""
            loop j in 0..opt_p1.len { buf[pos] = opt_p1[j]  pos = pos + 1 }
            if colon_pos >= 0 {
                let val_s = seg[0..colon_pos]
                let lbl_s = seg[colon_pos+1..seg.len]
                loop j in 0..val_s.len { buf[pos] = val_s[j]  pos = pos + 1 }
                buf[pos] = '"'  pos = pos + 1
                if forge_slice_eq(val_s, selected) {
                    let sel_s = " selected"
                    loop j in 0..sel_s.len { buf[pos] = sel_s[j]  pos = pos + 1 }
                }
                buf[pos] = '>'  pos = pos + 1
                loop j in 0..lbl_s.len { buf[pos] = lbl_s[j]  pos = pos + 1 }
            } else {
                loop j in 0..seg.len { buf[pos] = seg[j]  pos = pos + 1 }
                buf[pos] = '"'  pos = pos + 1
                if forge_slice_eq(seg, selected) {
                    let sel_s = " selected"
                    loop j in 0..sel_s.len { buf[pos] = sel_s[j]  pos = pos + 1 }
                }
                buf[pos] = '>'  pos = pos + 1
                loop j in 0..seg.len { buf[pos] = seg[j]  pos = pos + 1 }
            }
            let opt_p2 = "</option>"
            loop j in 0..opt_p2.len { buf[pos] = opt_p2[j]  pos = pos + 1 }
            start = i + 1
        }
    }
    loop i in 0..p3.len { buf[pos] = p3[i]  pos = pos + 1 }
    ret buf[0..pos]
}

// =============================================================================
// Form builder with model binding — generates a label + input pair in a
// <div class="field"> wrapper, pre-filled from the supplied current value.
// Use inside ERB templates with <%== %> since the output is already HTML-safe.
//
// Example:
//   <%== forge_field_tag("title", "Post Title", p.title) %>
//   <%== forge_textarea_field_tag("body", "Body", p.body, 8, 60) %>
//   <%== forge_select_field_tag("status", "Status", "draft,published,archived", p.status) %>
// =============================================================================

fn forge_field_tag(col: []i8, label: []i8, current_val: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("<div class=\"field\">")
    buf.write(forge_label_tag(col, label))
    buf.write(forge_input_tag("text", col, current_val))
    buf.write("</div>")
    ret buf.done()
}

fn forge_field_tag_type(col: []i8, label: []i8, type_s: []i8, current_val: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("<div class=\"field\">")
    buf.write(forge_label_tag(col, label))
    buf.write(forge_input_tag(type_s, col, current_val))
    buf.write("</div>")
    ret buf.done()
}

fn forge_textarea_field_tag(col: []i8, label: []i8, current_val: []i8, rows: i64, cols: i64) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("<div class=\"field\">")
    buf.write(forge_label_tag(col, label))
    buf.write(forge_textarea_tag(col, current_val, rows, cols))
    buf.write("</div>")
    ret buf.done()
}

fn forge_select_field_tag(col: []i8, label: []i8, options: []i8, current_val: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("<div class=\"field\">")
    buf.write(forge_label_tag(col, label))
    buf.write(forge_select_tag(col, options, current_val))
    buf.write("</div>")
    ret buf.done()
}

fn forge_path(resource: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    buf[pos] = '/'  pos = pos + 1
    loop i in 0..resource.len { buf[pos] = resource[i]  pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_path_id(resource: []i8, id: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    buf[pos] = '/'  pos = pos + 1
    loop i in 0..resource.len { buf[pos] = resource[i]  pos = pos + 1 }
    buf[pos] = '/'  pos = pos + 1
    loop i in 0..id.len { buf[pos] = id[i]  pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_path_new(resource: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    buf[pos] = '/'  pos = pos + 1
    loop i in 0..resource.len { buf[pos] = resource[i]  pos = pos + 1 }
    let suf = "/new"
    loop i in 0..suf.len { buf[pos] = suf[i]  pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_path_edit(resource: []i8, id: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    buf[pos] = '/'  pos = pos + 1
    loop i in 0..resource.len { buf[pos] = resource[i]  pos = pos + 1 }
    buf[pos] = '/'  pos = pos + 1
    loop i in 0..id.len { buf[pos] = id[i]  pos = pos + 1 }
    let suf = "/edit"
    loop i in 0..suf.len { buf[pos] = suf[i]  pos = pos + 1 }
    ret buf[0..pos]
}

// Nested resource path helpers — build /parent/parent_id/child[/id][/edit|/new]
fn forge_nested_path(parent: []i8, parent_id: []i8, child: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("/").write(parent).write("/").write(parent_id).write("/").write(child)
    ret buf.done()
}

fn forge_nested_path_id(parent: []i8, parent_id: []i8, child: []i8, id: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("/").write(parent).write("/").write(parent_id)
       .write("/").write(child).write("/").write(id)
    ret buf.done()
}

fn forge_nested_path_new(parent: []i8, parent_id: []i8, child: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("/").write(parent).write("/").write(parent_id)
       .write("/").write(child).write("/new")
    ret buf.done()
}

fn forge_nested_path_edit(parent: []i8, parent_id: []i8, child: []i8, id: []i8) -> []i8 {
    let buf = forge_buf_new(1)
    buf.write("/").write(parent).write("/").write(parent_id)
       .write("/").write(child).write("/").write(id).write("/edit")
    ret buf.done()
}

fn forge_truncate(s: []i8, max: i64) -> []i8 {
    if s.len <= max { ret s }
    let buf: &i8 = alloc_pages(1)
    let cut = max - 3
    if cut < 0 { cut = 0 }
    loop i in 0..cut { buf[i] = s[i] }
    let dots = "..."
    loop i in 0..dots.len { buf[cut + i] = dots[i] }
    ret buf[0..cut + 3]
}

fn forge_pluralize(count: i64, singular: []i8, plural: []i8) -> []i8 {
    if count == 1 { ret singular }
    ret plural
}

// forge_highlight — wrap every case-insensitive occurrence of phrase in str with
// open_tag + match + close_tag.  tag_name is just the element name, e.g. "em".
fn forge_highlight(s: []i8, phrase: []i8, tag_name: []i8) -> []i8 {
    if phrase.len == 0 { ret s }
    let buf = forge_buf_new(4)
    let i = 0i64
    loop i < s.len {
        // Check for phrase match at position i (case-insensitive)
        let match = false
        if i + phrase.len <= s.len {
            match = true
            loop k in 0..phrase.len {
                let sc = s[i + k]
                let pc = phrase[k]
                if sc >= 'A' and sc <= 'Z' { sc = sc + 32 }
                if pc >= 'A' and pc <= 'Z' { pc = pc + 32 }
                if sc != pc { match = false  break }
            }
        }
        if match {
            buf.write("<").write(tag_name).write(">")
            buf.write(s[i..(i + phrase.len)])
            buf.write("</").write(tag_name).write(">")
            i = i + phrase.len
        } else {
            let ch: [1]i8
            ch[0] = s[i]
            buf.write(ch[0..1])
            i = i + 1
        }
    }
    ret buf.done()
}

// forge_excerpt — extract up to radius chars around the first occurrence of phrase.
// Adds "..." at edges when the excerpt doesn't include the string boundaries.
fn forge_excerpt(s: []i8, phrase: []i8, radius: i64) -> []i8 {
    if s.len == 0 { ret "" }
    let found = -1i64
    if phrase.len == 0 {
        found = 0
    } else {
        loop i in 0..(s.len - phrase.len + 1) {
            let m = true
            loop k in 0..phrase.len {
                let sc = s[i + k]
                let pc = phrase[k]
                if sc >= 'A' and sc <= 'Z' { sc = sc + 32 }
                if pc >= 'A' and pc <= 'Z' { pc = pc + 32 }
                if sc != pc { m = false  break }
            }
            if m { found = i  break }
        }
    }
    if found < 0 { ret s[0..radius] }
    let start = found - radius
    if start < 0 { start = 0 }
    let end = found + phrase.len + radius
    if end > s.len { end = s.len }
    let buf = forge_buf_new(1)
    if start > 0 { buf.write("...") }
    buf.write(s[start..end])
    if end < s.len { buf.write("...") }
    ret buf.done()
}

// forge_enum_val — return the 0-based index of name in a comma-separated list.
// Returns "-1" when not found.
fn forge_enum_val(name: []i8, vals_csv: []i8) -> []i8 {
    let idx = 0i64
    let i = 0i64
    loop i < vals_csv.len {
        loop i < vals_csv.len and vals_csv[i] == ' ' { i = i + 1 }
        let j = i
        loop j < vals_csv.len and vals_csv[j] != ',' { j = j + 1 }
        let k = j
        loop k > i and vals_csv[k-1] == ' ' { k = k - 1 }
        let entry = vals_csv[i..k]
        if forge_slice_eq(entry, name) {
            let out: &i8 = alloc_pages(1)
            let ol = fmt_i64(out, idx)
            ret out[0..ol]
        }
        idx = idx + 1
        i = j
        if i < vals_csv.len and vals_csv[i] == ',' { i = i + 1 }
    }
    ret "-1"
}

// forge_enum_name — return the name at 0-based position idx in a comma-separated list.
// Returns "" when idx is out of range.
fn forge_enum_name(idx: i64, vals_csv: []i8) -> []i8 {
    let cur = 0i64
    let i = 0i64
    loop i < vals_csv.len {
        loop i < vals_csv.len and vals_csv[i] == ' ' { i = i + 1 }
        let j = i
        loop j < vals_csv.len and vals_csv[j] != ',' { j = j + 1 }
        let k = j
        loop k > i and vals_csv[k-1] == ' ' { k = k - 1 }
        if cur == idx { ret vals_csv[i..k] }
        cur = cur + 1
        i = j
        if i < vals_csv.len and vals_csv[i] == ',' { i = i + 1 }
    }
    ret ""
}

// forge_time_ago — return human-readable relative time string ("5 minutes ago").
fn forge_time_ago(ts_ms: i64) -> []i8 {
    let now = time_now_ms()
    let diff = now - ts_ms
    if diff < 0 { diff = -diff }
    let secs = diff / 1000
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let suffix = " ago"
    if secs < 60 {
        let s = "less than a minute"
        loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
    } else if secs < 3600 {
        let mins = secs / 60
        if mins == 1 {
            let s = "1 minute"
            loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
        } else {
            let n: &i8 = alloc_pages(1)
            let nl = fmt_i64(n, mins)
            loop i in 0..nl { buf[pos] = n[i]  pos = pos + 1 }
            let s = " minutes"
            loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
        }
    } else if secs < 86400 {
        let hrs = secs / 3600
        if hrs == 1 {
            let s = "about 1 hour"
            loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
        } else {
            let s = "about "
            loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
            let n: &i8 = alloc_pages(1)
            let nl = fmt_i64(n, hrs)
            loop i in 0..nl { buf[pos] = n[i]  pos = pos + 1 }
            let s2 = " hours"
            loop i in 0..s2.len { buf[pos] = s2[i]  pos = pos + 1 }
        }
    } else {
        let days = secs / 86400
        if days == 1 {
            let s = "1 day"
            loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
        } else {
            let n: &i8 = alloc_pages(1)
            let nl = fmt_i64(n, days)
            loop i in 0..nl { buf[pos] = n[i]  pos = pos + 1 }
            let s = " days"
            loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
        }
    }
    loop i in 0..suffix.len { buf[pos] = suffix[i]  pos = pos + 1 }
    ret buf[0..pos]
}

// forge_distance_of_time — human-readable distance between two timestamps (ms).
fn forge_distance_of_time(from_ms: i64, to_ms: i64) -> []i8 {
    let diff = to_ms - from_ms
    if diff < 0 { diff = -diff }
    let secs = diff / 1000
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    if secs < 30 {
        let s = "less than a minute"
        loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
    } else if secs < 3600 {
        let mins = (secs + 30) / 60
        let p1 = "about "
        loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
        let n: &i8 = alloc_pages(1)
        let nl = fmt_i64(n, mins)
        loop i in 0..nl { buf[pos] = n[i]  pos = pos + 1 }
        let s = " minutes"
        loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
    } else if secs < 86400 {
        let hrs = (secs + 1800) / 3600
        let p1 = "about "
        loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
        let n: &i8 = alloc_pages(1)
        let nl = fmt_i64(n, hrs)
        loop i in 0..nl { buf[pos] = n[i]  pos = pos + 1 }
        let s = " hours"
        loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
    } else {
        let days = (secs + 43200) / 86400
        let n: &i8 = alloc_pages(1)
        let nl = fmt_i64(n, days)
        loop i in 0..nl { buf[pos] = n[i]  pos = pos + 1 }
        let s = " days"
        loop i in 0..s.len { buf[pos] = s[i]  pos = pos + 1 }
    }
    ret buf[0..pos]
}

// forge_number_to_currency — format integer cents as "$12.34".
fn forge_number_to_currency(cents: i64) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    if cents < 0 {
        buf[pos] = '-'  pos = pos + 1
        cents = -cents
    }
    buf[pos] = '$'  pos = pos + 1
    let dollars = cents / 100
    let frac    = cents mod 100
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, dollars)
    // Insert thousands separators
    let tmp: &i8 = alloc_pages(1)
    loop i in 0..nl { tmp[i] = nb[i] }
    let sep_count = (nl - 1) / 3
    let i = 0i64
    loop i < nl {
        buf[pos] = tmp[i]  pos = pos + 1
        let rem = nl - i - 1
        if rem > 0 and rem mod 3 == 0 { buf[pos] = ','  pos = pos + 1 }
        i = i + 1
    }
    buf[pos] = '.'  pos = pos + 1
    if frac < 10 { buf[pos] = '0'  pos = pos + 1 }
    nl = fmt_i64(nb, frac)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    ret buf[0..pos]
}

// forge_number_with_delimiter — format integer with commas: 1234567 → "1,234,567".
fn forge_number_with_delimiter(n: i64) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let neg = n < 0
    if neg { n = -n }
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, n)
    if neg { buf[pos] = '-'  pos = pos + 1 }
    let i = 0i64
    loop i < nl {
        buf[pos] = nb[i]  pos = pos + 1
        let rem = nl - i - 1
        if rem > 0 and rem mod 3 == 0 { buf[pos] = ','  pos = pos + 1 }
        i = i + 1
    }
    ret buf[0..pos]
}

// forge_word_wrap — wrap s at word boundaries, inserting "\n" at width.
fn forge_word_wrap(s: []i8, width: i64) -> []i8 {
    let buf: &i8 = alloc_pages(4)
    let pos = 0i64
    let col = 0i64
    let i   = 0i64
    loop i < s.len {
        if s[i] == '\n' {
            buf[pos] = '\n'  pos = pos + 1
            col = 0
            i = i + 1
            continue
        }
        // Find end of current word
        let j = i
        loop j < s.len and s[j] != ' ' and s[j] != '\n' { j = j + 1 }
        let word_len = j - i
        if col > 0 and col + 1 + word_len > width {
            buf[pos] = '\n'  pos = pos + 1
            col = 0
        } else if col > 0 {
            buf[pos] = ' '   pos = pos + 1
            col = col + 1
        }
        loop k in i..j { buf[pos] = s[k]  pos = pos + 1 }
        col = col + word_len
        i = j
        // Skip the space
        if i < s.len and s[i] == ' ' { i = i + 1 }
    }
    ret buf[0..pos]
}

fn forge_content_for(ctx: i64, key: []i8, content: []i8) {
    let kb: &i8 = alloc_pages(1)
    let kp = 0i64
    let pfx = "_cf_"
    loop i in 0..pfx.len { kb[kp] = pfx[i]  kp = kp + 1 }
    loop i in 0..key.len  { kb[kp] = key[i]   kp = kp + 1 }
    ctx_set(ctx, kb[0..kp], content as i64)
}

fn forge_yield_content(ctx: i64, key: []i8) -> []i8 {
    let kb: &i8 = alloc_pages(1)
    let kp = 0i64
    let pfx = "_cf_"
    loop i in 0..pfx.len { kb[kp] = pfx[i]  kp = kp + 1 }
    loop i in 0..key.len  { kb[kp] = key[i]   kp = kp + 1 }
    let val = ctx_get(ctx, kb[0..kp])
    if val == 0 { ret "" }
    ret val as []i8
}

// Template registry
const FORGE_TMPL_MAX      = 32
const FORGE_TMPL_NAME_CAP = 32

struct ForgeTmplEntry {
    name:  [FORGE_TMPL_NAME_CAP]i8
    nlen:  i64
    tmpl:  []i8
    used:  bool
}

let g_forge_tmpl_store: &ForgeTmplEntry = 0
let g_forge_tmpl_count: i64 = 0

fn forge_tmpl_init() {
    if g_forge_tmpl_store != 0 { ret }
    g_forge_tmpl_store = alloc_pages(4) as &ForgeTmplEntry
}

fn forge_template_register(name: []i8, tmpl: []i8) {
    forge_tmpl_init()
    let stride = 50i64   // 32 + 8 + 8 + 1 + 1 pad
    let n = g_forge_tmpl_count
    if n >= FORGE_TMPL_MAX { ret }
    let entry: &ForgeTmplEntry = (g_forge_tmpl_store as i64 + n * stride) as &ForgeTmplEntry
    let nl = name.len
    if nl > FORGE_TMPL_NAME_CAP { nl = FORGE_TMPL_NAME_CAP }
    loop i in 0..nl { entry.name[i] = name[i] }
    entry.nlen = nl
    entry.tmpl = tmpl
    entry.used = true
    g_forge_tmpl_count = n + 1
}

fn forge_partial(name: []i8, vars: &i64) -> []i8 {
    forge_tmpl_init()
    let stride = 50i64
    loop i in 0..g_forge_tmpl_count {
        let entry: &ForgeTmplEntry = (g_forge_tmpl_store as i64 + i * stride) as &ForgeTmplEntry
        if not entry.used { continue }
        if forge_slice_eq(entry.name[0..entry.nlen], name) {
            ret erb_render(entry.tmpl, vars)
        }
    }
    ret ""
}

// =============================================================================
// Section J — Testing Framework
// =============================================================================
const FORGE_MAX_TESTS      = 128
const FORGE_TEST_NAME_CAP  = 64

struct ForgeTestCase {
    name:   [FORGE_TEST_NAME_CAP]i8
    nlen:   i64
    fn_ptr: i64
    used:   bool
}

let g_forge_tests:      &ForgeTestCase = 0
let g_forge_test_count: i64            = 0
let g_forge_test_fails: i64            = 0

fn forge_test_init() {
    if g_forge_tests != 0 { ret }
    g_forge_tests = alloc_pages(8) as &ForgeTestCase
}

fn forge_test(name: []i8, fn_ptr: i64) {
    forge_test_init()
    let stride = 82i64   // 64 + 8 + 8 + 1 + 1 pad
    let n = g_forge_test_count
    if n >= FORGE_MAX_TESTS { ret }
    let tc: &ForgeTestCase = (g_forge_tests as i64 + n * stride) as &ForgeTestCase
    let nl = name.len
    if nl > FORGE_TEST_NAME_CAP { nl = FORGE_TEST_NAME_CAP }
    loop i in 0..nl { tc.name[i] = name[i] }
    tc.nlen   = nl
    tc.fn_ptr = fn_ptr
    tc.used   = true
    g_forge_test_count = n + 1
}

fn forge_test_run() {
    forge_test_init()
    let stride = 82i64
    let pass_count = 0i64
    let fail_count = 0i64
    loop i in 0..g_forge_test_count {
        let tc: &ForgeTestCase = (g_forge_tests as i64 + i * stride) as &ForgeTestCase
        if not tc.used { continue }
        g_forge_test_fails = 0
        call_fn(tc.fn_ptr, 0)
        let ok = g_forge_test_fails == 0
        let buf: &i8 = alloc_pages(1)
        let pos = 0i64
        if ok {
            let p = "PASS "
            loop j in 0..p.len { buf[pos] = p[j]  pos = pos + 1 }
            pass_count = pass_count + 1
        } else {
            let p = "FAIL "
            loop j in 0..p.len { buf[pos] = p[j]  pos = pos + 1 }
            fail_count = fail_count + 1
        }
        loop j in 0..tc.nlen { buf[pos] = tc.name[j]  pos = pos + 1 }
        buf[pos] = '\n'  pos = pos + 1
        syscall(FORGE_SYS_WRITE, 1, buf, pos, 0, 0, 0)
    }
    let sum_buf: &i8 = alloc_pages(1)
    let sp = 0i64
    let s1 = "\n--- "
    loop i in 0..s1.len { sum_buf[sp] = s1[i]  sp = sp + 1 }
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, pass_count)
    loop i in 0..nl { sum_buf[sp] = nb[i]  sp = sp + 1 }
    let s2 = " passed, "
    loop i in 0..s2.len { sum_buf[sp] = s2[i]  sp = sp + 1 }
    nl = fmt_i64(nb, fail_count)
    loop i in 0..nl { sum_buf[sp] = nb[i]  sp = sp + 1 }
    let s3 = " failed ---\n"
    loop i in 0..s3.len { sum_buf[sp] = s3[i]  sp = sp + 1 }
    syscall(FORGE_SYS_WRITE, 1, sum_buf, sp, 0, 0, 0)
    if fail_count > 0 {
        syscall(231, 1, 0, 0, 0, 0, 0)   // exit_group(1)
    }
}

fn forge_test_request(method: []i8, path: []i8, body: []i8) -> &ForgeTestResponse {
    g_forge_test_mode = true
    g_forge_test_cap_status   = 0
    g_forge_test_cap_body_ptr = 0
    g_forge_test_cap_body_len = 0
    let ctx_raw: &i8 = alloc_pages(4)
    let ctx_ptr = ctx_raw as i64
    let c: &ForgeCtx = ctx_ptr
    c.fd          = -1
    c.param_count = 0
    c.out_hcount  = 0
    c.store_count = 0
    c.sent        = false
    c.is_ws       = false
    // Extract query string from path
    let path_only = path
    let query_s   = ""
    loop i in 0..path.len {
        if path[i] == '?' {
            path_only = path[0..i]
            query_s   = path[i+1..path.len]
            break
        }
    }
    c.req.method = method
    c.req.path   = path_only
    c.req.query  = query_s
    c.req.body   = body
    if g_forge_app != 0 {
        let app: &ForgeApp = g_forge_app
        forge_dispatch(app, ctx_ptr)
    }
    let resp: &ForgeTestResponse = alloc_pages(1)
    resp.status = g_forge_test_cap_status
    if g_forge_test_cap_body_ptr != 0 {
        let bp: &i8 = g_forge_test_cap_body_ptr as &i8
        resp.body = bp[0..g_forge_test_cap_body_len]
    } else {
        resp.body = ""
    }
    g_forge_test_mode = false
    ret resp
}

fn forge_test_get(path: []i8) -> &ForgeTestResponse {
    ret forge_test_request("GET", path, "")
}

fn forge_test_post(path: []i8, body: []i8) -> &ForgeTestResponse {
    ret forge_test_request("POST", path, body)
}

fn forge_test_put(path: []i8, body: []i8) -> &ForgeTestResponse {
    ret forge_test_request("PUT", path, body)
}

fn forge_test_delete(path: []i8) -> &ForgeTestResponse {
    ret forge_test_request("DELETE", path, "")
}

// Short request aliases — drop the _test_ infix
fn forge_get(path: []i8) -> &ForgeTestResponse              { ret forge_test_get(path) }
fn forge_post(path: []i8, body: []i8) -> &ForgeTestResponse { ret forge_test_post(path, body) }
fn forge_put(path: []i8, body: []i8) -> &ForgeTestResponse  { ret forge_test_put(path, body) }
fn forge_delete(path: []i8) -> &ForgeTestResponse           { ret forge_test_delete(path) }

// Response accessors  (UFCS prefix: forge_test_res)
fn forge_test_res_body(res: &ForgeTestResponse) -> []i8 { ret res.body }
fn forge_test_res_status(res: &ForgeTestResponse) -> i32 { ret res.status }

// Chainable assertion methods  (UFCS: res.ok(200)  res.redirect()  res.has(s)  res.not_has(s))
fn forge_test_res_ok(res: &ForgeTestResponse, code: i32) -> &ForgeTestResponse {
    forge_assert_status(res, code)
    ret res
}
fn forge_test_res_redirect(res: &ForgeTestResponse) -> &ForgeTestResponse {
    forge_assert_redirect(res)
    ret res
}
fn forge_test_res_has(res: &ForgeTestResponse, s: []i8) -> &ForgeTestResponse {
    forge_assert_body_has(res, s)
    ret res
}
fn forge_test_res_not_has(res: &ForgeTestResponse, s: []i8) -> &ForgeTestResponse {
    let body = res.body
    if s.len == 0 { ret res }
    loop i in 0..body.len {
        if i + s.len > body.len { break }
        let match = true
        loop j in 0..s.len {
            if body[i + j] != s[j] { match = false  break }
        }
        if match {
            let buf: &i8 = alloc_pages(1)
            let pos = 0i64
            let p1 = "  ASSERT NOT HAS FAILED: found unexpected substring: "
            loop k in 0..p1.len { buf[pos] = p1[k]  pos = pos + 1 }
            loop k in 0..s.len  { buf[pos] = s[k]   pos = pos + 1 }
            buf[pos] = '\n'  pos = pos + 1
            syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
            g_forge_test_fails = g_forge_test_fails + 1
            ret res
        }
    }
    ret res
}

fn forge_assert(cond: bool, msg: []i8) -> bool {
    if not cond {
        let p = "  ASSERT FAILED: "
        let buf: &i8 = alloc_pages(1)
        let pos = 0i64
        loop i in 0..p.len   { buf[pos] = p[i]    pos = pos + 1 }
        loop i in 0..msg.len { buf[pos] = msg[i]   pos = pos + 1 }
        buf[pos] = '\n'  pos = pos + 1
        syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
        g_forge_test_fails = g_forge_test_fails + 1
        ret false
    }
    ret true
}

fn forge_assert_eq(a: []i8, b: []i8, msg: []i8) -> bool {
    if not forge_slice_eq(a, b) {
        let p = "  ASSERT EQ FAILED: "
        let buf: &i8 = alloc_pages(1)
        let pos = 0i64
        loop i in 0..p.len   { buf[pos] = p[i]    pos = pos + 1 }
        loop i in 0..msg.len { buf[pos] = msg[i]   pos = pos + 1 }
        buf[pos] = '\n'  pos = pos + 1
        syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
        g_forge_test_fails = g_forge_test_fails + 1
        ret false
    }
    ret true
}

fn forge_assert_status(res: &ForgeTestResponse, expected: i32) -> bool {
    if res.status != expected {
        let buf: &i8 = alloc_pages(1)
        let pos = 0i64
        let p1 = "  ASSERT STATUS FAILED: expected "
        loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
        let nb: &i8 = alloc_pages(1)
        let nl = fmt_i64(nb, expected as i64)
        loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
        let p2 = " got "
        loop i in 0..p2.len { buf[pos] = p2[i]  pos = pos + 1 }
        nl = fmt_i64(nb, res.status as i64)
        loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
        buf[pos] = '\n'  pos = pos + 1
        syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
        g_forge_test_fails = g_forge_test_fails + 1
        ret false
    }
    ret true
}

fn forge_assert_body_has(res: &ForgeTestResponse, substr: []i8) -> bool {
    let body = res.body
    if substr.len == 0 { ret true }
    loop i in 0..body.len {
        if i + substr.len > body.len { break }
        let match = true
        loop j in 0..substr.len {
            if body[i + j] != substr[j] { match = false  break }
        }
        if match { ret true }
    }
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "  ASSERT BODY HAS FAILED: substring not found: "
    loop i in 0..p1.len    { buf[pos] = p1[i]     pos = pos + 1 }
    loop i in 0..substr.len { buf[pos] = substr[i]  pos = pos + 1 }
    buf[pos] = '\n'  pos = pos + 1
    syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
    g_forge_test_fails = g_forge_test_fails + 1
    ret false
}

fn forge_assert_body_eq(res: &ForgeTestResponse, expected: []i8) -> bool {
    if not forge_slice_eq(res.body, expected) {
        let buf: &i8 = alloc_pages(1)
        let pos = 0i64
        let p1 = "  ASSERT BODY EQ FAILED\n"
        loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
        syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
        g_forge_test_fails = g_forge_test_fails + 1
        ret false
    }
    ret true
}

fn forge_assert_redirect(res: &ForgeTestResponse) -> bool {
    if res.status != 301 and res.status != 302 {
        let buf: &i8 = alloc_pages(1)
        let pos = 0i64
        let p1 = "  ASSERT REDIRECT FAILED: status "
        loop i in 0..p1.len { buf[pos] = p1[i]  pos = pos + 1 }
        let nb: &i8 = alloc_pages(1)
        let nl = fmt_i64(nb, res.status as i64)
        loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
        buf[pos] = '\n'  pos = pos + 1
        syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
        g_forge_test_fails = g_forge_test_fails + 1
        ret false
    }
    ret true
}

fn forge_test_db_truncate(table: []i8) {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "TRUNCATE TABLE "
    let p2 = " RESTART IDENTITY CASCADE"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len  { buf[pos] = table[i]  pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    forge_db_exec(buf[0..pos])
}

fn forge_test_db_count(table: []i8) -> i64 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "SELECT COUNT(*) FROM "
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len  { buf[pos] = table[i]  pos = pos + 1 }
    let res = forge_db_query(buf[0..pos])
    if res.count == 0 { ret 0 }
    let val = forge_row_col(res, 0, 0)
    let acc = 0i64
    loop i in 0..val.len {
        let d = val[i] as i64 - 48
        if d >= 0 and d <= 9 { acc = acc * 10 + d }
    }
    ret acc
}

// forge_test_rollback — issue ROLLBACK so DB changes in a test don't persist.
fn forge_test_rollback() {
    forge_db_exec("ROLLBACK")
}

// forge_test_setup — begin a transaction so forge_test_rollback can undo it.
fn forge_test_setup() {
    forge_db_exec("BEGIN")
}

// forge_test_fixture — insert a test record and return its id.
// attrs is a &ForgeAttrs built with forge_attrs_new().set(...).
fn forge_test_fixture(table: []i8, attrs: &ForgeAttrs) -> []i8 {
    forge_attrs_insert(attrs, table)
    let q = forge_q_with_deleted(forge_q(table))
    forge_q_order_desc(q, "id")
    q.lim = 1
    let res = forge_q_exec(q)
    if res.count == 0 { ret "" }
    ret forge_row_col(res, 0, forge_col_index(res, "id"))
}

// forge_test_res_json — assert that a JSON response body contains key=expected.
// Looks for "key":"expected" or "key":expected (non-string) in the body.
fn forge_test_res_json(res: &ForgeTestResponse, key: []i8, expected: []i8) -> &ForgeTestResponse {
    let body = res.body
    // Build search patterns: "key":"expected" and "key":expected
    let pat_buf: &i8 = alloc_pages(1)
    let pp = 0i64
    pat_buf[pp] = '"'  pp = pp + 1
    loop i in 0..key.len { pat_buf[pp] = key[i]  pp = pp + 1 }
    pat_buf[pp] = '"'  pp = pp + 1
    pat_buf[pp] = ':'  pp = pp + 1
    let key_colon_len = pp
    // Try to find key: in body then compare value
    let found = false
    loop i in 0..body.len {
        if i + key_colon_len > body.len { break }
        let match = true
        loop j in 0..key_colon_len { if body[i + j] != pat_buf[j] { match = false  break } }
        if not match { continue }
        // Skip optional whitespace and quote
        let vi = i + key_colon_len
        loop vi < body.len and (body[vi] == ' ' or body[vi] == '\t') { vi = vi + 1 }
        let quoted = vi < body.len and body[vi] == '"'
        if quoted { vi = vi + 1 }
        // Check expected value
        if vi + expected.len <= body.len {
            let vm = true
            loop j in 0..expected.len { if body[vi + j] != expected[j] { vm = false  break } }
            if vm { found = true  break }
        }
    }
    if not found {
        let pb: &i8 = alloc_pages(1)
        let pp2 = 0i64
        let p1 = "  ASSERT JSON FAILED: key \""
        loop k in 0..p1.len      { pb[pp2] = p1[k]       pp2 = pp2 + 1 }
        loop k in 0..key.len     { pb[pp2] = key[k]       pp2 = pp2 + 1 }
        let p2 = "\" expected: "
        loop k in 0..p2.len      { pb[pp2] = p2[k]        pp2 = pp2 + 1 }
        loop k in 0..expected.len { pb[pp2] = expected[k]  pp2 = pp2 + 1 }
        pb[pp2] = '\n'  pp2 = pp2 + 1
        syscall(FORGE_SYS_WRITE, 2, pb, pp2, 0, 0, 0)
        g_forge_test_fails = g_forge_test_fails + 1
    }
    ret res
}

// =============================================================================
// Section K — Environment & Config
// =============================================================================
const FORGE_ENV_MAX  = 64
const FORGE_ENV_KCAP = 64
const FORGE_ENV_VCAP = 256

struct ForgeEnvEntry {
    key:  [64]i8
    klen: i64
    val:  [256]i8
    vlen: i64
    used: bool
}

let g_forge_env_store: &ForgeEnvEntry = 0
let g_forge_env_count: i64            = 0

const FORGE_LOG_DEBUG = 0
const FORGE_LOG_INFO  = 1
const FORGE_LOG_WARN  = 2
const FORGE_LOG_ERROR = 3

let g_forge_log_level: i64 = 1

fn forge_env_init() {
    if g_forge_env_store != 0 { ret }
    g_forge_env_store = alloc_pages(4) as &ForgeEnvEntry
}

fn forge_env_get(name: []i8) -> []i8 {
    forge_env_init()
    let stride = 337i64   // 64+8+256+8+1
    loop i in 0..g_forge_env_count {
        let e: &ForgeEnvEntry = (g_forge_env_store as i64 + i * stride) as &ForgeEnvEntry
        if not e.used { continue }
        if forge_slice_eq(e.key[0..e.klen], name) {
            ret e.val[0..e.vlen]
        }
    }
    // Search /proc/self/environ
    let env_buf: &i8 = alloc_pages(16)
    let path_buf = [32]i8
    let ps = "/proc/self/environ"
    loop i in 0..ps.len { path_buf[i] = ps[i] }
    path_buf[ps.len] = 0
    let nread = fs_read_file(path_buf, env_buf, 65536)
    if nread <= 0 { ret "" }
    let i = 0i64
    loop i < nread {
        // Each entry is KEY=VALUE\0
        let kstart = i
        loop i < nread and env_buf[i] != '=' and env_buf[i] != 0 { i = i + 1 }
        let kend = i
        let key_s = env_buf[kstart..kend]
        if env_buf[i] == '=' {
            i = i + 1
            let vstart = i
            loop i < nread and env_buf[i] != 0 { i = i + 1 }
            let vend = i
            if forge_slice_eq(key_s, name) {
                ret env_buf[vstart..vend]
            }
        }
        i = i + 1  // skip null terminator
    }
    ret ""
}

fn forge_env() -> []i8 {
    let v = forge_env_get("FORGE_ENV")
    if v.len == 0 { ret "development" }
    ret v
}

fn forge_env_is(env: []i8) -> bool {
    ret forge_slice_eq(forge_env(), env)
}

fn forge_dotenv_load(path: []i8) {
    forge_env_init()
    let path_buf = [512]i8
    let pl = path.len
    if pl > 511 { pl = 511 }
    loop i in 0..pl { path_buf[i] = path[i] }
    path_buf[pl] = 0
    let file_buf: &i8 = alloc_pages(8)
    let nread = fs_read_file(path_buf, file_buf, 32768)
    if nread <= 0 { ret }
    let stride = 337i64
    let i = 0i64
    loop i < nread {
        // Skip blank lines and comments
        if file_buf[i] == '\n' or file_buf[i] == '\r' { i = i + 1  continue }
        if file_buf[i] == '#' {
            loop i < nread and file_buf[i] != '\n' { i = i + 1 }
            continue
        }
        let kstart = i
        loop i < nread and file_buf[i] != '=' and file_buf[i] != '\n' { i = i + 1 }
        let kend = i
        let key_s = file_buf[kstart..kend]
        if file_buf[i] != '=' { continue }
        i = i + 1
        let vstart = i
        loop i < nread and file_buf[i] != '\n' and file_buf[i] != '\r' { i = i + 1 }
        let vend = i
        let val_s = file_buf[vstart..vend]
        // Check if key already in env store
        let already = false
        loop j in 0..g_forge_env_count {
            let e2: &ForgeEnvEntry = (g_forge_env_store as i64 + j * stride) as &ForgeEnvEntry
            if e2.used and forge_slice_eq(e2.key[0..e2.klen], key_s) {
                already = true
                break
            }
        }
        if not already {
            let cn = g_forge_env_count
            if cn < FORGE_ENV_MAX {
                let ne: &ForgeEnvEntry = (g_forge_env_store as i64 + cn * stride) as &ForgeEnvEntry
                let kl = key_s.len
                if kl > FORGE_ENV_KCAP { kl = FORGE_ENV_KCAP }
                loop j in 0..kl { ne.key[j] = key_s[j] }
                ne.klen = kl
                let vl = val_s.len
                if vl > FORGE_ENV_VCAP { vl = FORGE_ENV_VCAP }
                loop j in 0..vl { ne.val[j] = val_s[j] }
                ne.vlen = vl
                ne.used = true
                g_forge_env_count = cn + 1
            }
        }
        i = i + 1
    }
}

fn forge_log_level_set(level: i64) {
    g_forge_log_level = level
}

fn forge_log_write(level: i64, prefix: []i8, msg: []i8) {
    if level < g_forge_log_level { ret }
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    buf[pos] = '['  pos = pos + 1
    loop i in 0..prefix.len { buf[pos] = prefix[i]  pos = pos + 1 }
    buf[pos] = ']'  pos = pos + 1
    buf[pos] = ' '  pos = pos + 1
    loop i in 0..msg.len { buf[pos] = msg[i]  pos = pos + 1 }
    buf[pos] = '\n'  pos = pos + 1
    syscall(FORGE_SYS_WRITE, 2, buf, pos, 0, 0, 0)
}

fn forge_log_debug(msg: []i8) { forge_log_write(FORGE_LOG_DEBUG, "DEBUG", msg) }
fn forge_log_info (msg: []i8) { forge_log_write(FORGE_LOG_INFO,  "INFO",  msg) }
fn forge_log_warn (msg: []i8) { forge_log_write(FORGE_LOG_WARN,  "WARN",  msg) }
fn forge_log_error(msg: []i8) { forge_log_write(FORGE_LOG_ERROR, "ERROR", msg) }

// forge_log_ctx_at — structured request log: "[req_id method path] msg"
fn forge_log_ctx_at(ctx: i64, level: i64, msg: []i8) {
    if level < g_forge_log_level { ret }
    let rid = ctx_header(ctx, "X-Request-ID")
    let c: &ForgeCtx = ctx
    let buf = forge_buf_new(1)
    if rid.len > 0 { buf.write("[").write(rid).write("] ") }
    buf.write(c.req.method).write(" ").write(c.req.path).write(" ").write(msg)
    let prefix = "INFO"
    if level == FORGE_LOG_DEBUG { prefix = "DEBUG" }
    else if level == FORGE_LOG_WARN  { prefix = "WARN"  }
    else if level == FORGE_LOG_ERROR { prefix = "ERROR" }
    forge_log_write(level, prefix, buf.done())
}

fn forge_log_ctx_info (ctx: i64, msg: []i8) { forge_log_ctx_at(ctx, FORGE_LOG_INFO,  msg) }
fn forge_log_ctx_debug(ctx: i64, msg: []i8) { forge_log_ctx_at(ctx, FORGE_LOG_DEBUG, msg) }
fn forge_log_ctx_warn (ctx: i64, msg: []i8) { forge_log_ctx_at(ctx, FORGE_LOG_WARN,  msg) }
fn forge_log_ctx_error(ctx: i64, msg: []i8) { forge_log_ctx_at(ctx, FORGE_LOG_ERROR, msg) }

// forge_log_tagged — emit a tagged log line: "[tag] msg"
fn forge_log_tagged(tag: []i8, level: i64, msg: []i8) {
    if level < g_forge_log_level { ret }
    let buf = forge_buf_new(1)
    buf.write("[").write(tag).write("] ").write(msg)
    let prefix = "INFO"
    if level == FORGE_LOG_DEBUG { prefix = "DEBUG" }
    else if level == FORGE_LOG_WARN  { prefix = "WARN"  }
    else if level == FORGE_LOG_ERROR { prefix = "ERROR" }
    forge_log_write(level, prefix, buf.done())
}

// =============================================================================
// Dirty tracking — snapshot and compare attribute values across a request.
//
// Snapshot loaded values right after a find:
//   let res = post_find(id)
//   forge_dirty_load_result("posts", id, res, "title")
//   forge_dirty_load_result("posts", id, res, "body")
//
// Check before save:
//   if forge_dirty_changed("posts", id, "title", new_title) { ... }
//
// Original value:
//   let original = forge_dirty_was("posts", id, "title")
// =============================================================================

fn forge__dirty_key(table: []i8, id: []i8, col: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let pfx = "__orig_"
    loop i in 0..pfx.len   { buf[pos] = pfx[i]    pos = pos + 1 }
    loop i in 0..table.len  { buf[pos] = table[i]   pos = pos + 1 }
    buf[pos] = '_'  pos = pos + 1
    loop i in 0..id.len     { buf[pos] = id[i]      pos = pos + 1 }
    buf[pos] = '_'  pos = pos + 1
    loop i in 0..col.len    { buf[pos] = col[i]     pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_dirty_set(table: []i8, id: []i8, col: []i8, orig_val: []i8) {
    forge_cache_set(forge__dirty_key(table, id, col), orig_val, 300)
}

fn forge_dirty_was(table: []i8, id: []i8, col: []i8) -> []i8 {
    ret forge_cache_get(forge__dirty_key(table, id, col))
}

fn forge_dirty_changed(table: []i8, id: []i8, col: []i8, current: []i8) -> bool {
    let orig = forge_dirty_was(table, id, col)
    if orig.len == 0 { ret false }
    ret not forge_slice_eq(orig, current)
}

fn forge_dirty_load_result(table: []i8, id: []i8, res: &ForgeResult, col: []i8) {
    let val = forge_result_col(res, 0, col)
    forge_dirty_set(table, id, col, val)
}

// =============================================================================
// Instrumentation — lightweight event bus.
//
// Subscribe before the server starts:
//   forge_subscribe("sql.query", fn_addr(on_sql_query))
//
// Instrument from anywhere:
//   forge_instrument("sql.query", payload_ptr)
//
// Handler signature: fn my_handler(payload: i64)
// =============================================================================
const FORGE_INSTR_MAX       = 32
const FORGE_INSTR_EVENT_CAP = 64

struct ForgeInstrEntry {
    event:  [FORGE_INSTR_EVENT_CAP]i8
    elen:   i64
    fn_ptr: i64
    used:   bool
}

const FORGE_INSTR_STRIDE = 80

let g_forge_instr_store: &ForgeInstrEntry = 0
let g_forge_instr_count: i64 = 0

fn forge_instr_init() {
    if g_forge_instr_store != 0 { ret }
    g_forge_instr_store = alloc_pages(2) as &ForgeInstrEntry
}

fn forge_subscribe(event: []i8, fn_ptr: i64) {
    forge_instr_init()
    if g_forge_instr_count >= FORGE_INSTR_MAX { ret }
    let e: &ForgeInstrEntry = (g_forge_instr_store as i64 + g_forge_instr_count * FORGE_INSTR_STRIDE) as &ForgeInstrEntry
    let el = event.len
    if el > FORGE_INSTR_EVENT_CAP { el = FORGE_INSTR_EVENT_CAP }
    loop i in 0..el { e.event[i] = event[i] }
    e.elen   = el
    e.fn_ptr = fn_ptr
    e.used   = true
    g_forge_instr_count = g_forge_instr_count + 1
}

fn forge_instrument(event: []i8, payload: i64) {
    forge_instr_init()
    loop i in 0..g_forge_instr_count {
        let e: &ForgeInstrEntry = (g_forge_instr_store as i64 + i * FORGE_INSTR_STRIDE) as &ForgeInstrEntry
        if not e.used { continue }
        if forge_slice_eq(e.event[0..e.elen], event) {
            call_fn(e.fn_ptr, payload)
        }
    }
}

// =============================================================================
// Section L — Concerns
// =============================================================================

fn forge_timestamps_create(table: []i8, id: []i8) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "UPDATE "
    let p2 = " SET created_at = NOW(), updated_at = NOW() WHERE id = '"
    let p3 = "'"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len  { buf[pos] = table[i]  pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    let el = forge_db_escape_str(id, buf + pos)
    pos = pos + el
    loop i in 0..p3.len    { buf[pos] = p3[i]    pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

fn forge_timestamps_update(table: []i8, id: []i8) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "UPDATE "
    let p2 = " SET updated_at = NOW() WHERE id = '"
    let p3 = "'"
    loop i in 0..p1.len    { buf[pos] = p1[i]    pos = pos + 1 }
    loop i in 0..table.len  { buf[pos] = table[i]  pos = pos + 1 }
    loop i in 0..p2.len    { buf[pos] = p2[i]    pos = pos + 1 }
    let el = forge_db_escape_str(id, buf + pos)
    pos = pos + el
    loop i in 0..p3.len    { buf[pos] = p3[i]    pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

fn forge_tags_schema() -> []i8 {
    ret "CREATE TABLE IF NOT EXISTS forge_tags (id BIGSERIAL PRIMARY KEY, model VARCHAR(64) NOT NULL, record_id VARCHAR(64) NOT NULL, tag VARCHAR(128) NOT NULL, created_at TIMESTAMP DEFAULT NOW())"
}

fn forge_tags_add(model: []i8, record_id: []i8, tag: []i8) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "INSERT INTO forge_tags (model, record_id, tag) VALUES ('"
    let p2 = "', '"
    let p3 = "', '"
    let p4 = "')"
    loop i in 0..p1.len      { buf[pos] = p1[i]       pos = pos + 1 }
    let el = forge_db_escape_str(model, buf + pos)     pos = pos + el
    loop i in 0..p2.len      { buf[pos] = p2[i]       pos = pos + 1 }
    el = forge_db_escape_str(record_id, buf + pos)     pos = pos + el
    loop i in 0..p3.len      { buf[pos] = p3[i]       pos = pos + 1 }
    el = forge_db_escape_str(tag, buf + pos)           pos = pos + el
    loop i in 0..p4.len      { buf[pos] = p4[i]       pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

fn forge_tags_remove(model: []i8, record_id: []i8, tag: []i8) -> bool {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "DELETE FROM forge_tags WHERE model = '"
    let p2 = "' AND record_id = '"
    let p3 = "' AND tag = '"
    let p4 = "'"
    loop i in 0..p1.len      { buf[pos] = p1[i]       pos = pos + 1 }
    let el = forge_db_escape_str(model, buf + pos)     pos = pos + el
    loop i in 0..p2.len      { buf[pos] = p2[i]       pos = pos + 1 }
    el = forge_db_escape_str(record_id, buf + pos)     pos = pos + el
    loop i in 0..p3.len      { buf[pos] = p3[i]       pos = pos + 1 }
    el = forge_db_escape_str(tag, buf + pos)           pos = pos + el
    loop i in 0..p4.len      { buf[pos] = p4[i]       pos = pos + 1 }
    ret forge_db_exec(buf[0..pos])
}

fn forge_tags_for(model: []i8, record_id: []i8) -> &ForgeResult {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "SELECT tag FROM forge_tags WHERE model = '"
    let p2 = "' AND record_id = '"
    let p3 = "'"
    loop i in 0..p1.len      { buf[pos] = p1[i]       pos = pos + 1 }
    let el = forge_db_escape_str(model, buf + pos)     pos = pos + el
    loop i in 0..p2.len      { buf[pos] = p2[i]       pos = pos + 1 }
    el = forge_db_escape_str(record_id, buf + pos)     pos = pos + el
    loop i in 0..p3.len      { buf[pos] = p3[i]       pos = pos + 1 }
    ret forge_db_query(buf[0..pos])
}

fn forge_tags_find(model: []i8, tag: []i8) -> &ForgeResult {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "SELECT record_id FROM forge_tags WHERE model = '"
    let p2 = "' AND tag = '"
    let p3 = "'"
    loop i in 0..p1.len      { buf[pos] = p1[i]       pos = pos + 1 }
    let el = forge_db_escape_str(model, buf + pos)     pos = pos + el
    loop i in 0..p2.len      { buf[pos] = p2[i]       pos = pos + 1 }
    el = forge_db_escape_str(tag, buf + pos)           pos = pos + el
    loop i in 0..p3.len      { buf[pos] = p3[i]       pos = pos + 1 }
    ret forge_db_query(buf[0..pos])
}

fn forge_audit_schema() -> []i8 {
    ret "CREATE TABLE IF NOT EXISTS forge_audit_log (id BIGSERIAL PRIMARY KEY, model VARCHAR(64), action VARCHAR(32), record_id VARCHAR(64), user_id VARCHAR(64), created_at TIMESTAMP DEFAULT NOW())"
}

fn forge_audit_log(ctx: i64, model: []i8, action: []i8, record_id: []i8) {
    let user_id = ctx_session_get(ctx, "user_id")
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let p1 = "INSERT INTO forge_audit_log (model, action, record_id, user_id, created_at) VALUES ('"
    let p2 = "', '"
    let p3 = "', '"
    let p4 = "', '"
    let p5 = "', NOW())"
    loop i in 0..p1.len      { buf[pos] = p1[i]       pos = pos + 1 }
    let el = forge_db_escape_str(model, buf + pos)     pos = pos + el
    loop i in 0..p2.len      { buf[pos] = p2[i]       pos = pos + 1 }
    el = forge_db_escape_str(action, buf + pos)        pos = pos + el
    loop i in 0..p3.len      { buf[pos] = p3[i]       pos = pos + 1 }
    el = forge_db_escape_str(record_id, buf + pos)     pos = pos + el
    loop i in 0..p4.len      { buf[pos] = p4[i]       pos = pos + 1 }
    el = forge_db_escape_str(user_id, buf + pos)       pos = pos + el
    loop i in 0..p5.len      { buf[pos] = p5[i]       pos = pos + 1 }
    forge_db_exec(buf[0..pos])
}

// =============================================================================
// Section M — File Uploads (Multipart)
// =============================================================================

struct ForgeUpload {
    field_name:   []i8
    filename:     []i8
    content_type: []i8
    data:         []i8
    size:         i64
}

fn forge_multipart_boundary(ctx: i64, dst: &i8) -> i64 {
    let ct = ctx_header(ctx, "Content-Type")
    let marker = "boundary="
    loop i in 0..ct.len {
        if i + marker.len > ct.len { break }
        let match = true
        loop j in 0..marker.len {
            if ct[i + j] != marker[j] { match = false  break }
        }
        if match {
            let start = i + marker.len
            let blen = 0i64
            loop k in start..ct.len {
                let c = ct[k]
                if c == ';' or c == ' ' or c == '\r' or c == '\n' { break }
                dst[blen] = c
                blen = blen + 1
            }
            ret blen
        }
    }
    ret 0
}

fn forge_multipart_parse(ctx: i64, field: []i8, upload: &ForgeUpload) -> bool {
    let body = ctx_body(ctx)
    let bnd_buf = [256]i8
    let bnd_len = forge_multipart_boundary(ctx, bnd_buf)
    if bnd_len == 0 { ret false }
    let boundary = bnd_buf[0..bnd_len]
    let i = 0i64
    loop i < body.len {
        // Find "--boundary"
        if body[i] == '-' and i + 2 + bnd_len <= body.len {
            let is_bnd = body[i+1] == '-'
            if is_bnd {
                loop j in 0..bnd_len {
                    if body[i + 2 + j] != boundary[j] { is_bnd = false  break }
                }
            }
            if is_bnd {
                i = i + 2 + bnd_len
                if i < body.len and body[i] == '\r' { i = i + 1 }
                if i < body.len and body[i] == '\n' { i = i + 1 }
                // Parse headers until blank line
                let part_name   = ""
                let part_file   = ""
                let part_ct     = "application/octet-stream"
                loop i < body.len {
                    let hdr_start = i
                    loop i < body.len and body[i] != '\r' and body[i] != '\n' { i = i + 1 }
                    let hdr_line = body[hdr_start..i]
                    if i < body.len and body[i] == '\r' { i = i + 1 }
                    if i < body.len and body[i] == '\n' { i = i + 1 }
                    if hdr_line.len == 0 { break }
                    let cd = "Content-Disposition:"
                    let ctype = "Content-Type:"
                    if forge_starts_with(hdr_line, cd) {
                        let nm_marker = "name=\""
                        loop k in 0..hdr_line.len {
                            if k + nm_marker.len > hdr_line.len { break }
                            let m2 = true
                            loop j in 0..nm_marker.len {
                                if hdr_line[k+j] != nm_marker[j] { m2 = false  break }
                            }
                            if m2 {
                                let ns = k + nm_marker.len
                                let ne = ns
                                loop ne < hdr_line.len and hdr_line[ne] != '"' { ne = ne + 1 }
                                part_name = hdr_line[ns..ne]
                                break
                            }
                        }
                        let fn_marker = "filename=\""
                        loop k in 0..hdr_line.len {
                            if k + fn_marker.len > hdr_line.len { break }
                            let m3 = true
                            loop j in 0..fn_marker.len {
                                if hdr_line[k+j] != fn_marker[j] { m3 = false  break }
                            }
                            if m3 {
                                let ns2 = k + fn_marker.len
                                let ne2 = ns2
                                loop ne2 < hdr_line.len and hdr_line[ne2] != '"' { ne2 = ne2 + 1 }
                                part_file = hdr_line[ns2..ne2]
                                break
                            }
                        }
                    } else if forge_starts_with(hdr_line, ctype) {
                        let vs = ctype.len
                        loop vs < hdr_line.len and hdr_line[vs] == ' ' { vs = vs + 1 }
                        part_ct = hdr_line[vs..hdr_line.len]
                    }
                }
                // Find end of part: next "--boundary"
                let data_start = i
                let data_end   = body.len
                let ki = i
                loop ki < body.len {
                    if body[ki] == '\r' and ki + 4 + bnd_len <= body.len {
                        let is_b2 = body[ki+1] == '\n' and body[ki+2] == '-' and body[ki+3] == '-'
                        if is_b2 {
                            loop j in 0..bnd_len {
                                if body[ki + 4 + j] != boundary[j] { is_b2 = false  break }
                            }
                        }
                        if is_b2 { data_end = ki  break }
                    }
                    ki = ki + 1
                }
                if forge_slice_eq(part_name, field) {
                    let data_slice = body[data_start..data_end]
                    let data_copy: &i8 = alloc_pages(((data_slice.len / 4096) + 1) as i64)
                    loop j in 0..data_slice.len { data_copy[j] = data_slice[j] }
                    upload.field_name   = part_name
                    upload.filename     = part_file
                    upload.content_type = part_ct
                    upload.data         = data_copy[0..data_slice.len]
                    upload.size         = data_slice.len
                    ret true
                }
                i = data_end
                continue
            }
        }
        i = i + 1
    }
    ret false
}

fn ctx_multipart_file(ctx: i64, field: []i8) -> &ForgeUpload {
    let up: &ForgeUpload = alloc_pages(1)
    forge_multipart_parse(ctx, field, up)
    ret up
}

fn ctx_multipart_field(ctx: i64, field: []i8) -> []i8 {
    let up: &ForgeUpload = alloc_pages(1)
    if forge_multipart_parse(ctx, field, up) {
        ret up.data
    }
    ret ""
}

fn forge_upload_save(upload: &ForgeUpload, dir: []i8) -> []i8 {
    let path_buf: &i8 = alloc_pages(1)
    let pos = 0i64
    loop i in 0..dir.len      { path_buf[pos] = dir[i]              pos = pos + 1 }
    path_buf[pos] = '/'  pos = pos + 1
    loop i in 0..upload.filename.len { path_buf[pos] = upload.filename[i]  pos = pos + 1 }
    path_buf[pos] = 0   // null terminate
    let flags = 577i64   // O_WRONLY|O_CREAT|O_TRUNC
    let mode  = 420i64   // 0644
    let fd = syscall(2, path_buf, flags, mode, 0, 0, 0) as i32
    if fd < 0 { ret "" }
    let data = upload.data
    // Write in 4096-byte chunks using a stack buffer
    let wbuf: &i8 = alloc_pages(1)
    let written = 0i64
    loop written < data.len {
        let chunk = data.len - written
        if chunk > 4096 { chunk = 4096 }
        loop j in 0..chunk { wbuf[j] = data[written + j] }
        let w = syscall(FORGE_SYS_WRITE, fd, wbuf, chunk, 0, 0, 0) as i64
        if w <= 0 { break }
        written = written + w
    }
    syscall(FORGE_SYS_CLOSE, fd, 0, 0, 0, 0, 0)
    ret path_buf[0..pos]
}

fn forge_validate_upload_type(upload: &ForgeUpload, allowed: []i8) -> bool {
    let start = 0i64
    loop i in 0..allowed.len {
        if allowed[i] == ',' {
            let seg = allowed[start..i]
            if forge_slice_eq(seg, upload.content_type) { ret true }
            start = i + 1
        }
    }
    let seg = allowed[start..allowed.len]
    if forge_slice_eq(seg, upload.content_type) { ret true }
    ret false
}

fn forge_validate_upload_size(upload: &ForgeUpload, max_bytes: i64) -> bool {
    ret upload.size <= max_bytes
}

// =============================================================================
// Section N — Caching
// =============================================================================
const FORGE_CACHE_MAX  = 256
const FORGE_CACHE_KCAP = 128

struct ForgeCacheEntry {
    key:     [FORGE_CACHE_KCAP]i8
    klen:    i64
    val_ptr: i64
    val_len: i64
    expires: i64
    used:    bool
}

const FORGE_CACHE_ENTRY_STRIDE = 162

let g_forge_cache_store: &ForgeCacheEntry = 0

fn forge_cache_init() {
    if g_forge_cache_store != 0 { ret }
    g_forge_cache_store = alloc_pages(12) as &ForgeCacheEntry
}

fn forge_cache_entry_at(i: i64) -> &ForgeCacheEntry {
    forge_cache_init()
    ret (g_forge_cache_store as i64 + i * FORGE_CACHE_ENTRY_STRIDE) as &ForgeCacheEntry
}

fn forge_cache_get(key: []i8) -> []i8 {
    forge_cache_init()
    let now = time_now_ms()
    loop i in 0..FORGE_CACHE_MAX {
        let e = forge_cache_entry_at(i)
        if not e.used { continue }
        if e.expires > 0 and now >= e.expires {
            e.used = false
            continue
        }
        if forge_slice_eq(e.key[0..e.klen], key) {
            let vp: &i8 = e.val_ptr as &i8
            ret vp[0..e.val_len]
        }
    }
    ret ""
}

fn forge_cache_set(key: []i8, val: []i8, ttl_sec: i64) {
    forge_cache_init()
    let now = time_now_ms()
    let exp = 0i64
    if ttl_sec > 0 { exp = now + ttl_sec * 1000 }
    // Find existing slot
    loop i in 0..FORGE_CACHE_MAX {
        let e = forge_cache_entry_at(i)
        if e.used and forge_slice_eq(e.key[0..e.klen], key) {
            let vp: &i8 = alloc_pages(1)
            loop j in 0..val.len { vp[j] = val[j] }
            e.val_ptr = vp as i64
            e.val_len = val.len
            e.expires = exp
            ret
        }
    }
    // Find empty slot
    loop i in 0..FORGE_CACHE_MAX {
        let e = forge_cache_entry_at(i)
        if not e.used or (e.expires > 0 and now >= e.expires) {
            let kl = key.len
            if kl > FORGE_CACHE_KCAP { kl = FORGE_CACHE_KCAP }
            loop j in 0..kl { e.key[j] = key[j] }
            e.klen    = kl
            let vp: &i8 = alloc_pages(1)
            loop j in 0..val.len { vp[j] = val[j] }
            e.val_ptr = vp as i64
            e.val_len = val.len
            e.expires = exp
            e.used    = true
            ret
        }
    }
}

fn forge_cache_has(key: []i8) -> bool {
    let v = forge_cache_get(key)
    ret v.len > 0
}

fn forge_cache_del(key: []i8) {
    forge_cache_init()
    loop i in 0..FORGE_CACHE_MAX {
        let e = forge_cache_entry_at(i)
        if e.used and forge_slice_eq(e.key[0..e.klen], key) {
            e.used = false
            ret
        }
    }
}

fn forge_cache_clear() {
    forge_cache_init()
    loop i in 0..FORGE_CACHE_MAX {
        let e = forge_cache_entry_at(i)
        e.used = false
    }
}

// forge_cache_fetch — return cached value if present; otherwise call fn_ptr()
// which must return []i8, store it with ttl_sec, and return it.
// fn_ptr signature: fn(i64) -> i64  (arg unused; return value cast to []i8)
fn forge_cache_fetch(key: []i8, ttl_sec: i64, fn_ptr: i64) -> []i8 {
    let cached = forge_cache_get(key)
    if cached.len > 0 { ret cached }
    let result = call_fn(fn_ptr, 0) as []i8
    if result.len > 0 { forge_cache_set(key, result, ttl_sec) }
    ret result
}

// =============================================================================
// Current attributes — request-scoped key/value store keyed by ctx pointer.
// Values live for 30 seconds (well beyond any request lifetime) and are
// addressed by a composite key "__cur_<ctx>_<key>" inside the cache.
// =============================================================================

fn forge__current_key(ctx: i64, key: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    let pfx = "__cur_"
    loop i in 0..pfx.len { buf[pos] = pfx[i]  pos = pos + 1 }
    let nb: &i8 = alloc_pages(1)
    let nl = fmt_i64(nb, ctx)
    loop i in 0..nl { buf[pos] = nb[i]  pos = pos + 1 }
    buf[pos] = '_'  pos = pos + 1
    loop i in 0..key.len { buf[pos] = key[i]  pos = pos + 1 }
    ret buf[0..pos]
}

fn forge_current_set(ctx: i64, key: []i8, val: []i8) {
    forge_cache_set(forge__current_key(ctx, key), val, 30)
}

fn forge_current_get(ctx: i64, key: []i8) -> []i8 {
    ret forge_cache_get(forge__current_key(ctx, key))
}

fn forge_current_clear(ctx: i64, key: []i8) {
    forge_cache_del(forge__current_key(ctx, key))
}

fn forge_cache_middleware(ctx: i64) {
    let path = ctx_path(ctx)
    let inm  = ctx_header(ctx, "If-None-Match")
    if inm.len == 0 { ret }
    let cached = forge_cache_get(inm)
    if cached.len > 0 and forge_slice_eq(cached, path) {
        ctx_not_modified(ctx)
    }
}

fn forge_etag_middleware(ctx: i64) {
    let c: &ForgeCtx = ctx
    if not c.sent { ret }
    let path = ctx_path(ctx)
    // Build a simple hash-based ETag from path + timestamp
    let hash_buf = [64]i8
    let hp = 0i64
    let ts_buf: &i8 = alloc_pages(1)
    let ts_len = fmt_i64(ts_buf, time_now_ms())
    loop i in 0..path.len  { if hp < 63 { hash_buf[hp] = path[i]    hp = hp + 1 } }
    loop i in 0..ts_len    { if hp < 63 { hash_buf[hp] = ts_buf[i]  hp = hp + 1 } }
    let etag_b64: &i8 = alloc_pages(1)
    let etag_len = b64_encode(hash_buf, hp, etag_b64)
    let etag_s = etag_b64[0..etag_len]
    ctx_set_header(ctx, "ETag", etag_s)
    forge_cache_set(etag_s, path, 3600)
}

// =============================================================================
// Default welcome page — shown at / in new apps until the developer defines
// their own root route.  Mount with forge_welcome_mount(app) in main.jda.
// =============================================================================

fn forge_welcome_handler(ctx: i64) {
    let env         = forge_env()
    let forge_ver   = forge_env_get("FORGE_CLI_VERSION")
    let jda_ver     = forge_env_get("JDA_VERSION")
    if forge_ver.len == 0 { forge_ver = "—" }
    if jda_ver.len  == 0  { jda_ver  = "—" }
    let env_class = "badge-other"
    if forge_slice_eq(env, "development") { env_class = "badge-dev"  }
    if forge_slice_eq(env, "production")  { env_class = "badge-prod" }
    if forge_slice_eq(env, "test")        { env_class = "badge-test" }

    let b = forge_buf_new(16)
    b.write("<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"utf-8\">")
    b.write("<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">")
    b.write("<title>JDA Forge \xe2\x80\x94 Welcome</title>")
    b.write("<style>")
    b.write("*{margin:0;padding:0;box-sizing:border-box}")
    b.write("body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;")
    b.write("background:#f0f4ff;color:#1e293b;min-height:100vh;display:flex;")
    b.write("align-items:center;justify-content:center;padding:2rem}")
    b.write(".page{text-align:center;max-width:820px;width:100%}")
    b.write(".logo{margin:0 auto 1.5rem}")
    b.write("h1{font-size:2.5rem;font-weight:800;color:#0e4ab4;margin-bottom:.35rem}")
    b.write(".tagline{font-size:1.05rem;color:#64748b;margin-bottom:1.75rem}")
    b.write(".badges{display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap;margin-bottom:2rem}")
    b.write(".badge{padding:.25rem .9rem;border-radius:9999px;font-size:.8rem;font-weight:600}")
    b.write(".badge-ver{background:#ede9fe;color:#6d28d9}")
    b.write(".badge-jda{background:#e0f2fe;color:#0369a1}")
    b.write(".badge-dev{background:#dcfce7;color:#15803d}")
    b.write(".badge-prod{background:#fee2e2;color:#dc2626}")
    b.write(".badge-test{background:#fef9c3;color:#a16207}")
    b.write(".badge-other{background:#f1f5f9;color:#475569}")
    b.write(".grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));")
    b.write("gap:1rem;margin-bottom:2rem}")
    b.write(".card{background:#fff;border:1px solid #dde6ff;border-radius:.75rem;")
    b.write("padding:1.25rem;text-align:left;box-shadow:0 1px 4px rgba(14,74,180,.06)}")
    b.write(".card h3{font-size:.75rem;font-weight:700;color:#94a3b8;text-transform:uppercase;")
    b.write("letter-spacing:.08em;margin-bottom:.5rem}")
    b.write(".card p{font-size:.9rem;color:#334155;line-height:1.55}")
    b.write(".card a{color:#0e4ab4;text-decoration:none}.card a:hover{text-decoration:underline}")
    b.write("code{background:#f1f5f9;padding:.1em .4em;border-radius:4px;")
    b.write("font-family:ui-monospace,monospace;font-size:.85em}")
    b.write(".hint{font-size:.78rem;color:#94a3b8;line-height:1.6;margin-top:1rem}")
    b.write("</style></head><body><div class=\"page\">")

    // SVG logo — blue shield, dark anvil, orange arrow, sparks, curly brace
    b.write("<div class=\"logo\">")
    b.write("<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 240 210\" width=\"160\" height=\"140\">")
    b.write("<defs>")
    b.write("<linearGradient id=\"sg\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">")
    b.write("<stop offset=\"0%\" stop-color=\"#0d47a1\"/>")
    b.write("<stop offset=\"100%\" stop-color=\"#42a5f5\"/>")
    b.write("</linearGradient></defs>")
    // Shield
    b.write("<path d=\"M100 12 L166 36 L166 102 Q166 155 100 180 Q34 155 34 102 L34 36 Z\"")
    b.write(" fill=\"white\" stroke=\"url(#sg)\" stroke-width=\"9\" stroke-linejoin=\"round\"/>")
    // Anvil base
    b.write("<rect x=\"58\" y=\"148\" width=\"84\" height=\"11\" rx=\"4\" fill=\"#1a237e\"/>")
    // Anvil body (lower block)
    b.write("<rect x=\"62\" y=\"128\" width=\"76\" height=\"22\" rx=\"3\" fill=\"#1a237e\"/>")
    // Anvil face (upper platform) with left horn
    b.write("<path d=\"M52 128 L52 118 L70 112 L70 104 L130 104 L130 112 L148 112 L148 128 Z\"")
    b.write(" fill=\"#1a237e\"/>")
    // Arrow shaft (orange, diagonal lower-left to upper-right)
    b.write("<line x1=\"72\" y1=\"100\" x2=\"122\" y2=\"62\" stroke=\"#e65100\" stroke-width=\"7\"")
    b.write(" stroke-linecap=\"round\"/>")
    // Arrow head
    b.write("<polygon points=\"128,56 110,64 118,74\" fill=\"#ff6d00\"/>")
    // Sparks / flames
    b.write("<circle cx=\"133\" cy=\"50\" r=\"4\" fill=\"#ffd740\"/>")
    b.write("<circle cx=\"140\" cy=\"60\" r=\"2.5\" fill=\"#ffc400\"/>")
    b.write("<circle cx=\"126\" cy=\"44\" r=\"2.5\" fill=\"#ffe57f\"/>")
    b.write("<line x1=\"138\" y1=\"48\" x2=\"144\" y2=\"42\" stroke=\"#ffab00\" stroke-width=\"2\"")
    b.write(" stroke-linecap=\"round\"/>")
    // Curly brace (right side, outside shield)
    b.write("<text x=\"174\" y=\"128\" font-family=\"Georgia,serif\" font-size=\"72\" font-weight=\"bold\"")
    b.write(" fill=\"#1565c0\" opacity=\"0.85\">}</text>")
    b.write("</svg></div>")

    b.write("<h1>JDA Forge</h1>")
    b.write("<p class=\"tagline\">Your application is up and running.</p>")
    b.write("<div class=\"badges\">")
    b.write("<span class=\"badge badge-ver\">Forge v")
    b.write(forge_ver)
    b.write("</span>")
    b.write("<span class=\"badge badge-jda\">JDA ")
    b.write(jda_ver)
    b.write("</span>")
    b.write("<span class=\"badge ")
    b.write(env_class)
    b.write("\">")
    b.write(env)
    b.write("</span></div>")

    b.write("<div class=\"grid\">")

    b.write("<div class=\"card\"><h3>Routes</h3><p>")
    b.write("Define routes in <code>config/routes.jda</code>. ")
    b.write("Add <code>root \"pages#home\"</code> to replace this page.")
    b.write("</p></div>")

    b.write("<div class=\"card\"><h3>Generate</h3><p>")
    b.write("Scaffold resources with<br><code>forge generate model Post title:string</code><br>")
    b.write("or <code>forge generate controller Posts</code>.")
    b.write("</p></div>")

    b.write("<div class=\"card\"><h3>Models</h3><p>")
    b.write("Add migrations to <code>db/migrate/</code>. ")
    b.write("Run <code>make run</code> \xe2\x80\x94 Forge auto-migrates on start.")
    b.write("</p></div>")

    b.write("<div class=\"card\"><h3>Docs</h3><p>")
    b.write("Read the <a href=\"https://github.com/jdalang/jda-forge/tree/main/docs\">JDA Forge documentation</a> ")
    b.write("for guides on models, routing, views, background jobs, and more.")
    b.write("</p></div>")

    b.write("</div>")

    b.write("<p class=\"hint\">This page is shown until you define your own root route.<br>")
    b.write("Remove the <code>forge_welcome_mount(app)</code> call in <code>main.jda</code> to disable it.</p>")

    b.write("</div></body></html>")
    ctx_html(ctx, 200, b.done())
}

fn forge_welcome_mount(app: &ForgeApp) {
    app_get(app, "/", fn_addr(forge_welcome_handler))
}

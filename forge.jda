    b.write("<h1>JDA Forge</h1>")
    b.write("<p class=\"tagline\">Your application is up and running.</p>")
    b.write("<div class=\"badges\">")
    b.write("<span class=\"badge badge-ver\">Forge v")
    b.write(forge_ver)
    b.write("</span>")
    b.write("<span class=\"badge badge-jda\">JDA ")
    b.write(jda_ver)
    b.write("</span>")
    b.write("<span class=\"badge ")
    b.write(env_class)
    b.write("\">")
    b.write(env)
    b.write("</span></div>")

    b.write("<div class=\"grid\">")

    b.write("<div class=\"card\"><h3>Routes</h3><p>")
    b.write("Define routes in <code>config/routes.jda</code>. ")
    b.write("Add <code>root \"pages#home\"</code> to replace this page.")
    b.write("</p></div>")

    b.write("<div class=\"card\"><h3>Generate</h3><p>")
    b.write("Scaffold resources with<br><code>forge generate model Post title:string</code><br>")
    b.write("or <code>forge generate controller Posts</code>.")
    b.write("</p></div>")

    b.write("<div class=\"card\"><h3>Models</h3><p>")
    b.write("Add migrations to <code>db/migrate/</code>. ")
    b.write("Run <code>make run</code> &mdash; Forge auto-migrates on start.")
    b.write("</p></div>")

    b.write("<div class=\"card\"><h3>Docs</h3><p>")
    b.write("Read the <a href=\"https://github.com/jdalang/jda-forge/tree/main/docs\">JDA Forge documentation</a> ")
    b.write("for guides on models, routing, views, background jobs, and more.")
    b.write("</p></div>")

    b.write("</div>")

    b.write("<p class=\"hint\">This page is shown until you define your own root route.<br>")
    b.write("Remove the <code>forge_welcome_mount(app)</code> call in <code>main.jda</code> to disable it.</p>")

    b.write("</div></body></html>")
    ctx_html(ctx, 200, b.done())
}

fn forge_welcome_mount(app: &ForgeApp) {
    app_get(app, "/", fn_addr(forge_welcome_handler))
}

// =============================================================================
// Short-name wrappers — ForgeQuery method-call shims
// The JDA ARM64 compiler resolves .method() calls on untracked pointer types
// as plain function calls (e.g. q.exec() -> exec(q)).
// =============================================================================
fn exec(q: &ForgeQuery) -> &ForgeResult { ret forge_q_exec(q) }
fn first(q: &ForgeQuery) -> &ForgeResult { ret forge_q_first(q) }
fn count(q: &ForgeQuery) -> i64 { ret forge_q_count(q) }
fn exists(q: &ForgeQuery) -> bool { ret forge_q_exists(q) }
fn where_eq(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery { ret forge_q_where_eq(q, col, val) }
fn order_asc(q: &ForgeQuery, col: []i8) -> &ForgeQuery { ret forge_q_order_asc(q, col) }
fn order_desc(q: &ForgeQuery, col: []i8) -> &ForgeQuery { ret forge_q_order_desc(q, col) }
fn update_all(q: &ForgeQuery, set_clause: []i8) -> bool { ret forge_q_update_all(q, set_clause) }
fn where_not_deleted(q: &ForgeQuery) -> &ForgeQuery { ret forge_q_where_not_deleted(q) }
fn with_deleted(q: &ForgeQuery) -> &ForgeQuery { ret forge_q_with_deleted(q) }
fn only_deleted(q: &ForgeQuery) -> &ForgeQuery { ret forge_q_only_deleted(q) }
fn where_raw(q: &ForgeQuery, expr: []i8) -> &ForgeQuery { ret forge_q_where_raw(q, expr) }
fn where_not(q: &ForgeQuery, col: []i8, val: []i8) -> &ForgeQuery { ret forge_q_where_not(q, col, val) }
fn limit(q: &ForgeQuery, n: i64) -> &ForgeQuery { ret forge_q_limit(q, n) }
fn offset(q: &ForgeQuery, n: i64) -> &ForgeQuery { ret forge_q_offset(q, n) }

// ForgeAttrs method-call shims
fn set(a: &ForgeAttrs, key: []i8, val: []i8) -> &ForgeAttrs { ret forge_attrs_set(a, key, val) }
fn insert(a: &ForgeAttrs, table: []i8) -> bool { ret forge_attrs_insert(a, table) }
fn update(a: &ForgeAttrs, table: []i8, id: []i8) -> bool { ret forge_attrs_update(a, table, id) }

// Utility functions referenced in generated and app code
fn forge_result_empty(r: &ForgeResult) -> bool { ret r.count == 0 }
fn forge_str_concat(a: []i8, b: []i8) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    loop i in 0..a.len { buf[pos] = a[i]  pos = pos + 1 }
    loop i in 0..b.len { buf[pos] = b[i]  pos = pos + 1 }
    ret buf[0..pos]
}
fn i64_to_str(n: i64) -> []i8 {
    let buf: &i8 = alloc_pages(1)
    let pos = 0i64
    if n == 0 { buf[0] = '0'  ret buf[0..1] }
    let neg = false
    if n < 0 { neg = true  n = 0 - n }
    let tmp = [32]i8
    let tpos = 0i64
    loop n > 0 { tmp[tpos] = ('0' as i64 + n % 10) as i8  tpos = tpos + 1  n = n / 10 }
    if neg { buf[pos] = '-'  pos = pos + 1 }
    loop tpos > 0 { tpos = tpos - 1  buf[pos] = tmp[tpos]  pos = pos + 1 }
    ret buf[0..pos]
}
fn forge_log(level: i64, msg: []i8) { forge_log_write(level, "", msg) }
fn forge_mail_send_async(mail: ForgeMail) -> bool { ret forge_mail_send(mail) }

let g_forge_vstr:     &i8 = 0
let g_forge_vstr_pos: i64 = 0

    buf.write(forge_h(title))
    buf.write(" — Blog</title>\n  ")
    buf.write(forge_stylesheet_tag("application.css"))
    buf.write("\n</head>\n<body>\n<nav><a href=\"")
    buf.write(posts_path)
    buf.write("\">Blog</a> &nbsp;|&nbsp; <a href=\"")
    buf.write(new_post_path)
    buf.write("\">New Post</a></nav>\n")
    buf.write(body)
    buf.write(forge_javascript_tag("application.js"))
    buf.write("\n</body>\n</html>\n")
    ret buf.done()
}

// app/views/posts/_form.html.jda
fn render_post_form(action: []i8, title_val: []i8, body_val: []i8, tok: []i8, submit_label: []i8) -> []i8 {
    let buf = forge_buf_new(8)
    buf.write("\n<form method=\"POST\" action=\"")
    buf.write(action)
    buf.write("\">\n  ")
    buf.write(forge_field_tag("title", "Title", title_val))
    buf.write(forge_textarea_field_tag("body", "Body", body_val, 10, 60))
    buf.write(forge_field_tag("author", "Author", ""))
    buf.write("\n  <input type=\"hidden\" name=\"_csrf\" value=\"")
    buf.write(forge_h(tok))
    buf.write("\">\n  <button>")
    buf.write(submit_label)
    buf.write("</button>\n  <a href=\"")
    buf.write(posts_path)
    buf.write("\">Cancel</a>\n</form>\n")
    ret buf.done()
}

// app/views/posts/_post.html.jda
fn tmpl_post_row(post: &PostRow) -> []i8 {
    let buf = forge_buf_new(8)
    buf.write("\n<div class=\"post\">\n  <h2><a href=\"")
    buf.write(post_path(post.id))
    buf.write("\">")
    buf.write(forge_h(post.title))
    buf.write("</a></h2>\n  <p class=\"meta\">by ")
    buf.write(forge_h(post.author))
    buf.write(" on ")
    buf.write(post.created_at)
    buf.write(" &mdash; ")
    buf.write(post.comments_count)
    buf.write(" comment(s)</p>\n  <p class=\"excerpt\">")
    buf.write(forge_excerpt(post.body, post.body, 120))
    buf.write("</p>\n</div>\n")
    ret buf.done()
}

// app/views/posts/edit.html.jda
fn view_posts_edit(ctx: i64, post: &ForgeResult) -> []i8 {
    let buf = forge_buf_new(8)
    let p = post_row(post, 0)
    buf.write("\n\n<h1>Edit Post</h1>\n<form method=\"POST\" action=\"")
    buf.write(post_path(p.id))
    buf.write("\">\n  <input type=\"hidden\" name=\"_method\" value=\"PUT\">\n  <label>Title<br>\n    <input name=\"title\" value=\"")
    buf.write(forge_h(p.title))
    buf.write("\">\n  </label><br><br>\n  <label>Body<br>\n    <textarea name=\"body\" rows=\"10\">")
    buf.write(forge_h(p.body))
    buf.write("</textarea>\n  </label><br><br>\n  <input type=\"hidden\" name=\"_csrf\" value=\"")
    buf.write(forge_h(forge_csrf_token(ctx)))
    buf.write("\">\n  <button>Update</button> <a href=\"")
    buf.write(post_path(p.id))
    buf.write("\">Cancel</a>\n</form>\n")
    ret tmpl_layout("Edit Post", buf.done())
}

// app/views/posts/index.html.jda
fn view_posts_index(ctx: i64, posts: &ForgeResult) -> []i8 {
    let buf = forge_buf_new(8)
    buf.write(tmpl_flash(ctx))
    buf.write("\n<h1>Blog Posts</h1>\n<a href=\"")
    buf.write(new_post_path)
    buf.write("\">New Post</a>\n<hr>\n")
    if posts.count == 0 {
    buf.write("\n<p>No posts yet. <a href=\"")
    buf.write(new_post_path)
    buf.write("\">Write the first one.</a></p>\n")
    }
    loop r in 0..posts.count {
    buf.write(tmpl_post_row(post_row(posts, r)))
    }
    ret tmpl_layout("Posts", buf.done())
}

// app/views/posts/new.html.jda
fn view_posts_new(ctx: i64) -> []i8 {
    let buf = forge_buf_new(8)
    buf.write(tmpl_flash(ctx))
    buf.write("\n<h1>New Post</h1>\n")
    buf.write(render_post_form(posts_path, "", "", forge_csrf_token(ctx), "Publish"))
    ret tmpl_layout("New Post", buf.done())
}

// app/views/posts/show.html.jda
fn view_posts_show(ctx: i64, post: &ForgeResult, comments: &ForgeResult) -> []i8 {
    let buf = forge_buf_new(8)
    let p   = post_row(post, 0)
    let tok = forge_csrf_token(ctx)
    buf.write(tmpl_flash(ctx))
    buf.write("\n<h1>")
    buf.write(forge_h(p.title))
    buf.write("</h1>\n<p class=\"meta\">by ")
    buf.write(forge_h(p.author))
    buf.write(" on ")
    buf.write(p.created_at)
    buf.write("</p>\n<div class=\"body\"><p>")
    buf.write(forge_h(p.body))
    buf.write("</p></div>\n<a href=\"")
    buf.write(edit_post_path(p.id))
    buf.write("\">Edit</a> &nbsp;\n")
    buf.write(forge_link_to_delete("Delete", post_path(p.id), tok))
    buf.write("\n\n<hr>\n<h2>Comments (")
    buf.write(forge_h(i64_to_str(comments.count)))
    buf.write(")</h2>\n")
    loop r in 0..comments.count {
    buf.write(tmpl_comment_row(comment_row(comments, r)))
    }
    buf.write("\n\n<hr>\n<h3>Leave a comment</h3>\n<form method=\"POST\" action=\"")
    buf.write(post_comments_path(p.id))
    buf.write("\">\n  <label>Name<br><input name=\"author\"></label><br><br>\n  <label>Comment<br><textarea name=\"body\" rows=\"4\"></textarea></label><br><br>\n  <input type=\"hidden\" name=\"_csrf\" value=\"")
    buf.write(forge_h(tok))
    buf.write("\">\n  <button>Post Comment</button>\n</form>\n")
    ret tmpl_layout(p.title, buf.done())
}

// app/views/shared/_errors.html.jda
fn render_errors(errs: &ForgeErrors) -> []i8 {
    let buf = forge_buf_new(8)
    if !forge_errors_any(errs) { ret "" }
    buf.write("\n<div class=\"errors\"><ul>\n  <li>")
    buf.write(forge_errors_json(errs))
    buf.write("</li>\n</ul></div>\n")
    ret buf.done()
}

// Auto-generated by forge compile-assets -- do not edit

fn forge_asset_path(name: []i8) -> []i8 {
    if forge_slice_eq(name, "application.css") { ret "/assets/application.css" }
    if forge_slice_eq(name, "application.js") { ret "/assets/application.js" }
    let b = forge_buf_new(1)
    forge_buf_append(b, "/assets/")
    forge_buf_append(b, name)
    ret forge_buf_str(b)
}

fn forge_stylesheet_tag(name: []i8) -> []i8 {
    let b = forge_buf_new(1)
    forge_buf_append(b, "<link rel=\"stylesheet\" href=\"")
    forge_buf_append(b, forge_asset_path(name))
    forge_buf_append(b, "\">")
    ret forge_buf_str(b)
}

fn forge_javascript_tag(name: []i8) -> []i8 {
    let b = forge_buf_new(1)
    forge_buf_append(b, "<script src=\"")
    forge_buf_append(b, forge_asset_path(name))
    forge_buf_append(b, "\"></script>")
    ret forge_buf_str(b)
}

fn forge_image_tag(name: []i8, alt: []i8) -> []i8 {
    let b = forge_buf_new(1)
    forge_buf_append(b, "<img src=\"/assets/")
    forge_buf_append(b, name)
    forge_buf_append(b, "\" alt=\"")
    forge_buf_append(b, alt)
    forge_buf_append(b, "\">")
    ret forge_buf_str(b)
}
// app/models/comment.jda
// CRUD functions and association accessors are auto-generated into _build/models.jda

fn comment_model_init() {
    forge_model("comments")

    forge_assoc_belongs_to("post", "posts", "post_id")

    forge_field    ("body, author", FORGE_V_PRESENCE)
    forge_field_min("body",         2)
}

// --- Custom scopes ---

fn comment_for_post(post_id: []i8) -> &ForgeResult {
    ret forge_q("comments")
        .where_eq("post_id", post_id)
        .order_asc("created_at")
        .exec()
}
// app/models/post.jda
// CRUD functions and association accessors are auto-generated into _build/models.jda

// Called before every save — logs if the title was changed.
fn post_before_save(id: []i8) {
    if forge_dirty_changed("posts", id, "title", forge_fa_get("title")) {
        forge_log_tagged("post", FORGE_LOG_INFO, "title changed")
    }
}

// Called after a post is created — fires an instrumentation event so any
// subscriber (mailer, analytics, etc.) can react without coupling to this model.
fn post_after_create(id: []i8) {
    forge_instrument("post.created", id as i64)
}

fn post_model_init() {
    forge_model("posts")

    forge_assoc_has_many("comments", "comments", "post_id")

    // Keep comments_count on the posts row in sync automatically.
    forge_counter_cache("comments", "post_id", "posts", "comments_count")

    forge_callback(FORGE_CB_BEFORE_SAVE,   fn_addr(post_before_save))
    forge_callback(FORGE_CB_AFTER_CREATE,  fn_addr(post_after_create))

    forge_field       ("title, body, author", FORGE_V_PRESENCE)
    forge_field_length("title",               2, 255)
    forge_field_min   ("body",                10)
}

// --- Custom scopes ---

fn post_published() -> &ForgeResult {
    ret forge_q("posts")
        .where_eq("published", "true")
        .order_desc("created_at")
        .exec()
}

// --- Custom actions ---

fn post_publish(id: []i8) -> bool {
    ret forge_q("posts").where_eq("id", id).update_all("published = true, updated_at = NOW()")
}
// app/mailers/post_mailer.jda

// Sent when a post is created. The subscriber is wired up in main.jda via
// forge_subscribe("post.created", ...) so the mailer is decoupled from the
// controller and model.
fn post_mailer_new_post(post_id_raw: i64) {
    let post_id: []i8 = post_id_raw as []i8
    let post = post_find(post_id)
    if forge_result_empty(post) { ret }
    let p = post_row(post, 0)

    let mail: ForgeMail
    mail.to      = forge_env_get("NOTIFY_EMAIL")
    mail.from    = forge_env_get("MAIL_FROM")
    mail.subject = forge_str_concat("New post: ", p.title)
    mail.body    = forge_str_concat("A new post has been published by ", p.author)
    forge_mail_send_async(mail)
}

// Preview — visible at /_forge/mailers/new_post in development.
fn post_mailer_preview_new_post() -> ForgeMail {
    let mail: ForgeMail
    mail.to      = "preview@example.com"
    mail.from    = "blog@example.com"
    mail.subject = "New post: Hello World"
    mail.body    = "A new post has been published by Alice"
    ret mail
}
// --- application_controller ---
// ApplicationController — shared helpers for all controllers

fn require_login(ctx: i64) -> bool {
    if ctx_session_get(ctx, "user_id").len == 0 {
        ctx_flash_set(ctx, "alert", "Please sign in.")
        ctx_redirect(ctx, "/login")
        ret false
    }
    ret true
}

fn current_user_id(ctx: i64) -> []i8 {
    ret ctx_session_get(ctx, "user_id")
}

// --- comments_controller ---
// Controller: Comments

fn comments_create(ctx: i64) {
    let post_id = ctx_param(ctx, "post_id")
    if comment_create_from(ctx_permit(ctx, "post_id, author, body")) {
        ctx_flash_set(ctx, "notice", "Comment added.")
        ctx_redirect(ctx, post_path(post_id))
        ret
    }
    ctx_save_errors(ctx)
    ctx_redirect(ctx, post_path(post_id))
}

fn comments_delete(ctx: i64) {
    let post_id = ctx_param(ctx, "post_id")
    comment_delete(ctx_param(ctx, "id"))
    ctx_flash_set(ctx, "notice", "Comment removed.")
    ctx_redirect(ctx, post_path(post_id))
}

// --- posts_controller ---
// Controller: Posts
// All fn NAME(ctx: i64) functions use bare names — compile-routes
// prefixes them with "posts_" in the generated build.

fn posts_rescue(ctx: i64) {
    forge_log_ctx_error(ctx, "unhandled error in posts controller")
    ctx_html(ctx, 500, "<h1>Something went wrong</h1>")
}

fn posts_log_action(ctx: i64) {
    forge_log_ctx_info(ctx, "posts action completed")
}

fn posts_set_post(ctx: i64) {
    let id   = ctx_param(ctx, "id")
    let post = post_find(id)
    if forge_result_empty(post) { ctx_not_found(ctx)  ret }
    forge_dirty_load_result("posts", id, post, "title")
    ctx_set(ctx, "post", post as i64)
}

fn posts_index(ctx: i64) {
    ctx_render(ctx, view_posts_index(ctx, post_published()))
}

fn posts_new(ctx: i64) {
    ctx_render(ctx, view_posts_new(ctx))
}

fn posts_create(ctx: i64) {
    let attrs = ctx_permit(ctx, "title, body, author")
    if post_create_from(attrs) {
        forge_log_ctx_info(ctx, "post created")
        ctx_flash_set(ctx, "notice", "Post created.")
        ctx_redirect(ctx, posts_path)
        ret
    }
    ctx_save_errors(ctx)
    ctx_redirect(ctx, new_post_path)
}

fn posts_show(ctx: i64) {
    let post:     &ForgeResult = ctx_get(ctx, "post") as &ForgeResult
    let comments: &ForgeResult = comment_for_post(ctx_param(ctx, "id"))
    ctx_render(ctx, view_posts_show(ctx, post, comments))
}

fn posts_edit(ctx: i64) {
    let post: &ForgeResult = ctx_get(ctx, "post") as &ForgeResult
    ctx_render(ctx, view_posts_edit(ctx, post))
}

fn posts_update(ctx: i64) {
    let id = ctx_param(ctx, "id")
    if post_update_from(id, ctx_permit(ctx, "title, body, author")) {
        if forge_dirty_changed("posts", id, "title", ctx_param(ctx, "title")) {
            forge_log_ctx_info(ctx, "post title was changed")
        }
        ctx_flash_set(ctx, "notice", "Post updated.")
        ctx_redirect(ctx, post_path(id))
        ret
    }
    ctx_save_errors(ctx)
    ctx_redirect(ctx, edit_post_path(id))
}

fn posts_delete(ctx: i64) {
    post_delete(ctx_param(ctx, "id"))
    forge_log_ctx_info(ctx, "post deleted")
    ctx_flash_set(ctx, "notice", "Post deleted.")
    ctx_redirect(ctx, posts_path)
}

// posts_before_actions is called from main() — not a route action, no ctx: i64
// signature, so compile-routes leaves it untouched.
// fn_addr references use bare names; compile-routes rewrites them to the
// prefixed form (fn_addr(posts_set_post) → fn_addr(posts_set_post)).
fn posts_before_actions() {
    let ctrl = forge_ctrl_new()
    forge_ctrl_before (ctrl, fn_addr(posts_set_post),   "show, edit, update, delete")
    forge_ctrl_after  (ctrl, fn_addr(posts_log_action), "")
    forge_ctrl_rescue (ctrl, fn_addr(posts_rescue))
    forge_ctrl_register("posts", ctrl)
}

fn forge__dispatch_comments_create(ctx: i64) { forge_ctrl_run("comments", "create", fn_addr(comments_create), ctx) }
fn forge__dispatch_comments_delete(ctx: i64) { forge_ctrl_run("comments", "delete", fn_addr(comments_delete), ctx) }
fn forge__dispatch_posts_rescue(ctx: i64) { forge_ctrl_run("posts", "rescue", fn_addr(posts_rescue), ctx) }
fn forge__dispatch_posts_log_action(ctx: i64) { forge_ctrl_run("posts", "log_action", fn_addr(posts_log_action), ctx) }
fn forge__dispatch_posts_set_post(ctx: i64) { forge_ctrl_run("posts", "set_post", fn_addr(posts_set_post), ctx) }
fn forge__dispatch_posts_index(ctx: i64) { forge_ctrl_run("posts", "index", fn_addr(posts_index), ctx) }
fn forge__dispatch_posts_new(ctx: i64) { forge_ctrl_run("posts", "new", fn_addr(posts_new), ctx) }
fn forge__dispatch_posts_create(ctx: i64) { forge_ctrl_run("posts", "create", fn_addr(posts_create), ctx) }
fn forge__dispatch_posts_show(ctx: i64) { forge_ctrl_run("posts", "show", fn_addr(posts_show), ctx) }
fn forge__dispatch_posts_edit(ctx: i64) { forge_ctrl_run("posts", "edit", fn_addr(posts_edit), ctx) }
fn forge__dispatch_posts_update(ctx: i64) { forge_ctrl_run("posts", "update", fn_addr(posts_update), ctx) }
fn forge__dispatch_posts_delete(ctx: i64) { forge_ctrl_run("posts", "delete", fn_addr(posts_delete), ctx) }
fn forge_controllers_init() {
    forge_action_register("comments", "create", fn_addr(forge__dispatch_comments_create))
    forge_action_register("comments", "delete", fn_addr(forge__dispatch_comments_delete))
    forge_action_register("posts", "rescue", fn_addr(forge__dispatch_posts_rescue))
    forge_action_register("posts", "log_action", fn_addr(forge__dispatch_posts_log_action))
    forge_action_register("posts", "set_post", fn_addr(forge__dispatch_posts_set_post))
    forge_action_register("posts", "index", fn_addr(forge__dispatch_posts_index))
    forge_action_register("posts", "new", fn_addr(forge__dispatch_posts_new))
    forge_action_register("posts", "create", fn_addr(forge__dispatch_posts_create))
    forge_action_register("posts", "show", fn_addr(forge__dispatch_posts_show))
    forge_action_register("posts", "edit", fn_addr(forge__dispatch_posts_edit))
    forge_action_register("posts", "update", fn_addr(forge__dispatch_posts_update))
    forge_action_register("posts", "delete", fn_addr(forge__dispatch_posts_delete))
}
// Auto-generated from config/routes.jda -- do not edit directly

let posts_path: []i8    = "/posts"
let new_post_path: []i8 = "/posts/new"
fn post_path(id: []i8) -> []i8      { ret forge_path_id("posts", id) }
fn edit_post_path(id: []i8) -> []i8 { ret forge_path_edit("posts", id) }
fn post_comments_path(post_id: []i8) -> []i8                { ret forge_nested_path("posts", post_id, "comments") }
fn post_comment_path(post_id: []i8, id: []i8) -> []i8     { ret forge_nested_path_id("posts", post_id, "comments", id) }
fn new_post_comment_path(post_id: []i8) -> []i8           { ret forge_nested_path_new("posts", post_id, "comments") }
fn edit_post_comment_path(post_id: []i8, id: []i8) -> []i8 { ret forge_nested_path_edit("posts", post_id, "comments", id) }

fn routes(app: &ForgeApp) {
    forge_app_root(app, "posts#index")
    let _s0 = forge_app_resources(app, "posts")
    forge_scope_resources(_s0, "comments")
}
// main.jda

// Job lifecycle hook — log every job start/finish.
fn on_job_before(arg: i64) {
    forge_log(FORGE_LOG_DEBUG, "job starting")
}
fn on_job_after(arg: i64) {
    forge_log(FORGE_LOG_DEBUG, "job finished")
}

fn main() {
    load_env()
    // forge_jobs_start disabled: spawn{} is inline on this platform — workers loop forever
    // forge_jobs_start(4)
    // forge_job_before_perform(fn_addr(on_job_before))
    // forge_job_after_perform (fn_addr(on_job_after))

    let app = app_new_config(app_config())
    app_use(app, fn_addr(forge_logger))
    app_use(app, fn_addr(forge_request_id))
    app_use(app, fn_addr(forge_secure_headers))
    app_use(app, fn_addr(forge_session_start))
    app_use(app, fn_addr(forge_csrf))

    app_static(app, "/static", "./public")

    post_model_init()
    comment_model_init()

    // Subscribe to the post.created instrumentation event — fires the mailer
    // after the HTTP response has already been sent (async, in a job).
    forge_subscribe("post.created", fn_addr(post_mailer_new_post))

    // Register mailer previews (only active in development via /_forge/mailers).
    forge_mail_preview_register("new_post", fn_addr(post_mailer_preview_new_post))
    app_get(app, "/_forge/mailers", fn_addr(forge_mail_preview_handler))
    app_get(app, "/_forge/mailers/:name", fn_addr(forge_mail_preview_handler))

    posts_before_actions()

    forge_controllers_init()
    routes(app)

    app_listen(app, str_to_i32(forge_env_get("APP_PORT")))
}

<% fn render_post_form(action: []i8, title_val: []i8, body_val: []i8, tok: []i8, submit_label: []i8) %>
<form method="POST" action="<%== action %>">
  <%== forge_field_tag("title", "Title", title_val) %>
  <%== forge_textarea_field_tag("body", "Body", body_val, 10, 60) %>
  <%== forge_field_tag("author", "Author", "") %>
  <input type="hidden" name="_csrf" value="<%= tok %>">
  <button><%== submit_label %></button>
  <a href="<%== posts_path %>">Cancel</a>
</form>
